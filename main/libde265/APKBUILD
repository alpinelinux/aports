# Use the optimization level the project is optimised for.
# This is en/decoder, so performance matters more than size.
export CPPFLAGS="${CPPFLAGS/-Os/}"
export CXXFLAGS="${CXXFLAGS/-Os/}"

build() {
	_build build-shared -DBUILD_SHARED_LIBS=ON
	_build build-static -DBUILD_SHARED_LIBS=OFF
}

_build() {
	local builddir="$1"; shift

	local crossopts=
	[ "$CBUILD" != "$CHOST" ] \
		&& crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"

	cmake -B "$builddir" -G Ninja -Wno-dev \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_VERBOSE_MAKEFILE=ON \
		-DBUILD_SHARED_LIBS=ON \
		$crossopts \
		"$@"
	cmake --build "$builddir"
}

package() {
	DESTDIR="$pkgdir" cmake --install build-shared

	# The upstream do the same in their Ubuntu/PPA packages.
	mv "$pkgdir"/usr/bin/dec265 "$pkgdir"/usr/bin/libde265-dec265

	install -D -m755 build-static/libde265/libde265.a -t "$pkgdir"/usr/lib/
}

examples() {
	pkgdesc="$pkgdesc (examples)"
	depends="$pkgname=$pkgver-r$pkgrel"

	amove usr/bin/*
}

