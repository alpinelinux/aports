# Contributor: Simon Frankenberger <simon-alpine@fraho.eu>
# Maintainer: Simon Frankenberger <simon-alpine@fraho.eu>
pkgname=py3-dotenv
_pyname=python-dotenv
pkgver=1.2.2
pkgrel=0
pkgdesc="Reads the key-value pair from .env file and adds them to environment variable."
url="https://github.com/theskumar/python-dotenv"
arch="noarch"
license="BSD-3-Clause"
depends="python3"
checkdepends="py3-pytest py3-click py3-sortedcontainers"
makedepends="py3-setuptools py3-gpep517"
subpackages="$pkgname-pyc dotenv:cli"
source="$pkgname-$pkgver.tar.gz::https://github.com/theskumar/$_pyname/archive/v$pkgver.tar.gz"
builddir="$srcdir/$_pyname-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	# skip test(s):
	# - run_with_command_flags: requires the "printenv" binary to support "--version" flag
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	PATH="$(pwd)/.testenv/bin/:$PATH" .testenv/bin/python3 -m pytest -k 'not test_run_with_command_flags'

}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

cli() {
	depends="py3-dotenv py3-click"
	amove usr/bin/dotenv
}

sha512sums="
9af88675407d01b9fcc0fec3eb1d4f593cdc78ff2ad476157c8718523935f2d835bc9fbb69bfb745a3a9fcddb0a06938fe78af1eb2239d907c73e419302437bf  py3-dotenv-1.2.2.tar.gz
"
