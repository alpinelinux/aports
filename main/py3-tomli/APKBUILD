maintainer="Michał Polański <michal@polanski.me>"
pkgname=py3-tomli
pkgver=2.3.1
pkgrel=0
pkgdesc="A lil' TOML parser"
url="https://github.com/hukkin/tomli"
license="MIT"
arch="noarch"
makedepends="py3-gpep517 py3-flit-core"
subpackages="$pkgname-pyc"
source="https://github.com/hukkin/tomli/archive/$pkgver/py3-tomli-$pkgver.tar.gz"
builddir="$srcdir/tomli-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	PYTHONPATH=src python3 -m unittest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/tomli-$pkgver-py3-none-any.whl
}

sha512sums="
f41ec5fa106f61c991e7b1cac327793625c6cd1b6795c37c3a2f340fbe93ee9360e0ae8f93a017753a8a75b2b356eb2b3cb75abf7bbadc8ee288cdb1934ec808  py3-tomli-2.3.1.tar.gz
"
