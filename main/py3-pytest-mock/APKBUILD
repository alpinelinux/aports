# Maintainer: Andy Postnikov <apostnikov@gmail.com>
pkgname=py3-pytest-mock
pkgver=3.15.1
pkgrel=0
pkgdesc="Thin-wrapper around the mock package for easier use with py.test"
url="https://github.com/pytest-dev/pytest-mock"
arch="noarch"
license="MIT"
depends="
	py3-mock
	py3-pytest
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/pytest-mock/pytest_mock-$pkgver.tar.gz"
builddir="$srcdir/pytest_mock-$pkgver"

replaces="pytest-mock" # Backwards compatibility
provides="pytest-mock=$pkgver-r$pkgrel" # Backwards compatibility

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# This tests requires py3-pytest-asyncio which is in community repo
	PYTHONPATH="$PWD/build/lib" PATH="$PWD/.testenv/bin:$PATH" .testenv/bin/python3 -m pytest \
		--deselect="tests/test_pytest_mock.py::test_instance_async_method_spy" \
		--deselect="tests/test_pytest_mock.py::test_detailed_introspection" \
		--deselect="tests/test_pytest_mock.py::test_detailed_introspection_async" \
		--deselect="tests/test_pytest_mock.py::test_plain_stopall" \
		--deselect="tests/test_pytest_mock.py::test_used_with_class_scope" \
		--deselect="tests/test_pytest_mock.py::test_used_with_module_scope" \
		--deselect="tests/test_pytest_mock.py::test_used_with_package_scope" \
		--deselect="tests/test_pytest_mock.py::test_used_with_session_scope"

}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1807446f2f1547459820d7b0b196d089d2fc574d5e017c4a0d318f5b430c12c83ef0a5593498425cc08972c4b77ce43cc935ee44e1ffef2887f7efbd5fe0d7cc  pytest_mock-3.15.1.tar.gz
"
