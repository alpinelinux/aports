pkgname=ntfs-3g
pkgver=2026.2.25
pkgrel=0
pkgdesc="Stable, full-featured, read-write NTFS"
url="https://www.tuxera.com/company/open-source/"
arch="all"
license="GPL-2.0-only"
options="!check" # No test suite
makedepends="attr-dev util-linux-dev linux-headers"
subpackages="
	$pkgname-static
	$pkgname-doc
	$pkgname-dev
	$pkgname-libs
	$pkgname-progs
	"
source="https://download.tuxera.com/opensource/ntfs-3g_ntfsprogs-$pkgver.tgz"

# secfixes:
#   2026.2.25-r0:
#     - CVE-2026-40706
#   2022.10.3-r0:
#     - CVE-2022-40284
#   2022.5.17-r0:
#     - CVE-2021-46790
#     - CVE-2022-30783
#     - CVE-2022-30784
#     - CVE-2022-30785
#     - CVE-2022-30786
#     - CVE-2022-30787
#     - CVE-2022-30788
#     - CVE-2022-30789
#   2017.3.23-r2:
#     - CVE-2019-9755

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info
	make
}

package() {
	pkgdesc="$pkgdesc (driver)"

	mkdir -p "$pkgdir"/lib
	make -j1 DESTDIR="$pkgdir" LDCONFIG=: install
	ln -s /bin/ntfs-3g "$pkgdir"/sbin/mount.ntfs
}

progs() {
	pkgdesc="$pkgdesc (utilities)"

	mkdir -p "$subpkgdir"/sbin
	mv "$pkgdir"/usr "$pkgdir"/lib "$subpkgdir"/
	rm -fr "$subpkgdir"/lib "$subpkgdir"/usr/lib
}

