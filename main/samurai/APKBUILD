# Maintainer: DWwanghao <wanghao03@loongson.cn>
maintainer="DWwanghao <wanghao03@loongson.cn>"
pkgname=samurai
pkgver=1.3
pkgrel=0
pkgdesc="ninja-compatible build tool written in C"
url="https://github.com/michaelforney/samurai"
arch="all"
license="Apache-2.0"
options="!check"  # No test suite.
subpackages="$pkgname-doc $pkgname-dbg"
source="https://github.com/michaelforney/samurai/releases/download/$pkgver/samurai-$pkgver.tar.gz"
provides="ninja"
replaces="ninja"
provider_priority=10

# secfixes:
#   1.2-r1:
#     - CVE-2021-30218
#     - CVE-2021-30219

build() {
	make CFLAGS="${CFLAGS//-Os/-O2}"
}

package() {
	make install PREFIX="/usr" DESTDIR="$pkgdir"
	ln -s samu "$pkgdir"/usr/bin/ninja
}

sha512sums="
