# Contributor: Rasmus Thomsen <oss@cogitri.dev>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=cbindgen
# Please be VERY careful bumping this - Firefox regularly fails to build
# with new versions!
pkgver=0.29.4
pkgrel=0
pkgdesc="Tool to generate C bindings from Rust code"
url="https://github.com/mozilla/cbindgen"
arch="all"
license="MPL-2.0"
makedepends="cargo cargo-auditable"
checkdepends="cmake cython samurai"
source="$pkgname-$pkgver.tar.gz::https://github.com/mozilla/cbindgen/archive/refs/tags/$pkgver.tar.gz"
options="net"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
	# tests use -Zunpretty=expand -> require nightly toolchain
	rm -rf tests/rust/expand* \
		tests/rust/bitfield \
		tests/profile.rs
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm0755 target/release/cbindgen -t "$pkgdir"/usr/bin
}

sha512sums="
c2b22a094c4caf993b03ea712eb1c5c057254615aca9d657eb9e768458f1aa35390aba49a86a54d4bf8fde7e17422a3c1107661e880d50e23a3d6082e549b3bf  cbindgen-0.29.4.tar.gz
"
