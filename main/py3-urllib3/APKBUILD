# Contributor: Yura Kushnir <kushnir.yura@gmail.com>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=py3-urllib3
_pkgname=urllib3
pkgver=2.7.0
pkgrel=0
pkgdesc="HTTP library with thread-safe connection pooling, file post, and more"
url="https://urllib3.readthedocs.io/"
arch="noarch"
license="MIT"
depends="python3"
makedepends="
	py3-gpep517
	py3-hatch-vcs
	py3-hatchling
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
subpackages="$pkgname-pyc"
source="https://github.com/urllib3/urllib3/releases/download/$pkgver/urllib3-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"
options="!check" # needs various py3-* packages from community and testing

replaces="py-urllib3" # Backwards compatibility
provides="py-urllib3=$pkgver-r$pkgrel" # Backwards compatibility

# secfixes:
#   2.6.3-r0:
#     - CVE-2026-21441
#   1.26.18-r0:
#     - CVE-2023-45803
#   1.26.17-r0:
#     - CVE-2023-43804
#   1.25.9-r0:
#     - CVE-2020-26137
#   1.26.4-r0:
#     - CVE-2021-28363

export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
6f75e5873f18301de37c0d7f17c726b21c9928f2fe9ec58d843f1172b80be6eb05117bdf7af27dd7eb1ab0175a94e0f49cde01d8d8919f61de8710e163fabc03  urllib3-2.7.0.tar.gz
"
