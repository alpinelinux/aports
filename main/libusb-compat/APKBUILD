# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=libusb-compat
pkgver=0.1.9
pkgrel=0
pkgdesc="Compatility for older libusb"
url="https://libusb.info/"
arch="all"
license="LGPL-2.1-or-later"
subpackages="$pkgname-dev"
depends="libusb"
makedepends="autoconf automake linux-headers libtool libusb-dev"
source="https://github.com/libusb/libusb-compat-0.1/releases/download/v$pkgver/libusb-compat-$pkgver.tar.gz"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
476380c71454ef2ad8ebfdc35caa88d49522d60a92098f1581944a699287020440b8a173a1e79c990a78ccd070a1598d0b884598826930c6edcc29c16dc40fa9  libusb-compat-0.1.9.tar.gz
"
