From f2189748fbe1f85242874298c27f349786bca60a Mon Sep 17 00:00:00 2001
From: Sertonix <sertonix@posteo.net>
Date: Mon, 13 Jul 2026 12:03:04 +0200
Subject: [PATCH 1/2] abuild: fix amove failing with absolute paths

test -L and test -e were checking the host filesystem

Fixes ddc695168a22 abuild: remove shell expansion inside of amove
---
 abuild.in | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/abuild.in b/abuild.in
index 67ac613..d33096a 100644
--- a/abuild.in
+++ b/abuild.in
@@ -72,13 +72,13 @@ amove() {
 
 	local ret=0 f d
 	for f; do
+		# strip all leading and trailing /
+		f=${f#"${f%%[!/]*}"}
+		f=${f%"${f##*[!/]}"}
 		[ -L "$f" ] || [ -e "$f" ] || {
 			ret=1
 			continue
 		}
-		# strip all leading and trailing /
-		f=${f#"${f%%[!/]*}"}
-		f=${f%"${f##*[!/]}"}
 		d=${f%/*}
 		[ "$d" = "$f" ] && d=.
 		mkdir -p "$subpkgdir/$d"
-- 
