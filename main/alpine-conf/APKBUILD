# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=alpine-conf
pkgver=3.22.0_rc1
pkgrel=0
pkgdesc="Alpine configuration management scripts"
url="https://gitlab.alpinelinux.org/alpine/alpine-conf"
arch="all"
license="MIT"
depends="openrc>=0.24.1-r6 busybox>=1.26.1-r3"
makedepends="scdoc"
checkdepends="kyua sfdisk"
subpackages="$pkgname-doc"
source="https://gitlab.alpinelinux.org/alpine/alpine-conf/-/archive/$pkgver/alpine-conf-$pkgver.tar.gz"

build() {
	make PREFIX="/usr" VERSION=$pkgver-r$pkgrel
}

package() {
	make install PREFIX="/usr" DESTDIR="$pkgdir"
	for i in commit exclude include status; do
		ln -s lbu "$pkgdir"/usr/sbin/lbu_$i
	done
}

check() {
	make check
}

sha512sums="
9ccd18b00fa6fc317975183e0ea19768bc2f15ae4375871f9dc9c94adb98857df38f45b23c04a2dbb29a56e9b1a9f5b7b270fa634cae7490e7179518b5ca7743  alpine-conf-3.22.0_rc1.tar.gz
"
