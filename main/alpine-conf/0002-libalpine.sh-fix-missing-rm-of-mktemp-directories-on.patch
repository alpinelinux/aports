From ccd11279af9a634f9d82f36b2c2640ad58c44d54 Mon Sep 17 00:00:00 2001
From: Thomas Liske <liske@ibh.de>
Date: Fri, 20 Jun 2025 13:26:42 +0200
Subject: [PATCH] libalpine.sh: fix missing rm of mktemp directories on exit
 (regression of b8d5f71d)

---
 libalpine.sh.in | 1 +
 1 file changed, 1 insertion(+)

diff --git a/libalpine.sh.in b/libalpine.sh.in
index 07db42e..4834800 100644
--- a/libalpine.sh.in
+++ b/libalpine.sh.in
@@ -35,6 +35,7 @@ init_tmpdir() {
 	local __tmpd
 	__tmpd=$(mktemp -d /tmp/$PROGRAM-${$}-$(date +%s)-XXXXXXXXXX) ||
 		die "Failed to create tmp dir"
+	trap "rc=\$?; rm -fr \"$__tmpd\"; exit \$rc" 0
 	eval "$1=\"$__tmpd\""
 }
 
-- 
