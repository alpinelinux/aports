# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=wasi-libc
pkgver=27.20250626
_gitrev=3f7eb4c7d6ede4dde3c4bffa6ed14e8d656fe93f
pkgrel=1
pkgdesc="WASI libc implementation for WebAssembly"
url="https://github.com/WebAssembly/wasi-libc"
arch="all"
options="!check" # no testsuite
# https://github.com/WebAssembly/wasi-libc/blob/main/LICENSE
#   wasi-libc			- Apache License v2.0 WITH LLVM Exceptions AND
#				  Apache License v2.0 AND MIT
#   dlmalloc/			- CC0
#   libc-bottom-half/cloudlibc/	- BSD-2-Clause
#   libc-top-half/musl/		- MIT
license="Apache-2.0 WITH LLVM-exception AND Apache-2.0 AND MIT AND CC0-1.0 AND BSD-2-Clause"
_llvmver=22
makedepends="bash clang$_llvmver llvm$_llvmver wasi-compiler-rt"
source="wasi-libc-$_gitrev.tar.gz::https://github.com/WebAssembly/wasi-libc/archive/$_gitrev.tar.gz
	no-double-build.patch
	fix-clang22-compat.patch
	"
builddir="$srcdir"/$pkgname-$_gitrev

export AR=llvm$_llvmver-ar
export NM=llvm$_llvmver-nm


build() {
	export BUILTINS_LIB=usr/lib/llvm$_llvmver/lib/clang/$_llvmver/lib/wasi/libclang_rt.builtins-wasm32.a
	make CC=clang-$_llvmver TARGET_TRIPLE=wasm32-wasip1 BUILTINS_LIB=$BUILTINS_LIB
	make CC=clang-$_llvmver TARGET_TRIPLE=wasm32-wasip1-threads THREAD_MODEL=posix BUILTINS_LIB=$BUILTINS_LIB


	# new wasm targets needed by rust
	make CC=clang-$_llvmver BUILTINS_LIB=$BUILTINS_LIB TARGET_TRIPLE=wasm32-wasip1
	make CC=clang-$_llvmver BUILTINS_LIB=$BUILTINS_LIB TARGET_TRIPLE=wasm32-wasip1-threads THREAD_MODEL=posix
	make CC=clang-$_llvmver BUILTINS_LIB=$BUILTINS_LIB TARGET_TRIPLE=wasm32-wasip2 WASI_SNAPSHOT=p2
	make CC=clang-$_llvmver TARGET_TRIPLE=wasm32-wasip2 WASI_SNAPSHOT=p2 BUILTINS_LIB=$BUILTINS_LIB
	mkdir -p sysroot/share
}

package() {
	mkdir -p "$pkgdir"/usr/share/wasi-sysroot/share
	make TARGET_TRIPLE=NOBUILD CC=clang-$_llvmver INSTALL_DIR="$pkgdir"/usr/share/wasi-sysroot install
}

sha512sums="
