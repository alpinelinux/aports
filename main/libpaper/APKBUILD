# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=libpaper
pkgver=2.2.8
pkgrel=0
pkgdesc="Library for handling paper characteristics"
url="https://github.com/rrthomas/libpaper/"
arch="all"
license="LGPL-2.1-or-later OR MIT"
makedepends="help2man"
checkdepends="bash"
subpackages="$pkgname-dev $pkgname-doc"
source="https://github.com/rrthomas/libpaper/releases/download/v$pkgver/libpaper-$pkgver.tar.gz"
options="!check" # really broken

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--disable-static
	make
}

check() {
	cd tests
	./run-test
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
f216c35624cc4d0a5f947880943028f03d3ecfe445b71630ab680ef4c63ee1ad8e6a8852ab469d9e416f5283db2468eb1f52ed82ae47600949d0312ce9250afd  libpaper-2.2.8.tar.gz
"
