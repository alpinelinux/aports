A follow up to: 
https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git/commit/drivers/s390/cio?h=linux-6.6.y&id=3d0cfecf4ff77a78d5efe99006fce541460e591f

diff --git a/drivers/s390/cio/device.c b/drivers/s390/cio/device.c
index 93307ca75c10..57cbba03beb8 100644
--- a/drivers/s390/cio/device.c
+++ b/drivers/s390/cio/device.c
@@ -1322,7 +1322,7 @@ static int purge_fn(struct subchannel *sch, void *data)
 {
 	struct ccw_device *cdev;
 
-	spin_lock_irq(sch->lock);
+	spin_lock_irq(&sch->lock);
 	if (sch->st != SUBCHANNEL_TYPE_IO || !sch->schib.pmcw.dnv)
 		goto unlock;
 
@@ -1345,7 +1345,7 @@ static int purge_fn(struct subchannel *sch, void *data)
 		      sch->schib.pmcw.dev, cdev ? "" : " (no cdev)");
 
 unlock:
-	spin_unlock_irq(sch->lock);
+	spin_unlock_irq(&sch->lock);
 	/* Abort loop in case of pending signal. */
 	if (signal_pending(current))
 		return -EINTR;
