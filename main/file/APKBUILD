pkgname=file
pkgver=5.47
pkgrel=2
pkgdesc="File type identification utility"
url="https://www.darwinsys.com/file/"
arch="all"
license="BSD-2-Clause"
subpackages="libmagic-static $pkgname-dev $pkgname-doc libmagic"
source="https://astron.com/pub/file/file-$pkgver.tar.gz
	0001-softmagic-compare-FILE_GUID-values-in-wire-format.patch
	0002-inliniac-revert-previous-and-always-offset.patch
	"

# secfixes:
#   5.37-r1:
#     - CVE-2019-18218
#   5.36-r0:
#     - CVE-2019-1543
#     - CVE-2019-8904
#     - CVE-2019-8905
#     - CVE-2019-8906
#     - CVE-2019-8907

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--datadir=/usr/share \
		--enable-static
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

libmagic() {
	pkgdesc="File type identification library"

	amove \
		usr/lib/libmagic.so.* \
		usr/share/misc/magic.mgc
}

