# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=libsrtp
pkgver=2.8.0
pkgrel=0
pkgdesc="implementation of the Secure Real-time Transport Protocol (SRTP)"
url="https://github.com/cisco/libsrtp"
arch="all"
license="BSD-3-Clause"
makedepends="libpcap-dev meson openssl-dev"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/cisco/libsrtp/archive/refs/tags/v$pkgver.tar.gz"

build() {
	abuild-meson \
		-Dtests="$(want_check && echo enabled || echo disabled)" \
		-Dcrypto-library=openssl \
		-Dpcap-tests=enabled \
		builddir .
	meson compile -C builddir
}

check() {
	meson test --print-errorlogs -C builddir -t 5
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C builddir
}

sha512sums="
6768f7976e5cc14a3bf2e9fc32042cab0b964f616fe5654516643a649a5d5f2b9ecb9e996467dd6d337777a9051b83a6e95f3cdc27e945062ce6da1cf8a2d462  libsrtp-2.8.0.tar.gz
"
