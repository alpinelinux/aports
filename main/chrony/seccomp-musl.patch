On musl libc, the readv syscall is required in addition to the read syscall.
Otherwise, chrony-nts crashes on start with "Bad syscall".

diff --git a/sys_linux.c b/sys_linux.c
index 210428b..7425591 100644
--- a/sys_linux.c
+++ b/sys_linux.c
@@ -539,6 +539,7 @@ SYS_Linux_EnableSystemCallFilter(int level, SYS_ProcessConte>
     SCMP_SYS(pselect6_time64),
 #endif
     SCMP_SYS(read),
+    SCMP_SYS(readv),
     SCMP_SYS(futex),
 #ifdef __NR_futex_time64
     SCMP_SYS(futex_time64),
