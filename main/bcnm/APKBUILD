# Maintainer: Laurent Bercot <ska-devel@skarnet.org>
pkgname=bcnm
pkgver=0.0.2.2
pkgrel=0
pkgdesc="Better Client Network Manager"
url="https://skarnet.org/software/bcnm/"
arch="all"
license="ISC"
options="!check"
makedepends="skalibs-dev linux-headers"
subpackages="$pkgname-static $pkgname-libs $pkgname-dev $pkgname-doc"
source="https://skarnet.org/software/bcnm/bcnm-$pkgver.tar.gz"

build() {
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--libexecdir="/usr/libexec/$pkgname" \
		--enable-shared \
		--disable-allstatic \
		--with-pkgconfig \
		--enable-pkgconfig
	make
}

package() {
	make DESTDIR="$pkgdir" install
	mkdir -p "$pkgdir/usr/share/doc"
	cp -a "$builddir/doc" "$pkgdir/usr/share/doc/$pkgname"
}

sha512sums="
