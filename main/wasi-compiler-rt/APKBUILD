81f49bf572b6e6fe6443b57d22184fc0a64ddd3532c7fd8398a7d01b7755ad357ca2b8b9a42600125d0e649454b218c9233c22ef3df4bbaba8988ca75c0fb89b  wasi-sdk-wasi-sdk-27.tar.gz
84caede1053df4a966a36fffc08fee79b7cd889f4ebb600d7a791e35651d2f8ead6bc1dc573c75e09b247fba001f5463175eb92d12bbc50e88abdc241b34519a  wasi-libc-ac020b86fd44bafe60aa4fa12f407d16e3731329.tar.gz
"
