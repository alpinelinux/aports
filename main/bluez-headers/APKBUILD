# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=bluez-headers
pkgver=5.87
pkgrel=0
pkgdesc="Bluez development headers"
url="https://www.bluez.org/"
arch="noarch"
license="GPL-2.0-or-later"
depends="!bluez-dev"
source="https://www.kernel.org/pub/linux/bluetooth/bluez-$pkgver.tar.xz"
builddir="$srcdir/bluez-$pkgver"
options="!check" # just headers

package() {
	local headers="
		bluetooth
		bnep
		cmtp
		hci
		hci_lib
		hidp
		l2cap
		rfcomm
		sco
		sdp
		sdp_lib
		"
	for header in $headers; do
		install -Dm644 ./lib/bluetooth/$header.h -t "$pkgdir"/usr/include/bluetooth
	done
}

sha512sums="
f1e3bede9b0bbc3b5cfe9fed5f7945be7cbcf7a299729b5f82f1cba4bbbd6c4d2e372c9685f61458dfc374c9dfee352b6c2933a2c0d7727b8171ff394055e169  bluez-5.87.tar.xz
"
