# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: Runxi Yu <me@runxiyu.org>
maintainer="Runxi Yu <me@runxiyu.org>"
pkgname=groff
pkgver=1.24.0
pkgrel=0
pkgdesc="GNU troff text-formatting system"
url="https://www.gnu.org/software/groff/groff.html"
arch="all"
license="GPL-3.0-or-later"
depends="perl"
makedepends="bison zlib-dev texinfo"
checkdepends="diffutils"
subpackages="$pkgname-doc"
source="https://ftp.gnu.org/gnu/groff/groff-$pkgver.tar.gz"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--without-x \
		--disable-rpath
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
	rm -rf "$pkgdir"/usr/lib/charset.alias
	rmdir -p "$pkgdir"/usr/lib 2>/dev/null || true

	# Prevent conflict with mandoc-doc
	rm -f "$pkgdir"/usr/share/man/man1/soelim.1 \
		"$pkgdir"/usr/share/man/man7/roff.7
}

sha512sums="
