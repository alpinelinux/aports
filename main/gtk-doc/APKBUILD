maintainer="team/gnome <achill@achill.org>"
pkgname=gtk-doc
pkgver=1.36.0
pkgrel=0
pkgdesc="Documentation tool for public library API"
url="https://gitlab.gnome.org/GNOME/gtk-doc"
arch="noarch"
license="GPL-2.0-or-later AND GFDL-1.1-or-later"
depends="
	docbook-xsl
	glib-dev
	pkgconf
	py3-pygments
	python3
	"
makedepends="
	gettext
	libtool
	meson
	rarian-dev
	itstool
	"
checkdepends="
	bc
	py3-parameterized
	"
# https://discourse.gnome.org/t/new-way-of-releasing-gtk-doc/31754
#source="https://download.gnome.org/sources/gtk-doc/${pkgver%.*}/gtk-doc-$pkgver.tar.xz"
source="https://gitlab.gnome.org/GNOME/gtk-doc/-/archive/$pkgver/gtk-doc-$pkgver.tar.gz"
options="!check" # needs py3-parameterized from community

build() {
	abuild-meson \
		-Dtests="$(want_check && echo true || echo false)" \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
3a0c40d4954787b2262d39dd2c549883e703ce1c7c63d761dc960dbffe8d4643a605d0f4ef19fa18aa9f0dc91a90d635e1df511c81774d0660aa5f49e38c9faf  gtk-doc-1.36.0.tar.gz
"
