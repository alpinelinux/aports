# Contributor: Sergei Lukin <sergej.lukin@gmail.com>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=lcms2
pkgver=2.19
pkgrel=0
pkgdesc="Color Management Engine"
url="https://www.littlecms.com"
arch="all"
license="MIT"
depends_dev="
	$pkgname-plugins=$pkgver-r$pkgrel
	libjpeg-turbo-dev
	tiff-dev
	zlib-dev
	"
makedepends="$depends_dev meson"
subpackages="$pkgname-static $pkgname-dev $pkgname-doc $pkgname-utils $pkgname-plugins"
source="https://github.com/mm2/Little-CMS/releases/download/lcms$pkgver/lcms2-$pkgver.tar.gz"

# secfixes:
#   2.19-r0:
#     - CVE-2026-41254
#   2.9-r1:
#     - CVE-2018-16435
#   2.8-r1:
#     - CVE-2016-10165

build() {
	abuild-meson \
		--default-library=both \
		-Dfastfloat=true \
		-Dthreaded=true \
		-Dutils=true \
		-Djpeg=enabled \
		-Dtiff=enabled \
		. output
	meson compile -C output
}

check() {
	meson test -t4 -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

utils() {
	pkgdesc="Utility applications for lcms2"

	amove usr/bin
}

plugins() {
	set -x
	pkgdesc="$pkgdesc (threaded + fast_float plugins)"
	license="GPL-3.0-or-later"

	amove usr/lib/liblcms2_*.so*
}

sha512sums="
0d282fae9ca16b9cbc75ef8845d6ad1062aca8c8783e39c09ad294050e0574da8ee437b9ac58771f259e3b2dea702d8d094dcc7dba4eeba8453d82f54d06ab9c  lcms2-2.19.tar.gz
"
