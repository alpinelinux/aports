# Contributor: Sören Tempel <soeren+alpine@soeren-tempel.net>
# Contributor: Carlo Landmeter <clandmeter@alpinelinux.org>
# Maintainer: mio <miyopan@e.email>
maintainer="mio <miyopan@e.email>"
pkgname=htop
pkgver=3.5.2
pkgrel=0
pkgdesc="Interactive process viewer"
url="https://htop.dev/"
arch="all"
license="GPL-2.0-or-later"
# lsof is needed for the "open files" screen (keybinding: l).
# Without this dependency, this screen doesn't emit an error
# as busybox provides lsof but its output format is incompatible.
depends="lsof"
makedepends="ncurses-dev linux-headers lm-sensors-dev"
subpackages="$pkgname-doc"
source="https://github.com/htop-dev/htop/releases/download/$pkgver/htop-$pkgver.tar.xz"
options="!check" # no upstream/available test-suite

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--enable-cgroup \
		--enable-taskstats
	make
}

package() {
	make DESTDIR="$pkgdir" pixmapdir=/usr/share/icons/hicolor/128x128/apps install
}

sha512sums="
e9a813a205505b5b24fee51b2524137c785d08956defb1968a3b60d6114a605d92b9b916aefb0228424b2d0022a97ecd0b287cec348d6494b4dce9a023b2841c  htop-3.5.2.tar.xz
"
