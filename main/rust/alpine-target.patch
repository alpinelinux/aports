 .../spec/targets/loongarch64_alpine_linux_musl.rs    | 10 ++++++++++
 .../src/spec/targets/mips64_alpine_linux_musl.rs     | 10 ++++++++++
 .../src/spec/targets/powerpc64_alpine_linux_musl.rs  | 10 ++++++++++
 .../spec/targets/powerpc64le_alpine_linux_musl.rs    | 11 +++++++++++
 .../src/spec/targets/powerpc_alpine_linux_musl.rs    | 10 ++++++++++
