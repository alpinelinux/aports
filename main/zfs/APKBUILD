7037805e2a4b6f636f03a70b2f684dbc8c728767cf9d4bcbd16a8fc84581ba3ed943fbcec04afdf7c27d4905664b22c031e97d5a7d66e7005bbbf070444b2ea5  alpine-bash-completion-dir.patch
"
