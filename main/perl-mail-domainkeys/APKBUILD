# Maintainer: Leonardo Arena <rnalrd@alpinelinux.org>
pkgname=perl-mail-domainkeys
_pkgreal=Mail-DomainKeys
pkgver=1.0
pkgrel=6
pkgdesc="A perl implementation of DomainKeys"
url="https://metacpan.org/dist/Mail-DomainKeys"
arch="noarch"
license="Artistic-1.0-Perl OR GPL-1.0-or-later"
depends="perl"
checkdepends="perl-cryptx perl-mailtools perl-net-dns"
subpackages="$pkgname-doc"
source="
	https://cpan.metacpan.org/authors/id/A/AN/ANTHONYU/Mail-DomainKeys-$pkgver.tar.gz
	convert-to-cryptx.patch
	"
builddir="$srcdir/$_pkgreal-$pkgver"

build() {
	PERL_MM_USE_DEFAULT=1 perl Makefile.PL INSTALLDIRS=vendor
	make
}

check() {
	make test
}

package() {
	make DESTDIR="$pkgdir" install
	# creates file collision among perl modules
	find "$pkgdir" -name perllocal.pod -delete
}

