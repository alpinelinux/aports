From 3129943edcbfdac381dce223cb7dc7175ba4154f Mon Sep 17 00:00:00 2001
From: Yu Watanabe <watanabe.yu+github@gmail.com>
Date: Tue, 16 Jun 2026 02:42:45 +0900
Subject: [PATCH] [Alpine] distro: use Type=exec

Alpine Linux builds knot without systemd integration, and knotd
therefore does not send notification messages to systemd.
Use Type=exec instead.
---
 distro/common/knot.service | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/distro/common/knot.service b/distro/common/knot.service
index e6c13ed61..f86a2a768 100644
--- a/distro/common/knot.service
+++ b/distro/common/knot.service
@@ -5,7 +5,7 @@ After=network-online.target
 Documentation=man:knotd(8) man:knot.conf(5) man:knotc(8)
 
 [Service]
-Type=notify
+Type=exec
 User=knot
 Group=knot
 CapabilityBoundingSet=CAP_NET_BIND_SERVICE CAP_SETPCAP
-- 
2.54.0

