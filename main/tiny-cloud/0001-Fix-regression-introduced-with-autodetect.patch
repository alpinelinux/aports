From 39c79be74e0c73569293279ba770d0fc2f1e6d64 Mon Sep 17 00:00:00 2001
From: Natanael Copa <ncopa@alpinelinux.org>
Date: Mon, 8 Jun 2026 21:07:18 +0200
Subject: [PATCH] Fix regression introduced with autodetect

Fixes commit f6046351caee (Tiny cloud autodetect)
---
 lib/tiny-cloud/common | 1 +
 tests/init.test       | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/lib/tiny-cloud/common b/lib/tiny-cloud/common
index 1269a9a..f4eda41 100644
--- a/lib/tiny-cloud/common
+++ b/lib/tiny-cloud/common
@@ -68,6 +68,7 @@ cloud_hint() {
 			return
 		}
 	done
+	return 0
 }
 
 cloud_autodetect() {
diff --git a/tests/init.test b/tests/init.test
index d60e82d..0ca89c1 100755
--- a/tests/init.test
+++ b/tests/init.test
@@ -475,7 +475,7 @@ autodetect_nocloud_volume_body() {
 
 	atf_check \
 		-o match:"nocloud" \
-		sh -c ". \"$lib\"; echo \$CLOUD"
+		sh -e -c ". \"$lib\"; echo \$CLOUD"
 }
 
 autodetect_oci_body() {
-- 
2.54.0

