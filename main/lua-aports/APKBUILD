# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=lua-aports
pkgver=1.3.2
pkgrel=2
pkgdesc="Lua modules for parsing aports tree"
url="https://gitlab.alpinelinux.org/alpine/lua-aports"
arch="noarch"
license="MIT"
# NOTE: must correspond with _luaver in aports-build
_luaver=5.5
depends="
	abuild
	lua$_luaver
	lua$_luaver-cjson
	lua$_luaver-filesystem
	lua$_luaver-mqtt-publish
	lua$_luaver-optarg
	"
makedepends="scdoc"
checkdepends="lua$_luaver-penlight lua$_luaver-busted lua$_luaver-posix"
subpackages="$pkgname-doc"
replaces="abuild"

source="$pkgname-$pkgver.tar.gz::https://gitlab.alpinelinux.org/alpine/lua-aports/-/archive/$pkgver/lua-aports-$pkgver.tar.gz"

build() {
	make
}

check() {
	# ensure that we depend on the right lua version
	sh -x -c "test $_luaver = $(make print-lua-version)"

	env -i busted-$_luaver --verbose -o gtest
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
5f931aa58eaa8bd5cb3344c3e190b14dd84d6c66e36494a6d760b26a46271e74b4e4430446aa8b751b919333ebe020118ca2e994b0e29096a1a9475f6d5e5c80  lua-aports-1.3.2.tar.gz
"
