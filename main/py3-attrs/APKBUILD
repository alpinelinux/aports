f21770a2b0b73a8ec67c66f34fe53a61772f17c140012dd4019cee515672c9a447f1abfe3d48274b0d716c62d44da9baa919b5ad58cf244855a48e4ffc54f690  no-fancy.patch
36bcb4ec145f29e79fc019dc39672f13dc94e1c07225968af51f19e17b2aede0b23dafdff265f1e77a251e53af9802bcf1db5068900ee0a03e1bfc1051c01ef9  check.py
"
