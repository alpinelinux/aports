package() {
	mkdir -p "$pkgdir"/usr/share/alsa
	cp -r ucm2 "$pkgdir"/usr/share/alsa
	find "$pkgdir"/usr/share/alsa \( -name '*.md' -o -name '.gitignore' \) -delete
}

