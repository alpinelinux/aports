From abba6d619cd70dd89f8cb9a6f46c07b5d953c719 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?S=C3=B6ren=20Tempel?= <soeren+git@soeren-tempel.net>
Date: Mon, 22 Jun 2026 15:10:57 +0200
Subject: [PATCH] Install lsblk to /bin instead of /usr/bin
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

On Alpine, the util-linux lsblk utility is installed in /bin and
since BusyBox only gained support for that applet recently, we
should make sure to install it to the same location.

Otherwise, the BusyBox symlink is not overwritten by the lsblk pkg.

Signed-off-by: Sören Tempel <soeren+git@soeren-tempel.net>
---
 util-linux/lsblk.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/util-linux/lsblk.c b/util-linux/lsblk.c
index 3bd40bcb4..bc9e540e3 100644
--- a/util-linux/lsblk.c
+++ b/util-linux/lsblk.c
@@ -10,7 +10,7 @@
 //config:	help
 //config:	List information about all available or specified block devices.
 
-//applet:IF_LSBLK(APPLET(lsblk, BB_DIR_USR_BIN, BB_SUID_DROP))
+//applet:IF_LSBLK(APPLET(lsblk, BB_DIR_BIN, BB_SUID_DROP))
 
 //kbuild:lib-$(CONFIG_LSBLK) += lsblk.o
 
