From: =?UTF-8?q?S=C3=B6ren=20Tempel?= <soeren+git@soeren-tempel.net>
Date: Wed, 10 Jun 2026 21:27:51 +0200
Subject: [PATCH] Skip additional hexdump test on big-endian systems

This one fails on s390x.
---
 testsuite/hexdump.tests | 1 +
 1 file changed, 1 insertion(+)

diff --git a/testsuite/hexdump.tests b/testsuite/hexdump.tests
index d3707a8f4..a39eb4d4e 100755
--- a/testsuite/hexdump.tests
+++ b/testsuite/hexdump.tests
@@ -145,6 +145,7 @@ testing "hexdump -n4 -e '\"%u\"' (big endian)" \
 	"\x4e\x61\xbc\x00AAAA"
 SKIP=
 
+$little_endian || SKIP=1
 testing "hexdump -n4 -e '\"%u\"'" \
 	"hexdump -n4 -e '\"%u\"'" \
 	"12345678" \
