From 3f6e2091c34fea7801328cb24ab7b927904aa4aa Mon Sep 17 00:00:00 2001
From: Natanael Copa <ncopa@alpinelinux.org>
Date: Tue, 19 May 2026 08:07:02 +0200
Subject: [PATCH] ash: exec busybox.static

---
 shell/ash.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/shell/ash.c b/shell/ash.c
index fb887f31b..becef761e 100644
--- a/shell/ash.c
+++ b/shell/ash.c
@@ -6164,6 +6164,8 @@ tryexec_applet(int applet_no, const char *cmd, char **argv, char **envp)
 	}
 	/* re-exec ourselves with the new arguments */
 	execve(bb_busybox_exec_path, argv, envp);
+	execve("/bin/busybox.static",argv,envp);
+	execve("/bin/busybox",argv,envp);
 	/* If they called chroot or otherwise made the binary
 	 * no longer executable, return.
 	 */
