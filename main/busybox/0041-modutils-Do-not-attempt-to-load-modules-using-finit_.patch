From f9a562583eefe79972fb3dd565542490443b49f4 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?S=C3=B6ren=20Tempel?= <soeren+git@soeren-tempel.net>
Date: Wed, 22 Jul 2026 02:32:45 +0200
Subject: [PATCH] modutils: Do not attempt to load modules using
 finit_module(2)

Alpine does not enable CONFIG_MODULE_DECOMPRESS. However, when
using finit_module(2) BusyBox relies on decompression in kernel-space.
As it further attempts loading the compressed module without
the MODULE_INIT_COMPRESSED_FILE, it causes the following message
to be written to the Kernel log:

	Invalid ELF header magic: != ELF

To prevent that, we can (1) enable CONFIG_MODULE_DECOMPRESS in our
Kernel config, (2) rewrite the BusyBox code to not attempt loading
of compressed module w/o MODULE_INIT_COMPRESSED_FILE, or (3) just
disable the finit_module(2)-based loading. This patch implements
(3) as it is the least invasive.
---
 modutils/modutils.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/modutils/modutils.c b/modutils/modutils.c
index c57564023..a49850fad 100644
--- a/modutils/modutils.c
+++ b/modutils/modutils.c
@@ -9,6 +9,20 @@
 
 #include <sys/syscall.h>
 
+// We /have/ finit_module. However, Alpine does (at the time of writing)
+// not enable CONFIG_MODULE_DECOMPRESS in its Kernel config. However,
+// BusyBox attempts to do decompression in kernel-space when using
+// finit_module(2). Since all Alpine Kernel modules are gzip compressed
+// loading using the finit_module code fails until BusyBox falls back to
+// the init_module(2) code where it does decompression in userspace.
+//
+// Due to the way the finit_module(2) code is written, this always
+// causes an "invalid ELF header magic" message in the Kernel log, as it
+// also attempts loading of the module without MODULE_INIT_COMPRESSED_FILE.
+//
+// To prevent that, just disable the finit_module(2) code for now.
+#undef __NR_finit_module
+
 #define init_module(mod, len, opts) syscall(__NR_init_module, mod, len, opts)
 #if defined(__NR_finit_module)
 # define finit_module(fd, uargs, flags) syscall(__NR_finit_module, fd, uargs, flags)
