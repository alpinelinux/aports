# Contributor: Leo <thinkabit.ukim@gmail.com>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=subunit
pkgver=1.4.6
pkgrel=0
pkgdesc="A streaming protocol for test results"
url="https://launchpad.net/subunit"
arch="noarch"
license="Apache-2.0 OR BSD-3-Clause"
depends="py3-$pkgname=$pkgver-r$pkgrel"
_depends_py="py3-iso8601 py3-testtools py3-yaml"
makedepends="
	$_depends_py
	autoconf
	automake
	check-dev
	cppunit-dev
	libtool
	py3-gpep517
	py3-setuptools
	python3-dev
	"
subpackages="py3-$pkgname-pyc py3-$pkgname:_py $pkgname-dev::all $pkgname-libs::all"
source="subunit-$pkgver.tar.gz::https://github.com/testing-cabal/subunit/archive/refs/tags/$pkgver.tar.gz"
options="!check" # Dependencies for checking stuff are in testing/

prepare() {
	default_prepare
	autoreconf -vfi
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--localstatedir=/var \
		--disable-dependency-tracking \
		--disable-static \
		--with-pic
	make
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	make check
}

package() {
	# we set pkgpython_PYTHON='' to disable automake python compilation
	make pkgpython_PYTHON='' DESTDIR="$pkgdir" install
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

_py() {
	depends="$_depends_py"
	amove usr/lib/python3*
}

sha512sums="
23c96b46908c24fbf455ea67c87b1374b157190b76b1fe3875d23364b17922e30dd29e64e9c779d9440630d28e749de7c40d45bcd16b77304aa6df6f54c0a05d  subunit-1.4.6.tar.gz
"
