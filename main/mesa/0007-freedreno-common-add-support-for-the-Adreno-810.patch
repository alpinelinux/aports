From c75eecc3c0c48b49d2a778b589aacfe1ba305e7d Mon Sep 17 00:00:00 2001
From: Alexander Koskovich <akoskovich@pm.me>
Date: Wed, 18 Mar 2026 08:07:38 -0400
Subject: [PATCH 7/7] freedreno/common: add support for the Adreno 810

Add support for the Adreno 810 found on the SM7635 (milos).

Signed-off-by: Alexander Koskovich <akoskovich@pm.me>
Part-of: <https://gitlab.freedesktop.org/mesa/mesa/-/merge_requests/40613>
(cherry picked from commit f560760b273ecd60c4de344578abcacc04103101)
---
 src/freedreno/common/freedreno_devices.py | 26 +++++++++++++++++++++++
 src/freedreno/drm-shim/freedreno_noop.c   |  5 +++++
 2 files changed, 31 insertions(+)

diff --git a/src/freedreno/common/freedreno_devices.py b/src/freedreno/common/freedreno_devices.py
index 32aebb206af..eb6b68f76e2 100644
--- a/src/freedreno/common/freedreno_devices.py
+++ b/src/freedreno/common/freedreno_devices.py
@@ -1516,6 +1516,32 @@ a8xx_gen2 = GPUProps(
         has_salu_int_narrowing_quirk = True
 )
 
+add_gpus([
+       GPUId(chip_id=0xffff44010000, name="Adreno (TM) 810"),
+    ], A6xxGPUInfo(
+        CHIP.A8XX,
+        [a7xx_base, a7xx_gen3, a8xx_base, a8xx_gen1, GPUProps(
+            gmem_vpc_attr_buf_size = 16384,
+            gmem_vpc_pos_buf_size = 12288,
+            gmem_vpc_bv_pos_buf_size = 20480,
+            # This is possibly also needed for a830 (and all of a8xx),
+            # move to a8xx_base if confirmed needed for a830.
+            has_fs_tex_prefetch = False,
+        )],
+        num_ccu = 1,
+        num_slices = 1,
+        tile_align_w = 32,
+        tile_align_h = 16,
+        tile_max_w = 16384,
+        tile_max_h = 16384,
+        num_vsc_pipes = 32,
+        cs_shared_mem_size = 32 * 1024,
+        wave_granularity = 2,
+        fibers_per_sp = 128 * 2 * 16,
+        magic_regs = dict(),
+        raw_magic_regs = a8xx_base_raw_magic_regs,
+    ))
+
 add_gpus([
         GPUId(chip_id=0xffff44050000, name="Adreno (TM) 830"),
         GPUId(chip_id=0x44050001, name="Adreno (TM) 830"), # KGSL
diff --git a/src/freedreno/drm-shim/freedreno_noop.c b/src/freedreno/drm-shim/freedreno_noop.c
index 4c3e817fce7..5541c6cd90e 100644
--- a/src/freedreno/drm-shim/freedreno_noop.c
+++ b/src/freedreno/drm-shim/freedreno_noop.c
@@ -276,6 +276,11 @@ static const struct msm_device_info device_infos[] = {
       .chip_id = 0x43051401,
       .gmem_size = 3 * 1024 * 1024,
    },
+   {
+      .gpu_id = 810,
+      .chip_id = 0x44010000,
+      .gmem_size = 576 * 1024,
+   },
    {
       .gpu_id = 830,
       .chip_id = 0x44050000,
-- 
2.53.0

