@@ -1536,7 +1536,7 @@ add_gpus([
         wave_granularity = 2,
         fibers_per_sp = 128 * 2 * 16,
         magic_regs = dict(),
-        raw_magic_regs = a8xx_gen2_raw_magic_regs,
+        raw_magic_regs = a8xx_base_raw_magic_regs,
