commit 775dd1c7b0a6fe2f45d1e368b0190e73b257bb8b
Author: Yao Zi <me@ziyao.cc>
Date:   2026-04-13T16:36:59Z

    riscv: Fix detection when cpuinfo contains no multi-character extension
    
    orc_riscv_target_detection_extension() wrongly assumes that there's
    at least one underscore in the ISA string, which isn't true on RISC-V
    platforms where no CPU core declares any multi-character
    extensions, leading to crashes in strcmp() on the NULL pointer
    returned by strsep().
    
    This isn't reproducible on modern kernels and devicetrees, since
    CSR/timer-related instructions (zicsr/zifencei) have been separated out
    of RISC-V base extension in later RISC-V specifications, and are
    necessary for Linux to boot. But it's still problematic with
    vendor-provided older devicetree/kernels, or ones generated by QEMU
    earlier than v7.1.0 (without commit 5160bacc0638 ("target/riscv: add
    zicsr/zifencei to isa_string")).
    
    Fixes: c9c39f3482fd ("riscv: Add target")
    Part-of: <https://gitlab.freedesktop.org/gstreamer/orc/-/merge_requests/279>

diff --git a/orc/riscv/orcriscvtarget.c b/orc/riscv/orcriscvtarget.c
index 503145b..259148b 100644
--- a/orc/riscv/orcriscvtarget.c
+++ b/orc/riscv/orcriscvtarget.c
@@ -60,10 +60,10 @@ orc_riscv_target_detect_extension (const char *exts, const char *ext)
     return found && (found < sep || sep == NULL);
   }
 
-  do {
+  for (; sep; sep = strchr (sep + 1, '_')) {
     if (strncmp (sep + 1, ext, n) && !isalnum (exts[n]))
       return TRUE;
-  } while ((sep = strchr (sep + 1, '_')));
+  }
 
   return FALSE;
 }

