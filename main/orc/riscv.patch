commit 484cb7b7247ca9b331dd7d38c5f294a391ca8c91
Author: Felix-Gong <gongxiaofei24@iscas.ac.cn>
Date:   2026-05-28T00:58:02Z

    riscv: Fix missing normalize_result in addF rule
    
    The addF rule normalizes its inputs via NORMALIZE_SRC_ARG but does not
    normalize its output. All other float rules (mulF, divF, subF) call
    orc_riscv_rule_normalize_result after the operation. Without it, the
    compiled path and the interpreted path diverge on denormal results,
    causing test_s_2d_addf compiled function test to fail.
    
    Fixes: #109
    Signed-off-by: Felix Gong <Felix-Gong@users.noreply.gitlab.freedesktop.org>
    Part-of: <https://gitlab.freedesktop.org/gstreamer/orc/-/merge_requests/297>

diff --git a/orc/riscv/orcriscvrules.c b/orc/riscv/orcriscvrules.c
index 260007c..7bd058a 100644
--- a/orc/riscv/orcriscvrules.c
+++ b/orc/riscv/orcriscvrules.c
@@ -1084,6 +1084,7 @@ orc_riscv_rule_addF (OrcCompiler *c, void *user, OrcInstruction *insn)
   const OrcRiscvRegister dest = ORC_DEST_ARG (c, insn, 0);
 
   orc_riscv_insn_emit_vfadd_vv (c, dest, src1, src2);
+  orc_riscv_rule_normalize_result (c, insn);
 }
 
 static void

commit 3c1d4f71c50c133ef76ecd9ff42b228b21e295eb
Author: Felix-Gong <gongxiaofei24@iscas.ac.cn>
Date:   2026-05-30T08:39:23Z

    riscv: Fix missing normalize_result in subF rule
    
    The subF rule was missing the normalize_result call after vfsub_vv,
    same bug pattern as addF. Subtraction of two close normal floats can
    produce a denormalized result that needs flushing to match the
    emulator's behavior.
    
    Verified on SpacemiT C920: direct test shows JIT produces denormal
    (0x800037c0) while emulator produces -0.0 (0x80000000) without this
    fix. The existing test suite doesn't trigger this because random
    float data rarely produces the exact subtraction case, but the bug
    is real and can be hit by real workloads.
    
    Signed-off-by: Felix-Gong <gongxiaofei24@iscas.ac.cn>
    Part-of: <https://gitlab.freedesktop.org/gstreamer/orc/-/merge_requests/298>

diff --git a/orc/riscv/orcriscvrules.c b/orc/riscv/orcriscvrules.c
index 7bd058a..1312b8e 100644
--- a/orc/riscv/orcriscvrules.c
+++ b/orc/riscv/orcriscvrules.c
@@ -1095,6 +1095,7 @@ orc_riscv_rule_subF (OrcCompiler *c, void *user, OrcInstruction *insn)
   const OrcRiscvRegister dest = ORC_DEST_ARG (c, insn, 0);
 
   orc_riscv_insn_emit_vfsub_vv (c, dest, src1, src2);
+  orc_riscv_rule_normalize_result (c, insn);
 }
 
 static void

