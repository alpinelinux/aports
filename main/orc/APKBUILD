# Contributor: Łukasz Jendrysik <scadu@yandex.com>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=orc
pkgver=0.4.42
pkgrel=0
pkgdesc="Oil Run-time Compiler"
url="https://gstreamer.freedesktop.org/modules/orc.html"
arch="all"
license="BSD-2-Clause"
depends_dev="$pkgname-compiler=$pkgver-r$pkgrel"
makedepends="linux-headers meson"
subpackages="$pkgname-dev $pkgname-compiler"
source="https://gstreamer.freedesktop.org/src/orc/orc-$pkgver.tar.xz"

# secfixes:
#   0.4.39-r0:
#     - CVE-2024-40897

build() {
	abuild-meson \
		-Db_lto=true \
		-Dorc-test=disabled \
		-Dbenchmarks=enabled \
		-Dtools=enabled \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

compiler() {
	pkgdesc="Orc compiler"

	amove usr/bin
}

sha512sums="
3a1ebe31a49255df10dbf2eb2aa72265dfc8a3806107d57b92c187aab8be32e01ad5652fb385d6886a15c23017a4db5374c0234be4c6d69b9af18347f83b1e6f  orc-0.4.42.tar.xz
"
