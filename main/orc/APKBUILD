# Contributor: Łukasz Jendrysik <scadu@yandex.com>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=orc
pkgver=0.4.42
pkgrel=1
pkgdesc="Oil Run-time Compiler"
url="https://gstreamer.freedesktop.org/modules/orc.html"
arch="all"
license="BSD-2-Clause"
depends_dev="$pkgname-compiler=$pkgver-r$pkgrel"
makedepends="linux-headers meson"
subpackages="$pkgname-bugreport $pkgname-compiler $pkgname-test:_test $pkgname-test-dev:_test_dev $pkgname-dev"
source="https://gstreamer.freedesktop.org/src/orc/orc-$pkgver.tar.xz
	riscv.patch
	"

# secfixes:
#   0.4.39-r0:
#     - CVE-2024-40897

build() {
	abuild-meson \
		-Db_lto=true \
		-Dorc-test=enabled \
		-Dbenchmarks=enabled \
		-Dtools=enabled \
		-Dtests=enabled \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

bugreport() {
	amove usr/bin/orc-bugreport
}

compiler() {
	pkgdesc="Orc compiler"

	amove usr/bin
}

_test() {
	amove usr/lib/liborc-test*.so.*
}

_test_dev() {
	amove \
		usr/lib/liborc-test*.so \
		usr/lib/pkgconfig/orc-test-*.pc \
		usr/include/orc-*/orc-test
}

sha512sums="
3a1ebe31a49255df10dbf2eb2aa72265dfc8a3806107d57b92c187aab8be32e01ad5652fb385d6886a15c23017a4db5374c0234be4c6d69b9af18347f83b1e6f  orc-0.4.42.tar.xz
b5f26bcaec221362cd57bb51ec8c1a60e04aaee12ad30846bc1ec0fdb188e114bb354d9d423708b15b7c62c008b24da1370c9b26dfac186b4e5d032c6795265d  riscv.patch
"
