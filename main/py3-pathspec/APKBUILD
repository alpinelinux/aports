pkgname=py3-pathspec
_pyname=pathspec
pkgver=1.0.3
pkgrel=0
pkgdesc="Utility library for gitignore style pattern matching of file paths"
url="https://github.com/cpburnz/python-path-specification"
license="MPL-2.0"
arch="noarch"
depends="python3"
makedepends="py3-flit-core py3-gpep517"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://files.pythonhosted.org/packages/source/p/pathspec/pathspec-$pkgver.tar.gz"
builddir="$srcdir/$_pyname-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m unittest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/pathspec-$pkgver-py3-none-any.whl
}

sha512sums="
8ca509c3085949827274efd73f5bb618b7446eab5e08e0c1a19b27dc5910d35b3e9dac36dc2f60152c2db4c95c776e5c4b9a436a17d9ade5da71a2bcf098dea8  py3-pathspec-1.0.3.tar.gz
"
