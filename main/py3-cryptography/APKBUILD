44197977e2c46680d9c78061bb04e8ba9e5118666a90c76e560d2f5b2ca1488615b380dd23429ab2bec75bc73c8c9b87bb51a7d6220067a8eb548fbfb5b23c8e  cryptography_vectors-46.0.5.tar.gz
08c5a80ec8427b612e6ec8e27d813e3ebafdb77300ad7cd97d19e3eb537abbb4ee93ed987d6a124a55ef9c9ea428bc2dc7c7f6602dc4787cc22a0eff93eb15f0  vectors-build-backend-flit_core_patch
"
