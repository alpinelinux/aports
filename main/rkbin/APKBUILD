# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=rkbin
pkgver=0_git20251028
pkgrel=0
pkgdesc="Rockchip binary firmware files"
url="https://github.com/rockchip-linux/rkbin"
arch="noarch"
license="custom"
options="!check !strip !spdx !archcheck"
_commit=5f6fb8f92674de284fd963fd50d23b9df0c33be7
source="$pkgname-$_commit.tar.gz::https://github.com/rockchip-linux/rkbin/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit"

package() {
	mkdir -p "$pkgdir"/usr/share/rkbin
	cp -a bin "$pkgdir"/usr/share/rkbin/
	find "$pkgdir"/usr/share/rkbin/bin -type f -exec chmod 644 {} +

	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

sha512sums="
0ea152af1960a6d0bc6dd524d74a1b9f0ae28e6d25681fcf42d3b4917fc4288fa8535cc33cd9ac5798fc846a8b9439fd48f2e9122fb82054978fd7834944a5c6  rkbin-5f6fb8f92674de284fd963fd50d23b9df0c33be7.tar.gz
"
