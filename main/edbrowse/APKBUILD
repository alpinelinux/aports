# Maintainer: mio <miyopan@e.email>
maintainer="mio <miyopan@e.email>"
pkgname=edbrowse
pkgver=3.8.16
pkgrel=0
pkgdesc="Line-oriented editor, web browser, and mail client"
url="https://edbrowse.org/"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	curl-dev
	openssl-dev
	pcre2-dev
	perl
	quickjs-ng-dev
	readline-dev
	unixodbc-dev
	"
subpackages="$pkgname-doc $pkgname-plugins"
case "$pkgver" in
*_git*)
	source="https://github.com/edbrowse/edbrowse/archive/$_gitrev/edbrowse-$_gitrev.tar.gz"
	builddir="$srcdir/$pkgname-$_gitrev"
	;;
*)
	source="https://github.com/edbrowse/edbrowse/archive/v$pkgver/edbrowse-$pkgver.tar.gz"
	;;
esac

prepare() {
	default_prepare

	# "edbrowse -v" in check() fails if ~/.ebrc is not found
	if want_check; then
		touch "$srcdir"/.ebrc
	fi
}

build() {
	make QUICKJS_INCLUDE=/usr/include/quickjs-ng
}

check() {
	HOME="$srcdir" ./src/edbrowse -v
}

package() {
	# Reset INSTALL env variable to remove -C flag unsupported by busybox
	# INSTALLBASE is used by other path variables e.g. DOCDIR
	make \
		DESTDIR="$pkgdir" \
		INSTALL="install -D" \
		INSTALLBASE="$pkgdir/usr" \
		PREFIX=/usr \
		-C src install

	install -Dvm644 "$builddir"/doc/man-edbrowse-debian.1 \
		"$pkgdir"/usr/share/man/man1/edbrowse.1
	install -Dvm644 "$builddir"/README.md -t "$pkgdir"/usr/share/doc/$pkgname/
	install -Dvm644 "$builddir"/LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

plugins() {
	pkgdesc="$pkgdesc (plugins)"
	depends="$pkgname=$pkgver-r$pkgrel"
	amove usr/bin/edbrowse-plugin-*
	amove usr/share/edbrowse/plugins
}

sha512sums="
4d273ecfa5f05d3b133521ae03ee176e3207f3d5f0142807ad89baab3daf38eee92c32dbd4cfc30f38b71b9e49e8cc980eb5d3e8feafd6744f551f77f6e32dbf  edbrowse-3.8.16.tar.gz
"
