Remove -C option unsupported by busybox.
Ref: https://github.com/edbrowse/edbrowse/commit/c6c451fc8d0a3ea635c154b30c01666124f7aa84
---
diff -rupN a/src/makefile b/src/makefile
--- a/src/makefile	2026-05-29 19:09:24.000000000 +0000
+++ b/src/makefile	2026-05-31 03:48:08.474431317 +0000
@@ -21,7 +21,7 @@ EXECMODE ?= 755
 FILEMODE ?= 644
 # install macros
 define install_generic
-$(MKDIR) -p -m $(DIRMODE) $(1); $(INSTALL) -C -m $(2) $(3) $(1)
+$(MKDIR) -p -m $(DIRMODE) $(1); $(INSTALL) -m $(2) $(3) $(1)
 endef
 install_exec = $(call install_generic,$(1),$(EXECMODE),$(2))
 install_file = $(call install_generic,$(1),$(FILEMODE),$(2))
