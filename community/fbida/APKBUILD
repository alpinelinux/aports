# Contributor: Sören Tempel <soeren+alpine@soeren-tempel.net>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=fbida
pkgver=2.15
pkgrel=0
pkgdesc="Few applications to display and elementary edit images"
url="https://www.kraxel.org/blog/linux/$pkgname/"
arch="all"
license="GPL-2.0-only"
makedepends="
	cairo-dev
	giflib-dev
	glib-dev
	libdrm-dev
	libexif-dev
	libinput-dev
	libjpeg-turbo-dev
	libpng-dev
	libxkbcommon-dev
	meson
	motif-dev
	perl
	pixman-dev
	tiff-dev
	"
subpackages="
	$pkgname-fbgs:_tool:noarch
	$pkgname-exiftran:_tool
	$pkgname-fbi:_tool
	$pkgname-ida
	$pkgname-doc
	"
source="$pkgname-$pkgver.tar.gz::https://gitlab.com/kraxel/fbida/-/archive/fbida-$pkgver-1/fbida-fbida-$pkgver-1.tar.gz
	alpine-meson.patch
	ida-desktop.patch
	"
builddir="$srcdir/fbida-fbida-$pkgver-1"
options="!check" # no upstream testsuite

build() {
	abuild-meson \
		-Dpdf=disabled \
		-Dmotif=enabled \
		-Dpng=enabled \
		-Dtiff=enabled \
		-Dgif=enabled \
		. output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

_tool() {
	local name=$(echo $subpkgname | cut -d '-' -f2)
	pkgdesc="$name tool from $pkgname"

	depends=""
	if [ "$name" = "fbgs" ]; then
		depends="$pkgname-fbi ghostscript"
	fi

	mkdir -p "$subpkgdir"/usr/bin
	mv "$pkgdir"/usr/bin/$name \
		"$subpkgdir"/usr/bin/$name

	rmdir "$pkgdir"/usr/bin/ 2>/dev/null || true
	rmdir "$pkgdir"/usr/ 2>/dev/null || true
}

ida() {
	pkgdesc="ida tool from $pkgname"

	amove usr/bin/ida
	amove etc/X11/app-defaults/fbida
	amove usr/share/applications/ida.desktop
}

