4b25e7bd64ad18deaca475a76541fa562ac496108d1eccea207d9fd64ec40c43765fa2949c4b7e5fb85bdf98fc5193a2ce5994884a8a50c88738deef252c9931  0001-Compile-extension-as-C.patch
3f5bbb422c6739e701daece5576513704240261dcf6f33580b2330bd4ca2bbeba9b59c49ed99a3ebd0f3ea9792acc874d2cff25e9a8b436472fa45829c9fda28  0002-Upgrade-cython-allow-3.2.x-series.patch
"
