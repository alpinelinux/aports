maintainer="Adam Thiede <me@adamthiede.com>"
pkgname=depthcharge-tools
pkgver=0.6.4
pkgrel=0
pkgdesc="Tools to manage the Chrome OS bootloader"
url="https://gitlab.postmarketos.org/postmarketOS/depthcharge-tools"
# other arches blocked by vboot-utils
arch="armhf armv7 aarch64 x86_64 x86"
license="GPL-2.0-or-later"
depends="
	cgpt
	dtc
	gzip
	lz4
	py3-packaging
	py3-importlib-metadata
	py3-importlib-resources
	u-boot-tools
	vboot-utils
	xz
"
makedepends="
	py3-gpep517
	py3-installer
	py3-setuptools
"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://gitlab.postmarketos.org/postmarketOS/depthcharge-tools/-/archive/v$pkgver/depthcharge-tools-v$pkgver.tar.gz"
options="!check"
builddir="$srcdir/$pkgname-v$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
f04efb5ffa7ab68332745fc113b92ffa4238584432a9f87791ffb6199f4c1016cb72160936ac34eaae3a176c705dba273051a88ab4d038fa9c7e383eef8c0656  depthcharge-tools-0.6.4.tar.gz
"
