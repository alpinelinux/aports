# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-settings-daemon
pkgver=1.2.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Settings daemon for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-settings-daemon"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-only"
depends="
	acpid
	alsa-utils
	geoclue
	playerctl
"
makedepends="
	cargo-auditable
	clang22-libclang
	libinput-dev
	pipewire-dev
	pulseaudio-dev
	openssl-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-settings-daemon/archive/refs/tags/epoch-$_upstreamver.tar.gz
	fe74f652b6b3f0c65f3b1a1bfc48402f439a9bbe.patch
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
