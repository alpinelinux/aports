# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-settings-daemon
pkgver=1.0.12
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Settings daemon for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-settings-daemon"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-only"
depends="
	acpid
	alsa-utils
	geoclue
	playerctl
	pulseaudio-dev
"
makedepends="
	cargo-auditable
	libinput-dev
	openssl-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-settings-daemon/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
10e1456b82022ade58fb52dfae9aeb980e458e8e47ee48c4fe3578cdcd99c62b76b3d5205a4c92f4a2015d080e6c9802ff203b0550154ca98a518e42344f5fbd  cosmic-settings-daemon-1.0.12.tar.gz
"
