# Contributor: Adam Plumb <adamplumb@gmail.com>
maintainer="team/gnome <achill@achill.org>"
pkgname=libadwaita
pkgver=1.9.2
pkgrel=0
pkgdesc="Building blocks for modern GNOME applications"
url="https://gitlab.gnome.org/GNOME/libadwaita"
arch="all"
license="LGPL-2.1-or-later"
depends="adwaita-fonts"
makedepends="
	appstream-dev
	fribidi-dev
	glib-dev
	gobject-introspection-dev
	gtk4.0-dev
	meson
	sassc
	vala
	"
# Tests need any font
checkdepends="
	dbus
	font-dejavu
	mesa-dri-gallium
	xvfb-run
	"
subpackages="$pkgname-dbg $pkgname-dev $pkgname-lang $pkgname-demo"
source="https://download.gnome.org/sources/libadwaita/${pkgver%.*}/libadwaita-$pkgver.tar.xz"

case "$CARCH" in
arm*) options="!check" ;; # race condition
esac

build() {
	CFLAGS="$CFLAGS -g1" \
	CPPFLAGS="$CPPFLAGS -g1" \
	abuild-meson \
		-Db_lto=true \
		-Dexamples=true \
		-Ddocumentation=false \
		-Dtests="$(want_check && echo true || echo false)" \
		. output
	meson compile -C output
}

check() {
	GTK_THEME=Adwaita \
	XDG_RUNTIME_DIR="$(mktemp -d -p "$builddir")" \
	dbus-run-session -- \
	xvfb-run -a \
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

demo() {
	pkgdesc="$pkgdesc (libadwaita demo)"
	amove usr/share usr/bin
}

sha512sums="
324fffe7fc2ffa1e5c1da3085d0f8c836f03da79d70d9ca7293e778f2820f10f202d4a81c27edefeb03c3656e2a7829de55c84c2b792660c03b84ee65fa5373f  libadwaita-1.9.2.tar.xz
"
