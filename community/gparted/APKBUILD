# Contributor: Dominika Liberda <ja@sdomi.pl>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=gparted
pkgver=1.8.0
pkgrel=0
pkgdesc="graphical partition editor for creating, reorganizing, and deleting disk partitions"
url="https://gparted.sourceforge.net/"
arch="all"
license="GPL-2.0-or-later"
depends="e2fsprogs"
makedepends="
	gettext-dev
	gtkmm3-dev
	parted-dev
	polkit-dev
	util-linux-dev
	"
checkdepends="eudev"
subpackages="$pkgname-doc $pkgname-lang"
source="https://downloads.sourceforge.net/project/gparted/gparted/gparted-$pkgver/gparted-$pkgver.tar.gz"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--disable-doc
	make
}

package() {
	make appdatadir=/usr/share/metainfo DESTDIR="$pkgdir" install
}

sha512sums="
7b1137e6529257b8e1eeab03a1cfb178c525a9ee38f9f76d8a7bf6710f2c4b9d584a5c601bf1f55b904fefdd03911371577218412cff1e53adfc902cb93c4d60  gparted-1.8.0.tar.gz
"
