diff --git a/src/gn/functions_unittest.cc b/src/gn/functions_unittest.cc
index c51c4875..c51351a8 100644
--- a/src/gn/functions_unittest.cc
+++ b/src/gn/functions_unittest.cc
@@ -200,6 +200,50 @@ TEST(Functions, SplitList) {
