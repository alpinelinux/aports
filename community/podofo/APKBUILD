prepare() {
	default_prepare

	rmdir extern/resources
	ln -sfv "$srcdir"/podofo-resources-$_resources extern/resources
}

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DPODOFO_BUILD_STATIC=0 \
		-DPODOFO_BUILD_TEST="$(want_check && echo ON || echo OFF)"
	cmake --build build
}

check() {
	ctest --test-dir build -E "TestMalformedAnnotationAction|TestImageInvalidLength|TestMaxObjectCount|TestBitsPerComponent1|UserHasLimitedPermissions|OwnerHasFullPermissions|TestCertificateRSA"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

