From 1f8f6c530fe479dfade40c11b13c87ded5c730ec Mon Sep 17 00:00:00 2001
From: Mike Williams <mike.williams@grommunio.com>
Date: Mon, 2 Feb 2026 19:05:44 +0100
Subject: [PATCH] security: de-globalize non-required headers and split off for
 re-inclusion

---
 usr/share/grommunio-common/nginx.conf               | 1 -
 usr/share/grommunio-common/nginx/security.conf      | 3 ---
 usr/share/grommunio-common/nginx/security_perm.conf | 2 ++
 usr/share/grommunio-common/nginx/security_php.conf  | 1 +
 4 files changed, 3 insertions(+), 4 deletions(-)
 create mode 100644 usr/share/grommunio-common/nginx/security_perm.conf
 create mode 100644 usr/share/grommunio-common/nginx/security_php.conf

diff --git a/usr/share/grommunio-common/nginx.conf b/usr/share/grommunio-common/nginx.conf
index 93efc95..fdd82cf 100644
--- a/usr/share/grommunio-common/nginx.conf
+++ b/usr/share/grommunio-common/nginx.conf
@@ -58,7 +58,6 @@ server {
 	include /etc/grommunio-common/nginx/ssl_*.conf;
 	include /usr/share/grommunio-common/nginx/proxy_params.conf;
 	include /usr/share/grommunio-common/nginx/proxy_headers.conf;
-	include /usr/share/grommunio-common/nginx/security.conf;
 
 	include /usr/share/grommunio-common/nginx/brotli-params*.conf;
 	include /usr/share/grommunio-common/nginx/traffic_status_params*.conf;
diff --git a/usr/share/grommunio-common/nginx/security.conf b/usr/share/grommunio-common/nginx/security.conf
index c0e2d46..cdcd347 100644
--- a/usr/share/grommunio-common/nginx/security.conf
+++ b/usr/share/grommunio-common/nginx/security.conf
@@ -1,5 +1,3 @@
-add_header Content-Security-Policy "default-src 'self' data:; frame-src * blob:; connect-src * data: blob:; font-src * data:; img-src * data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; object-src 'self'; base-uri 'self'; frame-ancestors 'self';";
-add_header Permissions-Policy "accelerometer=(), autoplay=(self), camera=(self), display-capture=(self), encrypted-media=(self), fullscreen=(self), geolocation=(self), gyroscope=(), keyboard-map=(self), magnetometer=(), microphone=(self), midi=(), payment=(), picture-in-picture=(self), publickey-credentials-get=(self), screen-wake-lock=(self), sync-xhr=(), usb=(), web-share=(self), xr-spatial-tracking=(self)";
 add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
 add_header X-Content-Type-Options nosniff;
 add_header X-Frame-Options "SAMEORIGIN" always;
@@ -7,4 +5,3 @@ add_header X-Permitted-Cross-Domain-Policies none always;
 add_header X-Robots-Tag none always;
 add_header X-XSS-Protection "1; mode=block";
 add_header Referrer-Policy "no-referrer" always;
-fastcgi_hide_header X-Powered-By;
diff --git a/usr/share/grommunio-common/nginx/security_perm.conf b/usr/share/grommunio-common/nginx/security_perm.conf
new file mode 100644
index 0000000..509115b
--- /dev/null
+++ b/usr/share/grommunio-common/nginx/security_perm.conf
@@ -0,0 +1,2 @@
+add_header Content-Security-Policy "default-src 'self' data:; frame-src * blob:; connect-src * data: blob:; font-src * data:; img-src * data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; object-src 'self'; base-uri 'self'; frame-ancestors 'self';";
+add_header Permissions-Policy "accelerometer=(), autoplay=(self), camera=(self), display-capture=(self), encrypted-media=(self), fullscreen=(self), geolocation=(self), gyroscope=(), keyboard-map=(self), magnetometer=(), microphone=(self), midi=(), payment=(), picture-in-picture=(self), publickey-credentials-get=(self), screen-wake-lock=(self), sync-xhr=(), usb=(), web-share=(self), xr-spatial-tracking=(self)";
diff --git a/usr/share/grommunio-common/nginx/security_php.conf b/usr/share/grommunio-common/nginx/security_php.conf
new file mode 100644
index 0000000..9b9928a
--- /dev/null
+++ b/usr/share/grommunio-common/nginx/security_php.conf
@@ -0,0 +1 @@
+fastcgi_hide_header X-Powered-By;
