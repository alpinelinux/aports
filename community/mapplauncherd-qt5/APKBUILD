maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=mapplauncherd-qt5
pkgver=1.2.0
pkgrel=0
pkgdesc="Application launch boosters for Qt5"
url="https://github.com/sailfishos/mapplauncherd-qt"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-only"
depends_dev="
	libxml2-dev
	mapplauncherd-dev
	qt5-qtbase-dev
	qt5-qtdeclarative-dev
	"
makedepends="$depends_dev"
subpackages="
	$pkgname-dev
	$pkgname-systemd
	"
source="https://github.com/sailfishos/mapplauncherd-qt/archive/$pkgver/mapplauncherd-qt-$pkgver.tar.gz"
builddir="$srcdir/mapplauncherd-qt-$pkgver"
options="!check" # No tests

build() {
	qmake-qt5 \
		PREFIX=/usr
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install
}
sha512sums="
