# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=xdg-desktop-portal-cosmic
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="xdg-desktop-portal implementation for the COSMIC Desktop Environment"
url="https://github.com/pop-os/xdg-desktop-portal-cosmic"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armhf !armv7 !riscv64 !x86"
license="GPL-3.0-only"
depends="
	cosmic-icons
	xdg-desktop-portal
"
makedepends="
	cargo-auditable
	clang-libclang
	findutils
	just
	glib-dev
	gstreamer-dev
	libxkbcommon-dev
	mesa-dev
	pipewire-dev
	wayland-dev
	xdg-desktop-portal-dev
"
options="net !check"  # fetch dependencies, no tests
subpackages="$pkgname-systemd"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/xdg-desktop-portal-cosmic/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
7fb53fec552b0b47341dab8ff7522530245a5ab8633024b6f0bd40b13bad532ad1e7d5a6a37ed54cfbc15c87a10abcee24e6e94c59e20672e2df5364f2b11de7  xdg-desktop-portal-cosmic-1.4.0.tar.gz
"
