c202d7d673966fa6a767bc5f2019fc82a8cdd73b01fd61095667c25e9cba15f3b6c10a055ddfef6a6e879d6c3c57a47d29fdee99f4af3f37cdf45df4136ccea2  cargo-auditable.patch
"
