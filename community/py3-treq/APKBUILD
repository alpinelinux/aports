# Maintainer:
pkgname=py3-treq
pkgver=24.9.0
pkgrel=0
pkgdesc="py3-requests-like API build on top of Twisted's HTTP client"
url="https://github.com/twisted/treq"
arch="noarch"
license="MIT"
depends="
	py3-attrs
	py3-hyperlink
	py3-incremental
	py3-requests
	py3-twisted
	py3-typing-extensions
	python3
	"
makedepends="
	py3-gpep517
	py3-setuptools
	"
checkdepends="
	py3-httpbin
	py3-openssl
	py3-pytest
	py3-twisted-tests
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/twisted/treq/archive/refs/tags/treq-$pkgver.tar.gz
	vendor-multipart.patch
	"
builddir="$srcdir/treq-treq-$pkgver"

# secfixes:
#   22.1.0-r0:
#     - CVE-2022-23607

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

