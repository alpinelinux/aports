# Contributor: Anon <danilagdn.2004@gmail.com>
# Maintainer: Lindsay Zhou <i@lin.moe>
maintainer="Lindsay Zhou <i@lin.moe>"
pkgname=sing-box
pkgver=1.13.2
pkgrel=0
pkgdesc="The universal proxy platform"
url="https://sing-box.sagernet.org/"
arch="all"
license="GPL-3.0-or-later with name use or association addition"
makedepends="go clang lld"
subpackages="$pkgname-openrc $pkgname-systemd $pkgname-bash-completion $pkgname-fish-completion $pkgname-zsh-completion"
options="net" # go modules and check
source="$pkgname-$pkgver.tar.gz::https://github.com/SagerNet/sing-box/archive/v$pkgver.tar.gz
	$pkgname.initd
	$pkgname.confd
	"
build() {
	export CGO_CPPFLAGS="$CPPFLAGS"
	export CGO_CFLAGS="$CFLAGS"
	export CGO_CXXFLAGS="$CXXFLAGS"
	export CGO_LDFLAGS="$LDFLAGS"

	case "$CARCH" in
		x86|x86_64|armv7|aarch64|riscv64|loongarch64)
			_tags="$(cat release/DEFAULT_BUILD_TAGS),with_musl"
			_cc=clang
			_cxx=clang++
			_cgo_ldflags="-fuse-ld=lld"
			case "$CARCH" in
				x86|armv7|loongarch64) _cgo_ldflags="$_cgo_ldflags -Wl,-no-pie" ;;
			esac
			;;
		*)
			_tags=$(cat release/DEFAULT_BUILD_TAGS_OTHERS)
			;;
	esac
	_ldflags=$(cat release/LDFLAGS)

	CC="${_cc:-${CC:-cc}}" CXX="${_cxx:-${CXX:-c++}}" CGO_LDFLAGS="$LDFLAGS $_cgo_ldflags" \
	go build -v -tags "$_tags" \
	-ldflags "-X \"github.com/sagernet/sing-box/constant.Version=$pkgver\" $_ldflags -s -w
	-buildid= -linkmode=external" ./cmd/sing-box

	install -d completions
	./"$pkgname" completion bash   > completions/bash
	./"$pkgname" completion fish   > completions/fish
	./"$pkgname" completion zsh    > completions/zsh
}

check() {
	go test -tags "$(cat release/DEFAULT_BUILD_TAGS_OTHERS)" -ldflags "$_ldflags" -v ./...
	# require docker to run test cases in the "test" submodule,
	# so we don't use `make test`.
}

package() {
	install -Dm644 LICENSE                      -t "$pkgdir/usr/share/licenses/$pkgname"
	install -Dm755 "$pkgname"                   -t "$pkgdir/usr/bin"
	install -Dm644 "release/config/config.json" -t "$pkgdir/etc/$pkgname"
	install -Dm755 "$srcdir/$pkgname.initd" 		"$pkgdir/etc/init.d/$pkgname"
	install -Dm755 "$srcdir/$pkgname.confd" 		"$pkgdir/etc/conf.d/$pkgname"

	install -Dm644 completions/bash "$pkgdir/usr/share/bash-completion/completions/$pkgname.bash"
	install -Dm644 completions/fish "$pkgdir/usr/share/fish/vendor_completions.d/$pkgname.fish"
	install -Dm644 completions/zsh  "$pkgdir/usr/share/zsh/site-functions/_$pkgname"

	install -Dm644 release/config/*.service -t "$pkgdir"/usr/lib/systemd/system/
}

