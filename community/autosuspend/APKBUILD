# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=autosuspend
pkgver=10.1.0
pkgrel=2
pkgdesc="Daemon to automatically suspend and wake up a system"
url="https://github.com/languitar/autosuspend"
arch="all"
license="GPL-2.0"
depends="
	py3-dateutil
	py3-dbus
	py3-gobject3
	py3-icalendar
	py3-jsonpath-ng
	py3-lxml
	py3-mpd2
	py3-psutil
	py3-requests-file
	py3-tzlocal
"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="
	py3-dbusmock
	py3-pytest-cov
	py3-pytest-datadir
	py3-pytest-freezegun
	py3-pytest-httpserver
	py3-pytest-mock
"
subpackages="$pkgname-systemd"
source="$pkgname-$pkgver.tar.gz::https://github.com/languitar/autosuspend/archive/refs/tags/v10.1.0.tar.gz"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# TestXIdleTime::test_smoke: test is broke
	.testenv/bin/python3 -m pytest \
		--deselect tests/test_checks_xorg.py::TestXIdleTime::test_smoke
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
77a10f50beb2a227267c3c71acf2881c1d2d1d5d028858b7506e97a509739aa56db7a68c132231278cabcac0f07df599ba6331d49496ee959cd1166fa5ea525a  autosuspend-10.1.0.tar.gz
"
