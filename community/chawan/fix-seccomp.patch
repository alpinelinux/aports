---
From db8f50a5e40aa7a1088f71633d3d34f3bfa9cda7 Mon Sep 17 00:00:00 2001
From: bptato <nincsnevem662@gmail.com>
Date: Mon, 18 May 2026 16:27:37 +0200
Subject: [PATCH] read_nr: fix incorrect usage of -N switch

-N takes a number of bytes to read, so if we want to read a word then we
have to pass 2 there too.

This broke seccomp on newer architectures that happen to use an ELF machine
number >= 256, notably LoongArch.
---
 lib/chaseccomp/read_nr | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/lib/chaseccomp/read_nr b/lib/chaseccomp/read_nr
index 77c6fdf10aba9ff154d7bb57f7691d128842990d..32e2efede6c5251d0209abaff41d06c8ecd9d832 100755
--- a/lib/chaseccomp/read_nr
+++ b/lib/chaseccomp/read_nr
@@ -13,7 +13,7 @@ die() {
 }
 test -n "$file" || die "usage: read_nr [file]"
 get_bytes() {
-	od -v -t d"$2" -A n -N 1 -j "$1" "$file" | sed 's/ //g'
+	od -v -t d"$2" -A n -N "$2" -j "$1" "$file" | sed 's/ //g'
 }
 
 nr=$(get_bytes 18 2)
