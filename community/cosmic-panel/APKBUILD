# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-panel
pkgver=1.0.9
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Panel component for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-panel"
# s390x: nix
# riscv64: too slow to build
arch="all !s390x !riscv64"
license="GPL-3.0-or-later"
makedepends="
	appstream-glib
	cargo
	desktop-file-utils
	findutils
	intltool
	just
	libxkbcommon-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-panel/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo build --release --frozen
}

check() {
	cargo test --release --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
82b50acbe5e64cd1268e8807e3571a975c1d5ae3ec851f22b8d1be29e373cb534020340926b819f6bb96c72b957cf90ea71ee3e56c47a9d6d9032b2e6b5b3e6a  cosmic-panel-1.0.9.tar.gz
"
