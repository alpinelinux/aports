# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-panel
pkgver=1.3.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Panel component for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-panel"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-or-later"
makedepends="
	appstream-glib
	cargo-auditable
	desktop-file-utils
	findutils
	intltool
	just
	libxkbcommon-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-panel/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST"
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
ae5f75a4b7b635548d29c95051c455c1925f71474f9d474bbf6436696a44ed7b916be0312af399b2176b41a1c991a682c06be3a56173f91d1521551b28c2c91a  cosmic-panel-1.3.0.tar.gz
"
