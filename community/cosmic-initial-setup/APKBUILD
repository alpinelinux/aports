# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-initial-setup
pkgver=1.0.14
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Initial setup for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-initial-setup"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-or-later"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	eudev-dev
	desktop-file-utils
	just
	libinput-dev
	libxkbcommon-dev
	mesa-dev
	openssl-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-initial-setup/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
4df094d1fe531c4a86858b7856c3784a9ec8d225db1f517072ec2d10f032a6ce97d321b5db3595d32e259c188e88336eedf9ac1321110c366e7dcdc19de8461e  cosmic-initial-setup-1.0.14.tar.gz
"
