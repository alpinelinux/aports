# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-initial-setup
pkgver=1.0.11
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Initial setup for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-initial-setup"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-or-later"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	eudev-dev
	desktop-file-utils
	just
	libinput-dev
	libxkbcommon-dev
	mesa-dev
	openssl-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-initial-setup/archive/refs/tags/epoch-$_upstreamver.tar.gz

	loongarch64-libc.patch
	"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
acc31413e71f4191dc9757c735c17648701cb9d2811ed3314da38a77a061a8779a6a27c13bb85726653fd27d0cd6470085ef86508ceeea982c2c9174992f81b7  cosmic-initial-setup-1.0.11.tar.gz
09dd2196240b7e522e974f51a73973a41eefc3dde1b9eb0c13c76064fc821f7453353afc5df8deb059b7fe52aa98b6d47620fe14593fd33b804e882a76d170cc  loongarch64-libc.patch
"
