# Maintainer: Noel Kuntze <noel.kuntze@contauro.com>
pkgname=py3-openapi-core
pkgver=0.22.0
pkgrel=0
pkgdesc="Client-side and server-side support for the OpenAPI Specification v3"
arch="noarch"
url="https://github.com/p1c2u/openapi-core"
license="BSD-3-Clause"
# many check failures
# notably: AttributeError: 'SchemaAccessor' object has no attribute 'resolver'. Did you mean: 'resolve'
options="!check"
depends="python3
	py3-asgiref
	py3-isodate
	py3-jsonschema
	py3-jsonschema-path
	py3-more-itertools
	py3-openapi-schema-validator
	py3-openapi-spec-validator
	py3-parse
	py3-werkzeug
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	py3-poetry-core
	"
checkdepends="
	py3-pytest
	py3-pytest-aiohttp
	py3-pytest-asyncio
	py3-aiohttp
	py3-aioitertools
	py3-django
	py3-django-rest-framework
	py3-falcon
	py3-fastapi
	py3-flask
	py3-httpx
	py3-multidict
	py3-requests
	py3-responses
	py3-starlette
	"

subpackages="$pkgname-pyc"

source="$pkgname-$pkgver.tar.gz::https://github.com/python-openapi/openapi-core/archive/refs/tags/$pkgver.tar.gz"

builddir="$srcdir"/openapi-core-$pkgver

prepare() {
	default_prepare
	sed -i 's/--cov\S*//' pyproject.toml
}

build() {
	gpep517 build-wheel \
		--wheel-dir dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --system-site-packages testenv
	testenv/bin/python3 -m installer dist/*.whl
	testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" dist/*.whl
}

sha512sums="
2192c9b583bd4450f2de885bd2cbfcd763f89bbe1db9f840670fdd7893703d594116bb8a63f6416a73c7841e19e92e4007d82e60ab64acf2c19db0eb36dc4866  py3-openapi-core-0.22.0.tar.gz
"
