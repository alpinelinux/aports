check() {
	export CFLAGS=$(perl -MConfig -E 'say $Config{ccflags}')

	# run dummy smtp server
	python3 "$srcdir"/fake-smtp.py &
	local pid=$!
	local rc=0
	if ! make test; then
		rc=1
	fi
	kill $pid
	return $rc
}

