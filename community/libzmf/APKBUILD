# Maintainer: Timo Teräs <timo.teras@iki.fi>
pkgname=libzmf
pkgver=0.0.2
pkgrel=22
pkgdesc="Import filter and tools for Zoner Callisto/Draw documents"
url="https://wiki.documentfoundation.org/DLP/Libraries/libzmf"
arch="all"
license="MPL-2.0"
depends_dev="boost-dev icu-dev libpng-dev zlib-dev"
makedepends="$depends_dev librevenge-dev doxygen automake autoconf libtool"
subpackages="$pkgname-dev $pkgname-doc"
source="https://dev-www.libreoffice.org/src/libzmf/libzmf-$pkgver.tar.xz
	install-all-files-generated-by-doxygen.patch"

prepare() {
	default_prepare
	update_config_sub
	autoreconf -fi
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--disable-werror
	make
}

package() {
	make DESTDIR="$pkgdir" install
}

