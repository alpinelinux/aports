From f37cd61288ad7d2776ad2a847f7c0841a5a92350 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Thu, 16 Apr 2026 20:17:14 +0200
Subject: [PATCH] Add forward compatibility for KMime from KDE Frameworks

---
 CMakeLists.txt                     |  6 +++++-
 KPimIncidenceEditorConfig.cmake.in | 18 ++++++++++++++----
 tests/CMakeLists.txt               |  2 +-
 3 files changed, 20 insertions(+), 6 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 5f3d6b6d..fe81b283 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -135,7 +135,11 @@ find_package(KPim6AkonadiCalendar ${AKONADICALENDAR_LIB_VERSION} CONFIG REQUIRED
 find_package(KPim6AkonadiMime ${AKONADI_MIMELIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6CalendarSupport ${CALENDARSUPPORT_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6CalendarUtils ${CALENDARUTILS_LIB_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KPim6PimCommonAkonadi ${PIMCOMMON_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6TextEdit ${PIMTEXTEDIT_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6IdentityManagementCore ${IDENTITYMANAGEMENT_LIB_VERSION} CONFIG REQUIRED)
diff --git a/KPimIncidenceEditorConfig.cmake.in b/KPimIncidenceEditorConfig.cmake.in
index c40e3f63..985d7319 100644
--- a/KPimIncidenceEditorConfig.cmake.in
+++ b/KPimIncidenceEditorConfig.cmake.in
@@ -18,10 +18,20 @@ find_dependency(
     KF6CalendarCore
     "@KF_MIN_VERSION@"
 )
-find_dependency(
-    KPim6Mime
-    "@KMIME_LIB_VERSION@"
-)
+if(@KF6Mime_FOUND@)
+    find_dependency(
+        KF6Mime
+        "@KF_MIN_VERSION@"
+    )
+else()
+    find_dependency(
+        KPim6Mime
+        "@KPIM_MIME_VERSION@"
+    )
+    if(NOT TARGET KF6::Mime)
+        add_library(KF6::Mime ALIAS KPim6::Mime)
+    endif()
+endif()
 find_dependency(
     KPim6AkonadiMime
     "@AKONADI_MIMELIB_VERSION@"
diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
index 6b649a81..d1aec0f3 100644
--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -7,7 +7,7 @@ target_link_libraries(
     resourcemanagement_gui
     Qt::Core
     Qt::Gui
-    KPim6::Mime
+    KF6::Mime
     KPim6::IncidenceEditor
     KPim6::Libkdepim
     KPim6::LdapWidgets
-- 
