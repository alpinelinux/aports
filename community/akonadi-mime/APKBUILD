92b0cd1e3df9e00443af8c72ec9adfe7ec6d9407163e739f4fe5d9be80aaedced088535ddcaaac386dfb942112a0cebf9edecb4ecb125b159945375551e0be8b  0001-akonadi-mime-KMime-from-KF6.patch
"
