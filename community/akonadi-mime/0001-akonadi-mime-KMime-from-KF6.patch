From 9a7f042f9aceb697a42eec0f02fbd011837cb6de Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Sun, 12 Apr 2026 09:49:22 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

As KMime in Frameworks can only intall its backward compatibility targets
until shortly before its first KF release and we need to make the switch
somewhat atomic this will transparently use the KF version when available.

Once the switch is complete we just remove the if() block in the toplevel
CMakeLists.txt and make the KF one REQUIRED.
---
 CMakeLists.txt                        | 6 +++++-
 autotests/CMakeLists.txt              | 4 ++--
 autotests/benchmarker/CMakeLists.txt  | 2 +-
 autotests/messagetests/CMakeLists.txt | 2 +-
 serializers/CMakeLists.txt            | 2 +-
 src/CMakeLists.txt                    | 2 +-
 tests/CMakeLists.txt                  | 2 +-
 7 files changed, 12 insertions(+), 8 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index d88d4a4..5dfc16c 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -114,7 +114,11 @@ find_package(Qt6QmlIntegration ${QT_REQUIRED_VERSION} REQUIRED)
 find_package(KF6KIO ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6I18n ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6XmlGui ${KF_MIN_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KF6ItemModels ${KF_MIN_VERSION} CONFIG REQUIRED)
 
 find_package(KPim6Akonadi ${AKONADI_VERSION} CONFIG REQUIRED)
diff --git a/autotests/CMakeLists.txt b/autotests/CMakeLists.txt
index f251664..dbba7f8 100644
--- a/autotests/CMakeLists.txt
+++ b/autotests/CMakeLists.txt
@@ -38,13 +38,13 @@ add_definitions(-DREQUESTER_EXE="${requester_exe_string}")
 add_subdirectory(benchmarker)
 
 ecm_add_test(mailserializerplugintest.cpp ${CMAKE_BINARY_DIR}/serializers/akonadi_serializer_mail_debug.cpp
-    LINK_LIBRARIES KPim6::AkonadiMime KPim6::AkonadiCore KPim6::AkonadiPrivate KPim6::Mime Qt::Test
+    LINK_LIBRARIES KPim6::AkonadiMime KPim6::AkonadiCore KPim6::AkonadiPrivate KF6::Mime Qt::Test
     TEST_NAME mailserializerplugintest
 )
 ecm_add_test(mailserializertest.cpp
     ${CMAKE_SOURCE_DIR}/serializers/akonadi_serializer_mail.cpp
     ${CMAKE_BINARY_DIR}/serializers/akonadi_serializer_mail_debug.cpp
-    LINK_LIBRARIES KPim6::AkonadiMime KPim6::AkonadiCore KPim6::AkonadiPrivate KPim6::Mime Qt::Test
+    LINK_LIBRARIES KPim6::AkonadiMime KPim6::AkonadiCore KPim6::AkonadiPrivate KF6::Mime Qt::Test
     TEST_NAME mailserializertest
 )
 ecm_add_test(newmailnotifierattributetest.cpp newmailnotifierattributetest.h
diff --git a/autotests/benchmarker/CMakeLists.txt b/autotests/benchmarker/CMakeLists.txt
index 13bf54c..b8a1a8b 100644
--- a/autotests/benchmarker/CMakeLists.txt
+++ b/autotests/benchmarker/CMakeLists.txt
@@ -23,7 +23,7 @@ add_executable(akonadi_benchmarker ${benchmarker_SRCS})
 target_link_libraries(
     akonadi_benchmarker
     KPim6::AkonadiMime
-    KPim6::Mime
+    KF6::Mime
     Qt::Test
     KPim6::AkonadiCore
     KF6::I18n
diff --git a/autotests/messagetests/CMakeLists.txt b/autotests/messagetests/CMakeLists.txt
index 61c0ffc..b13104b 100644
--- a/autotests/messagetests/CMakeLists.txt
+++ b/autotests/messagetests/CMakeLists.txt
@@ -8,7 +8,7 @@ macro(ADD_AKONADIMIME_TEST)
         add_test(NAME akonadimime-${_testName} COMMAND ${_testName})
         target_link_libraries(
             ${_testName}
-            KPim6::Mime
+            KF6::Mime
             Qt::Test
             KPim6::AkonadiCore
             KPim6::AkonadiMime
diff --git a/serializers/CMakeLists.txt b/serializers/CMakeLists.txt
index c5c1ae9..7440839 100644
--- a/serializers/CMakeLists.txt
+++ b/serializers/CMakeLists.txt
@@ -22,7 +22,7 @@ ecm_qt_declare_logging_category(akonadi_serializer_mail
 
 target_link_libraries(
     akonadi_serializer_mail
-    KPim6::Mime
+    KF6::Mime
     KPim6::AkonadiCore
     KPim6::AkonadiMime
     KPim6::AkonadiPrivate
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index c79c15a..7d95ee4 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -141,7 +141,7 @@ target_link_libraries(
     PUBLIC
         KPim6::AkonadiCore
     PRIVATE
-        KPim6::Mime
+        KF6::Mime
         KPim6::AkonadiWidgets
         KF6::KIOCore
         KF6::I18n
diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
index c34ab88..87024f1 100644
--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -32,7 +32,7 @@ macro(add_akonadimime_demo _source)
     target_link_libraries(
         ${_name}
         KPim6AkonadiMime
-        KPim6::Mime
+        KF6::Mime
         KPim6::AkonadiCore
         KF6::I18n
         Qt::Widgets
