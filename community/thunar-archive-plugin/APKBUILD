# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=thunar-archive-plugin
pkgver=0.6.0
pkgrel=0
pkgdesc="Create and deflate archives in Thunar"
url="https://docs.xfce.org/xfce/thunar/archive"
arch="all"
license="GPL-2.0-only"
options="!check" # no test suite
makedepends="
	thunar-dev
	exo-dev
	meson
	"
subpackages="$pkgname-lang"
source="https://archive.xfce.org/src/thunar-plugins/thunar-archive-plugin/${pkgver%.*}/thunar-archive-plugin-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
	# dont want file-roller
	rm -f "$pkgdir"/usr/lib/xfce4/thunar-archive-plugin/file-roller.tap
}

sha512sums="
bc1b5ed3a5518b1f3ee3b29fcdaa58c579c6fcc608be3b9d50df351b2648882114623a558e541b7bd2450f9e0519bc7a40d4562479f970afa0a3ac4c32057678  thunar-archive-plugin-0.6.0.tar.xz
"
