maintainer="Iztok Fister, Jr. <iztok@iztok.dev>"
pkgname=eml2mbox
pkgver=0.1.1
pkgrel=0
pkgdesc="Convert .eml files to a standards-compliant .mbox archive"
url="https://codeberg.org/firefly-cpp/eml2mbox"
arch="noarch"
license="MIT"
depends="python3 py3-typer py3-tqdm"
makedepends="py3-gpep517 py3-poetry-core"
checkdepends="py3-pytest-xdist"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver-1.tar.gz::https://codeberg.org/firefly-cpp/eml2mbox/archive/$pkgver.tar.gz"
builddir="$srcdir/$pkgname"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
29f8a6e9b8515946e756401929dc69daab76b3eb042a88d0601548617cb190efca34777c29cf116f6479670df75c7f756ae2fbb4ce981f4cef0a204be62d7f34  eml2mbox-0.1.1-1.tar.gz
"
