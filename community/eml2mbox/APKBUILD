maintainer="Iztok Fister, Jr. <iztok@iztok.dev>"
pkgname=eml2mbox
pkgver=0.2.1
pkgrel=0
pkgdesc="Convert .eml files to a standards-compliant .mbox archive"
url="https://codeberg.org/firefly-cpp/eml2mbox"
arch="noarch"
license="MIT"
depends="python3 py3-typer py3-tqdm"
makedepends="py3-gpep517 py3-poetry-core"
checkdepends="py3-pytest-xdist"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/firefly-cpp/eml2mbox/archive/$pkgver.tar.gz"
builddir="$srcdir/$pkgname"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
79033bd5872a897e1d8676c83c05e0f4fccff634cf3b91e70dda7da8a34a1870d384d958afb51cafd3feacad490ac5a0be06311ec7cbad88998ffafd0a2933fd  eml2mbox-0.2.1.tar.gz
"
