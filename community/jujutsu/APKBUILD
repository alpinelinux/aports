# Maintainer: Jingyun Hua <huajingyun@loongson.cn>
maintainer="Jingyun Hua <huajingyun@loongson.cn>"
pkgname=jujutsu
pkgver=0.43.0
pkgrel=0
pkgdesc="Git-compatible distributed version control system"
url="https://www.jj-vcs.dev/"
# armhf, armv7, x86: tests fail
# s390x: serde_bser crate fails to build
arch="all !armhf !armv7 !x86 !s390x"
license="Apache-2.0"
depends="git"
makedepends="
	cargo
	cargo-auditable
	"
checkdepends="
	git
	gpg
	gpg-agent
	gpgsm
	jq
	openssh-keygen
	"
subpackages="
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="
	https://github.com/jj-vcs/jj/archive/v$pkgver/jujutsu-$pkgver.tar.gz
	b32e4c391251248178dcd13789b4f51dcb943ed4.patch
	"
builddir="$srcdir/jj-$pkgver"
options="net" # cargo fetch

if [ "$CARCH" != "loongarch64" ]; then
	checkdepends="
		$checkdepends
		taplo
		"
fi

case "$CARCH" in
# Hangs on the builder
riscv64) options="$options !check" ;;
esac

# taken from main/rust/APKBUILD
_clear_vendor_checksums() {
	sed -i 's/\("files":{\)[^}]*/\1/' vendor/$1/.cargo-checksum.json
}

prepare() {
	cargo vendor --locked

	default_prepare

	mkdir -p .cargo
	cat >> .cargo/config.toml <<-EOF
		[source.crates-io]
		replace-with = "vendored-sources"

		[source.vendored-sources]
		directory = "vendor"
	EOF

	_clear_vendor_checksums gix-index
}

build() {
	cargo auditable build --frozen --release --bin jj

	for shell in bash fish zsh; do
		./target/release/jj util completion $shell > jj.$shell
	done

	./target/release/jj util install-man-pages .
}

check() {
	# test_gc: flaky on s390x
	case "$CARCH" in
	s390x)
		_test_args="-- --skip test_git_backend::test_gc"
		;;
	aarch64)
		_test_args="-- --skip test_git::test_shallow_commits_lack_parents"
		;;
	loongarch64)
		_test_args="-- --skip test_config_schema"
		;;
	esac

	cargo test --frozen $_test_args
}

package() {
	install -Dvm755 target/release/jj -t "$pkgdir"/usr/bin/

	install -Dvm644 jj.bash \
		"$pkgdir"/usr/share/bash-completion/completions/jj
	install -Dvm644 jj.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/jj.fish
	install -Dvm644 jj.zsh \
		"$pkgdir"/usr/share/zsh/site-functions/_jj

	install -dvm755 "$pkgdir"/usr/share/man
	cp -av man1 "$pkgdir"/usr/share/man/
	install -dvm755 "$pkgdir"/usr/share/doc
	cp -av docs "$pkgdir"/usr/share/doc/$pkgname
}

sha512sums="
b421817893e379fe6239cb27e70fc551988433408188d1589a799744c842ab5de3655d20b07ff058e70f25213cbe061eb4d8adabac5edd4d7876cde19322513d  jujutsu-0.43.0.tar.gz
f71bd6af8abf3338a472725cba8a62093b456845f2c0e7849a07e986c7e429cab21a4bda0697a3a8135a584786b1dae546848232e0cf2514defbee40f83a3f60  b32e4c391251248178dcd13789b4f51dcb943ed4.patch
"
