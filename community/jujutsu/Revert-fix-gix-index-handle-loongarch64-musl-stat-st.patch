-                target_os = "aix",
-                target_os = "hurd",
-                all(target_arch = "loongarch64", target_env = "musl")
-            )))]
+            #[cfg(not(any(target_os = "aix", target_os = "hurd")))]
             let seconds = self.0.st_mtime;
-            #[cfg(any(
-                target_os = "aix",
-                target_os = "hurd",
-                all(target_arch = "loongarch64", target_env = "musl")
-            ))]
+            #[cfg(any(target_os = "aix", target_os = "hurd"))]
             let seconds = self.0.st_mtim.tv_sec;
 
