-                target_os = "hurd",
-                all(target_arch = "loongarch64", target_env = "musl")
-            ))]
+            #[cfg(any(target_os = "aix", target_os = "hurd"))]
             let nanoseconds = self.0.st_mtim.tv_nsec;
 
             // All operating systems treat the seconds as offset from unix epoch, hence it must
