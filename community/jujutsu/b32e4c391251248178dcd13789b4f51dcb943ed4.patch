From b32e4c391251248178dcd13789b4f51dcb943ed4 Mon Sep 17 00:00:00 2001
From: Waleed Khan <me@waleedkhan.name>
Date: Fri, 3 Jul 2026 10:50:50 -0700
Subject: [PATCH] tests: switch `bash` to `sh` in `test_run_shell_command`

As per <https://github.com/jj-vcs/jj/issues/9749> and <https://gitlab.alpinelinux.org/alpine/aports/-/merge_requests/104798#note_628134>, it looks like not all platforms have `bash` available, so switch to `sh`.
---
 cli/tests/test_run_command.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/cli/tests/test_run_command.rs b/cli/tests/test_run_command.rs
index 4d808988350..cca207abb4b 100644
--- a/cli/tests/test_run_command.rs
+++ b/cli/tests/test_run_command.rs
@@ -547,7 +547,7 @@ fn test_run_shell_command() {
             "-r",
             "..@",
             "--",
-            "bash",
+            "sh",
             "-c",
             r#"echo "$JJ_COMMIT_ID""#,
         ]
