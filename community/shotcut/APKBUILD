67bd2dffa7e4d39bae92a23b8ce3c14695541c2688fc7974cde552bc25872a1081a0d969eecf3cb60011df6b2e18ffe9eec2be07273ca331141d8cfcf195d039  gles2.patch
c9d4263cf5c4a1964ad73fb810353e338e6417e3241a177f444ef151c2da7970eaaa0ca94cfcf52da4d3fe9b1abc4d5fac78361c287aa7e10e3aab2026893cca  launcher
"
