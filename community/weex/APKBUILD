pkgname=weex
pkgver=2.8.4.5
_pkgver=$pkgver+nmu1
pkgrel=0
pkgdesc="Non-interactive FTP and FTPS client for updating web pages"
url="https://weex.sourceforge.net/"
arch="all"
license="GPL-2.0-or-later"
makedepends="openssl-dev automake autoconf"
options="!check" #no tests
subpackages="$pkgname-doc"
source="https://deb.debian.org/debian/pool/main/w/weex/weex_$_pkgver.tar.xz"

prepare() {
	default_prepare
	update_config_sub
}

build() {
	export CBUILD=$CHOST
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--disable-dependency-tracking \
		--disable-nls
	make
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
