# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: mio <miyopan@e.email>
maintainer="mio <miyopan@e.email>"
pkgname=ait
pkgver=1.15
pkgrel=0
pkgdesc="Small yet mighty GNU Emacs style editor"
url="https://www.netbsd.org/~ktnb/ait.html"
arch="all"
license="BSD-3-Clause"
subpackages="$pkgname-doc"
source="https://ftp.netbsd.org/pub/NetBSD/misc/ktnb/ait-$pkgver.tar.gz
	gcc15.patch
	"
builddir="$srcdir/$pkgname"

build() {
	make CC="$CC" LD="$CC"
}

check() {
	./ait -v
}

package() {
	install -Dvm755 ait -t "$pkgdir"/usr/bin/

	install -Dvm644 ait.1 -t "$pkgdir"/usr/share/man/man1/
	install -Dvm644 README.md -t "$pkgdir"/usr/share/doc/$pkgname/
	install -Dvm644 ./*LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

