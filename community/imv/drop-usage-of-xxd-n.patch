From 804c83aea1a0881a339f52e605180a5e1223611c Mon Sep 17 00:00:00 2001
From: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
Date: Mon, 16 Mar 2026 17:08:30 +0100
Subject: [PATCH] Drop usage of 'xxd -n'

This flag doesn't exist in busybox's xxd, and builds fail in busybox
environments.
---
 meson.build     |  3 ++-
 test/backends.c | 12 ++++++------
 2 files changed, 8 insertions(+), 7 deletions(-)

diff --git a/meson.build b/meson.build
index 34a6d4d..7ab24f8 100644
--- a/meson.build
+++ b/meson.build
@@ -252,7 +252,8 @@ if dep_cmocka.found() and xxd.found()
   embed = generator(
     xxd,
     output: '@PLAINNAME@.c',
-    arguments: ['-n', '@PLAINNAME@', '-i', '@INPUT@', '@OUTPUT@']
+    arguments: ['-i', '@INPUT@'],
+    capture: true
   )
 
   test_images = static_library(
diff --git a/test/backends.c b/test/backends.c
index 6dcb674..3e4d7c7 100644
--- a/test/backends.c
+++ b/test/backends.c
@@ -50,13 +50,13 @@ static void assert_bitmap_equal_to_sample(struct imv_bitmap *bitmap)
 }
 
 #ifdef IMV_BACKEND_LIBTIFF
-extern unsigned char sample_tiff[];
-extern unsigned int sample_tiff_len;
+extern unsigned char ___test_data_sample_tiff[];
+extern unsigned int ___test_data_sample_tiff_len;
 static void test_open_ttf_file(void **state)
 {
   struct imv_source *src;
   assert_int_equal(
-      backends_open_memory(*state, sample_tiff, sample_tiff_len, &src),
+      backends_open_memory(*state, ___test_data_sample_tiff, ___test_data_sample_tiff_len, &src),
       BACKEND_SUCCESS);
 
   struct imv_image *image;
@@ -74,13 +74,13 @@ static void test_open_ttf_file(void **state)
 #endif
 
 #ifdef IMV_BACKEND_LIBPNG
-extern unsigned char sample_png[];
-extern unsigned int sample_png_len;
+extern unsigned char ___test_data_sample_png[];
+extern unsigned int ___test_data_sample_png_len;
 static void test_open_png_file(void **state)
 {
   struct imv_source *src;
   assert_int_equal(
-      backends_open_memory(*state, sample_png, sample_png_len, &src),
+      backends_open_memory(*state, ___test_data_sample_png, ___test_data_sample_png_len, &src),
       BACKEND_SUCCESS);
 
   struct imv_image *image;
-- 
2.53.0

