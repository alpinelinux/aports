# Maintainer: Steven Guikal <void@fluix.one>
pkgname=imv
pkgver=5.0.1
pkgrel=0
pkgdesc="Image viewer for X11/Wayland"
url="https://sr.ht/~exec64/imv"
arch="all"
license="MIT"
makedepends="
	asciidoc
	fontconfig-dev
	freeimage-dev
	glu-dev
	inih-dev
	libheif-dev
	libjpeg-turbo-dev
	libjxl-dev
	libpng-dev
	librsvg-dev
	libxkbcommon-dev
	mesa-dev
	meson
	pango-dev
	sdl2_ttf-dev
	wayland-dev
	wayland-protocols
	"
checkdepends="
	cmocka
	cmocka-dev
	"
subpackages="$pkgname-dbg $pkgname-doc $pkgname-wayland $pkgname-x11"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~exec64/imv/archive/v$pkgver.tar.gz
	move-wayland-and-x11-to-libexec.patch
	version.patch
	backend-librsvg-include-stdio.patch
	drop-usage-of-xxd-n.patch
	"
builddir="$srcdir/$pkgname-v$pkgver"

build() {
	local _test=enabled
	if ! want_check; then
		_test=disabled
	fi
	abuild-meson \
		-Dwindows=all \
		-Dtest=$_test \
		-Dman=enabled \
		-Dlibtiff=disabled \
		-Dlibnsgif=disabled \
		-Dlibrsvg=enabled \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

wayland() {
	pkgdesc="Image viewer for Wayland"
	depends="$pkgname=$pkgver-r$pkgrel"
	install_if="$pkgname=$pkgver-r$pkgrel wayland-libs-server"

	amove usr/libexec/imv-wayland
}

x11() {
	pkgdesc="Image viewer for X11"
	depends="$pkgname=$pkgver-r$pkgrel"
	install_if="$pkgname=$pkgver-r$pkgrel xorg-server"

	amove usr/libexec/imv-x11
}

