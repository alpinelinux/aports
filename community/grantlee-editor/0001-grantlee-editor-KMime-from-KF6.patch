From 5650e4886d745d445c0618d4e0a4bb57ca784760 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Thu, 16 Apr 2026 19:45:33 +0200
Subject: [PATCH] Add forward compatibility for KMime from KDE Frameworks

---
 CMakeLists.txt                   | 6 +++++-
 headerthemeeditor/CMakeLists.txt | 2 +-
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index da6c5a1..d9e478f 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -154,7 +154,11 @@ set_package_properties(
 )
 
 # Find KdepimLibs Package
-find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 
 find_package(KF6SyntaxHighlighting ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6TextCustomEditor ${KTEXTADDONS_MIN_VERSION} CONFIG REQUIRED)
diff --git a/headerthemeeditor/CMakeLists.txt b/headerthemeeditor/CMakeLists.txt
index cf408d6..f1ab8a7 100644
--- a/headerthemeeditor/CMakeLists.txt
+++ b/headerthemeeditor/CMakeLists.txt
@@ -43,7 +43,7 @@ endif()
 
 target_link_libraries(
     headerthemeeditor
-    KPim6::Mime
+    KF6::Mime
     KPim6::PimCommon
     KPim6::MessageViewer
     grantleethemeeditor
-- 
