# Contributor: Sören Tempel <soeren+alpine@soeren-tempel.net>
# Maintainer: Bart Ribbers <bribbers@disroot.org>
pkgname=py3-astor
pkgver=0.8.1_git20260217
# release is from 2019. This recent commit pulls in many bug fixes.
_commit=708038844745b2a2c37c206ec422547ea6ddc367
pkgrel=0
pkgdesc="Easy manipulation of Python source via the AST"
url="https://github.com/berkerpeksag/astor"
arch="noarch"
license="BSD-3-Clause-Clear"
depends="python3"
makedepends="py3-gpep517 py3-setuptools"
subpackages="$pkgname-pyc"
source="astor-$pkgver.tar.gz::https://github.com/berkerpeksag/astor/archive/$_commit.tar.gz
	fix-tests.patch
	"
builddir="$srcdir/astor-$_commit"

prepare() {
	default_prepare
	# Tries to roundtrip every package on the system and is unreliable
	rm -f tests/test_rtrip.py
}

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m unittest discover -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
