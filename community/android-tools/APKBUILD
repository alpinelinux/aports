pkgname=android-tools
pkgver=36.0.1
pkgrel=1
pkgdesc="Android platform tools"
url="https://sites.google.com/a/android.com/tools/"
# s390x, ppc64le: Unsupported by vendored BoringSSL
arch="all !s390x !ppc64le"
license="Apache-2.0 MIT"
options="!check" # upstream doesn't have a test suite
depends="
	$pkgname-adb
	$pkgname-append2simg
	$pkgname-avbtool
	$pkgname-e2fsdroid
	$pkgname-ext2simg
	$pkgname-fastboot
	$pkgname-img2simg
	$pkgname-lpadd
	$pkgname-lpdump
	$pkgname-lpflash
	$pkgname-lpmake
	$pkgname-lpunpack
	$pkgname-make_f2fs
	$pkgname-mkbootimg
	$pkgname-mkdtboimg
	$pkgname-mke2fs.android
	$pkgname-repack_bootimg
	$pkgname-simg2img
	$pkgname-sload_f2fs
	$pkgname-unpack_bootimg
	"
makedepends="pcre2-dev linux-headers libusb-dev gtest-dev perl cmake protobuf-dev
	brotli-dev zstd-dev lz4-dev samurai abseil-cpp-dev fmt-dev"
subpackages="
	$pkgname-adb:_command
	$pkgname-append2simg:_command
	$pkgname-avbtool:_command
	$pkgname-bash-completion:bashcomp:noarch
	$pkgname-doc
	$pkgname-e2fsdroid:_command
	$pkgname-ext2simg:_command
	$pkgname-fastboot:_command
	$pkgname-img2simg:_command
	$pkgname-lpadd:_command
	$pkgname-lpdump:_command
	$pkgname-lpflash:_command
	$pkgname-lpmake:_command
	$pkgname-lpunpack:_command
	$pkgname-make_f2fs:_command
	$pkgname-mkbootimg
	$pkgname-mkdtboimg:_command
	$pkgname-mke2fs.android:_command
	$pkgname-repack_bootimg:_command
	$pkgname-simg2img:_command
	$pkgname-sload_f2fs:_command
	$pkgname-unpack_bootimg:_command
	"
source="https://github.com/nmeum/android-tools/releases/download/$pkgver/android-tools-$pkgver.tar.xz"

build() {
	LDFLAGS="$LDFLAGS -Wl,--copy-dt-needed-entries" \
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_BUILD_TYPE=None
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

bashcomp() {
	default_bashcomp
	amove usr/share/android-tools/completions
}

_command() {
	local binary_name=${subpkgname##*-}
	pkgdesc="$pkgdesc ($binary_name)"
	# Some need it
	depends="python3"

	amove usr/bin/"$binary_name"
}

mkbootimg() {
	pkgdesc="$pkgdesc (mkbootimg)"
	depends="python3"

	amove usr/bin/mkbootimg
	amove usr/share/android-tools
}

sha512sums="
f51e6b2197f455c3192fe27ba5c1bc04edfb6d37f20208c64a7c17a9c54e3d1d327c1d8a52014ecb3ec4bc1fae5a1205dea2fc54017dfada5a10ce6435405379  android-tools-36.0.1.tar.xz
"
