# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-settings
pkgver=1.0.14
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Settings application for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-settings"
# 32-bit: https://gitlab.freedesktop.org/pipewire/pipewire-rs/-/issues/111
# s390x: nix
# riscv64: too slow to build
arch="all !armhf !armv7 !x86 !s390x !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	clang-libclang
	cosmic-icons
	cosmic-randr
	findutils
	fontconfig-dev
	iso-codes-dev
	just
	libinput-dev
	libxkbcommon-dev
	pulseaudio-dev
	pipewire-dev
	wayland-dev
"
options="net"  # fetch dependencies
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-settings/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
02f675e0a45ccb538416b6f0fa16a8f10fd9009d4c69f68388684a98e0b71f6443c933180d67d83456129efcbe59f5fe4c0df218b635e73059e69f5a35a358d2  cosmic-settings-1.0.14.tar.gz
"
