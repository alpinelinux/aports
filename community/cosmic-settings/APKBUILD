# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-settings
pkgver=1.2.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Settings application for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-settings"
# armv7,armhf: std::bad_alloc <- deadly signal
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	clang-libclang
	cosmic-icons
	cosmic-randr
	findutils
	fontconfig-dev
	iso-codes-dev
	just
	libinput-dev
	libxkbcommon-dev
	pulseaudio-dev
	pipewire-dev
	wayland-dev
"
options="net"  # fetch dependencies
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-settings/archive/refs/tags/epoch-$_upstreamver.tar.gz
	wgpu.patch
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
130f58182dc384a24b364fc77085a30018c38ab50003918e85a2592bb483591c3e2a5cfeb4dba7a9d03b6716e929b496ccc28069e629cc7f75553c4ac49c0f85  cosmic-settings-1.2.0.tar.gz
cfb59f4c5705a14cb9357ae8d7a064642759c754f9c6568a3fc70e86ced6c1ff68280fc1e1a3344ac64c890011f71b0b935ca11e769b4a10956ef77cc0495fa5  wgpu.patch
"
