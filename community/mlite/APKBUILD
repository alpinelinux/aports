maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=mlite
pkgver=0.5.5
pkgrel=2
pkgdesc="Useful classes originating from MeeGo Touch"
url="https://github.com/sailfishos/mlite"
arch="all"
license="LGPL-2.1-only"
depends_dev="dconf-dev"
makedepends="$depends_dev
	qt5-qtbase-dev
	qt5-qttools-dev
	qt6-qtbase-dev
	qt6-qttools-dev
	"
checkdepends="xwayland-run"
subpackages="
	$pkgname-dev
	$pkgname-qt5
	$pkgname-qt5-dev:qt5_dev
	"
source="https://github.com/sailfishos/mlite/archive/$pkgver/mlite-$pkgver.tar.gz"
options="!check" # Requires an impossible to replicate on CI environment

build() {
	msg "Building Qt5 variant"
	mkdir build-qt5 && build-qt5
	qmake-qt5 ..
	make

	msg "Building Qt6 variant"
	cd "$builddir"
	qmake6
	make
}

check() {
	wlheadless-run make check
}

package() {
	INSTALL_ROOT="$pkgdir" make install

	# Remove installed tests
	rm -r "$pkgdir"/opt
}

qt5() {
	cd "$builddir"/build-qt5
	INSTALL_ROOT="$subpkgdir" make install

	# Remove installed tests
	rm -r "$subpkgdir"/opt

	rm -r "$subpkgdir"/usr/include
	rm -r "$subpkgdir"/usr/lib/pkgconfig
	rm "$subpkgdir"/usr/lib/*.so
}

qt5_dev() {
	cd "$builddir"/build-qt5
	INSTALL_ROOT="$subpkgdir" make install

	# Remove installed tests
	rm -r "$subpkgdir"/opt

	rm -r "${subpkgdir:?}"/usr/bin
	rm -r "$subpkgdir"/usr/libexec
	rm "$subpkgdir"/usr/lib/*.so.*
}

sha512sums="
9fb9142f721e46831a9a47a4e39318b5540486c05317cea130335717cb97a1c930b457b8f44e8dd71efe0b70869d7f84e8eaf04d6f80f2cbf1b0ca980afea15f  mlite-0.5.5.tar.gz
"
