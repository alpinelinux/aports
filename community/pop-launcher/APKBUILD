# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=pop-launcher
pkgver=1.4.0
pkgrel=0
pkgdesc="Modular IPC-based desktop launcher service"
url="https://github.com/pop-os/launcher"
# riscv64: too slow to build
arch="all !riscv64"
license="MPL-2.0 AND GPL-3.0-only"
depends="
	fd
	xdg-utils
"
makedepends="
	cargo
	coreutils
	clang-libclang
	dbus-dev
	just
	libxkbcommon-dev
	mesa-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/launcher/archive/refs/tags/epoch-$pkgver.tar.gz"
builddir="$srcdir/launcher-epoch-$pkgver"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	just build-release --frozen
}

check() {
	cargo test --release --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
555fa33d15a39b8c791a771c7c72efc5ebb59a21b02d94b64949cebbd3b5363ef1f91ea7a7f5f9399786818b58ed5adaa42bfc3571e5c5dd122b9e980b10bf1a  pop-launcher-1.4.0.tar.gz
"
