# Don't corrupt -Werror=<feature> flags when stripping bare -Werror for configure.
#
# configure.ac strips -Werror from CFLAGS/CXXFLAGS so its feature-test compiles
# don't fail, then re-adds it for the real build. The upstream expression
# `sed -e s/-Werror//g` also matches the -Werror substring inside
# -Werror=format-security (Alpine's default CFLAGS), rewriting it to a bare
# `=format-security` token that the compiler/linker then treats as a phantom
# input file ("cannot find format-security"), breaking configure detection.
#
# Restricting the match to -Werror NOT followed by '=' leaves -Werror=<feature>
# intact while still eating a bare -Werror. This is an upstream bug affecting
# every distro that sets -Werror=format-security; reported upstream.
--- a/configure.ac
+++ b/configure.ac
@@ -64,8 +64,8 @@
 dnl Eat -Werror so configure will run properly, if the user provided it
 enable_werror=no
 save_CFLAGS="$CFLAGS"
-CFLAGS=$(echo $save_CFLAGS | sed -e s/-Werror//g)
-CXXFLAGS=$(echo $save_CXXFLAGS | sed -e s/-Werror//g)
+CFLAGS=$(echo "$save_CFLAGS" | sed -e 's/-Werror[^=]//g')
+CXXFLAGS=$(echo "$save_CXXFLAGS" | sed -e 's/-Werror[^=]//g')
 if test "x$CFLAGS" != "x$save_CFLAGS"; then
 	dnl -Werror was set; treat it as implicit --enable-werror below
 	enable_werror="yes"
