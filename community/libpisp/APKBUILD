# Contributor: Luca Weiss <luca@lucaweiss.eu>
# Maintainer: Luca Weiss <luca@lucaweiss.eu>
pkgname=libpisp
pkgver=1.5.0
pkgrel=0
pkgdesc="Helper library for the PiSP hardware block"
url="https://github.com/raspberrypi/libpisp"
arch="all"
license="BSD-2-Clause"
makedepends="
	linux-headers
	meson
	nlohmann-json
	"
subpackages="$pkgname-dev"
source="https://github.com/raspberrypi/libpisp/releases/download/v$pkgver/libpisp-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
e4cfdd7b62e8710d4464d6cec1d09a4cc7053f9f248643004d0cde3c3a954c89780c6fc0c4d67347abc2bffc4fda0081dd10799716d74e104be4ceaab6f6a82c  libpisp-1.5.0.tar.xz
"
