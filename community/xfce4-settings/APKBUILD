# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=xfce4-settings
pkgver=4.20.4
pkgrel=0
pkgdesc="Settings manager for xfce"
url="https://xfce.org/"
arch="all"
license="GPL-2.0-or-later"
subpackages="$pkgname-lang"
makedepends="
	colord-dev
	exo-dev
	garcon-dev
	gtk-layer-shell-dev
	intltool
	libcanberra-dev
	libnotify-dev
	libxcursor-dev
	libxfce4ui-dev
	libxi-dev
	libxklavier-dev
	libxrandr-dev
	upower-dev
	xf86-input-libinput-dev
	xfce4-dev-tools
	xfconf
	"
source="https://archive.xfce.org/src/xfce/xfce4-settings/${pkgver%.*}/xfce4-settings-$pkgver.tar.bz2"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--localstatedir=/var \
		--disable-static \
		--enable-libxklavier \
		--enable-sound-settings=yes \
		--enable-upower-glib \
		--enable-xorg-libinput \
		--enable-xrandr
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
40fc31ff45690f2adedeaa49cf728ac39f2f474fbe9f67ff459f7aeeb0867c30cc5d3dfb015fe3b2bf477feac28c1c97b1c706c19f8a9fc059b053e47f417acb  xfce4-settings-4.20.4.tar.bz2
"
