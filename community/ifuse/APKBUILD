# Contributor: Kasper K <kasperkantz@outlook.com>
maintainer="Krassy Boykinov <kboykinov@teamcentrixx.com>"
pkgname=ifuse
pkgver=1.2.1
pkgrel=0
pkgdesc="Fuse filesystem to access the contents of iOS devices"
url="https://libimobiledevice.org"
arch="all"
license="LGPL-2.1-or-later"
depends="usbmuxd"
makedepends="eudev-dev libimobiledevice-dev fuse3-dev"
subpackages="$pkgname-doc"
source="https://github.com/libimobiledevice/ifuse/releases/download/$pkgver/ifuse-$pkgver.tar.bz2"

build() {
	./configure \
		--host=$CHOST \
		--build=$CBUILD \
		--prefix=/usr \
		--disable-static
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
