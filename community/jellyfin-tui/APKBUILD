# Contributor: Anjandev Momi <anjan@momi.ca>
# Maintainer: Anjandev Momi <anjan@momi.ca>
pkgname=jellyfin-tui
pkgver=1.4.2
pkgrel=0
pkgdesc="Music streaming client for the terminal"
url="https://github.com/dhonus/jellyfin-tui"
arch="all !armhf !armv7 !x86" # blocked by libmpv-sys from libmpv2 crate
license="GPL-3.0-only"
makedepends="cargo cargo-auditable mpv-dev"
options="net" # cargo
source="$pkgname-$pkgver.tar.gz::https://github.com/dhonus/jellyfin-tui/archive/refs/tags/v$pkgver.tar.gz"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/jellyfin-tui \
		-t "$pkgdir"/usr/bin/
}

sha512sums="
b355a0d61e0753fb6b8ff9dd51e9eefe3e8aa0b28cb7e59666509b00c6f84292a280933fafff5a871b4b5d41b4a0561e8c2c01910d6285ca2b84819fa42da1a9  jellyfin-tui-1.4.2.tar.gz
"
