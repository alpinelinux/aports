From 7078a2d7356b165036e4c7df76e871dc044c01cc Mon Sep 17 00:00:00 2001
From: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
Date: Mon, 30 Mar 2026 01:59:34 +0200
Subject: [PATCH] Revert "Add a workaround for test on s390x"

This patch was for Python 3.13 and fails on 3.14.

This reverts commit 1108318e0f31c7b78ff92c01f5a7a0af48de8e64.
---
 mpmath/tests/test_functions2.py | 10 +---------
 1 file changed, 1 insertion(+), 9 deletions(-)

diff --git a/mpmath/tests/test_functions2.py b/mpmath/tests/test_functions2.py
index 47fcbf68..a7db90a8 100644
--- a/mpmath/tests/test_functions2.py
+++ b/mpmath/tests/test_functions2.py
@@ -1,5 +1,3 @@
-import platform
-
 import pytest
 
 from mpmath import (agm, airyai, airybi, appellf1, bei, ber, besseli, besselj,
@@ -1472,13 +1470,7 @@ def test_issue_239():
     x = ldexp(2476979795053773,-52)
     assert betainc(206, 385, 0, 0.55, 1).ae('0.99999999999999999999996570910644857895771110649954')
     mp.dps = 15
-    expected_exc = ValueError
-    if platform.machine() == 's390x':
-        # This case has recursion depth beyond platform capabilities, that
-        # could be controlled with sys.setrecursionlimit().  See issue #1046
-        # for details.
-        expected_exc = RecursionError
-    pytest.raises(expected_exc, lambda: hyp2f1(-5,5,0.5,0.5))
+    pytest.raises(ValueError, lambda: hyp2f1(-5,5,0.5,0.5))
 
 # Extra stress testing for Bessel functions
 # Reference zeros generated with the aid of scipy.special
-- 
2.53.0

