pkgname=py3-routes
pkgver=2.5.1_git20250518
_commit=7e82bd895a120cbf73f271c32ac289d51124303f
pkgrel=0
pkgdesc="Routing Recognition and Generation Tools"
url="https://routes.readthedocs.io/en/latest/"
arch="noarch"
license="MIT"
makedepends="py3-gpep517 py3-setuptools"
checkdepends="py3-pytest py3-webob py3-webtest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/bbangert/routes/archive/$_commit.tar.gz
	six.patch
	"
builddir="$srcdir/routes-$_commit"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

