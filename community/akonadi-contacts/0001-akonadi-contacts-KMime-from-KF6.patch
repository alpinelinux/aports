From 3ff6bea84fc55793be62c7a5880a5991ce0df556 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Wed, 15 Apr 2026 18:04:40 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt                           | 6 +++++-
 src/akonadi-contacts-core/CMakeLists.txt | 2 +-
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index d3bd1a1b..a9a087ba 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -136,8 +136,12 @@ find_package(KF6Prison ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6Codecs ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6ColorScheme ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6Contacts ${KF_MIN_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIMELIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 
-find_package(KPim6Mime ${KMIMELIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6Akonadi ${AKONADI_VERSION} CONFIG REQUIRED)
 
 find_package(KPim6GrantleeTheme ${GRANTLEETHEME_LIB_VERSION} CONFIG REQUIRED)
diff --git a/src/akonadi-contacts-core/CMakeLists.txt b/src/akonadi-contacts-core/CMakeLists.txt
index 5daeb9db..0f08b457 100644
--- a/src/akonadi-contacts-core/CMakeLists.txt
+++ b/src/akonadi-contacts-core/CMakeLists.txt
@@ -125,7 +125,7 @@ target_link_libraries(
         KF6::IconThemes
         KF6::GuiAddons
         KF6::I18n
-        KPim6::Mime
+        KF6::Mime
         KF6::TextUtils
 )
 set_target_properties(
