# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=planarity
pkgver=5.0.0.0
pkgrel=0
pkgdesc="Edge addition planar graph embedding related algorithms"
url="https://github.com/graph-algorithms/edge-addition-planarity-suite"
arch="all"
license="BSD-3-Clause"
makedepends="autoconf automake libtool"
subpackages="$pkgname-dev $pkgname-libs $pkgname-doc"
source="https://github.com/graph-algorithms/edge-addition-planarity-suite/archive/Version_$pkgver/planarity-$pkgver.tar.gz"
builddir="$srcdir/edge-addition-planarity-suite-Version_$pkgver"

prepare() {
	default_prepare
	autoreconf -fi
}

build() {
	export CFLAGS="${CFLAGS/-Os/-O3}" # gotta go fast

	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--disable-static
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
