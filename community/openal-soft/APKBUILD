# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=openal-soft
pkgver=1.25.1
pkgrel=0
pkgdesc="software implementation of OpenAL API"
url="https://openal-soft.org/"
arch="all"
license="LGPL-2.0-or-later"
makedepends="
	alsa-lib-dev
	cmake
	jack-dev
	libsndfile-dev
	linux-headers
	portaudio-dev
	pulseaudio-dev
	qt6-qtbase-dev
	samurai
	zlib-dev
	"
subpackages="$pkgname-libs $pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/kcat/openal-soft/archive/$pkgver.tar.gz"
options="!check" # no tests

build() {
	case "$CARCH" in
	armhf)
		local cpuext_neon=-DALSOFT_CPUEXT_NEON=OFF
	;;
	esac
	cmake -B build \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DALSOFT_UPDATE_BUILD_VERSION=OFF \
		-DALSOFT_ENABLE_MODULES=OFF \
		$cpuext_neon
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
47eccb317ed6040c549f2b51d2d45afcdcd03d56d8cb0ea9ef8a98d2c61c9629ffad39596cffa2ad848dd3b65a227a6591406dc483ebd3a3e03bb0a4d0f112b1  openal-soft-1.25.1.tar.gz
"
