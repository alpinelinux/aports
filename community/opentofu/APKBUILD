# Contributor: Kevin Daudt <kdaudt@alpinelinux.org>
# Maintainer: Kevin Daudt <kdaudt@alpinelinux.org>
pkgname=opentofu
pkgver=1.12.3
pkgrel=0
pkgdesc="OpenTofu lets you declaratively manage your cloud infrastructure"
url="https://opentofu.org/"
arch="all"
license="MPL-2.0"
makedepends="go"
checkdepends="bash"
source="$pkgname-$pkgver.tar.gz::https://github.com/opentofu/opentofu/archive/refs/tags/v${pkgver/_/-}.tar.gz"
options="net" # go
builddir="$srcdir/$pkgname-${pkgver/_/-}"

# secfixes:
#   1.11.4-r0:
#     - CVE-2025-61728

build() {
	local ldflags="-X 'github.com/opentofu/opentofu/version.dev=no'"
	go build -ldflags "$ldflags" ./cmd/tofu
}

check() {
	local flags=
	# https://github.com/golang/go/issues/78161
	case "$CARCH" in riscv64) flags="-gcflags -l" ;;
	esac
	go test $flags -v ./...
}

package() {
	install -Dm0755 tofu -t "$pkgdir"/usr/bin/
}

sha512sums="
cf9bec9e6fae08366947ad84d15590d955b2a20cd6dc1605bd9ac2ca4d4f03c650946bd32c675c197ce99a9d6aad5d4ceb8bb3ec289df5a1eeb296f4db6adac3  opentofu-1.12.3.tar.gz
"
