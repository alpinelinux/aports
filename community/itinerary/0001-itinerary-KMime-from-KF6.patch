From 05f1876e3426409532719d7dd082dcb70a009c83 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Fri, 17 Apr 2026 17:29:23 +0200
Subject: [PATCH] Add forward compatibility for KMime from KDE Frameworks

---
 CMakeLists.txt         | 5 +++++
 src/app/CMakeLists.txt | 2 +-
 2 files changed, 6 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index fa93df648..cbd5af7d2 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -54,6 +54,11 @@ if(Qt6Core_VERSION VERSION_GREATER_EQUAL "6.9.0")
 endif()
 find_package(KF6 ${KF_MIN_VERSION} REQUIRED COMPONENTS I18n CoreAddons Contacts Notifications CalendarCore Holidays UnitConversion)
 find_package(KF6KirigamiAddons 1.9.0 REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime 6.7.0 CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KPim6PkPass 6.5.41 CONFIG REQUIRED)
 find_package(KPim6Itinerary 6.7.40 CONFIG REQUIRED)
 find_package(KPublicTransport ${GEAR_MIN_VERSION} CONFIG REQUIRED)
diff --git a/src/app/CMakeLists.txt b/src/app/CMakeLists.txt
index 44f114804..094ba6e25 100644
--- a/src/app/CMakeLists.txt
+++ b/src/app/CMakeLists.txt
@@ -250,7 +250,7 @@ target_link_libraries(itinerary PUBLIC
     KOSMIndoorMap
     KPim6::Itinerary
     KPim6::PkPass
-    KPim6::Mime
+    KF6::Mime
     KF6::CalendarCore
     KF6::I18n
     KF6::I18nLocaleData
