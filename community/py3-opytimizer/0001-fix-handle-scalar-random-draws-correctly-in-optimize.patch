--- a/opytimizer/optimizers/evolutionary/hs.py
+++ b/opytimizer/optimizers/evolutionary/hs.py
@@ -737,19 +737,15 @@ class GOGHS(NGHS):
 
         a = copy.deepcopy(agents[0])
 
-        A = np.zeros((a.n_variables))
