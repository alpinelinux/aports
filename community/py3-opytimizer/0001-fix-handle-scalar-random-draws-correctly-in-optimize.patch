         return new_mean
 
@@ -161,9 +165,11 @@ class CEM(Optimizer):
 
         """
 
-        new_std = self.alpha * self.std + (1 - self.alpha) * np.sqrt(
-            np.mean((updates - self.mean) ** 2)
