fafdb267b7d6c0a943f8b97daba576d326ee4cda71e6c0e85b6910f095bd041e643299f973e722be6232f5d9c48085f5a4ce00d93e39c12f23e61bdba68082dc  fix-endian-test.patch
52f0d56af8dade7806fe138ba6c99b282ae2ed8d5b46ae0d812f188a28bdb9ae55130793c487b37162c73a9a0836eeab710044fffd3ce6308b8169f906797d7c  glm.pc
"
