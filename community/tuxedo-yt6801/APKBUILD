# Maintainer: Ariadne Conill <ariadne@dereferenced.org>
pkgname=tuxedo-yt6801
pkgver=1.0.31
_pkgver=$pkgver.orig
_modname=yt6801
pkgrel=0
pkgdesc="third-party driver for YT6801 gigabit ethernet NICs"
url="https://gitlab.com/tuxedocomputers/development/packages/tuxedo-yt6801"
arch="all"
license="GPL-2.0-or-later"
depends="akms"
makedepends="rsync"
install="$pkgname.post-deinstall"
source="https://deb.tuxedocomputers.com/ubuntu/pool/main/t/tuxedo-yt6801/tuxedo-yt6801_$_pkgver.tar.gz"
options="!check" # No tests available

package() {
	mkdir -p "$pkgdir"/usr/src/$_modname-$pkgver
	rsync --recursive --exclude=*.cmd --exclude=*.rules --exclude=*.d --exclude=*.ko --exclude=*.mod --exclude=*.mod.c --exclude=*.o --exclude=modules.order files/usr/src/tuxedo-yt6801-$pkgver/ "$pkgdir"/usr/src/$_modname-$pkgver
	cp "$pkgdir"/usr/src/$_modname-$pkgver/Kbuild_default "$pkgdir"/usr/src/$_modname-$pkgver/Kbuild

	cat > "$pkgdir"/usr/src/$_modname-$pkgver/AKMBUILD <<-EOF
	modname=$_modname
	modver=$pkgver-r$pkgrel
	built_modules="yt6801.ko"
	EOF
}

sha512sums="
ea7ef6f3b207e53db6aeb2f3ace4cd9ce5f058acbe7722bb2a6305d701cbdb1e9e6f4d2255de88f7d4a1992802a9622437dd833e32f19cae9d7a62a9c789a0c7  tuxedo-yt6801_1.0.31.orig.tar.gz
"
