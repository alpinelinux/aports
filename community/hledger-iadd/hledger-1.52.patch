                      , vty >= 6.1 && < 6.5
                      , text
@@ -89,7 +89,7 @@ executable hledger-iadd
   default-language:    Haskell2010
   build-depends:       base >= 4.14 && < 5
                      , hledger-iadd
-                     , hledger-lib >= 1.50 && <1.51
+                     , hledger-lib >= 1.50 && <1.53
                      , brick >= 2.1 && < 2.10
                      , vty >= 6.1 && < 6.5
                      , text
@@ -119,7 +119,7 @@ test-suite spec
   default-language:   Haskell2010
   build-depends:      base >= 4.14 && < 5
                     , hledger-iadd
-                    , hledger-lib >= 1.50 && <1.51
