e41084999e254459d7db2bf9cc2ac7b35702adb24a200058fe3b18808d8494d21c140a76c01b515d3a7669bc953db6be1b8d75ca1a23ab687b6b4469c5af5a4d  cabal.project.freeze
05236f8480f9605ff85fc169720d4e5243d633e77463f0e1020cf87636692a90b17dd7f9988ce5685fdb0dc9a2c641ff4c407ad3ca4695f5820562b28663bffe  hledger-1.52.patch
"
