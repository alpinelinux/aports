# Contributor: Guy Godfroy <guy.godfroy@gugod.fr>
# Maintainer: Guy Godfroy <guy.godfroy@gugod.fr>
pkgname=py3-joserfc
_pkgname=joserfc
pkgver=1.6.7
pkgrel=0
pkgdesc="Implementations of JOSE RFCs in Python"
url="https://jose.authlib.org"
arch="noarch"
license="BSD-3-Clause"
depends="py3-cryptography py3-pycryptodome"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$_pkgname-$pkgver.tar.gz::https://github.com/authlib/joserfc/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver/"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
ade3174924db02f9b9a989e574a37841c5f85719c93fd5f71741ba71ae80465b4bce2dd8298fda755ad118085cb700b6ea0998a153652c2323d1474aef0ec67e  joserfc-1.6.7.tar.gz
"
