# Contributor: Iztok Fister, Jr. <iztok@iztok-jr-fister.eu>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=py3-xarray
_pkgorig=xarray
pkgver=2026.4.0
pkgrel=0
pkgdesc="N-D labeled arrays and datasets in Python"
url="https://xarray.dev"
arch="all !armhf !armv7 !x86"  #Tests fail on 32-bit arches
license="Apache-2.0"
depends="python3 py3-numpy py3-packaging py3-pandas"
makedepends="py3-gpep517 py3-setuptools_scm py3-wheel"
checkdepends="py3-coverage
	py3-mock
	py3-pyarrow
	py3-pytest-asyncio
	py3-pytest-cov
	py3-pytest-xdist
	py3-scipy
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://files.pythonhosted.org/packages/source/x/xarray/xarray-$pkgver.tar.gz
	fix-pytest-ini-options.patch
	"
builddir="$srcdir/$_pkgorig-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -v -rs
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	rm -r "$pkgdir"/usr/lib/python3.*/site-packages/xarray/tests
}

sha512sums="
f70fc78978f255a413b61a113b2e9e5da15e2fcd5c290ec81b112bd6bb0cb8e55aacde684dc756bd1f6087970ac3c85c602a883fa149ff5ff0013c3f3cb32cd1  py3-xarray-2026.4.0.tar.gz
dd8295e36fb159b971bbefd9d828e3c55618065d401c6d073e860349d56c3c5b7a43b449b0fee399ed0551960c4ff24914f3356d1a64c85ac3db07ced6196198  fix-pytest-ini-options.patch
"
