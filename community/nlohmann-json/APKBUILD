# Contributor: Nick Black <dankamongmen@gmail.com>
# Maintainer: Bart Ribbers <bribbers@disroot.org>
pkgname=nlohmann-json
pkgver=3.11.3
pkgrel=0
pkgdesc="JSON for Modern C++"
url="https://github.com/nlohmann/json"
arch="noarch"
license="MIT"
makedepends="cmake samurai"
_testdata_ver=3.1.0
source="https://github.com/nlohmann/json/archive/v$pkgver/nlohmann-json-$pkgver.tar.gz
	json_test_data-$_testdata_ver.tar.gz::https://github.com/nlohmann/json_test_data/archive/refs/tags/v$_testdata_ver.tar.gz"
builddir="$srcdir/json-$pkgver"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DJSON_MultipleHeaders=ON \
		-DJSON_TestDataDirectory=../json_test_data-$_testdata_ver
	cmake --build build
}

check() {
	cd build
	ctest -E "cmake_fetch_content(|2)_(configure|build)"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
