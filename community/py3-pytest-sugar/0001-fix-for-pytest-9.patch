Patch-Source: https://salsa.debian.org/python-team/packages/pytest-sugar/-/raw/debian/master/debian/patches/0001-fix-for-pytest-9.patch

From: Edward Betts <edward@4angle.com>
Date: Mon, 22 Dec 2025 16:08:24 +0000
Subject: fix for pytest 9

---
 pytest_sugar.py | 6 +-----
 test_sugar.py   | 2 +-
 2 files changed, 2 insertions(+), 6 deletions(-)

diff --git a/pytest_sugar.py b/pytest_sugar.py
index fb80c72..df89e50 100644
--- a/pytest_sugar.py
+++ b/pytest_sugar.py
@@ -287,12 +287,8 @@ class SugarTerminalReporter(TerminalReporter):
             ),
             bold=True,
         )
-        if int(pytest.__version__.split(".")[0]) <= 6:
-            hook_call_kwargs = {"startdir": self.startpath}
-        else:
-            hook_call_kwargs = {"start_path": self.startpath}
         lines = self.config.hook.pytest_report_header(
-            config=self.config, **hook_call_kwargs
+            config=self.config, start_path=self.startpath
         )
         lines.reverse()
         for line in flatten(lines):
diff --git a/test_sugar.py b/test_sugar.py
index daec572..30195b9 100644
--- a/test_sugar.py
+++ b/test_sugar.py
@@ -114,7 +114,7 @@ class TestTerminalReporter:
     def test_report_header(self, testdir):
         testdir.makeconftest(
             """
-            def pytest_report_header(startdir):
+            def pytest_report_header(start_path):
                 pass
             """
         )
