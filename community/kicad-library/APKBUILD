aeb2f1c8fa0b19b62113dfee9008d61243ed1694f0067404f8f207117f2df88348008191e7a13e908c01f5587c4abcb2d54c229130c43c1cf7c9aa3cdeb213f8  kicad-footprints-10.0.3.tar.gz
