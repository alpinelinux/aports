maintainer="Michał Polański <michal@polanski.me>"
pkgname=syft
pkgver=1.42.4
pkgrel=0
pkgdesc="Generate a Software Bill of Materials (SBOM) from container images and filesystems"
url="https://github.com/anchore/syft"
license="Apache-2.0"
arch="all !armhf !armv7 !x86" # FTBFS on 32-bit arches
makedepends="go"
subpackages="
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="https://github.com/anchore/syft/archive/v$pkgver/syft-$pkgver.tar.gz
	disable-update-check.patch
	"
options="net !check" # Go modules, tests need docker

build() {
	go build -ldflags "
		-X main.version=$pkgver
		" \
		-o bin/syft ./cmd/syft

	bin/syft completion bash >$pkgname.bash
	bin/syft completion fish >$pkgname.fish
	bin/syft completion zsh >$pkgname.zsh
}

check() {
	go test ./...
}

package() {
	install -Dm755 bin/syft -t "$pkgdir"/usr/bin/

	install -Dm644 $pkgname.bash "$pkgdir"/usr/share/bash-completion/completions/$pkgname
	install -Dm644 $pkgname.fish "$pkgdir"/usr/share/fish/vendor_completions.d/$pkgname.fish
	install -Dm644 $pkgname.zsh "$pkgdir"/usr/share/zsh/site-functions/_$pkgname
}

sha512sums="
846637c7ced355722f86aee40a080383cd708f680216e83c664d3103af37ed4e205b2b64369cb61bd4f39233645ec3fa3694c527144e228b73b5c88b2f6242ba  syft-1.42.4.tar.gz
e261b6a817ebd1347540a18ff9a36e73b736aae8f07e7c554d716878abac1a6346a832d6ba1b5bbed17b6d13f3edf8f2fc757e7021fde3dd8d387247b479a00a  disable-update-check.patch
"
