# Contributor: Wen Heping <wenhepingalpine@sohu.com>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=py3-pyasyncore
pkgver=1.0.5
pkgrel=0
# _pkgreal is used by apkbuild-pypi to find modules at PyPI
_pkgreal=pyasyncore
pkgdesc="Make asyncore available for Python 3.12 onwards"
url="https://pypi.org/project/pyasyncore/"
arch="noarch"
license="PSF-2.0"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest python3-tests"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/pyasyncore/pyasyncore-$pkgver.tar.gz"
builddir="$srcdir/$_pkgreal-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
d9bc37c3d658b37593e3fd4364c3fa68644d2abb30013a6f82381d3e442da8d096f2bee2f06ef64640b63491ab697b3adec1a0be50dc3230a49404643cf00401  pyasyncore-1.0.5.tar.gz
"
