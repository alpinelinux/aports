# Contributor: Stuart Cardall <developer@it-offshore.co.uk>
# Maintainer: Stuart Cardall <developer@it-offshore.co.uk>
pkgname=py3-magic
_pkgname=python-magic
pkgver=0.4.27
pkgrel=4
pkgdesc="Python3 wrapper for libmagic"
url="https://pypi.org/project/python-magic/"
arch="noarch"
license="MIT"
depends="python3 libmagic"
makedepends="py3-gpep517 py3-setuptools"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/ahupp/$_pkgname/archive/$pkgver.tar.gz
	file-5.44.patch
	file-5.45.patch
	file-5.47.patch
	"
builddir="$srcdir/$_pkgname-$pkgver"

replaces="py-magic" # Backwards compatibility
provides="py-magic=$pkgver-r$pkgrel" # Backwards compatibility

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	# Temporarily skip tests affected by file 5.47 regression
	# https://github.com/houseabsolute/File-LibMagic/issues/31
	LC_ALL=en_US.UTF-8 PYTHONPATH=build/lib pytest \
		--deselect test/libmagic_test.py::MagicTestCase::test_detect_from_content \
		--deselect test/libmagic_test.py::MagicTestCase::test_detect_from_filename \
		--deselect test/libmagic_test.py::MagicTestCase::test_detect_from_fobj \
		--deselect test/python_magic_test.py::MagicTest::test_descriptions
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

