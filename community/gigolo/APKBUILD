# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=gigolo
pkgver=0.6.0
pkgrel=0
pkgdesc="GIO management application"
options="!check" # No testsuite
url="https://www.uvena.de/gigolo/"
license="GPL-2.0-only"
arch="all"
makedepends="
	gtk+3.0-dev
	python3
	intltool
	meson
	"
subpackages="$pkgname-doc $pkgname-lang"
source="https://archive.xfce.org/src/apps/gigolo/${pkgver%.*}/gigolo-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
08501cfa19ce83bd865477b9acf305c3a5cf99307c6fb48b50228c3c4d833dcc0ad07ea659d3c3e6978bf4cab965f3f1b021bcdfe09c1c1ad1b6d8eee214c9c0  gigolo-0.6.0.tar.xz
"
