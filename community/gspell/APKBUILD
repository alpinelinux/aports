# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=gspell
pkgver=1.14.3
pkgrel=0
pkgdesc="Flexible API to add spell checking to a GTK+ application"
url="https://gitlab.gnome.org/GNOME/gspell"
arch="all"
license="LGPL-2.1-or-later"
depends="iso-codes"
makedepends="
	enchant2
	enchant2-dev
	glib-dev
	gobject-introspection-dev
	gtk+3.0-dev
	iso-codes-dev
	meson
	vala
	"
checkdepends="xvfb-run hunspell-en ibus"
subpackages="$pkgname-dbg $pkgname-dev $pkgname-lang"
# https://discourse.gnome.org/t/new-way-of-releasing-gspell/31753
#source="https://download.gnome.org/sources/gspell/${pkgver%.*}/gspell-$pkgver.tar.xz"
source="https://gitlab.gnome.org/GNOME/gspell/-/archive/$pkgver/gspell-$pkgver.tar.gz"

build() {
	abuild-meson \
		-Dgtk_doc=false \
		output .
	meson compile -C output
}

check() {
	xvfb-run -a meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
f64eb049918d7876b2f8353714b9588a2723cffb28896dde13234adccdbae6eb708e6a9addd8d52757b77bc1583f28ca517ce33014d1819c39ddeb5b4aa4e71f  gspell-1.14.3.tar.gz
"
