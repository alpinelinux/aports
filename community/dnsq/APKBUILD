# Maintainer: DWwanghao <wanghao03@loongson.cn>
maintainer="DWwanghao <wanghao03@loongson.cn>"
pkgname=dnsq
pkgver=0.19.12
pkgrel=0
pkgdesc="Feature-rich command line DNS client"
url="https://github.com/natesales/q"
arch="all"
license="GPL-3.0-only"
makedepends="go"
source="https://github.com/natesales/q/archive/v$pkgver/dnsq-$pkgver.tar.gz"
builddir="$srcdir/q-$pkgver"
options="!check" # temporarily disabled, see 321abeb41840

export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

build() {
	go build -v -ldflags "-X main.version=$pkgver"
}

check() {
	go test -v ./...
}

package() {
	install -Dvm755 q -t "$pkgdir"/usr/bin/
}

sha512sums="
