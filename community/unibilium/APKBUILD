maintainer="John Vogel <jvogel@stygian.me>"
pkgname=unibilium
pkgver=2.1.2
pkgrel=0
pkgdesc="Terminfo parsing library"
url="https://github.com/neovim/unibilium"
arch="all"
license="LGPL-3.0-or-later"
makedepends="
	autoconf
	automake
	libtool
	perl
	"
checkdepends="perl-utils"
subpackages="
	$pkgname-dev
	$pkgname-doc
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/neovim/unibilium/archive/v$pkgver.tar.gz
	0001-fix-align-terminfo-search-logic-with-ncurses-31.patch
	"

prepare() {
	default_prepare
	autoreconf -fi
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--mandir=/usr/share/man

	make PREFIX=/usr
}

check() {
	make test
}

package() {
	make PREFIX=/usr DESTDIR="$pkgdir" install
}

