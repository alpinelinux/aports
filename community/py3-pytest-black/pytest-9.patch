Patch-Source: https://github.com/coherent-oss/pytest-black/pull/5
---
From 7e99a77c556fac2c28b6e8459413e1613529b4df Mon Sep 17 00:00:00 2001
From: Daniel Garcia Moreno <daniel.garcia@suse.com>
Date: Tue, 20 Jan 2026 15:44:08 +0100
Subject: [PATCH] Make it work with pytest 9.0

https://docs.pytest.org/en/latest/deprecations.html#py-path-local-arguments-for-hooks-replaced-with-pathlib-path
---
 pytest_black.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/pytest_black.py b/pytest_black.py
index e9c64dc..32d3547 100644
--- a/pytest_black.py
+++ b/pytest_black.py
@@ -20,9 +20,9 @@ def pytest_addoption(parser):
     )
 
 
-def pytest_collect_file(file_path, path, parent):
+def pytest_collect_file(file_path, parent):
     config = parent.config
-    if config.option.black and path.ext in [".py", ".pyi"]:
+    if config.option.black and file_path.suffix in [".py", ".pyi"]:
         return BlackFile.from_parent(parent, path=file_path)
 
 
