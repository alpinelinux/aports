# Contributor: Bart Ribbers <bribbers@disroot.org>
# Maintainer: Steven Guikal <void@fluix.one>
pkgname=py3-pytest-black
pkgver=0.6.0
pkgrel=0
pkgdesc="pytest plugin to enable format checking with black"
url="https://github.com/coherent-oss/pytest-black"
arch="noarch"
license="MIT"
depends="
	py3-pytest
	black
	py3-toml
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://github.com/coherent-oss/pytest-black/archive/v$pkgver/pytest-black-v$pkgver.tar.gz
	pytest-9.patch
	"
builddir="$srcdir/pytest-black-$pkgver"

build() {
	SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver \
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
55cc5977ad2f0fc56261b206793f3a235643eb4e161abbdcafe827cb9f7446111f4200527f5c5fc73ea21bc3dd1946b8c30bfca2f3c8165a9d7f8b8ae5710127  pytest-black-v0.6.0.tar.gz
96e78b1eaef8ed096422939d9d12d20b6adbcc4c3b1c56e4aa041b95ef8bb897466ef8868847ca75bc335c1a349c22d727694332d6d49bf36a0f495d144550be  pytest-9.patch
"
