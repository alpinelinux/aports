86f5143d381a21eaa83b9e30d7a99e1a64189ab8477cf6f226f50f6b80826447c25b33b3625b5f3ad45103d88f6fb557e76510622c94498c0a492980d1c375a0  0001-chore-drop-support-for-Python-3.8.patch
2a94ee221e6503f160de33d74c3ae398e0031677e487bdef87abc07f9ac9decfe45a10dc0f8df1b9e3b73b6a145126ef8765658ca35e7acc52f233228d981d04  0002-fix-test-tests-were-broken-under-Python-3.14.0b2-fix.patch
"
