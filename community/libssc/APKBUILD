# Contributor: Dylan Van Assche <dylan@postmarketos.org>
# Maintainer: Dylan Van Assche <dylan@postmarketos.org>
pkgname=libssc
pkgver=0.4.3
pkgrel=0
pkgdesc="Library to expose Qualcomm Sensor Core sensors"
url="https://codeberg.org/DylanVanAssche/libssc"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	eudev-dev
	glib-dev
	libgudev-dev
	linux-headers
	libqmi-dev
	meson
	protobuf-c-dev
	protobuf-dev
	python3-dev
	py3-gobject3
	py3-protobuf
	qrtr-libs
"
subpackages="$pkgname-dbg $pkgname-dev $pkgname-pyc"
builddir="$srcdir/$pkgname"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/DylanVanAssche/libssc/archive/v$pkgver.tar.gz"

# Tests suddenly fail on s390x, disable them for now
case "$CARCH" in
	s390x) options="!check";;
esac

build() {
	abuild-meson \
		-Db_lto=true \
		. output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

check() {
	meson test --print-errorlogs -C output
}

sha512sums="
71bc112b1be27e3d720f095b12d40c77a50f9c7b98d226194d4a68a132024b9d0ee5a063acb5bc5c614fd51698ebce24c8ccc785fa5a1ea13e3dddb526778b75  libssc-0.4.3.tar.gz
"
