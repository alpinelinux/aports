maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=py3-mozshellutil
pkgver=1.0.0
pkgrel=0
pkgdesc="Shell command line parsing utilities for Mozilla testing"
url="https://firefox-source-docs.mozilla.org/mozbase/index.html"
arch="noarch"
license="MPL-2.0"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/m/mozshellutil/mozshellutil-$pkgver.tar.gz"
builddir="$srcdir/mozshellutil-$pkgver"
options="!check" # tests depend on mozunit

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

