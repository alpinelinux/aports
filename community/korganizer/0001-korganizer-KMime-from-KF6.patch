From 353a1dc5c3d6c14bf9d3bfd33c2e5f7059d8f0d4 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Sun, 19 Apr 2026 10:11:13 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt               | 6 +++++-
 src/CMakeLists.txt           | 2 +-
 src/autotests/CMakeLists.txt | 2 +-
 3 files changed, 7 insertions(+), 3 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index e131fa2e4..eb64c4de1 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -203,7 +203,11 @@ find_package(KPim6LdapWidgets ${KLDAP_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6AkonadiCalendar ${AKONADICALENDAR_LIB_VERSION} CONFIG REQUIRED)
 
 find_package(KPim6KontactInterface ${KONTACTINTERFACE_LIB_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 
 find_package(KPim6PimCommonAkonadi ${PIMCOMMON_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6Libkdepim ${LIBKDEPIM_LIB_VERSION} CONFIG REQUIRED)
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index 675bf1204..fc9efc807 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -478,7 +478,7 @@ target_link_libraries(
         KF6::CalendarCore
         KPim6::CalendarUtils
         KF6::Holidays
-        KPim6::Mime
+        KF6::Mime
         KPim6::IdentityManagementCore
         KF6::KCMUtils
         KPim6::LdapWidgets
diff --git a/src/autotests/CMakeLists.txt b/src/autotests/CMakeLists.txt
index 1355ef7a3..231e5c843 100644
--- a/src/autotests/CMakeLists.txt
+++ b/src/autotests/CMakeLists.txt
@@ -49,7 +49,7 @@ set(koeventpopupmenutest_LIBS
     Qt::Test
     Qt::Gui
     Qt::Core
-    KPim6::Mime
+    KF6::Mime
     KPim6::AkonadiWidgets
     KPim6::AkonadiCore
     KPim6::AkonadiCalendar
