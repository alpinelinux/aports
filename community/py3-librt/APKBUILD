# Maintainer: Andy Postnikov <apostnikov@gmail.com>
pkgname=py3-librt
_pkgname=librt
pkgver=0.8.1
pkgrel=0
pkgdesc="Mypyc runtime library with efficient C implementations"
url="https://github.com/mypyc/librt"
arch="all"
license="MIT"
makedepends="clang python3-dev py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest py3-mypy-extensions"
source="https://files.pythonhosted.org/packages/source/${_pkgname:0:1}/$_pkgname/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

build() {
	CC=clang gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages test-env
	test-env/bin/python3 -m installer .dist/$_pkgname-*.whl
	test-env/bin/python3 -m pytest smoke_tests.py
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/$_pkgname-*.whl
}

sha512sums="
0cac416696dd87a1cd9c8276946d7ea25d125b07fe9bb0abc09a5590e549bb781944713f1c83edb83eede3a0038175cc33d8ad3fa4e945ed916aa3c590f91020  librt-0.8.1.tar.gz
"
