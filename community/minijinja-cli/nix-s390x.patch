--- a/Cargo.toml
+++ b/Cargo.toml
@@ -14,3 +14,7 @@ opt-level = 3
 inherits = "release"
 lto = "thin"
 panic = "abort"
+
+# to be able to bump nix crate to 0.31.2 for s390x
+[patch.crates-io]
+rustyline = { path = "vendored-rustyline" }
--- a/minijinja-cli/Cargo.toml
+++ b/minijinja-cli/Cargo.toml
@@ -47,7 +47,7 @@ minijinja = { version = "=2.19.0", path
     "loop_controls"
 ] }
 minijinja-contrib = { version = "=2.19.0", optional = true, path = "../minijinja-contrib", features = ["pycompat", "datetime", "timezone", "rand", "unicode_wordwrap", "wordcount"] }
-rustyline = { version = "14.0.0", optional = true }
+rustyline = { version = "18.0.0", optional = true, path = "../vendored-rustyline" }
 serde = { version = "1.0.183", features = ["derive", "rc"] }
 serde_json = "1.0.105"
 serde_json5 = { version = "0.1.0", optional = true }
--- a/vendored-rustyline/Cargo.toml
+++ b/vendored-rustyline/Cargo.toml
@@ -16,9 +16,6 @@ exclude = ["/.github/*", "/rustfmt.toml"
 [badges]
 maintenance = { status = "actively-developed" }
 
-[workspace]
-members = ["rustyline-derive"]
-
 [dependencies]
 bitflags = "2.11"
 cfg-if = "1.0.4"
@@ -120,14 +117,3 @@ all-features = false
 no-default-features = true
 default-target = "x86_64-unknown-linux-gnu"
 rustdoc-args = ["--cfg", "docsrs"]
-
-[workspace.lints.clippy]
-ref_option = "warn"
-semicolon_if_nothing_returned = "warn"
-unnecessary_semicolon = "warn"
-unused_trait_names = "warn"
-
-#collapsible_match = "allow"
-
-[lints]
-workspace = true
