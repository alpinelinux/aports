# Contributor: Sören Tempel <soeren+alpine@soeren-tempel.net>
pkgname=py3-requests-ratelimiter
pkgver=0.9.0
pkgrel=0
pkgdesc="Rate-limiting support for py3-requests"
url="https://github.com/JWCook/requests-ratelimiter"
arch="noarch"
license="MIT"
depends="python3 py3-pyrate-limiter py3-requests-cache"
makedepends="py3-hatchling py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest py3-requests-mock"
subpackages="$pkgname-pyc"
source="https://github.com/JWCook/requests-ratelimiter/archive/v$pkgver/py3-requests-ratelimiter-$pkgver.tar.gz"
builddir="$srcdir/requests-ratelimiter-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
89b0d73ebfb061b84606c73fc0bbe47fa890d84e83700fe56c3ea2da980a408d94c7ea118ec53dd6e4eea5f3e7c4f1075cb5774ad17816fe6c2e9bfe9dcd226a  py3-requests-ratelimiter-0.9.0.tar.gz
"
