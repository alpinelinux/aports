pkgname=tinyfugue
pkgver=5.2.2
pkgrel=1
pkgdesc="Powerful curses-based MUD client"
url="https://github.com/ingwarsw/tinyfugue"
arch="all"
options="!check" # no testsuite
license="GPL-2.0-or-later"
makedepends="
	icu-dev
	ncurses-dev
	openssl-dev
	pcre2-dev
	python3-dev
	zlib-dev
	"

source="$pkgname-$pkgver.tar.gz::https://github.com/ingwarsw/tinyfugue/archive/refs/tags/$pkgver.tar.gz
	gnu-source.patch
	python-3.14.patch
	"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--enable-atcp \
		--enable-gmcp \
		--enable-option102 \
		--enable-python
	make
}

package() {
	make DESTDIR="$pkgdir" install
}

