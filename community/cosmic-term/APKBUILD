# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-term
pkgver=1.2.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Terminal emulator for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-term"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	just
	libxkbcommon-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-term/archive/refs/tags/epoch-$_upstreamver.tar.gz
	wgpu.patch
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	export VERGEN_GIT_COMMIT_DATE="$(date -d @"$SOURCE_DATE_EPOCH" '+%Y-%m-%d')"
	export VERGEN_GIT_SHA="unknown"

	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
fb24cde13f12a2244528ee41b707b54562779c5afa96453d3225b227537d62c25b1f33e2f21fdbc8b859615a5c8cd95fd46ff01029498aa68757145470867985  cosmic-term-1.2.0.tar.gz
9f43afeefc2ae7edf177115c450a3176ba2c5c9c86617454525ee406bf0050388bcbbe1ce151e287bf8518a1ace0595a23728028a0b23726ca79ddd9d81c4ead  wgpu.patch
"
