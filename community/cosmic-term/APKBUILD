# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-term
pkgver=1.0.16
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Terminal emulator for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-term"
# 32-bit: mismatched types in compio-driver-0.9.0 crate
# riscv64: too slow to build
arch="all !armhf !armv7 !x86 !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	just
	libxkbcommon-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-term/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	export VERGEN_GIT_COMMIT_DATE="$(date -d @"$SOURCE_DATE_EPOCH" '+%Y-%m-%d')"
	export VERGEN_GIT_SHA="unknown"

	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
a15fa7c731ada6741759b6e5397d5446745ab8dd6d185f0eb8535e75807bb736a9cb3f58128abc72ed8b97d91a12dee07257fe85ea098eb8d80358b22d70fcf6  cosmic-term-1.0.16.tar.gz
"
