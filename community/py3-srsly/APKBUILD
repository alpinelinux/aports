# Contributor: Oleg Titov <oleg.titov@gmail.com>
# Maintainer: Oleg Titov <oleg.titov@gmail.com>
pkgname=py3-srsly
pkgver=2.5.2
pkgrel=1
pkgdesc="Modern high-performance serialization utilities for Python"
url="https://github.com/explosion/srsly"
arch="all"
license="MIT"
depends="py3-catalogue"
makedepends="
	cython
	python3-dev
	py3-installer
	py3-setuptools
	py3-wheel
	py3-gpep517
	"
checkdepends="
	py3-mock
	py3-numpy
	py3-psutil
	py3-pytest
	py3-pytest-timeout
	"
subpackages="$pkgname-doc $pkgname-pyc"
source="srsly-$pkgver.tar.gz::https://github.com/explosion/srsly/archive/release-v$pkgver.tar.gz
	python-3.14.patch
	"
builddir="$srcdir/srsly-release-v$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl

	# otherwise pytest picks up the local one,
	# which doesn't have the native shared library and fails
	cd .testenv/lib/python3.*/site-packages
	$builddir/.testenv/bin/python3 -m pytest -v \
		-k 'not test_extract_class_dict and not test_sortKeys'

}

package() {
	python -m installer -d "$pkgdir" .dist/*.whl

	install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"

	rm -r "$pkgdir"/usr/lib/python3*/site-packages/srsly/tests
}

sha512sums="
64a8900632be9bb376ca9b9fccd6ed691460ff12fbc08b142666b0444ddd6e964992c4094bcde4d7f83958d2de1f488a99165ebced0aee21aa03ac424ddb1ba7  srsly-2.5.2.tar.gz
9622c6c967d44ba5443eb0d1d89a7d671896d51c6f399eee7a996f4d39449658c152e40bff188a2e9f377f8533f5e4cb14fc09381727943cd08b67a072a90ecb  python-3.14.patch
"
