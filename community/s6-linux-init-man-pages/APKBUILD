# Maintainer: Peter Shkenev <santurysim@gmail.com>
pkgname=s6-linux-init-man-pages
pkgver=1.2.0.0.2
pkgrel=0
pkgdesc="Unofficial mdoc versions of the s6-linux-init documentation"
url="https://git.sr.ht/~humm/s6-linux-init-man-pages"
arch="noarch"
license="ISC"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~humm/s6-linux-init-man-pages/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-v$pkgver"
options="!check" # no tests
install_if="${pkgname%-*-*}>=${pkgver%.*} docs"

package() {
	make DESTDIR="$pkgdir" install

	find "$pkgdir" -type f ! -name "*.gz" \
		-exec gzip -9 {} \;
}

sha512sums="
f799c3696b8067991a1abf083ef0121c84eabb80d6bb912c130b3bee0c712b7ec22291dcbefde0b7132c2ec13d326ebb82f0b5e340ac2878a1653815d3b275ae  s6-linux-init-man-pages-1.2.0.0.2.tar.gz
"
