# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer:
pkgname=raku-digest-sha1-native
pkgver=1.0.1
pkgrel=0
pkgdesc="Fast SHA1 computation using NativeCall to C"
url="https://github.com/bduggan/raku-digest-sha1-native"
arch="all"
license="Artistic-2.0"
depends="rakudo"
makedepends="
	moarvm-dev
	rakudo-dev
	raku-librarymake
	"
checkdepends="perl-utils"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/bduggan/raku-digest-sha1-native/archive/refs/tags/$pkgver.tar.gz"
options="!archcheck" # Precompiled arch dependent files included (quiet noarch warning)

prepare() {
	default_prepare

	rm -v resources/libraries/sha1.dll
}

build() {
	raku Configure.raku

	RAKUDO_RERESOLVE_DEPENDENCIES=0 \
	/usr/share/rakudo/tools/install-dist.raku \
		--to=output --for=vendor
}

check() {
	prove -e 'raku -Ilib' --ext .rakutest
}

package() {
	mkdir -p "$pkgdir"/usr/share/rakudo
	cp -RT output "$pkgdir"/usr/share/rakudo/vendor

	install -Dvm644 META6.json README.md \
		-t "$pkgdir"/usr/share/doc/$pkgname/
}

sha512sums="
a9a5fd9ac8302f5ccaccd92a992a3f047d0436af57f64fc20ed55d147a80d1f3bf4b771446cad04a411a19c302ea5435d49955348e94d5bbf4a349a327c27527  raku-digest-sha1-native-1.0.1.tar.gz
"
