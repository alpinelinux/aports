# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=ruby-http_parser.rb
_gemname=http_parser.rb
pkgver=0.8.1
pkgrel=0
pkgdesc="A simple callback-based HTTP request/response parser"
url="https://github.com/tmm1/http_parser.rb"
arch="all"
license="MIT"
depends="ruby"
checkdepends="ruby-rspec"
makedepends="http-parser-dev ruby-dev"
source="https://github.com/tmm1/http_parser.rb/archive/v$pkgver/http_parser.rb-$pkgver.tar.gz
	remove-broken-test.patch
	use-system-libhttp_parser.patch
	gemspec.patch
	"
builddir="$srcdir/$_gemname-$pkgver"

build() {
	gem build $_gemname.gemspec
	gem install \
		--local \
		--install-dir dist \
		--ignore-dependencies \
		--no-document \
		--verbose \
		$_gemname
}

check() {
	GEM_PATH='./dist' rspec .
}

package() {
	local gemdir="$pkgdir/$(ruby -e 'puts Gem.default_dir')"
	cd "$builddir"/dist

	mkdir -p "$gemdir"
	cp -r extensions gems specifications "$gemdir"/

	# Remove unnecessary files and rubbish...
	find "$gemdir"/extensions/ -name mkmf.log -delete

	cd "$gemdir"/gems/$_gemname-$pkgver
	rm -r ext/ lib/*.so
}

