23fa382a7b2d507625878560ff669b9da97a85acf8660dabe84565b833b6b531870b5e1378fab9001d5eb01373960d4c214b35fb58f74c1654cb2653baffcfab  0001-rv64-use-pc-relative-addressing-for-globals.patch
"
