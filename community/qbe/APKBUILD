# Maintainer: Simon Zeni <simon@bl4ckb0ne.ca>
pkgname=qbe
pkgver=1.3
pkgrel=0
pkgdesc="A simple C compiler backend"
url="https://c9x.me/compile/"
arch="all"
license="MIT"
subpackages="$pkgname-dbg"
source="
	$pkgname-$pkgver.tar.xz::https://c9x.me/compile/release/qbe-$pkgver.tar.xz
	0001-rv64-use-pc-relative-addressing-for-globals.patch
	"

case $CARCH in
	aarch64|riscv64|x86_64) ;;
	*) options="$options !check" ;;
esac

prepare() {
	default_prepare

	case $CARCH in
		aarch64) echo '#define Deftgt T_arm64' ;;
		riscv64) echo '#define Deftgt T_rv64' ;;
		*) echo '#define Deftgt T_amd64_sysv' ;;
	esac > config.h
}

build() {
	make PREFIX=/usr CC="$CC" CFLAGS="$CFLAGS -std=c99"
}

check() {
	make check
}

package() {
	make PREFIX=/usr DESTDIR="$pkgdir" install
}

