# Contributor: agxr <agxr@disroot.org>
# Maintainer: Simon Zeni <simon@bl4ckb0ne.ca>
pkgname=qbe
pkgver=1.3
pkgrel=1
pkgdesc="Quick compiler backend"
url="https://c9x.me/compile/"
arch="all"
license="MIT"
subpackages="$pkgname-dbg $pkgname-doc"
source="$pkgname-$pkgver.tar.xz::https://c9x.me/compile/release/qbe-$pkgver.tar.xz
	e786f06032fefa2e3790d6b1c9e31ed138f475a6.patch
	"

case $CARCH in
	aarch64|riscv64|x86_64) ;;
	*) options="$options !check" ;; # tests not supported
esac

prepare() {
	default_prepare

	case $CARCH in
		aarch64) echo '#define Deftgt T_arm64' ;;
		riscv64) echo '#define Deftgt T_rv64' ;;
		*) echo '#define Deftgt T_amd64_sysv' ;;
	esac > config.h
}

build() {
	make PREFIX=/usr CC="$CC" CFLAGS="$CFLAGS -std=c99"
}

check() {
	make check
}

package() {
	make PREFIX=/usr DESTDIR="$pkgdir" install

	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
	install -Dm644 doc/*.txt -t "$pkgdir"/usr/share/doc/$pkgname/
}
sha512sums="
