# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-launcher
pkgver=1.3.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Application launcher for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-launcher"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !x86"
license="GPL-3.0-or-later"
depends="
	pop-launcher
"
makedepends="
	appstream-glib
	cargo-auditable
	desktop-file-utils
	intltool
	just
	libxkbcommon-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-launcher/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
b89c1c774369c2b28a582cd784868db5cc2898f3ff4d6df56342d984804c9004cd32af23ec43ff20edb7dcfed1996b9d7dd12abbfc5d785dd4788c33f41a0459  cosmic-launcher-1.3.0.tar.gz
"
