# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-launcher
pkgver=1.0.16
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Application launcher for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-launcher"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-or-later"
depends="
	pop-launcher
"
makedepends="
	appstream-glib
	cargo-auditable
	desktop-file-utils
	intltool
	just
	libxkbcommon-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-launcher/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
7011af7ada59d5fd83b058c5510273b2a62bb17ccecedee65967e66557f605aebd5307bc9cb50ccd5650ea3accea4540e3656b07083eb3eabd8cceadf21f7982  cosmic-launcher-1.0.16.tar.gz
"
