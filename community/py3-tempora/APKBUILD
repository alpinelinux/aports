maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=py3-tempora
pkgver=5.12.0
pkgrel=0
pkgdesc="Objects and routines pertaining to date and time (tempora)"
url="https://github.com/jaraco/tempora"
arch="noarch"
license="MIT"
depends="
	py3-dateutil
	py3-jaraco.collections
	py3-jaraco.functools
	py3-tz
	"
makedepends="
	py3-flit
	py3-gpep517
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="
	py3-freezegun
	py3-pytest
	py3-pytest-freezegun
	py3-tzdata
	"
subpackages="$pkgname-pyc"
source="https://pypi.python.org/packages/source/t/tempora/tempora-$pkgver.tar.gz"
builddir="$srcdir/tempora-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}



sha512sums="
3dc04ca741a86aeae6c0b6d465bf95bcfe41b7fc1c328fd1ad00df9af567d93dcf81b1a8f3953f043739e6cbaef7c9660a14c899db16a3ed8c636a69d01dca55  tempora-5.12.0.tar.gz
"
