maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=py3-tempora
pkgver=5.10.0
pkgrel=0
pkgdesc="Objects and routines pertaining to date and time (tempora)"
url="https://github.com/jaraco/tempora"
arch="noarch"
license="MIT"
depends="
	py3-dateutil
	py3-jaraco.collections
	py3-jaraco.functools
	py3-tz
	"
makedepends="
	py3-flit
	py3-gpep517
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="
	py3-freezegun
	py3-pytest
	py3-pytest-freezegun
	py3-tzdata
	"
subpackages="$pkgname-pyc"
source="https://pypi.python.org/packages/source/t/tempora/tempora-$pkgver.tar.gz"
builddir="$srcdir/tempora-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}



sha512sums="
03444c55810bd5b46e97a1a0698e5b070aaffaf5679541cfd83f7713f3fee22eb33da680d1fc165c8805d3fb9c12edd0b74ca28be8843a9d3838cd1b575efaf9  tempora-5.10.0.tar.gz
"
