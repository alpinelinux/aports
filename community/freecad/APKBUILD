# Contributor: Bryce Vandegrift <bryce@brycevandegrift.xyz>
# Maintainer: Bryce Vandegrift <bryce@brycevandegrift.xyz>
pkgname=freecad
pkgver=1.1.0
_addonm_ver="291366f293c8b1c073e7b1f300e04e38dc40c7fe"
_ondsel_ver="09d6175a2ba69e7016fcecc4f384946a2f84f92d"
_gsl_ver="4.2.1"
pkgrel=0
pkgdesc="Open-source parametric 3D modeler"
url="https://www.freecad.org/"
# armv7, armhf, and aarch64: GL_MULTISAMPLE not declared
# s390x: blocked by opencascade-dev, vtk-dev, and freeimage-dev
# riscv64: blocked by py3-pivy, py3-pyside6, pyside6-dev, and py3-shiboken6
arch="all !aarch64 !armhf !armv7 !s390x !riscv64"
license="LGPL-2.0-or-later"
depends="py3-pivy py3-matplotlib py3-pyside6"
makedepends="
	boost-dev
	cmake
	coin-dev
	doxygen
	eigen-dev
	freeimage-dev
	glew-dev
	gtest-dev
	jsoncpp-dev
	libmedc-dev
	libspnav-dev
	ninja
	opencascade-dev
	py3-matplotlib
	py3-pivy
	py3-pybind11-dev
	py3-shiboken6
	pyside6-dev
	python3-dev
	qt6-qtbase-dev
	qt6-qtsvg-dev
	qt6-qttools-dev
	swig
	vtk-dev
	xerces-c-dev
	yaml-cpp-dev
	"
subpackages="$pkgname-doc $pkgname-dev"
options="!check"
source="$pkgname-$pkgver.tar.gz::https://github.com/FreeCAD/FreeCAD/archive/$pkgver.tar.gz
	$pkgname-addonmanager-$_addonm_ver.tar.gz::https://github.com/FreeCAD/AddonManager/archive/$_addonm_ver.tar.gz
	OndselSolver-$_ondsel_ver.tar.gz::https://github.com/Ondsel-Development/OndselSolver/archive/$_ondsel_ver.tar.gz
	GSL-$_gsl_ver.tar.gz::https://github.com/microsoft/GSL/archive/refs/tags/v$_gsl_ver.tar.gz
	no-execinfo.patch
	UnlimitedUnsigned.h-cstdint.patch
	"
builddir="$srcdir/FreeCAD-$pkgver"

prepare() {
	default_prepare

	mv $srcdir/AddonManager-$_addonm_ver/* $builddir/src/Mod/AddonManager/
	mv $srcdir/OndselSolver-$_ondsel_ver/* $builddir/src/3rdParty/OndselSolver/
	mv $srcdir/GSL-$_gsl_ver/* $builddir/src/3rdParty/GSL/
}

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DFREECAD_QT_VERSION=6 \
		-DFREECAD_USE_EXTERNAL_PIVY=ON \
		-DBUILD_FLAT_MESH=ON \
		-DENABLE_DEVELOPER_TESTS=OFF \
		-DBUILD_TEST=OFF \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_DATAROOTDIR=/usr/share \
		-DCMAKE_INSTALL_DATADIR=/usr/share/$pkgname
	ninja -C build
}

package() {
	DESTDIR="$pkgdir" ninja -C build install
}

