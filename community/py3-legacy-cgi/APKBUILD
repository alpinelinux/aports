maintainer="Natanael Copa <ncopa@alpinelinux.org>"
pkgname="py3-legacy-cgi"
pkgver=2.6.4
pkgrel=0
pkgdesc="Fork of the standard library cgi and cgitb modules removed in Python 3.13"
url="https://pypi.org/project/legacy-cgi/"
arch="noarch"
license="MIT"
depends="python3"
makedepends="py3-gpep517"
checkdepends="py3-pytest py3-hatchling"
subpackages="$pkgname-pyc"
source="https://pypi.io/packages/source/l/legacy_cgi/legacy_cgi-$pkgver.tar.gz"

builddir="$srcdir"/legacy_cgi-$pkgver

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	# disable tests that requires wsgiproxy2 to avoid circular dependency
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
daeda7344bd9397c32febbc179e12fc5253ff025f3a56c3d63495a2c6551ebea23f9ea990f89ddf2666e7839a5f4e2dc78d3997970918a0dfa654d101b9464bb  legacy_cgi-2.6.4.tar.gz
"
