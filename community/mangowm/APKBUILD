# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=mangowm
pkgver=0.14.4
pkgrel=0
pkgdesc="Lightweight, high-performance Wayland compositor built on dwl"
arch="all"
url="https://mangowm.github.io/"
license="GPL-3.0-or-later"
makedepends="muon
	cjson-dev
	pcre2-dev
	scenefx-dev
	wlroots0.19-dev
	wayland-protocols
	"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/mangowm/mango/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/mango-$pkgver"

build() {
	abuild-muon output .
	ninja -C output
}

check() {
	./output/mango -v
}

package() {
	DESTDIR="$pkgdir" muon -C output install
	provides="mangowc=$pkgver-r$pkgrel"

	install -dm755 "$pkgdir"/usr/share/doc/"$pkgname"/
	mv docs/* "$pkgdir"/usr/share/doc/"$pkgname"/
}

sha512sums="
f8efc986ceedfd9d0b6525335936cf482de1c2e21462ed72bc231e4b9497e5998850a524c84044ad8afb2bba9bff98e60472ec75303df6d5943949cdb52fc9e3  mangowm-0.14.4.tar.gz
"
