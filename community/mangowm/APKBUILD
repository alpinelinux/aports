# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=mangowm
pkgver=0.14.0
pkgrel=0
pkgdesc="Lightweight, high-performance Wayland compositor built on dwl"
arch="all"
url="https://mangowm.github.io/"
license="GPL-3.0-or-later"
makedepends="muon
	cjson-dev
	pcre2-dev
	scenefx-dev
	wlroots0.19-dev
	wayland-protocols
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/mangowm/mango/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/mango-$pkgver"

build() {
	abuild-muon output .
	ninja -C output
}

check() {
	./output/mango -v
}

package() {
	DESTDIR="$pkgdir" muon -C output install
	provides="mangowc=$pkgver-r$pkgrel"
}

sha512sums="
add2f9dc92113f87e30a7afecbf6d7ab48f243f39bc4fd2b3d3bc700d839cb716aad675f246ba3f91e50f72968dc8a1fdd47ad7d79ac52c77bca21968c728ef5  mangowm-0.14.0.tar.gz
"
