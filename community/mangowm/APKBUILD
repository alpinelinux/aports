# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=mangowm
pkgver=0.13.1
pkgrel=0
pkgdesc="Lightweight, high-performance Wayland compositor built on dwl"
arch="all"
url="https://mangowm.github.io/"
license="GPL-3.0-or-later"
makedepends="muon
	pcre2-dev
	scenefx-dev
	wlroots0.19-dev
	wayland-protocols
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/mangowm/mango/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/mango-$pkgver"

build() {
	abuild-muon output .
	ninja -C output
}

check() {
	./output/mango -v
}

package() {
	DESTDIR="$pkgdir" muon -C output install
	provides="mangowc=$pkgver-r$pkgrel"
}

sha512sums="
70519f23b5432f614ef50b9361cd143baf85d0c33305170de0b072b99b3bde2ddd30d923d65013450810bd6585c01a88cce1f08a55df129b24aba5b270b30d5b  mangowm-0.13.1.tar.gz
"
