From dd6e98968c272c5e222ac1734a12ef63909cda0f Mon Sep 17 00:00:00 2001
From: Vlad Zahorodnii <vlad.zahorodnii@kde.org>
Date: Wed, 14 Jan 2026 15:38:07 +0200
Subject: [PATCH] backends/kwayland: Broadcast config changes even with pending
 outputs

The WaylandConfig tries to batch output configuration changes, but it
makes the code very difficult to follow and there are inconsistencies,
which make things even worse.

As is, without redesigning the protocol bits, there will be races, and
the effort put into trying to do some smart batching in the
WaylandConfig doesn't justify the gains.

(cherry picked from commit fb6c84f065812c47cb6bfc7d0c06252e376e54fb)
---
 backends/kwayland/waylandconfig.cpp | 19 ++++++-------------
 1 file changed, 6 insertions(+), 13 deletions(-)

diff --git a/backends/kwayland/waylandconfig.cpp b/backends/kwayland/waylandconfig.cpp
index fa73f6ed..3493262b 100644
--- a/backends/kwayland/waylandconfig.cpp
+++ b/backends/kwayland/waylandconfig.cpp
@@ -69,7 +69,7 @@ void WaylandConfig::initKWinTabletMode()
             return;
         }
         m_tabletModeEngaged = tabletMode;
-        if (!m_blockSignals && m_initializingOutputs.empty()) {
+        if (!m_blockSignals) {
             Q_EMIT configChanged();
         }
     });
@@ -78,7 +78,7 @@ void WaylandConfig::initKWinTabletMode()
             return;
         }
         m_tabletModeAvailable = available;
-        if (!m_blockSignals && m_initializingOutputs.empty()) {
+        if (!m_blockSignals) {
             Q_EMIT configChanged();
         }
     });
@@ -207,18 +207,11 @@ void WaylandConfig::addOutput(quint32 name, quint32 version)
             if (m_outputOrder) {
                 device->setIndex(m_outputOrder->order().indexOf(device->name()) + 1);
             }
+            m_screen->setOutputs(m_outputMap.values());
+        }
 
-            if (m_initializingOutputs.isEmpty()) {
-                m_screen->setOutputs(m_outputMap.values());
-            }
-            if (!m_blockSignals && m_initializingOutputs.isEmpty()) {
-                Q_EMIT configChanged();
-            }
-        } else {
-            // output got update must update current config
-            if (!m_blockSignals) {
-                Q_EMIT configChanged();
-            }
+        if (!m_blockSignals) {
+            Q_EMIT configChanged();
         }
     });
 
