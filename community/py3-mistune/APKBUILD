# Contributor: Newbyte <newbie13xd@gmail.com>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-mistune
pkgver=3.2.1
pkgrel=0
pkgdesc="Python Markdown parser module"
url="https://github.com/lepture/mistune"
arch="noarch"
license="BSD-3-Clause"
depends="python3"
makedepends="py3-gpep517 py3-installer py3-setuptools py3-wheel"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/lepture/mistune/archive/v$pkgver.tar.gz"
builddir="$srcdir/mistune-$pkgver"

# secfixes:
#   2.0.3-r0:
#     - CVE-2022-34749

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
4f94aeeaa11c0d63418480d227bfbe4191fe9ca7346721c4dbc5ed2df6d39d76c54c72aa5ec93b7117df85d1c8d4bf4aac4d761ee259d6eab1b8f93d7905ab23  py3-mistune-3.2.1.tar.gz
"
