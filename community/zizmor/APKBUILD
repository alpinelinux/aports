# Maintainer: Thiago Perrotta <tbperrotta@gmail.com>
pkgname=zizmor
pkgver=1.26.1
pkgrel=0
pkgdesc="A static analysis tool for GitHub Actions"
url="https://github.com/zizmorcore/zizmor"
arch="all"
license="MIT"
makedepends="cargo cargo-auditable"
subpackages="$pkgname-doc"
source="zizmor-$pkgver.tar.gz::https://github.com/zizmorcore/zizmor/archive/v$pkgver/zizmor-$pkgver.tar.gz"
options="net" # cargo

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	# zizmor 1.26+ derives workflow paths relative to the Git repo root,
	# discovered by walking up for a .git/ directory. The release tarball
	# has none, so an e2e snapshot test fails. abuild source= cannot pull a
	# git checkout, so stub an empty .git/ to satisfy root discovery.
	# https://github.com/zizmorcore/zizmor/issues/2139
	mkdir -p .git
	cargo test --frozen
}

package() {
	install -Dm 755 -t "$pkgdir/usr/bin" target/release/zizmor
	install -Dm 644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
}

sha512sums="
fea38f881b3bfca4c6c1733a5c0116d480f61a214fa9a784c5a2867192904529e74b340513b88d98241fe7e104e5c199b6aa0be0349ea4f5d1486d0197337239  zizmor-1.26.1.tar.gz
"
