# Contributor: Matthias Ahouansou <matthias@ahouansou.cz>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=oo7
pkgver=0.6.0_git20260709
_commit=e45b2e806d7d92f960ac7df0e441ed95b3bb28c9
pkgrel=0
pkgdesc="CLI application to interact with the system keyring"
url="https://github.com/linux-credentials/oo7"
arch="all"
license="MIT"
depends="
	$pkgname-cli
	$pkgname-pam
	$pkgname-portal
	$pkgname-server
	"
makedepends="
	cargo-auditable
	meson
"
subpackages="
	$pkgname-cli
	$pkgname-doc
	$pkgname-pam
	$pkgname-portal
	$pkgname-portal-openrc:portal_openrc
	$pkgname-portal-systemd:portal_systemd
	$pkgname-server
	$pkgname-server-openrc:server_openrc
	$pkgname-server-systemd:server_systemd
	cargo-credential-$pkgname:cred
"
source="$pkgname-$_commit.tar.gz::https://github.com/linux-credentials/oo7/archive/$_commit.tar.gz
	oo7-portal.initd
	oo7-server.initd
"
options="net !check" # cargo crates, no tests for the binaries
builddir="$srcdir/$pkgname-$_commit"

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen

	abuild-meson \
		-Dsystemduserunitdir=/usr/lib/systemd/user \
		portal portal-output
	meson compile -C portal-output

	abuild-meson \
		-Dsystemduserunitdir=/usr/lib/systemd/user \
		server server-output
	meson compile -C server-output

	abuild-meson \
		pam pam-output
	meson compile -C pam-output
}

package() {
	cargo install --frozen --root "$pkgdir"/usr --path cargo-credential
	cargo install --frozen --root "$pkgdir"/usr --path cli
	rm -r "$pkgdir"/usr/.crates*

	DESTDIR="$pkgdir" meson install --no-rebuild -C pam-output
	DESTDIR="$pkgdir" meson install --no-rebuild -C portal-output
	DESTDIR="$pkgdir" meson install --no-rebuild -C server-output

	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE

	install -Dm755 "$srcdir"/oo7-portal.initd "$pkgdir"/etc/user/init.d/oo7-portal
	install -Dm755 "$srcdir"/oo7-server.initd "$pkgdir"/etc/user/init.d/oo7-server

}

cli() {
	pkgdesc="CLI application to interact with the system keyring"
	depends=""

	amove usr/bin/oo7-cli
}

portal() {
	pkgdesc="An implementation of org.freedesktop.impl.portal.Secret"
	depends="dbus"

	amove usr/libexec/oo7-portal
	amove usr/share/applications/oo7-portal.desktop
	amove usr/share/dbus-1/services/org.freedesktop.impl.portal.desktop.oo7.service
	amove usr/share/xdg-desktop-portal/portals/oo7-portal.portal
}

portal_openrc() {
	pkgdesc="An implementation of org.freedesktop.impl.portal.Secret (OpenRC init scripts)"
	install_if="openrc ${subpkgname%-openrc}=$pkgver-r$pkgrel"

	amove etc/user/init.d/oo7-portal
}

portal_systemd() {
	pkgdesc="An implementation of org.freedesktop.impl.portal.Secret (systemd files)"
	install_if="systemd ${subpkgname%-systemd}=$pkgver-r$pkgrel"

	amove usr/lib/systemd/user/dbus-org.freedesktop.impl.portal.desktop.oo7.service
	amove usr/lib/systemd/user/oo7-portal.service
}

server() {
	pkgdesc="D-Bus Secret Service provider"
	depends="dbus"
	provides="dbus:org.freedesktop.Secrets"
	provider_priority=40

	amove usr/libexec/oo7-daemon
}

server_openrc() {
	pkgdesc="D-Bus Secret Service provider (OpenRC init scripts)"
	install_if="openrc ${subpkgname%-openrc}=$pkgver-r$pkgrel"

	amove etc/user/init.d/oo7-server
}

server_systemd() {
	pkgdesc="D-Bus Secret Service provider (systemd files)"
	install_if="systemd ${subpkgname%-systemd}=$pkgver-r$pkgrel"

	amove usr/lib/systemd/user/dbus-org.freedesktop.secrets.service
	amove usr/lib/systemd/user/oo7-daemon.service
}

pam() {
	pkgdesc="PAM integration for the server implementation"
	depends="$pkgname-server"

	amove usr/lib/security/pam_oo7.so
}

cred() {
	pkgdesc="Cargo credential provider built using oo7 instead of libsecret"
	depends="cargo"

	amove usr/bin/cargo-credential-oo7
}

