# Contributor: Bart Ribbers <bribbers@disroot.org>
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=py3-dask
pkgver=2026.3.0
pkgrel=0
pkgdesc="Parallel computing with task scheduling"
url="https://dask.org/"
arch="noarch"
license="BSD-3-Clause"
depends="
	py3-click
	py3-cloudpickle
	py3-fsspec
	py3-packaging
	py3-partd
	py3-toolz
	py3-yaml
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="
	py3-distributed
	py3-jinja2
	py3-lz4
	py3-numpy
	py3-pyarrow
	py3-pytest
	py3-pytest-cov
	py3-pytest-mock
	py3-pytest-rerunfailures
	py3-pytest-timeout
	py3-pytest-xdist
	py3-requests
	"
subpackages="$pkgname-pyc"
source="https://pypi.python.org/packages/source/d/dask/dask-$pkgver.tar.gz"
builddir="$srcdir/dask-$pkgver"

# secfixes:
#   2022.2.0-r0:
#     - CVE-2021-42343

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	local _skip
	case "$CARCH" in
		arm*)
			_skip="
				--deselect dask/tests/test_distributed.py::test_blockwise_dataframe_io
				--deselect dask/tests/test_distributed.py::test_dataframe_broadcast_merge
				--deselect dask/tests/test_distributed.py::test_default_scheduler_on_worker
				--deselect dask/tests/test_distributed.py::test_fused_blockwise_dataframe_merge
				--deselect dask/tests/test_distributed.py::test_futures_in_subgraphs
				--deselect dask/tests/test_distributed.py::test_serializable_groupby_agg
			"
			;;
		ppc64le)
			_skip="--deselect dask/array/tests/test_array_core.py::test_store_locks_failure_lock_released"
			;;
		x86*)
			_skip="--deselect dask/tests/test_threaded.py::test_interrupt"
	esac

	# dataframe is optional and appears to be broken
	# disable tests that does not work with our pandas version
	# or that appear to be flaky
	 pytest -v -n auto dask \
		--ignore dask/dataframe \
		--ignore dask/bag/tests/test_bag.py \
		--deselect dask/tests/test_system.py::test_cpu_affinity_taskset \
		--deselect dask/bytes/tests/test_http.py \
		$_skip
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	rm -r "$pkgdir"/usr/lib/python*/site-packages/dask/tests
	rm -r "$pkgdir"/usr/lib/python*/site-packages/dask/*/tests
}

sha512sums="
