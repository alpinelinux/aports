maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=py3-readme_renderer
pkgver=45.0
pkgrel=0
pkgdesc="readme_renderer is a library for rendering README descriptions for Warehouse"
url="https://github.com/pypa/readme_renderer"
arch="noarch"
license="Apache-2.0"
depends="
	py3-bleach
	py3-docutils
	py3-nh3
	py3-pygments
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-mock
	py3-pytest
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/r/readme_renderer/readme_renderer-$pkgver.tar.gz"
builddir="$srcdir/readme_renderer-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -k "not test_image_with_scale_and_url_does_not_abort_render"
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
719579e5f4e46776aaae34ce8a519bf2a57cf0aad967b363a8de4ef67d3911606ec46cb285a5b7bc896e01155d8b6013045c2fb5b022ef1b3fc5db85b3e9399a  readme_renderer-45.0.tar.gz
"
