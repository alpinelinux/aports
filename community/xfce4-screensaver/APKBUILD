# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=xfce4-screensaver
pkgver=4.20.2
pkgrel=0
pkgdesc="Screensaver and locker for XFCE"
url="https://docs.xfce.org/apps/screensaver/start"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	cmake
	dbus-glib-dev
	elogind-dev
	garcon-dev
	glib-dev
	gtk+3.0-dev
	libwnck3-dev
	libxfce4ui-dev
	libxfce4windowing-dev
	libxklavier-dev
	libxscrnsaver-dev
	linux-pam-dev
	meson
	xfconf-dev
	xmlto
	"
subpackages="$pkgname-doc $pkgname-lang"
source="https://archive.xfce.org/src/apps/xfce4-screensaver/${pkgver%.*}/xfce4-screensaver-$pkgver.tar.xz
	pam-base-auth.patch
	"

build() {
	abuild-meson \
		output \
		-Dsession-manager=elogind
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

