# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=xfce4-screensaver
pkgver=4.18.4
pkgrel=1
pkgdesc="Screensaver and locker for XFCE"
url="https://gitlab.xfce.org/apps/xfce4-screensaver"
arch="all"
license="GPL-2.0-or-later"
_configure_deps="python3 py3-gobject3"
makedepends="$_configure_deps
	dbus-glib-dev
	garcon-dev
	glib-dev
	gtk+3.0-dev
	libwnck3-dev
	libx11-dev
	libxext-dev
	libxfce4ui-dev
	libxklavier-dev
	libxrandr-dev
	libxscrnsaver-dev
	linux-pam-dev
	elogind-dev
	xfconf-dev
	"
subpackages="$pkgname-doc $pkgname-lang $pkgname-configure:_configure"
source="https://archive.xfce.org/src/apps/xfce4-screensaver/${pkgver%.*}/xfce4-screensaver-$pkgver.tar.bz2
	0001-manager-Use-only-one-permanent-window-as-overlay.patch
	0002-manager-Grab-devices-on-overlay-when-recreating-wind.patch
	0003-manager-Fix-keyboard-leak-when-recreating-windows.patch
	pam-base-auth.patch
	"
options="suid"
_libexecdir=/usr/lib/xfce4

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--libexecdir=$_libexecdir \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--enable-pam \
		--enable-locking \
		--with-elogind \
		--without-console-kit
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

_configure() {
	pkgdesc="$pkgname configure screesavers dialogs"
	depends="$_configure_deps"
	install_if="$pkgname=$pkgver-r$pkgrel python3"
	amove usr/bin/xfce4-screensaver-configure.py
}

