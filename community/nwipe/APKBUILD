# Contributor: Chad Dougherty <crd477@icloud.com>
# Maintainer: Chad Dougherty <crd477@icloud.com>
pkgname=nwipe
pkgver=0.42
pkgrel=0
pkgdesc="nwipe is a program that will securely erase the entire contents of hard disks"
url="https://github.com/martijnvanbrummelen/nwipe"
arch="all"
license="GPL-2.0-only"
depends="hdparm smartmontools dmidecode"
makedepends="
	bash
	autoconf
	automake
	libconfig-dev
	ncurses-dev
	parted-dev
	linux-headers
	"
subpackages="$pkgname-doc"
source="https://github.com/martijnvanbrummelen/nwipe/archive/v$pkgver/nwipe-v$pkgver.tar.gz"
options="!check" # No tests.

build() {
	./autogen.sh
	./configure \
		--build="$CBUILD" \
		--host="$CHOST" \
		--prefix=/usr
	make
}

package() {
	make DESTDIR="$pkgdir" install
}


sha512sums="
