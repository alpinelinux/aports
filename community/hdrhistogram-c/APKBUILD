e80cc687ee88424fb50437c278fff05b0c056d3a3f57196bc06ce7f3ab2c7e89e9bc3207d66020087545c32327e7dea4d9fc12000be48ed01322b3b3595b3f8a  disable-avx2-on-x86.patch
"
