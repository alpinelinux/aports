# Contributor: Carlo Landmeter <clandmeter@alpinelinux.org>
# Maintainer: Carlo Landmeter <clandmeter@alpinelinux.org>
pkgname=py3-mysqlclient
pkgver=2.2.8
pkgrel=0
pkgdesc="MySQL database connector for Python (with py3 support)"
url="https://mysqlclient.readthedocs.io/"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	mariadb-dev
	py3-gpep517
	py3-setuptools
	py3-wheel
	python3-dev
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="mysqlclient-python-$pkgver.tar.gz::https://github.com/PyMySQL/mysqlclient/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/mysqlclient-$pkgver"
options="!check" # tests need net

replaces="py-mysqlclient" # Backwards compatibility
provides="py-mysqlclient=$pkgver-r$pkgrel" # Backwards compatibility

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	rm "$pkgdir"/usr/lib/python*/site-packages/MySQLdb/_mysql.c
}

sha512sums="
0ed47aca115495a045e4ec61ed9e9da0876de2c0fb71895e20558a29ef1a4f3c1fd9747532c34a9863db1e820744d3eceaa4b31641f83ccfa536a7fa53eb3288  mysqlclient-python-2.2.8.tar.gz
"
