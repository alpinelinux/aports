daf56c8fee13b872264a6e9d29d2e8897f851252f74ee0103f9150e65945d0f80d7bd10e21da013ef501a04e6fa809677865aa4b7a4eac7234f9de512a55bb22  0001-QQmlTableInstanceModel-refactor-QModelIndex-calculat.patch
"
