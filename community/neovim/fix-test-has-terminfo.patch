Don't treat :verbose version as a canonical list of feature macros

HAVE_UNIBILIUM is not exposed by `:verbose version` even if the build has it.
The test is wrong to treat absence from :verbose version as evidence that the feature is off.

ref: https://github.com/neovim/neovim/issues/37456

diff --git a/test/functional/vimscript/has_spec.lua b/test/functional/vimscript/has_spec.lua
index 3236e9d..f2e5241 100644
--- a/test/functional/vimscript/has_spec.lua
+++ b/test/functional/vimscript/has_spec.lua
@@ -65,16 +65,19 @@ describe('has()', function()
   end)
 
   it('"terminfo"', function()
+    local version = n.exec_capture('verbose version'):lower()
+    if not version:match('have_unibilium') then
+      pending('build metadata does not report HAVE_UNIBILIUM')
+      return
+    end
     -- Looks like "HAVE_UNIBILIUM ", "HAVE_UNIBILIUM=1", "HAVE_UNIBILIUM off", ….
     -- Capture group returns the "1"/"off"/….
-    local build_flag = vim.trim(
-      (n.exec_capture('verbose version'):match('HAVE_UNIBILIUM([^-]+)') or 'missing'):lower()
-    )
+    local build_flag = vim.trim((version:match('have_unibilium([^%s]*)') or ''):lower())
+
     -- XXX: the match() above fails in CI so currently we assume CI always builds with unibilium.
     local is_enabled = t.is_ci()
       or not (
-        build_flag == 'missing'
-        or build_flag == 'false'
+        build_flag == 'false'
         or build_flag == '0'
         or build_flag == 'off'
       )
