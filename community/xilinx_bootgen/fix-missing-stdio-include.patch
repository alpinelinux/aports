Fix missing #include <stdio.h> in lms-hash-sigs/hss_param.c

The file uses printf() but does not include <stdio.h>, which causes a
build failure with GCC 14+ (Alpine 3.22) due to implicit function
declaration of printf being treated as an error.

--- a/lms-hash-sigs/hss_param.c
+++ b/lms-hash-sigs/hss_param.c
@@ -1,4 +1,5 @@
 #include <string.h>
+#include <stdio.h>
 #include "hss.h"
 #include "hss_internal.h"
 #include "endian.h"
