From: Wolfgang Wallner <wolfgang.wallner@br-automation.com>

Fix bn_mont_ctx_st struct layout for OpenSSL >= 3.6.0.

OpenSSL commit 3f540b6d reordered the fields in bn_mont_ctx_st to
eliminate padding waste (104 -> 96 bytes). Bootgen re-declares this
struct in xil-bignum.h; without matching the new layout, Montgomery
multiplication produces silently wrong cryptographic results.

Use a preprocessor conditional to match the correct field order based
on the OpenSSL version.

https://github.com/Xilinx/bootgen/pull/42

--- a/common/include/xil-bignum.h
+++ b/common/include/xil-bignum.h
@@ -26,6 +26,22 @@ struct bignum_st {
 };

 /* Used for montgomery multiplication */
+/*
+ * The layout of this structure was changed in openSSL commit 3f540b6d.
+ */
+#if OPENSSL_VERSION_NUMBER >= 0x30600000L
+struct bn_mont_ctx_st {
+    BIGNUM RR;                  /* used to convert to montgomery form */
+    BIGNUM N;                   /* The modulus */
+    BIGNUM Ni;                  /* R*(1/R mod N) - N*Ni = 1 (Ni is only
+                                 * stored for bignum algorithm) */
+    BN_ULONG n0[2];             /* least significant word(s) of Ni; (type
+                                 * changed with 0.9.9, was "BN_ULONG n0;"
+                                 * before) */
+    int ri;                     /* number of bits in R */
+    int flags;
+};
+#else
 struct bn_mont_ctx_st {
     int ri;                     /* number of bits in R */
     BIGNUM RR;                  /* used to convert to montgomery form */
@@ -37,5 +53,6 @@ struct bn_mont_ctx_st {
                                  * before) */
     int flags;
 };
+#endif

 #endif
