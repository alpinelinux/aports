pkgname=xilinx_bootgen
pkgver=2025.2
pkgrel=0
pkgdesc="Xilinx Bootgen - Convert FPGA bitstreams/bif to bin files"
url="https://github.com/Xilinx/bootgen"
arch="all"
license="Apache-2.0"
makedepends="openssl-dev>3"
source="$pkgname-$pkgver.tar.gz::https://github.com/Xilinx/bootgen/archive/xilinx_v$pkgver.tar.gz
	fix-verify-segfault.patch
	fix-missing-stdio-include.patch
	fix-double-free-authkeys.patch
	fix-openssl-3.6-struct-layout.patch
	"
builddir="$srcdir/bootgen-xilinx_v$pkgver"

build() {
	make
}

check() {
	"$builddir"/build/bin/bootgen -help

	# also smoke test by generating a boot image from an empty BIF
	cat > "$builddir"/test.bif <<-'EOF'
		the_ROM_image:
		{
		}
	EOF
	"$builddir"/build/bin/bootgen -arch zynqmp -image "$builddir"/test.bif \
		-o "$builddir"/test.bin -w
	test -f "$builddir"/test.bin
}

package() {
	install -D -m 0755 -t "$pkgdir/usr/bin" "$builddir/build/bin/bootgen"
}

