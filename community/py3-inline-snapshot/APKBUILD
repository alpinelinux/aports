# Contributor: Noel Kuntze <noel.kuntze@thermi.consulting>
# Maintainer: Noel Kuntze <noel.kuntze@thermi.consulting>
pkgname=py3-inline-snapshot
pkgver=0.32.5
pkgrel=0
pkgdesc="Create and update inline snapshots in your python tests"
url="https://github.com/15r10nk/inline-snapshot"
arch="noarch"
license="MIT"
depends="
	black
	py3-asttokens
	py3-click
	py3-executing
	py3-rich
	py3-tomli
	py3-typing-extensions"
makedepends="
	py3-gpep517
	py3-hatchling
	py3-setuptools
	py3-wheel"
#py3-time-machine
checkdepends="
	py3-dirty-equals
	py3-hypothesis
	py3-isort
	py3-mypy
	py3-pydantic
	py3-pytest-freezer
	py3-pytest-mock
	py3-pytest-subtests
	py3-pytest-xdist"
subpackages="$pkgname-pyc"

source="$pkgname-$pkgver.tar.gz::https://github.com/15r10nk/inline-snapshot/archive/v$pkgver.tar.gz"

builddir="$srcdir/inline-snapshot-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir dist \
		--output-fd 3 3>&1 >&2
}

check() {
	local _site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
	python3 -m installer -d test_dir dist/*.whl
	export PYTHONPATH="$PWD/test_dir/$_site_packages:$PYTHONPATH"
	pytest -vv --deselect tests/test_typing.py \
		--deselect tests/test_docs.py \
		--deselect tests/test_customize.py \
		--deselect tests/test_dirty_equals.py \
		--deselect tests/adapter/test_dataclass.py::test_attrs_unmanaged \
		tests/
}

package() {
	python -m installer -d "$pkgdir" dist/*.whl
}

sha512sums="
05dc45b60c5963fda741ce3f32f475733d332eb2758df796f088b28f192cf9fd6c60705127f6b57a686caf2ce54da1172975c3057ece81b51eb2815f0080b194  py3-inline-snapshot-0.32.5.tar.gz
"
