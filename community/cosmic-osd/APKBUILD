# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-osd
pkgver=1.0.10
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="On-Screen Display for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-osd"
# 32-bit: https://gitlab.freedesktop.org/pipewire/pipewire-rs/-/issues/111
# s390x: nix
# riscv64: too slow to build
arch="all !armhf !armv7 !x86 !s390x !riscv64"
license="GPL-3.0-only"
makedepends="
	cargo
	clang-libclang
	eudev-dev
	just
	libinput-dev
	libxkbcommon-dev
	pipewire-dev
	pulseaudio-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-osd/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	just polkit-agent-helper-1="/usr/lib/polkit-1/polkit-agent-helper-1" build-release --frozen
}

check() {
	cargo test --release --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
67412d078175989e4e751e2a302df6ea23079f00790ab7b5a4b7e1ad16f96538d297408ac6978667139b16d00cf9b0f0e67a8c4c1721a670b7e65cf5ef900b57  cosmic-osd-1.0.10.tar.gz
"
