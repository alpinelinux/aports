# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-osd
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="On-Screen Display for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-osd"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !x86"
license="GPL-3.0-only"
makedepends="
	cargo-auditable
	clang-libclang
	eudev-dev
	just
	libinput-dev
	libxkbcommon-dev
	pipewire-dev
	pulseaudio-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-osd/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	export POLKIT_AGENT_HELPER_1="/usr/lib/polkit-1/polkit-agent-helper-1"
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
1d668fc438e3bac5b33ecfd01aafe75419df3057bfaa7323eb337f7fd232d652f57063f5165e44cf157c0a2f6ead9b2629cc55f0071e90c5cef585890813a8d6  cosmic-osd-1.4.0.tar.gz
"
