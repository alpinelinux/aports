896902676bbd85acbcc2ee62ab1f1ff5c55be986b9e8ba2ebd976a5be0df274184aa8e3354c89b1bb628cd70f14f9d5d5977701f09e3a406277d7c11d5b0426e  minimize-size.patch
"
