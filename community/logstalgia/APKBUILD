# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=logstalgia
pkgver=1.1.5
pkgrel=1
pkgdesc="A website access log visualisation tool"
url="https://logstalgia.io/"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	automake
	autoconf
	boost-dev
	freetype-dev
	ftgl-dev
	glew-dev
	glm-dev
	jpeg-dev
	libpng-dev
	m4
	pcre2-dev
	sdl2-dev
	sdl2_image-dev
	"
subpackages="$pkgname-doc"
source="https://github.com/acaudwell/Logstalgia/releases/download/logstalgia-$pkgver/logstalgia-$pkgver.tar.gz"

prepare() {
	default_prepare
	autoreconf -fiv
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr
	make
}

check() {
	make check
}
package() {
	make prefix=$pkgdir/usr install
}

sha512sums="
aaa1135f3e1046fb1c485bb2e5b3f9671a3125c6c889453cbb2e7fcab139435980871f8af0c4573be878c3ee970f0861d8432ddba172662467eb01a8e1c37c5b  logstalgia-1.1.5.tar.gz
"
