maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=amber-mpris
pkgver=1.2.9
pkgrel=2
pkgdesc="MPRIS v.2 specification implementation for Qt and QML plugin"
url="https://github.com/sailfishos/amber-mpris"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-or-later"
depends_dev="$pkgname
	qt6-qtdeclarative-dev
	"
_depends_dev_qt5="$pkgname-qt5
	qt5-qtdeclarative-dev
	"
makedepends="
	$depends_dev
	$_depends_dev_qt5
	qt5-qtbase-dev
	qt6-qtbase-dev
	"
subpackages="
	$pkgname-dev
	$pkgname-qt5
	$pkgname-qt5-dev:qt5_dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/amber-mpris/archive/refs/tags/$pkgver.tar.gz
	0001-amber-mpris-Add-support-for-building-against-Qt6.patch
	"
options="!check" # No tests

build() {
	msg "Building Qt5 variant"
	mkdir build-qt5 && cd build-qt5
	qmake-qt5 ..
	make
	cd ..

	msg "Building Qt6 variant"
	qmake6 \
		PREFIX=/usr
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install
}

qt5() {
	cd "$builddir"/build-qt5
	INSTALL_ROOT="$subpkgdir" make install

	rm -r "$subpkgdir"/usr/include
	rm -r "$subpkgdir"/usr/lib/pkgconfig
	rm -r "$subpkgdir"/usr/lib/qt5/mkspecs
	rm "$subpkgdir"/usr/lib/libambermpris.so
}

qt5_dev() {
	depends="$_depends_dev_qt5"

	cd "$builddir"/build-qt5
	INSTALL_ROOT="$subpkgdir" make install

	rm -r "$subpkgdir"/usr/lib/qt5/qml
	rm "$subpkgdir"/usr/lib/*.so.*
}

