Patch-Source: https://github.com/drawpile/Drawpile/commit/ce59499b9888e32396c67bdd5f0db1974e0477ee
---
From ce59499b9888e32396c67bdd5f0db1974e0477ee Mon Sep 17 00:00:00 2001
From: askmeaboutloom <askmeaboutlo0m@users.noreply.github.com>
Date: Tue, 14 Apr 2026 11:29:23 +0200
Subject: [PATCH] Add build option to disable QTest-based tests

By passing -DALLOW_QTEST_TESTS=OFF, because GCC 15 currently segfaults
when trying to build those.
---
 cmake/DrawpileOptions.cmake  | 3 +++
 src/libclient/CMakeLists.txt | 2 +-
 src/libserver/CMakeLists.txt | 2 +-
 src/libshared/CMakeLists.txt | 2 +-
 src/thinsrv/CMakeLists.txt   | 2 +-
 5 files changed, 7 insertions(+), 4 deletions(-)

diff --git a/cmake/DrawpileOptions.cmake b/cmake/DrawpileOptions.cmake
index 84b82696bf..4637e53e2a 100644
--- a/cmake/DrawpileOptions.cmake
+++ b/cmake/DrawpileOptions.cmake
@@ -46,6 +46,9 @@ if(NOT ANDROID AND NOT EMSCRIPTEN)
 	option(TESTS "Build unit tests" OFF)
 	add_feature_info("Unit tests (TESTS)" TESTS "")
 
+	option(ALLOW_QTEST_TESTS "Allow building QTest-based tests (some gcc versions segfault on these)" ON)
+	add_feature_info("Allow QTest-based tests (ALLOW_QTEST_TESTS)" ALLOW_QTEST_TESTS "")
+
 	option(BENCHMARKS "Build benchmarks" OFF)
 	add_feature_info("Benchmarks (BENCHMARKS)" BENCHMARKS "")
 else()
diff --git a/src/libclient/CMakeLists.txt b/src/libclient/CMakeLists.txt
index f6b370e5ac..8e487db50f 100644
--- a/src/libclient/CMakeLists.txt
+++ b/src/libclient/CMakeLists.txt
@@ -374,7 +374,7 @@ if(${QT_PACKAGE_NAME}LinguistTools_FOUND)
 	add_subdirectory(i18n)
 endif()
 
-if(TESTS)
+if(TESTS AND ALLOW_QTEST_TESTS)
 	add_subdirectory(tests)
 endif()
 
diff --git a/src/libserver/CMakeLists.txt b/src/libserver/CMakeLists.txt
index d0d0bb7d80..431db4924f 100644
--- a/src/libserver/CMakeLists.txt
+++ b/src/libserver/CMakeLists.txt
@@ -61,7 +61,7 @@ if(TARGET "${QT_PACKAGE_NAME}::WebSockets")
 	target_link_libraries(dpserver PUBLIC ${QT_PACKAGE_NAME}::WebSockets)
 endif()
 
-if(TESTS)
+if(TESTS AND ALLOW_QTEST_TESTS)
 	add_subdirectory(tests)
 endif()
 
diff --git a/src/libshared/CMakeLists.txt b/src/libshared/CMakeLists.txt
index d92fa7f21d..744cfdb6a6 100644
--- a/src/libshared/CMakeLists.txt
+++ b/src/libshared/CMakeLists.txt
@@ -83,7 +83,7 @@ if(TARGET ${QT_PACKAGE_NAME}::WebSockets)
 	target_link_libraries(dpshared PUBLIC ${QT_PACKAGE_NAME}::WebSockets)
 endif()
 
-if(TESTS)
+if(TESTS AND ALLOW_QTEST_TESTS)
 	add_subdirectory(tests)
 endif()
 
diff --git a/src/thinsrv/CMakeLists.txt b/src/thinsrv/CMakeLists.txt
index 2c7af9aeaf..46df90aa4a 100644
--- a/src/thinsrv/CMakeLists.txt
+++ b/src/thinsrv/CMakeLists.txt
@@ -204,7 +204,7 @@ if(INSTALL_DOC AND UNIX)
 	)
 endif()
 
-if(TESTS)
+if(TESTS AND ALLOW_QTEST_TESTS)
 	add_subdirectory(tests)
 endif()
 
