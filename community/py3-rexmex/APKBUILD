532cbfc9fed5f55ec4b1e582c2690d082567f0b5d4c96fb7cc0292f88420d1fdb2560ebcef9e1db77bbe5bed3152175dd592e38bf0df1ca00969a1331cec29b0  fix-tests-regression-normalize.patch
