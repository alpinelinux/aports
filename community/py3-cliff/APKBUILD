maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=py3-cliff
pkgver=4.15.0
pkgrel=0
pkgdesc="Command Line Interface Formulation Framework"
url="https://docs.openstack.org/cliff/latest/"
arch="noarch"
license="Apache-2.0"
depends="
	py3-importlib-metadata
	py3-stevedore
	py3-yaml
	"
makedepends="
	py3-gpep517
	py3-pbr
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-autopage
	py3-cmd2
	py3-docutils
	py3-pytest
	py3-prettytable
	py3-stevedore
	py3-testtools
	"
subpackages="$pkgname-pyc"
source="https://pypi.python.org/packages/source/c/cliff/cliff-$pkgver.tar.gz"
options="!check" # Requires specific (old) version of py3-cmd2
builddir="$srcdir/cliff-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1a3353b5aa4313afe6e82c300fb8caa5530227992d123467c42b10db049b968e3219892e1b438057fa7afb50b7f38ef2b4d4d0241c632cc0ea2944bb8bb635c1  cliff-4.15.0.tar.gz
"
