# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-frameworks
maintainer="team/kde <bribbers@disroot.org>"
pkgname=kmime
pkgver=6.28.0
pkgrel=0
pkgdesc="Library to assist handling MIME data"
arch="all"
url="https://community.kde.org/Frameworks"
license="LGPL-2.0-only AND LGPL-2.0-or-later"
depends_dev="
	kcodecs-dev
	qt6-qtbase-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	kde-qdoc-common
	qt6-qttools-dev
	samurai
	"
subpackages="
	$pkgname-dev
	$pkgname-lang
	"
case "$CARCH" in
	armhf) ;;
	*) subpackages="$subpackages $pkgname-doc"
esac
_repo_url="https://invent.kde.org/frameworks/kmime.git"
source="https://download.kde.org/stable/frameworks/${pkgver%.*}/kmime-$pkgver.tar.xz"

build() {
	export KDE_DOCS=/usr/share/kde/documentation
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build

	cmake --build build --target prepare_docs
	cmake --build build --target generate_docs
	cmake --build build --target generate_qch
}

check() {
	ctest --test-dir build -E "kmime-messagetest"
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	DESTDIR="$pkgdir" cmake --build build --target install_html_docs
	DESTDIR="$pkgdir" cmake --build build --target install_qch_docs
}

sha512sums="
e57a0c93d2816a662043c1f5beac7f426f6e3ad110b23dafd6b02e6e8c09d656057fd1b02447f77b279f7cf807eba09bcb2bb142445a624634cd6dc06d9bf2e1  kmime-6.28.0.tar.xz
"
