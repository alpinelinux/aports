bde9d204a6480bb974e6d36d986461e8ea6bc2666680c2a3bef2ce7810edf620d99dc4add40ddd62f30c7c7ca5ea878eb7bf40bf92c7ef579633bd544e0fd7c4  fix-tests.patch
ecfc55f749210e18b76e79b008c8f631a4fe31a48e6947a8ac343e2c7505b87b77a1ec0c234aec5505c62671087a74c5dbb0cd5ba1ebef7fb3fbd4f44a7ae861  system-java-jna.patch
"
