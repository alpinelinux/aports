# Contributor: Bart Ribbers <bribbers@disroot.org>
# Maintainer: Lindsay Zhou <i@lin.moe>
maintainer="Lindsay Zhou <i@lin.moe>"
pkgname=py3-telethon
pkgver=1.44.0
pkgrel=0
pkgdesc="Full-featured Telegram client library"
url="https://docs.telethon.dev/"
arch="noarch"
license="MIT"
depends="
	py3-pyaes
	py3-rsa
	"
makedepends="
	py3-gpep517
	py3-hatchling
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-pytest
	py3-pytest-asyncio
	"
subpackages="$pkgname-pyc"
source="
	$pkgname-$pkgver.tar.gz::https://codeberg.org/Lonami/Telethon/archive/v$pkgver.tar.gz
	"
builddir="$srcdir"/telethon

build() {
	python3 setup.py gen
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
a51805a6b10b590b97cc8a2fcd1541fde8648c534e7a58044e7055998e76d700f2b7bd6c6489a6ed0d3aa8ee7658d4c9cdf5fd1929583a605d79a43efd317b88  py3-telethon-1.44.0.tar.gz
"
