From fcb6ec83fd98aa74fa01a46926642bd1c6fe0ab5 Mon Sep 17 00:00:00 2001
From: Egor Vorontsov <sdoregor@sdore.me>
Date: Sat, 14 Mar 2026 18:04:18 +0300
Subject: [PATCH] Fixed `get_running_loop()` for Python 3.14.

---
 telethon/helpers.py | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/telethon/helpers.py b/telethon/helpers.py
index f4abe296..708d6f80 100644
--- a/telethon/helpers.py
+++ b/telethon/helpers.py
@@ -425,10 +425,12 @@ class _FileStream(io.IOBase):
 # endregion
 
 def get_running_loop():
-    if sys.version_info >= (3, 7):
+    try:
+        return asyncio.get_running_loop()
+    except RuntimeError:
         try:
-            return asyncio.get_running_loop()
+            return asyncio.get_event_loop()
         except RuntimeError:
-            return asyncio.get_event_loop_policy().get_event_loop()
-    else:
-        return asyncio.get_event_loop()
+            loop = asyncio.new_event_loop()
+            asyncio.set_event_loop(loop)
+            return loop
-- 
2.47.3
