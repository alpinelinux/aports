From 7e07972a44c2c38d6ac14e61e6f0d063651afd9d Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Fri, 17 Apr 2026 17:48:21 +0200
Subject: [PATCH] Add forward compatibility for KMime from KDE Frameworks

---
 CMakeLists.txt                   | 6 +++++-
 src/CMakeLists.txt               | 4 ++--
 src/akonadiplugin/CMakeLists.txt | 2 +-
 3 files changed, 8 insertions(+), 4 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 5da39387b..f2eea7853 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -126,7 +126,11 @@ endif()
 # Find KDE PIM packages
 find_package(KPim6CalendarUtils ${CALENDARUTILS_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6IdentityManagementWidgets ${IDENTITYMANAGEMENT_LIB_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 
 # Build support for audio backend plugins
 option(ENABLE_LIBVLC "Build support for LibVLC" ON)
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index cfbfefb9e..2b8d2afc3 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -33,7 +33,7 @@ target_link_libraries(kalarmplugin PRIVATE
     kalarmcalendar
     KF6::CoreAddons
     KF6::CalendarCore
-    KPim6::Mime
+    KF6::Mime
 )
 
 target_include_directories(kalarmplugin PUBLIC "$<BUILD_INTERFACE:${kalarm_SOURCE_DIR}/src/kalarmcalendar>")
@@ -328,7 +328,7 @@ target_link_libraries(kalarm_bin
     KPim6::CalendarUtils
     KF6::Contacts
     KPim6::IdentityManagementWidgets
-    KPim6::Mime
+    KF6::Mime
 )
 
 if(TARGET KF6::GlobalAccel)
diff --git a/src/akonadiplugin/CMakeLists.txt b/src/akonadiplugin/CMakeLists.txt
index 592b67717..d6791afaa 100644
--- a/src/akonadiplugin/CMakeLists.txt
+++ b/src/akonadiplugin/CMakeLists.txt
@@ -40,7 +40,7 @@ target_link_libraries(akonadiplugin
     KF6::CalendarCore
     KF6::I18n
     KF6::Codecs
-    KPim6::Mime
+    KF6::Mime
     KPim6::AkonadiCore
     KPim6::AkonadiMime
     KPim6::AkonadiContactWidgets
-- 
2.54.0

