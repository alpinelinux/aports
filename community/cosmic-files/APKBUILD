# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-files
pkgver=1.0.11
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="File browser for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-files"
# "The prebuilt `sys.rs` may not be compatible with your target"..
# riscv64: too slow to build
arch="all !armhf !armv7 !x86 !s390x !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
	xdg-utils
"
makedepends="
	cargo-auditable
	clang-libclang
	glib-dev
	just
	libxkbcommon-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-files/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	export VERGEN_GIT_COMMIT_DATE="$(date -d @"$SOURCE_DATE_EPOCH" '+%Y-%m-%d')"
	export VERGEN_GIT_SHA="unknown"

	cargo auditable build --release --frozen
	cargo auditable build --release --frozen --package cosmic-files-applet
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
d65a513ea7bc3b19b5f07775e6500c5fea2d333858da20ee7165260581088d2da4656b630ab4031a6ffa32c22fe876259867d4309c26d3ce88fd7c2f228997a3  cosmic-files-1.0.11.tar.gz
"
