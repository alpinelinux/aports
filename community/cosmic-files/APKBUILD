# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-files
pkgver=1.3.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="File browser for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-files"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !x86"
license="GPL-3.0-only"
depends="
	cosmic-icons
	xdg-utils
"
makedepends="
	cargo-auditable
	clang-libclang
	glib-dev
	just
	libxkbcommon-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-files/archive/refs/tags/epoch-$_upstreamver.tar.gz
	10-io-uring.patch
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	export VERGEN_GIT_COMMIT_DATE="$(date -d @"$SOURCE_DATE_EPOCH" '+%Y-%m-%d')"
	export VERGEN_GIT_SHA="unknown"

	cargo auditable build --release --frozen
	cargo auditable build --release --frozen --package cosmic-files-applet
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
35998c48d901847aac1a2f4e85cb11e528cd2535b236479cd9c0a64fb3d3251d09bb92ee3c6efb7be7453f30468f940f14922cf26be72097252593bd17265dcf  cosmic-files-1.3.0.tar.gz
a1bc756ec1ad71e2432ec594e94f0c2cd8f5d4b7d0cc71058886a4cdba43e4309685acae23945b51f974de7c54c8d23898e5734ca703f0101cedfe3dda47b1e7  10-io-uring.patch
"
