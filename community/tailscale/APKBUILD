pkgname=tailscale
pkgver=1.94.2
pkgrel=0
pkgdesc="The easiest, most secure way to use WireGuard and 2FA"
url="https://tailscale.com/"
license="BSD-3-Clause"
# s390x: upstream still doesn't have hardware to debug this
arch="all !s390x"
options="chmod-clean"
# see https://tailscale.com/kb/1188/linux-dns#dhcp-dhclient-overwriting-etcresolvconf
depends="cmd:resolvconf"
makedepends="
	go
	linux-headers
	"
checkdepends="
	helm
	iproute2-minimal
	openssh
	"
pkgusers="tailscale"
pkggroups="tailscale"
install="
	$pkgname.pre-install
	$pkgname.pre-upgrade
	$pkgname.post-install
	$pkgname.post-upgrade
	"
subpackages="
	$pkgname-bash-completion
	$pkgname-doc
	$pkgname-fish-completion
	$pkgname-openrc
	$pkgname-systemd
	$pkgname-zsh-completion
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/tailscale/tailscale/archive/v$pkgver.tar.gz
	$pkgname.confd
	$pkgname.initd
	$pkgname.logrotate
	$pkgname.modules-load
	$pkgname.doasd
	resolvconf
	test-bump-conn-max-overhead.patch
	systemd-nftables.patch
	fix-tsnet_test-bump-bytesSentTolerance-to-30pct.patch
	test-atomicfile-use-tmpdir.patch
	cli-status-fix-non-constant-formatstring.patch
	"

export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

# secfixes:
#   1.66.1-r0:
#     - CVE-????-????? TS-2024-005
#   1.32.3-r0:
#     - CVE-2022-41924 TS-2022-004
#   0:
#     - CVE-2022-41925 TS-2022-005

prepare() {
	default_prepare

	# this script attempts to download a helm binary
	# use the helm we have in repo instead
	rm -v tool/helm
	ln -sv /usr/bin/helm tool/helm
}

build() {
	local tags="netcgo,ts_omit_aws,ts_omit_kube,ts_include_cli"
	local ldflags="
		-X tailscale.com/version.shortStamp=$pkgver
		-X tailscale.com/version.longStamp=$pkgver-AlpineLinux
		-X tailscale.com/version.gitCommitStamp=AlpineLinux
		"

	go build -v -tags "$tags" -ldflags "$ldflags" ./cmd/tailscaled
	ln -sv ./tailscaled ./tailscale

	mkdir -p completions
	local shell; for shell in bash fish zsh; do
		./tailscale completion $shell > completions/tailscale.$shell
	done
}

check() {
	# flaky test, on multiple archs
	local test_args="-skip TestAllEndpointsAreUpAndReturnExpectedResponse"

	# we don't use ./tool/go
	test_args="$test_args|TestGoVersion"

	# Broken on go 1.26
	# https://github.com/tailscale/tailscale/issues/18880
	test_args="$test_args|TestWhoIsPeerNotFound|TestNoiseClientHTTP2Upgrade"

	# Extra internal dependency in go 1.26 that matches blacklisted dependency
	test_args="$test_args|TestMinTailscaledWithCLI"

	# common tests exclude list for all arches
	# check list & description at https://pkg.go.dev/tailscale.com
	local skip_list="util/linuxfw|net/netcheck|wgengine/magicsock|tstest/(archtest|integration|jsdeps|iosdeps)|ssh/tailssh|containerboot|net/connstats|tool/gocross|derp/xdp|cmd/natc|tsconsensus"

	case "$CARCH" in
		arm*) # fail on the arm builders
			skip_list="$skip_list|testwrapper/flakytest|tailscale.com/portlist"
			;;
		riscv64) # fail on riscv64 builder (k8s/kube compile exceeds timeout >1h)
			skip_list="$skip_list|k8s|kube|feature/taildrop|testwrapper/flakytest|tailscale.com/wgengine"
			;;
	esac

	# shellcheck disable=SC2046,SC2086
	go run ./cmd/testwrapper \
		$(go list ./... | grep -Ev "$skip_list") \
		$test_args
}

package() {
	install -m755 -D tailscaled -t "$pkgdir"/usr/sbin/
	mkdir -p "$pkgdir"/usr/bin
	ln -sv /usr/sbin/tailscaled "$pkgdir"/usr/bin/tailscale

	install -m644 -D completions/tailscale.bash "$pkgdir"/usr/share/bash-completion/completions/tailscale
	install -m644 -D completions/tailscale.fish "$pkgdir"/usr/share/fish/vendor_completions.d/tailscale.fish
	install -m644 -D completions/tailscale.zsh "$pkgdir"/usr/share/zsh/site-functions/_tailscale

	install -m644 -D README.md -t "$pkgdir"/usr/share/doc/$pkgname/

	install -m644 -D cmd/tailscaled/tailscaled.service -t "$pkgdir"/usr/lib/systemd/system/
	install -m644 -D cmd/tailscaled/tailscaled.defaults "$pkgdir"/etc/default/tailscaled

	install -m755 -D "$srcdir"/tailscale.initd "$pkgdir"/etc/init.d/$pkgname
	install -m644 -D "$srcdir"/tailscale.confd "$pkgdir"/etc/conf.d/$pkgname
	install -m644 -D "$srcdir"/tailscale.logrotate "$pkgdir"/etc/logrotate.d/$pkgname
	install -m644 -D "$srcdir"/tailscale.modules-load "$pkgdir"/usr/lib/modules-load.d/$pkgname.conf

	install -m755 -D "$srcdir"/resolvconf -t "$pkgdir"/usr/libexec/$pkgname/
	install -m640 -D "$srcdir"/$pkgname.doasd "$pkgdir"/etc/doas.d/$pkgname.conf

	install -d -m750 -o tailscale -g tailscale "$pkgdir"/var/lib/$pkgname
}

systemd() {
	default_systemd
	amove etc/default/tailscaled
}

