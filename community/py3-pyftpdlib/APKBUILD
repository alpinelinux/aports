# Contributor: TBK <alpine@jjtc.eu>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=py3-pyftpdlib
pkgver=2.2.0
pkgrel=0
pkgdesc="Extremely fast and scalable Python FTP server library."
url="https://pypi.org/project/pyftpdlib/"
arch="noarch"
license="MIT"
depends="py3-openssl py3-pyasynchat py3-pysendfile"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-psutil py3-pytest py3-pytest-instafail py3-pytest-xdist"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/pyftpdlib/pyftpdlib-$pkgver.tar.gz
	"
builddir="$srcdir/pyftpdlib-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
28dda9db61e53fd06a7b1e5ea393790ad346c89f7157e92cc0671be5452af61ed554d93a6919e1a6a5cc26c21622765f6775d2a1a4ec0e0d53a5ed0882703ffd  pyftpdlib-2.2.0.tar.gz
"
