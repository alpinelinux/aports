# Contributor: Sören Tempel <soeren+alpine@soeren-tempel.net>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=bear
pkgver=4.1.3
pkgrel=0
pkgdesc="Tool that generates a compilation database for clang tooling"
url="https://github.com/rizsotto/Bear"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	cargo
	cargo-auditable
	lld
	"
checkdepends="
	bash
	"
subpackages="$pkgname-doc"
source="https://github.com/rizsotto/Bear/archive/$pkgver/bear-$pkgver.tar.gz
	musl-execvpe-interception.patch
	"
builddir="$srcdir/Bear-$pkgver"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	# Integration tests install release artifacts via scripts/install.sh.
	# s390x: skip tests that fail on musl/s390x (LD_PRELOAD/exec + TCP race).
	local skip=
	case "$CARCH" in
		s390x) skip="$(cat <<'EOF'
--skip cases::config::source_directory_filter_config
--skip cases::intercept_posix::
EOF
)" ;;
	esac
	cargo test --frozen --release -- $skip
}

package() {
	DESTDIR="$pkgdir" PREFIX=/usr SRCDIR="$builddir/target/release" \
		"$builddir/scripts/install.sh"
	rm "$pkgdir/usr/share/doc/bear/COPYING"

	install -Dm644 "$builddir/COPYING" -t "$pkgdir/usr/share/licenses/$pkgname/"
}

sha512sums="
6931b877c32880e3198bccacd8b90aecacfa8ab992c55ae7dcb53ecbbd6247afe25e1e1b0eddb42ec50448844ae7e97ea4202785fb9e62d5d3441ff6fe44165b  bear-4.1.3.tar.gz
d68e4bde18941bf361d6cc877186ef271c0f5356ec3b21dc3c05e976f1bdd0c6a17960362faaa8de4e543ee398035f77927eccbace194af6b4e934e7df26841f  musl-execvpe-interception.patch
"
