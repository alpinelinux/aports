maintainer="DWwanghao <wanghao03@loongson.cn>"
pkgname=pdfcpu
pkgver=0.13.0
pkgrel=0
pkgdesc="PDF processor written in Go"
url="https://pdfcpu.io"
arch="all"
license="Apache-2.0"
makedepends="go"
options="!check net" # test suite fails, go
source="$pkgname-$pkgver.tar.gz::https://github.com/pdfcpu/pdfcpu/archive/v$pkgver.tar.gz"

build() {
	go build -o bin/pdfcpu ./cmd/...
}

check() {
	go test ./...
}

package() {
	install -Dvm755 bin/pdfcpu -t "$pkgdir"/usr/bin/
}

