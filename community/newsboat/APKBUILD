# Maintainer: Mike Crute <mike@crute.us>
pkgname=newsboat
pkgver=2.43
pkgrel=0
pkgdesc="RSS/Atom feed reader for text terminals"
url="https://newsboat.org/"
arch="all"
license="MIT"
replaces="newsbeuter"
provides="newsbeuter=$pkgver-r$pkgrel"
makedepends="asciidoctor
	cargo
	cargo-auditable
	curl-dev
	gettext-dev
	json-c-dev
	libxml2-dev
	ncurses-dev
	sqlite-dev
	stfl-dev
	"
subpackages="$pkgname-doc $pkgname-lang $pkgname-fish-completion"
source="
	https://newsboat.org/releases/$pkgver/newsboat-$pkgver.tar.xz
	auditable-frozen.patch
	fix-version-number.patch
	newsboat.desktop
	"
options="net" # cargo fetch

# secfixes:
#   2.30.1-r0:
#     - CVE-2020-26235

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	./config.sh
	echo "LDFLAGS+= -lintl" >> config.mk
	make
}

check() {
	make rust-test
}

package() {
	make DESTDIR="$pkgdir" prefix=/usr install
	install -Dm644 "$srcdir"/newsboat.desktop \
		"$pkgdir"/usr/share/applications/newsboat.desktop
}

