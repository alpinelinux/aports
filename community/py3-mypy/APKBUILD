# Contributor: Justin Berthault <justin.berthault@zaclys.net>
# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=py3-mypy
pkgver=1.19.1
pkgrel=1
pkgdesc="Optional static typing for Python (PEP484)"
url="https://mypy-lang.org/"
arch="noarch"
license="MIT"
depends="
	py3-librt
	py3-mypy-extensions
	py3-pathspec
	py3-typing-extensions
	"
makedepends="python3-dev py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-attrs py3-pytest py3-pytest-xdist py3-lxml py3-psutil py3-virtualenv"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/python/mypy/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/mypy-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages test-env
	test-env/bin/python3 -m installer .dist/mypy-*.whl
	# daemon test: race condition after kill, reports "busy" instead of "died"
	# mypyc run tests: compile C extensions per test, too slow on slow arches
	# (3h on riscv64), Py_SIZE assertions on 32-bit, timeouts on riscv64
	test-env/bin/python3 -m pytest \
		--deselect mypy/test/testdaemon.py::DaemonSuite::daemon.test::testDaemonStatusKillRestartRecheck \
		--ignore=mypyc/test/test_run.py
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/mypy-*.whl
}

sha512sums="
3d0d0a8ad1599e00ee22140a62470fd01eb78c9b2ba2db55d48e5422a6c643d216c88c0281cfd31cd8cddc9cd8d11e42c3f48b21602bdbcb0bd795fbef8362dc  py3-mypy-1.19.1.tar.gz
"
