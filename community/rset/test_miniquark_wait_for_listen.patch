Wait for miniquark to listen before running integration tests
--- a/tests/test_miniquark.rb
+++ b/tests/test_miniquark.rb
@@ -77,16 +77,29 @@
 port = socket.local_address.ip_port
 socket.close
 
-@pid = spawn('../miniquark', '-p', port.to_s, '-d', File.join(@systmp, 'www'),
+@pid = spawn('../miniquark', '-p', port.to_s, '-h', '127.0.0.1',
+             '-d', File.join(@systmp, 'www'),
              in: '/dev/null', out: '/dev/null',
              unsetenv_others: true)
-sleep 0.2
+
+deadline = Time.now + 5
+loop do
+  begin
+    TCPSocket.new('127.0.0.1', port).close
+    break
+  rescue Errno::ECONNREFUSED, Errno::ETIMEDOUT
+    raise 'miniquark did not start' if Time.now >= deadline
+
+    sleep 0.1
+  end
+end
