maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=hare-lsp
pkgver=0.2.1
pkgrel=0
pkgdesc="Language server for Hare"
url="https://sr.ht/~whynothugo/hare-lsp/"
arch="x86_64 aarch64 riscv64" # Hare
license="ISC"
makedepends="hare hare-json"
source="hare-lsp-$pkgver.tar.gz::https://git.sr.ht/~whynothugo/hare-lsp/archive/v$pkgver.tar.gz"
builddir="$srcdir/hare-lsp-v$pkgver/"

build() {
	make PREFIX=/usr build HAREFLAGS="-a ${CHOST%%-*}"
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
	install -Dm644 LICENCE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

