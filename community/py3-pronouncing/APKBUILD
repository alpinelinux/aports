a46ba28cfb7357ab5ed946a735d7bd693e74953c5b61c3ff664597d9a244038f5bdda885e8899c9da5b2bb9a066ef0a00b1598dafbb50a3cc2d09d54fdf769a3  setuptools-82.patch
"
