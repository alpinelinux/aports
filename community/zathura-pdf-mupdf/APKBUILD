maintainer="omni <omni+alpine@hack.org>"
pkgname=zathura-pdf-mupdf
pkgver=2026.07.18
pkgrel=0
pkgdesc="mupdf plugin to zathura"
url="https://pwmt.org/projects/zathura-pdf-mupdf/"
arch="all"
license="Zlib"
options="!check" # no test suite
depends="zathura !zathura-pdf-poppler"
makedepends="
	meson
	mupdf-dev
	ninja
	zathura-dev
	"
source="https://pwmt.org/projects/zathura-pdf-mupdf/download/zathura-pdf-mupdf-$pkgver.tar.xz"

build() {
	abuild-meson build
	meson compile -C build
	# TODO: build with muon, find out why it will build this differently
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C build
}

