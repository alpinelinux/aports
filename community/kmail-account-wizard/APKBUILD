8179f01b17c8dad744b8e5128a3f0645cae09f3346071c3f499ed21f420e24ce8ac957e887eae0dde1b8e677f939647d50fd19b180f14ee6f0cec5a7dc09dcb8  0001-kmail-account-wizard-KMime-from-KF6.patch
