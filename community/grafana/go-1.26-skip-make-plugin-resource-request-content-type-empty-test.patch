Test is broken since go 1.26:

> failed to write resource response: http: request method or response status
> code does not allow body

The test sets the response code to StatusNoContent, which does not allow a
body, and httptest explicitly rejects it now.

Context explicitly includes the entire test body, so if anything changes in
this test, the patch will fail to apply.

https://github.com/golang/go/issues/75471
diff --git a/pkg/api/plugins_test.go b/pkg/api/plugins_test.go
index 4409395e..1a161fb1 100644
--- a/pkg/api/plugins_test.go
+++ b/pkg/api/plugins_test.go
@@ -406,23 +406,24 @@ func TestMakePluginResourceRequestContentTypeUnique(t *testing.T) {
 		})
 	}
 }
 
 func TestMakePluginResourceRequestContentTypeEmpty(t *testing.T) {
+	t.Skip("Broken since go1.26")
 	pluginClient := &fakePluginClient{
 		statusCode: http.StatusNoContent,
 	}
 	hs := HTTPServer{
 		Cfg:          setting.NewCfg(),
 		log:          log.New(),
 		pluginClient: pluginClient,
 	}
 	req := httptest.NewRequest(http.MethodGet, "/", nil)
 	resp := httptest.NewRecorder()
 	pCtx := backend.PluginContext{}
 	err := hs.makePluginResourceRequest(resp, req, pCtx)
 	require.NoError(t, err)
 
 	require.True(t, resp.Flushed, "response should be flushed after request is processed")
 	require.Zero(t, resp.Header().Get("Content-Type"))
 }
 
