# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=xfdashboard
pkgver=1.1.0
pkgrel=0
pkgdesc="Maybe a Gnome shell like dashboard for Xfce"
url="https://goodies.xfce.org/projects/applications/xfdashboard/start"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	clutter-dev
	xfconf-dev
	garcon-dev
	gtk+3.0-dev
	libwnck3-dev
	meson
	"
subpackages="$pkgname-dev $pkgname-lang"
source="https://archive.xfce.org/src/apps/xfdashboard/${pkgver%.*}/xfdashboard-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
83e0e552633e21f75b279c3ef3bee815dc15073ade8d90a0a4fe5971c064b93d2a4163078daa1a54df5806bd6fa83d3b8ab53335c7c818e2c158f8b93bf2e7ee  xfdashboard-1.1.0.tar.xz
"
