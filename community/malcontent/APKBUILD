# Contributor: Angelo Verlain <hey@vixalien.com>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=malcontent
pkgver=0.14.0
_tinycdb=0.81
pkgrel=0
pkgdesc="Parental control support for applications"
url="https://gitlab.freedesktop.org/pwithnall/malcontent"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	accountsservice-dev
	dbus-dev
	desktop-file-utils
	flatpak-dev
	gi-docgen
	gnome-desktop-dev
	gobject-introspection-dev
	gtk4.0-dev
	itstool
	libadwaita-dev
	libglib-testing-dev
	libgsystemservice-dev
	libsoup3-dev
	linux-pam-dev
	meson
	musl-nscd-dev
	polkit-dev
"
checkdepends="
	dbus
	gtk4.0-demo
"
subpackages="
	$pkgname-dev
	$pkgname-doc
	$pkgname-lang
	$pkgname-libs
	$pkgname-systemd
	"
source="https://tecnocode.co.uk/downloads/malcontent/malcontent-$pkgver.tar.xz
	https://www.corpit.ru/mjt/tinycdb/tinycdb-$_tinycdb.tar.gz
	systemd-dirs.patch
	no-nss-tests.patch
	"
options="!check" # systemd

build() {
	# tinycdb subproject
	export MESON_PACKAGE_CACHE_DIR="$srcdir"

	abuild-meson . output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

