0bff266b7775cbdde301414f7186395fa8ae3daef619e8e6c964cd0f5fd7a225d4661d00c4f0cd6a60588295bb42f6a289cec398fbc832a2dfd29931adcc5a60  sequoia-openpgp-2.3.0.patch
"
