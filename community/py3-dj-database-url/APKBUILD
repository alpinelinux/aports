# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=py3-dj-database-url
pkgver=3.1.2
pkgrel=0
pkgdesc="Use Database URLs in your Django Application"
url="https://pypi.org/project/dj-database-url/"
arch="noarch"
license="BSD-3-Clause"
depends="py3-django"
makedepends="
	py3-gpep517
	py3-uv-build
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://github.com/jazzband/dj-database-url/archive/v$pkgver/py3-dj-database-url-$pkgver.tar.gz"
builddir="$srcdir/dj-database-url-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
97711ea2c4a4280904586840277266db5cae1fb81c07090d2492261f99de61e654e366f191d1b4578881bb9e20ffd72d4aa5a986d8aa3849236c76b767f67006  py3-dj-database-url-3.1.2.tar.gz
"
