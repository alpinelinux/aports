# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=sdb
pkgver=2.4.6
pkgrel=0
pkgdesc="Key-value database with support for arrays and json"
url="https://github.com/radareorg/sdb"
arch="all"
license="MIT"
checkdepends="bash"
subpackages="$pkgname-static $pkgname-dev $pkgname-doc $pkgname-libs"
source="https://github.com/radareorg/sdb/archive/refs/tags/$pkgver/sdb-$pkgver.tar.gz
	missing-headers.patch
	"

build() {
	make
}

check() {
	make test
}

package() {
	make DESTDIR="$pkgdir" install
	rmdir -v "$pkgdir"/usr/share/vala/vapi "$pkgdir"/usr/share/vala

	install -Dvm644 doc/*.md -t "$pkgdir"/usr/share/doc/$pkgname/
	install -Dvm644 COPYING -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
