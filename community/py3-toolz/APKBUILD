# Contributor: Bart Ribbers <bribbers@disroot.org>
# Maintainer: Bart Ribbers <bribbers@disroot.org>
pkgname=py3-toolz
pkgver=1.1.0
pkgrel=0
pkgdesc="functional standard library for Python"
url="https://toolz.readthedocs.io/en/latest/"
arch="noarch"
license="BSD-3-Clause"
depends="python3"
makedepends="py3-setuptools py3-setuptools_scm py3-wheel py3-gpep517"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="
	https://pypi.python.org/packages/source/t/toolz/toolz-$pkgver.tar.gz
	ignore-asyncio-iscoroutinefunction-deprecation.patch
	use-setuptools-scm-for-version.patch
	"
builddir="$srcdir/toolz-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}
check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

