# Contributor: Bart Ribbers <bribbers@disroot.org>
# Maintainer: David Demelier <markand@malikania.fr>
pkgname=retroarch
# If you plan to upgrade RetroArch, you also need to upgrade the following
# packages at the same time:
# - libretro-database
# - libretro-core-info
# - retroarch-assets
# - retroarch-joypad-autoconfig
pkgver=1.22.2
pkgrel=0
arch="all"
url="https://retroarch.com"
pkgdesc="Reference frontend for the libretro API"
license="GPL-2.0-only"
depends="retroarch-assets retroarch-joypad-autoconfig libretro-core-info libretro-database"
makedepends="linux-headers mesa-dev qt6-qtbase-dev wayland-dev wayland-protocols
	zlib-dev alsa-lib-dev pulseaudio-dev sdl2-dev mbedtls-dev libusb-dev openssl-dev>3
	ffmpeg-dev libxkbcommon-dev eudev-dev vulkan-loader-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/libretro/retroarch/archive/v$pkgver.tar.gz
	config.patch
	"
subpackages="$pkgname-doc"
builddir="$srcdir/RetroArch-$pkgver"
options="!check" # No tests

build() {
	CFLAGS="$CFLAGS -I/usr/include/directfb"

	# Switched to the bundled FLAC in 1.22.2 because of:
	# https://github.com/libretro/RetroArch/issues/18370#issuecomment-3520301464
	./configure \
		--prefix=/usr \
		--disable-builtinmbedtls \
		--disable-builtinzlib \
		--disable-discord \
		--disable-vg \
		--disable-videocore \
		--enable-bluetooth \
		--enable-builtinflac \
		--enable-dynamic \
		--enable-egl \
		--enable-kms \
		--enable-wifi
	make
}

package() {
	DESTDIR="$pkgdir" make install
}

