# Maintainer: mio <miyopan@e.email>
maintainer="mio <miyopan@e.email>"
pkgname=libgedit-gfls
pkgver=0.4.1
pkgrel=0
pkgdesc="Gedit Technology — file loading and saving"
url="https://gitlab.gnome.org/World/gedit/libgedit-gfls"
arch="all"
license="LGPL-3.0-or-later"
makedepends="
	docbook-xsl-nons
	glib-dev
	gobject-introspection-dev
	gtk-doc
	gtk+3.0-dev
	meson
	"
subpackages="$pkgname-dev $pkgname-doc"
source="https://gitlab.gnome.org/World/gedit/libgedit-gfls/-/archive/$pkgver/libgedit-gfls-$pkgver.tar.gz"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dgobject_introspection=true \
		-Dgtk_doc=true \
		. output
	meson compile -C output
}

check() {
	# From 0.4.0, as of 0.4.1
	# test-encoding-convert: assertion failed: (65536 == 65538)
	# test-iconv: 'ok' should be TRUE
	local tests="$(meson test --list -C output)"
	tests=${tests//libgedit-gfls:test-encoding-convert}
	tests=${tests//libgedit-gfls:test-iconv}
	meson test -v -C output $tests
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
1b4bb3a95c13355aa98463120b4e11d76fe8f8da25b3282ba73a545868c48c04eb2ddceac25e9ba85510c43a3a783decd8817097b1db2f4e9e06967b9537e272  libgedit-gfls-0.4.1.tar.gz
"
