# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=darkice
pkgver=1.6
pkgrel=0
pkgdesc="Live audio streamer. Records audio from an audio interface, encodes it and sends it to a streaming server"
url="http://www.darkice.org/"
arch="all"
license="GPL-3.0-or-later"
makedepends="alsa-lib-dev faac-dev lame-dev libvorbis-dev automake autoconf libtool m4"
subpackages="$pkgname-doc $pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/rafael2k/darkice/archive/refs/tags/v$pkgver.tar.gz
	darkice.initd
	darkice.confd
	fix-stdint-include.patch"

builddir="$srcdir/$pkgname-$pkgver/darkice/trunk"

prepare() {
	default_prepare
	sh autogen.sh
}

build() {
	export CXXFLAGS="$CXXFLAGS -Wno-overloaded-virtual"
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc/darkice \
		--without-aacplus \
		--without-twolame
	make
}
package() {
	mkdir -p "$pkgdir"/etc/$pkgname
	make DESTDIR="$pkgdir" install
	install -m755 -D "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -m644 -D "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

