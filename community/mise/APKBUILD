# Contributor: Jeff Dickey <alpine@mise.jdx.dev>
# Contributor: Fabricio Silva <hi@fabricio.dev>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=mise
pkgver=2026.7.0
pkgrel=0
pkgdesc="Polyglot runtime and dev tool version manager"
url="https://mise.jdx.dev/"
arch="all !s390x" # nix 0.30.1: https://github.com/nix-rust/nix/issues/2641
license="MIT"
makedepends="
	cargo
	cargo-auditable
	clang-libclang
	cmake
	direnv
	openssl-dev
	lua5.1-dev
	bzip2-dev
	samurai
	zstd-dev
	"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/jdx/mise/archive/refs/tags/v$pkgver.tar.gz"
options="net !check" # cargo fetch; tests are OOM some builders
provides="rtx=$pkgver-r$pkgrel" # backwards compatibility
replaces="rtx"

prepare() {
	default_prepare

	# Rust target triple
	local target=$(rustc -vV | sed -n 's/host: //p')

	# build against system-provided libs
	mkdir -p .cargo
	cat >> .cargo/config.toml <<-EOF
		[target.$target]
		bzip2 = { rustc-link-lib = ["bz2"] }
		zstd = { rustc-link-lib = ["zstd"] }
	EOF

	cargo fetch --target="$CTARGET" --locked
}

build() {
	export CARGO_BUILD_JOBS=2
	export CARGO_PROFILE_RELEASE_LTO="false"
	export CARGO_PROFILE_RELEASE_CODEGEN_UNITS=16
	cargo auditable build --release --frozen --no-default-features --features native-tls
}

check() {
	cargo test --frozen --no-default-features --features native-tls
}

package() {
	install -Dm755 target/release/mise -t "$pkgdir"/usr/bin/
	install -Dm644 man/man1/*.1 -t "$pkgdir"/usr/share/man/man1/
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
8491c85f9f6cd7302a306ac720a42219ff8fb71329feecaa16a7315ddfda4cf1ac3b55334718329ae5b91c7ab67939a88fffdbe2ec91e96d432385f90e511b75  mise-2026.7.0.tar.gz
"
