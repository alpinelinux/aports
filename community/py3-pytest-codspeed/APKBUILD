# Contributor: Oleg Titov <oleg.titov@gmail.com>
# Maintainer: Oleg Titov <oleg.titov@gmail.com>
pkgname=py3-pytest-codspeed
pkgver=4.5.0
pkgrel=0
pkgdesc="Pytest plugin to create CodSpeed benchmarks"
url="https://codspeed.io/"
arch="noarch"
license="MIT"
depends="
	py3-cffi
	py3-pytest
	py3-rich
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
subpackages="$pkgname-doc $pkgname-pyc"
source="py3-pytest-codspeed-$pkgver.tar.gz::https://files.pythonhosted.org/packages/source/p/pytest-codspeed/pytest_codspeed-$pkgver.tar.gz"
builddir="$srcdir/pytest_codspeed-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl

	# disable following tests due to missing
	# tests/conftest.py in tarball
	.testenv/bin/python3 -m pytest \
		--ignore=tests/test_pytest_plugin.py \
		--ignore=tests/test_pytest_plugin_cpu_instrumentation.py \
		--ignore=tests/test_pytest_plugin_walltime.py
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	install -Dm644 README.md -t "$pkgdir"/usr/share/doc/$pkgname
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname
}

sha512sums="
e0c1110e16609b0e3db1ceafdf8cc24a9f4278f152f671e1543e353e60eb9c3419457675ef67051623a7aa624ad1af893c48be5b35e88e7a0951f324f456a932  py3-pytest-codspeed-4.5.0.tar.gz
"
