Date: Mon, 6 Mar 2023 12:34:31 +0200
Subject: [PATCH] Get rid of deprecated cgi module. Uses email module as
 suggested in docs:
 https://docs.python.org/3/library/cgi.html#cgi.parse_header Fixes #1352
Patch-Source: https://github.com/mvantellingen/python-zeep/commit/d0d737adbcd68213b940a5cc4f1da6cd43dfca81

---
 src/zeep/utils.py | 9 ++++++---
 1 file changed, 6 insertions(+), 3 deletions(-)

diff --git a/src/zeep/utils.py b/src/zeep/utils.py
index 2118253..e08cdcd 100644
--- a/src/zeep/utils.py
+++ b/src/zeep/utils.py
@@ -1,4 +1,4 @@
-import cgi
+from email.message import Message
 import inspect
 import typing
 
@@ -90,5 +90,8 @@ def detect_soap_env(envelope):
 
 def get_media_type(value):
     """Parse a HTTP content-type header and return the media-type"""
-    main_value, parameters = cgi.parse_header(value)
-    return main_value.lower()
+    msg = Message()
+    msg['content-type'] = value
+    
+    return msg.get_content_type()
+
