maintainer="leso-kn <info@lesosoftware.com>"
pkgname=onnxruntime
pkgver=1.27.0
pkgrel=0
pkgdesc="Cross-platform, high performance ML inferencing and training accelerator"
url="https://onnxruntime.ai/"
# s390x, x86: build fails
arch="all !s390x !x86"
license="MIT"
makedepends="
	abseil-cpp-dev
	bash
	cmake
	gtest-dev
	icu-dev
	linux-headers
	nlohmann-json
	protobuf-dev
	py3-numpy-dev
	py3-protobuf
	py3-pybind11-dev
	py3-setuptools
	py3-wheel
	python3-dev
	re2-dev
	samurai
	zlib-dev
	"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/microsoft/onnxruntime/archive/refs/tags/v$pkgver.tar.gz
	flatbuffers-locale.patch.noauto
	system.patch
	0001-Remove-MATH_NO_EXCEPT-macro.patch
	upb-fix.patch
	gcc-15.patch
	26187_disable-hascpudevice-test.patch.noauto
	"
options="net"

case "$CARCH" in
armhf) ;; # blocked by py3-flattbuffers
*)
	subpackages="
		$subpackages
		py3-$pkgname-pyc
		py3-$pkgname:py3
		"
	;;
esac

# tests fail on arm 32 bit, see https://github.com/microsoft/onnxruntime/issues/16387
case "$CARCH" in
armhf|armv7) options="!check $options"; _extra_cxxflags="-Wno-overflow";;
esac

# still affects aarch64: https://github.com/microsoft/onnxruntime/pull/19382#issuecomment-3346660511
case "$CARCH" in
aarch64) _extra_cmake_flags="-Donnxruntime_USE_NEURAL_SPEED=OFF";;
esac

# MatMulNBits.Float32_4b_Accuracy* tests fail on loongarch64 due to not meeting precision threshold
case "$CARCH" in
loongarch64) options="!check";;
esac

prepare() {
	default_prepare

	# https://github.com/microsoft/onnxruntime/issues/26187
	case "$CARCH" in
	aarch64|loongarch64|ppc64le|riscv64) patch -p1 < "$srcdir"/26187_disable-hascpudevice-test.patch.noauto;;
	esac
}

build() {
	# to build with backtrace support see https://gitlab.alpinelinux.org/alpine/aports/-/merge_requests/104971#note_629141
	CFLAGS="$CFLAGS -O2 -flto=auto" \
	CXXFLAGS="$CXXFLAGS $_extra_cxxflags -O2 -Wno-deprecated-declarations -Wno-error=template-id-cdtor -flto=auto -U_FORTIFY_SOURCE" \
	LDFLAGS="$LDFLAGS -Wl,--copy-dt-needed-entries" \
	cmake -S cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
		-DBUILD_ONNX_PYTHON=ON \
		-Donnxruntime_BUILD_SHARED_LIB=ON \
		-Donnxruntime_BUILD_UNIT_TESTS="$(want_check && echo ON || echo OFF)" \
		-Donnxruntime_ENABLE_PYTHON=ON \
		$_extra_cmake_flags

	# from testing/flutter/shared-libcxx.patch.engine
	patch -p1 < ../flatbuffers-locale.patch.noauto

	cmake --build build

	cd build
	msg "building python module"
	python3 ../setup.py build
}

check() {
	# musl does not guarantee that dlclose unmaps DSOs, so RTLD_NOLOAD
	# cannot validate this refcount regression test.
	GTEST_FILTER="-OrtEpLibrary.RegisterUnregisterDoesNotLeakLibraryHandle" \
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	cd build
	python3 ../setup.py install --skip-build --root="$pkgdir"

	cd "$pkgdir"/usr/lib/python3*/site-packages/onnxruntime/capi
	ln -sfv ../../../../libonnxruntime_providers_shared.so ../../../../libonnxruntime.so.* .
}

py3() {
	pkgdesc="$pkgname (python3 bindings)"
	depends="
		py3-coloredlogs
		py3-flatbuffers
		py3-numpy
		py3-packaging
		py3-sympy
		"

	amove usr/lib/python3*
}

