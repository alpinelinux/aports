# Maintainer: Lindsay Zhou <i@lin.moe>
maintainer="Lindsay Zhou <i@lin.moe>"
pkgname=yoga
pkgver=3.2.1
pkgrel=0
pkgdesc="Embeddable layout engine targeting web standards"
url="https://github.com/facebook/yoga"
arch="all"
license="MIT"
makedepends="cmake samurai"
subpackages="$pkgname-dev $pkgname-doc"
_gtestver=1.12.1 # test/CMakeLists.txt
source="$pkgname-$pkgver.tar.gz::https://github.com/facebook/yoga/archive/v$pkgver/yoga-v$pkgver.tar.gz
	gtest-$_gtestver.tar.gz::https://github.com/google/googletest/archive/release-$_gtestver.tar.gz"

build() {
	if [ "$CBUILD" != "$CHOST" ]; then
		local crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	fi
	gtest_opts="
		-DDOWNLOAD_GTEST=ON
		-DFETCHCONTENT_FULLY_DISCONNECTED=ON
		-DFETCHCONTENT_SOURCE_DIR_GOOGLETEST=$srcdir/googletest-release-$_gtestver
	"

	echo $gtest_opts
	cmake -G Ninja -B build \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_FUZZ_TESTS=OFF \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=None \
		$crossopts $gtest_opts
	cmake --build build
}

check() {
	cd build
	./tests/yogatests
}

package() {
	DESTDIR="$pkgdir" cmake --install build
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

