maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=distribution-gpg-keys
pkgver=1.119
pkgrel=0
pkgdesc="GPG keys used by various Linux distributions to sign packages"
url="https://github.com/rpm-software-management/distribution-gpg-keys"
arch="noarch"
license="CC0-1.0"
source="https://github.com/rpm-software-management/distribution-gpg-keys/archive/distribution-gpg-keys-$pkgver-1.tar.gz"
builddir="$srcdir/$pkgname-$pkgname-$pkgver-1"
options="!check" # no tests

package() {
	rm -r keys/copr # ~400M
	mkdir -p "$pkgdir"/usr/share/distribution-gpg-keys/
	cp -r keys/* "$pkgdir"/usr/share/distribution-gpg-keys/
}

sha512sums="
