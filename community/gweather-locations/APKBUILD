maintainer="team/gnome <newbyte@postmarketos.org>"
pkgname=gweather-locations
pkgver=2026.2
pkgrel=0
pkgdesc="GWeather locations database"
url="https://gitlab.gnome.org/GNOME/gweather-locations"
arch="noarch"
license="GPL-2.0-or-later"
makedepends="
	gettext
	meson
	py3-gobject3
	python3
	"
subpackages="$pkgname-dev $pkgname-lang"
source="https://download.gnome.org/sources/gweather-locations/${pkgver%.*}/gweather-locations-$pkgver.tar.xz"
builddir="$srcdir/gweather-locations-$pkgver"
options="!check" # No tests

build() {
	abuild-meson . output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
