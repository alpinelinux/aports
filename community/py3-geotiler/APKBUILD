820008a323b5e24d936be476b58e9890874440489352f95c0acb9ff670c564f09cb335dbf3225a5cc0d9bfbbdb911382ecd2936e999b007614624e39289baee7  replace-pkg-resources.patch
e3d57eb76f7ffaf79f61dd7624cc6c6f60d885a4ae97d97f0667caecd55cade58a89be2724ab13f757a8de5eb07d9658198d48b8d17f4d467643d5642002d7a6  python-3.14.patch
"
