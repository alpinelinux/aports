maintainer="Craig Comstock <craig@unreasonablefarm.org>"
pkgname=shelli
pkgver=0.9
pkgrel=0
pkgdesc="A shell environment (scripts/config/etc) to make a unix system more usable day-to-day with simple commands"
url="https://git.sr.ht/~unrznbl/shelli"
arch="all"
license="GPL-3.0-only"
makedepends="linux-headers"
depends="
	alsa-utils
	bash
	espeak
	kbd
	kbd-misc
	ofono
	py3-gobject3
	python3
	"
subpackages="$pkgname-openrc $pkgname-opinionated"
source="$pkgname-v$pkgver.tar.gz::https://git.sr.ht/~unrznbl/shelli/archive/v$pkgver.tar.gz"
options="!check" # No tests
builddir="$srcdir/shelli-v$pkgver"

build() {
	make all
}

package() {
	make DESTDIR="$pkgdir" install
}

opinionated() {
	pkgdesc="Install potentially conflicting generic shelli commands like call, off, etc as symlinks in /usr/bin to /usr/share/shelli/bin/shelli- commands"
	mkdir -p "$subpkgdir"/usr/bin
	mkdir -p "$subpkgdir/usr/share/shelli/bin"
	cp "$pkgdir"/usr/share/shelli/bin/* "$subpkgdir/usr/share/shelli/bin/"
	cd "$subpkgdir/usr/bin"
	for relpath in ../share/shelli/bin/*; do
	  name=$(echo $relpath | sed 's,\.\./share/shelli/bin/shelli-,,')
	  ln -sf ../share/shelli/bin/shelli-$name $name
	done
	rm -rf "$subpkgdir/usr/share/shelli/bin"
}

sha512sums="
53f05489d41b223df46d5d7a59cf236ec7deebc4d400d41cd4382a6af316bacfc50fa4c6d48d2bd0e5bf04f323e1bab02d7e1eadb5775082d562e292466fd032  shelli-v0.9.tar.gz
"
