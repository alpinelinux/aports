# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-plasma
maintainer="team/kde <bribbers@disroot.org>"
pkgname=kdeplasma-addons
pkgver=6.7.3
pkgrel=0
pkgdesc="All kind of addons to improve your Plasma experience"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
url="https://kde.org/plasma-desktop/"
license="LGPL-2.0-only AND GPL-2.0-or-later"
depends="purpose"
depends_dev="
	icu-dev
	karchive-dev
	kcmutils-dev
	kconfig-dev
	kcoreaddons-dev
	kdeclarative-dev
	kholidays-dev
	ki18n-dev
	kiconthemes-dev
	kio-dev
	knewstuff-dev
	knotifications-dev
	krunner-dev
	kservice-dev
	kunitconversion-dev
	kwindowsystem-dev
	networkmanager-qt-dev
	libplasma-dev
	plasma5support-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	sonnet-dev
	"
case "$CARCH" in
	x86_64|aarch64|ppc64le)
		depends_dev="$depends_dev qt6-qtwebengine-dev"
		;;
esac
makedepends="$depends_dev
	corrosion
	extra-cmake-modules
	qt6-qtdeclarative-private-dev
	samurai
	"
checkdepends="xwayland-run"
subpackages="$pkgname-dev $pkgname-lang"

case "$pkgver" in
	*.*.9*) _rel=unstable ;;
	*) _rel=stable ;;
esac
_repo_url="https://invent.kde.org/plasma/kdeplasma-addons.git"
source="https://download.kde.org/$_rel/plasma/$pkgver/kdeplasma-addons-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

check() {
	# converterrunnertest is broken
	# datetimerunnertest requires running Wayland session
	wlheadless-run -- ctest --test-dir build -E "(converterrunner|datetimerunner|kcm_(krunner_charrunner|cube|runner_spellcheck|krunner_dictionary)_smoke)test"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
5a495eda995d1fad1cb4e955d36ac5601f15b2de4216e973fe7b0adaa99030e5882110f25b7321ad75aaba3c018711f9db63d82d24083b5036e2438568d8c51b  kdeplasma-addons-6.7.3.tar.xz
"
