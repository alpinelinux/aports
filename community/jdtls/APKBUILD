1dc52d2e4a6e2b5dad175555905a1de6a70ad01a5ceb8dcd34f2edf5301934789da0991710244cbe8b8b3344f3f86731322afffb15456a94c14f04477239ec8f  update-p2-site-for-jdt-javac.patch
"
