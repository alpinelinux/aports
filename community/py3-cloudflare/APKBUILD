# Contributor: lauren n. liberda <lauren@selfisekai.rocks>
# Maintainer: lauren n. liberda <lauren@selfisekai.rocks>
pkgname=py3-cloudflare
pkgver=5.1.0
pkgrel=0
pkgdesc="Python wrapper for the Cloudflare Client API v4"
url="https://github.com/cloudflare/cloudflare-python"
arch="noarch"
license="Apache-2.0"
depends="
	py3-anyio
	py3-distro
	py3-httpx
	py3-pydantic
	py3-sniffio
	"
makedepends="
	py3-gpep517
	py3-hatch-fancy-pypi-readme
	py3-hatchling
	py3-wheel
	"
checkdepends="
	py3-dirty-equals
	py3-pytest
	py3-pytest-asyncio
	py3-pytest-xdist
	py3-respx
	"
subpackages="$pkgname-pyc"
source="
	https://github.com/cloudflare/cloudflare-python/archive/refs/tags/v$pkgver/python-cloudflare-v$pkgver.tar.gz

	no-examples.patch
	"
builddir="$srcdir/cloudflare-python-$pkgver"

build() {
	rm -rf examples

	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# tests/api_resources/ require mock server running
	.testenv/bin/python3 -m pytest -k 'not api_resources'
}

package() {
	python3 -m installer \
		-d "$pkgdir" .dist/*.whl
}

sha512sums="
10ca9735b79d65c927fa61a0d66094e5e4020487def1e70a16676337d76e357ae84bc6abf0e274197f008818add3a026234e28492783ddd3ff9090cf2b7ee74a  python-cloudflare-v5.1.0.tar.gz
3a18ea7e4ccbe324f1125e2593a2eafb24e77877e3cf6f75ab0a2a89484e9471cd332f38b11360069921662a6b87ece1286e00192e500192578d9a4e17d2c806  no-examples.patch
"
