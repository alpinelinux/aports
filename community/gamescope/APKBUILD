_wlroots=54e844748029d4874e14d0c086d50092c04c8899
pkgdesc="SteamOS session compositing window manager"
url="https://github.com/ValveSoftware/gamescope"
# riscv64: luajit -> does not build
arch="all !riscv64"
license="BSD-2-Clause"
makedepends="
