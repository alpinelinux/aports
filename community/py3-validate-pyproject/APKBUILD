# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=py3-validate-pyproject
pkgver=0.25
pkgrel=0
pkgdesc="Validation library for simple check on pyproject.toml"
url="https://validate-pyproject.readthedocs.io"
arch="noarch"
license="MPL-2.0"
depends="
	py3-fastjsonschema
	python3
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="py3-pytest-xdist"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/abravalheri/validate-pyproject/archive/refs/tags/v$pkgver.tar.gz
	no-useless-check.patch
	"
builddir="$srcdir/validate-pyproject-$pkgver"
options="net" # tests require network

build() {
	gpep517 build-wheel	\
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	local _skip="not test_downloaded"
	_skip="$_skip and not test_private_classifier"
	_skip="$_skip and not test_invalid_examples_api"
	_skip="$_skip and not test_examples_api[store/example.toml-cli_pre_compile]"
	_skip="$_skip and not test_examples_api[store/example.toml-api_pre_compile]"

	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -n auto \
		--ignore tests/test_examples.py \
		-k "$_skip"
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
c5de9f7f11ff3dc56f832d0f4989a99f485b82ee59b0dd9d9f0174bce3bd239004c4484173f76846aca066f6e018265c58a5919a6fe29103d98d5007a8c9668a  py3-validate-pyproject-0.25.tar.gz
1c538f93301c30cd5a62011692fb33e6638f4167ab3365f0dbb0f6857f75baf2131b959db2ff55c2ef81d8c1df38566220cd8e029b4fb61441f27005e4cd6798  no-useless-check.patch
"
