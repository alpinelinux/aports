From cb501f2ac92f29b035793cf46dac865a66e1e174 Mon Sep 17 00:00:00 2001
From: Natanael Copa <ncopa@alpinelinux.org>
Date: Tue, 28 Nov 2023 14:22:46 +0100
Subject: [PATCH 4/7] objtool: respect AWK setting

AWK= is not passed on as an makefile argument so we need pass it as an env.

Signed-off-by: Achill Gilgenast <achill@achill.org>
---
 tools/objtool/Makefile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/tools/objtool/Makefile b/tools/objtool/Makefile
index b71d1886022e..4e0721abf358 100644
--- a/tools/objtool/Makefile
+++ b/tools/objtool/Makefile
@@ -112,7 +112,7 @@ endif
 
 export BUILD_DISAS
 
-AWK = awk
+AWK ?= awk
 MKDIR = mkdir
 
 export srctree OUTPUT CFLAGS SRCARCH AWK
-- 
2.55.0

