# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-notifications
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Notification daemon for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-notifications"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !x86"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	just
	libxkbcommon-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-notifications/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
db007494ec53d3d46c5de99b1cd8f10e02b528a107a982ca91aac3c0ab6b04c7890056479d64d56f71f8d7a89657acc7c26c52016b911493e289e769e0e9514a  cosmic-notifications-1.4.0.tar.gz
"
