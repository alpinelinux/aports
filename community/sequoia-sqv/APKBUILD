799504d39ee251da48b1074f825fa64039b8fe8c2400a1ad331050a1a46ec4ae3ba86eefa314ffd13ba1bd85a65e8529456df358bd1d339ef5ef82544ac99b28  sequoia-openpgp-2.3.0.patch
"
