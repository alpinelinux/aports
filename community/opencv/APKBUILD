maintainer="Lindsay Zhou <i@lin.moe>"
pkgname=opencv
pkgver=4.13.0
pkgrel=0
pkgdesc="Open source computer vision and machine learning library"
url="https://opencv.org/"
# s390x blocked by vtk -> netcdf
arch="all !s390x"
license="Apache-2.0"
depends_dev="
