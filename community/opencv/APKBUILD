	qt6-qtbase-dev
	vtk-dev
	"
makedepends="
	$depends_dev
	clang
	cmake
	lld
	samurai
	python3-dev
	py3-gpep517
	py3-numpy-dev
	py3-setuptools
	py3-wheel
	"
subpackages="
