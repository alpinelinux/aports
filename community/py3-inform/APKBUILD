# Contributor: Andy Hawkins <andy@gently.org.uk>
# Maintainer: Andy Hawkins <andy@gently.org.uk>
pkgname=py3-inform
pkgver=1.37
pkgrel=0
pkgdesc="Print & Logging Utilities"
url="https://inform.readthedocs.io/"
arch="noarch"
license="GPL-3.0-or-later"
depends="
	python3
	py3-arrow
	py3-six
	"
makedepends="
	py3-flit-core>=2
	py3-gpep517
	"
checkdepends="
	py3-pytest
	py3-pytest-cov
	py3-hypothesis
	py3-num2words
	"
subpackages="$pkgname-pyc"
source="https://github.com/KenKundert/inform/archive/v$pkgver/inform-v$pkgver.tar.gz"
builddir="$srcdir/inform-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	PYTHONPATH="$PWD/build/lib" pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/inform-$pkgver*-py3-none-any.whl
}

sha512sums="
3e00b237c1309b62c78cbcaf336c40a9baee3e6a915e001d9c3d1e6df25dfe0bb7ba3d44781a9c6ed2c86452a2223772b6016c647599baa2520b878baeb6ade3  inform-v1.37.tar.gz
"
