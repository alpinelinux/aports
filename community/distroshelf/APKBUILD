# Contributor: knuxify <knuxify@gmail.com>
# Maintainer: knuxify <knuxify@gmail.com>
pkgname=distroshelf
pkgver=1.4.7
pkgrel=0
pkgdesc="GUI for managing Distrobox containers"
url="https://github.com/ranfdev/DistroShelf"
arch="all"
license="GPL-3.0-or-later"
depends="distrobox which"
makedepends="
	cargo
	desktop-file-utils
	glib-dev
	gtk4.0-dev
	libadwaita-dev
	meson
	vte3-dev
	"
checkdepends="appstream-glib"
subpackages="$pkgname-lang"
source="https://github.com/ranfdev/DistroShelf/releases/download/v$pkgver/distroshelf-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
24907c2b804011754f71a0323a2065a6e8cb91cbe7f098fdd1df3c3188de5bca2c042de24bcda1367da50fd6676143a6d04202687ce581119f76a0b14b4a6af9  distroshelf-1.4.7.tar.xz
"
