# Contributor: Michał Polański <michal@polanski.me>
# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=libqb
pkgver=2.0.10
pkgrel=0
pkgdesc="Library providing high performance logging, tracing, ipc, and poll"
url="https://clusterlabs.github.io/libqb"
license="LGPL-2.1-or-later"
arch="all"
makedepends="
	autoconf
	automake
	coreutils
	doxygen
	graphviz-dev
	libtool
	libxml2-dev
	"
checkdepends="check-dev"
subpackages="$pkgname-dev $pkgname-doc $pkgname-tools"
source="https://github.com/ClusterLabs/libqb/releases/download/v$pkgver/libqb-$pkgver.tar.gz"

case "$CARCH" in
	# tests fails in ci, passes in local builder and container
	loongarch64) options="!check";;
esac

prepare() {
	default_prepare
	./autogen.sh
}

check() {
	make -C tests VERBOSE=1 check
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--localstatedir=/var \
		--includedir=/usr/include \
		--disable-static
	make
}

package() {
	make install DESTDIR="$pkgdir"

	# remove a helper tool
	rm "$pkgdir"/usr/bin/doxygen2man
}

tools() {
	pkgdesc="Tools to use with $pkgname"

	amove usr/sbin
}

sha512sums="
c7e833c3bffbd40bd095c0866b870f7357d2960ff1a668bfd6251e46f6914db05c285574316518886ff7fe17c1a3dc990a023a538e521540782d84f011884543  libqb-2.0.10.tar.gz
"
