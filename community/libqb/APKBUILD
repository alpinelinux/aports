# Contributor: Michał Polański <michal@polanski.me>
# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=libqb
pkgver=2.0.9
pkgrel=0
pkgdesc="Library providing high performance logging, tracing, ipc, and poll"
url="https://clusterlabs.github.io/libqb"
license="LGPL-2.1-or-later"
arch="all"
makedepends="
	autoconf
	automake
	coreutils
	doxygen
	graphviz-dev
	libtool
	libxml2-dev
	"
checkdepends="check-dev"
subpackages="$pkgname-dev $pkgname-doc $pkgname-tools"
source="https://github.com/ClusterLabs/libqb/releases/download/v$pkgver/libqb-$pkgver.tar.xz"

case "$CARCH" in
	# tests fails in ci, passes in local builder and container
	loongarch64) options="!check";;
esac

prepare() {
	default_prepare
	./autogen.sh
}

check() {
	make -C tests VERBOSE=1 check
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--localstatedir=/var \
		--includedir=/usr/include \
		--disable-static
	make
}

package() {
	make install DESTDIR="$pkgdir"

	# remove a helper tool
	rm "$pkgdir"/usr/bin/doxygen2man
}

tools() {
	pkgdesc="Tools to use with $pkgname"

	amove usr/sbin
}

sha512sums="
257e736ba3f14e333dec3890dd4f28d84a6603f9474353a02d1e32f75b0fc72e9b6925cc05d36c75eb792143ffde0d2d0eca468b834cd5dbf30303d332c13b36  libqb-2.0.9.tar.xz
"
