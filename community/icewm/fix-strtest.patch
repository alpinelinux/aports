Remove portions of the strtest that are subjective and can fail
because of build system configuration rather than actual
failures of the software that is being tested.

diff -Naur a/src/strtest.cc b/src/strtest.cc
--- a/src/strtest.cc	2026-06-22 14:51:05.240807769 -0400
+++ b/src/strtest.cc	2026-06-22 14:55:12.819989298 -0400
@@ -314,7 +314,6 @@
     assert(re, !re.isRelative());
     assert(re, re.dirExists());
     assert(re, re.isReadable());
-    assert(re, !re.isWritable() || getuid() == 0);
     assert(re, re.isExecutable());
     assert(re, !re.fileExists());
 
@@ -454,17 +453,15 @@
         const char cpath[] = "/etc";
         cdir c(cpath);
         assert(cpath, c.isOpen());
-        int n = 0, p = 0, g = 0, r = 0;
+        int n = 0, p = 0, g = 0;
         while (c.next()) {
             ++n;
             if (0 == strcmp(c.entry(), "passwd")) ++p;
             if (0 == strcmp(c.entry(), "group")) ++g;
-            if (0 == strcmp(c.entry(), "resolv.conf")) ++r;
         }
-        assert(cpath, n >= 3);
+        assert(cpath, n >= 2);
         assert(cpath, p == 1);
         assert(cpath, g == 1);
-        assert(cpath, r == 1);
 
         c.open(cpath);
         n = 0;
@@ -486,17 +483,15 @@
         const char cpath[] = "/etc";
         udir u(cpath);
         assert(cpath, u.isOpen());
-        int n = 0, p = 0, g = 0, r = 0;
+        int n = 0, p = 0, g = 0;
         while (u.next()) {
             ++n;
             if (u.entry() == "passwd") ++p;
             if (u.entry() == "group") ++g;
-            if (u.entry() == "resolv.conf") ++r;
         }
-        assert(cpath, n >= 3);
+        assert(cpath, n >= 2);
         assert(cpath, p == 1);
         assert(cpath, g == 1);
-        assert(cpath, r == 1);
 
         u.open(cpath);
         n = 0;
