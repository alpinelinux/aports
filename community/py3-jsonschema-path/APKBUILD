# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-jsonschema-path
#_pkgreal is used by apkbuild-pypi to find modules at PyPI
_pkgreal=jsonschema-path
pkgver=0.4.5
pkgrel=0
pkgdesc="Object-oriented JSONSchema"
url="https://github.com/p1c2u/jsonschema-path"
arch="noarch"
license="Apache-2.0"
depends="
	py3-jsonschema
	py3-pathable
	py3-yaml
	py3-requests
	py3-referencing
"
checkdepends="
	py3-pytest
	py3-pytest-cov
	py3-responses
"
makedepends="
	poetry
	py3-setuptools
	py3-gpep517
	py3-wheel
"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/p1c2u/jsonschema-path/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/$_pkgreal-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer "$builddir"/.dist/*.whl
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
dcfc2ccbdd66c24b1863a3e7f87b727b548122aa3baf333f138efe4d3c4e9cc1ddc56a75c3457c53a40aa3e59a8828aa28a763d6afcffb4ae85a05ab8f2df056  py3-jsonschema-path-0.4.5.tar.gz
"
