Set the version statically, otherwise we need to package uv-dynamic-versioning
which, in turn, requires adding additional dependencies.  Since this package is
now needed by beets (which is currently in community/ and doesn't work without it),
work around that by setting the version statically and avoiding packaging
uv-dynamic-versioning and its dependencies.

The version is statically set from prepare() in the APKBUILD based on $pkgver.

See:

* https://hatch.pypa.io/1.12/version/
* https://hatch.pypa.io/1.12/config/metadata/#version

diff -upr PyrateLimiter-4.1.0.orig/pyproject.toml PyrateLimiter-4.1.0/pyproject.toml
--- PyrateLimiter-4.1.0.orig/pyproject.toml	2026-03-24 14:19:54.005705984 +0100
+++ PyrateLimiter-4.1.0/pyproject.toml	2026-03-24 14:20:12.828568131 +0100
@@ -1,6 +1,5 @@
 [project]
 name = "pyrate-limiter"
-dynamic = ["version"]
 description = "Python Rate-Limiter using Leaky-Bucket Algorithm"
 authors = [{ name = "vutr", email = "me@vutr.io" }]
 requires-python = ">=3.10"
@@ -94,12 +93,9 @@ output = 'test-reports/coverage.xml'
 context = 7
 
 [build-system]
-requires = ["hatchling", "uv-dynamic-versioning"]
+requires = ["hatchling"]
 build-backend = "hatchling.build"
 
