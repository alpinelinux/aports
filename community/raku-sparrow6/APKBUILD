# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: Robert Mongold <rmongold@gmail.com>
pkgname=raku-sparrow6
pkgver=0.0.93
pkgrel=1
pkgdesc="Raku-based automation framework"
url="https://github.com/melezhik/Sparrow6"
arch="all"
license="Artistic-2.0"
depends="
	bash
	rakudo
	raku-data-dump
	raku-file-directory-tree
	raku-hash-merge
	raku-json-fast
	raku-terminal-ansicolor
	raku-yamlish
	"
makedepends="moarvm-dev rakudo-dev"
checkdepends="perl-utils"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/melezhik/Sparrow6/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/Sparrow6-$pkgver"
options="!archcheck" # Precompiled arch dependent files included (quiet noarch warning)

build() {
	RAKUDO_RERESOLVE_DEPENDENCIES=0 \
	/usr/share/rakudo/tools/install-dist.raku \
		--to=output --for=vendor
}

check() {
	prove -e 'raku -Ilib'
}

package() {
	mkdir -p "$pkgdir"/usr/share/rakudo
	cp -RT output "$pkgdir"/usr/share/rakudo/vendor

	mkdir -p "$pkgdir"/usr/bin
	ln -s ../share/rakudo/vendor/bin/s6 "$pkgdir"/usr/bin/s6

	install -Dvm644 META6.json README.md \
		-t "$pkgdir"/usr/share/doc/$pkgname/
}

sha512sums="
51934c1c3c7f68d2f420bf0bfdc7559da1a222e193a41ad34a662c6101d295c58ab3a795d5fce58b4d14e1d3e1bad5522a1492b942f54f455f2d62aea2496ad7  raku-sparrow6-0.0.93.tar.gz
"
