# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-session
pkgver=1.0.14
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Session manager for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-session"
# riscv64: too slow to build
arch="all !armhf !armv7 !s390x !x86 !riscv64" # many apps missing
license="GPL-3.0-or-later"
depends="
	bash
	cosmic-app-library
	cosmic-applets
	cosmic-bg
	cosmic-comp
	cosmic-files
	cosmic-greeter
	cosmic-icons
	cosmic-idle
	cosmic-launcher
	cosmic-notifications
	cosmic-osd
	cosmic-panel
	cosmic-randr
	cosmic-screenshot
	cosmic-settings
	cosmic-settings-daemon
	cosmic-workspaces
	dbus
	xwayland
"
makedepends="
	cargo-auditable
	dbus-dev
	glib-dev
	just
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
subpackages="$pkgname-systemd"
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-session/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
6060f07f1883ad5446e01ec4a07cbe0347c851b691754d4f6cb9eebcd65074b18cac89ffbba2891d80b99c9e27389e589773bdb9fcaecd4bfde5ad8032d8996d  cosmic-session-1.0.14.tar.gz
"
