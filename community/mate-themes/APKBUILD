pkgname=mate-themes
pkgver=3.22.26
pkgrel=1
pkgdesc="MATE themes"
url="https://github.com/mate-desktop/mate-themes"
arch="noarch"
license="LGPL-2.1-or-later"
depends="mate-common"
makedepends="intltool gdk-pixbuf-dev icon-naming-utils gtk+3.0-dev"
subpackages="$pkgname-lang"
source="https://pub.mate-desktop.org/releases/themes/${pkgver%.*}/mate-themes-$pkgver.tar.xz
	gtk2.patch
	"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--sysconfdir=/etc \
		--prefix=/usr
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

