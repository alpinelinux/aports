From 8bdc10a287692674efab5a439b2195f9be4ebf2a Mon Sep 17 00:00:00 2001
From: Fiona Klute <fiona.klute@gmx.de>
Date: Mon, 2 Feb 2026 00:49:20 +0100
Subject: [PATCH logbookd] Check text columns for NULL when processing log
 message query

sqlite3_column_text() may return NULL, if a null value (rather than an
empty string) has been written. Calling strlen() with a NULL pointer
segfaults, making logbookd crash.

For log messages processed as type SRC_UNKNOWN in parse_log_message()
the "app" column is written as null, so logging such a message and
then calling logread was enough to crash logbookd.

Upstream: https://lists.sr.ht/~martijnbraam/public-inbox/patches/67368
---
 main.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/main.c b/main.c
index b477e1a..a2b332b 100644
--- a/main.c
+++ b/main.c
@@ -552,8 +552,8 @@ do_query(int client, unsigned char *cmd, ssize_t size)
 		packet_ptr = write_int8(packet_ptr, sqlite3_column_int(stmt, 3));
 		const unsigned char *app = (unsigned char *) sqlite3_column_text(stmt, 4);
 		const unsigned char *msg = sqlite3_column_text(stmt, 5);
-		int msglen = (int) strlen((char *) msg);
-		packet_ptr = write_varchar(packet_ptr, (char *) app);
+		int msglen = msg != NULL ? (int) strlen((char *) msg) : 0;
+		packet_ptr = write_varchar(packet_ptr, app != NULL ? (char *) app : "");
 		memcpy(packet_ptr, msg, msglen);
 		packet_ptr += msglen;
 		*packet_ptr++ = '\0';
-- 
