# Contributor: Leo <thinkabit.ukim@gmail.com>
# Maintainer:
pkgname=py3-hidapi
pkgver=0.15.0
pkgrel=0
pkgdesc="Cython interface for hidapi"
url="https://github.com/trezor/cython-hidapi"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	cython
	eudev-dev
	hidapi-dev
	libusb-dev
	py3-gpep517
	py3-setuptools
	py3-wheel
	python3-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/trezor/cython-hidapi/archive/$pkgver.tar.gz"
builddir="$srcdir/cython-hidapi-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--config-json '{"--build-option": ["--with-system-hidapi"]}' \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m unittest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
590ca0f7515792617126d3b619b7db68d926aedafd6fe5eb735677c760ff816dd715ab757fb032100797faa3f2aea0406f30b356099b42d404b9bb11298fb6b4  py3-hidapi-0.15.0.tar.gz
"
