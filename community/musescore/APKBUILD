# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=musescore
pkgver=4.7.3
pkgrel=0
_mnxdom_commit=e7c947bf768caccf315426dcae0dfac02caf738b
_mnx_commit=d513cf7a28a84c803ed36e448b416cb49c3a22f9
_json_schema_validator_commit=40af3ec39670e768fc3f01f935140af311d71024
pkgdesc="Create, play and print beautiful sheet music"
url="https://musescore.org/"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="GPL-3.0-only"
depends="
	kirigami-addons
	sonnet
	"
makedepends="
	clang
	cmake
	doxygen
	flac
	jack-dev
	harfbuzz-dev
	lame-dev
	libopusenc-dev
	libsndfile-dev
	nlohmann-json
	portmidi-dev
	pulseaudio-dev
	qt6-qt5compat-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtnetworkauth-dev
	qt6-qtscxml-dev
	qt6-qtsvg-dev
	qt6-qttools-dev
	samurai
	tinyxml2-dev
	xxd
	"
subpackages="$pkgname-doc $pkgname-lang"
source="$pkgname-$pkgver.tar.gz::https://github.com/musescore/MuseScore/archive/v$pkgver.tar.gz
	mnxdom-$_mnxdom_commit.tar.gz::https://github.com/rpatters1/mnxdom/archive/$_mnxdom_commit.tar.gz
	mnx-$_mnx_commit.tar.gz::https://github.com/w3c/mnx/archive/$_mnx_commit.tar.gz
	json-schema-validator-$_json_schema_validator_commit.tar.gz::https://github.com/pboettch/json-schema-validator/archive/$_json_schema_validator_commit.tar.gz
	no-fetch-mnxdom.patch
	fix-destdir-symlinks.patch
	no-fetch-mnxdom-deps.diff
	"
builddir="$srcdir"/MuseScore-$pkgver
options="!check" # todo

prepare() {
	default_prepare
	patch -p1 -d "$srcdir/mnxdom-$_mnxdom_commit" -i "$srcdir/no-fetch-mnxdom-deps.diff"
}

build() {
	# FIXME https://gitlab.alpinelinux.org/alpine/aports/-/issues/17612
	CMAKE_PREFIX_PATH="/usr" \
	PATH="$PATH:/usr/lib/qt6/bin" \
	CC=clang \
	CXX=clang++ \
	CFLAGS="${CFLAGS/-fstack-clash-protection} -O2 -DNDEBUG" \
	CXXFLAGS="${CXXFLAGS/-fstack-clash-protection} -O2 -DNDEBUG -D_LARGEFILE64_SOURCE" \
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DFETCHONTENT_FULLY_DISCONNECTED=ON \
		-DJSON_SCHEMA_VALIDATOR_SOURCE_DIR="$srcdir/json-schema-validator-$_json_schema_validator_commit" \
		-DCMAKE_SKIP_RPATH=ON \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DMNXDOM_SOURCE_DIR="$srcdir/mnxdom-$_mnxdom_commit" \
		-DMNX_W3C_SOURCE="$srcdir/mnx-$_mnx_commit" \
		-DMUSESCORE_BUILD_CONFIGURATION=app \
		-DMUSE_MODULE_UPDATE=OFF \
		-DMUSE_APP_BUILD_MODE=release \
		-DMUE_BUILD_UNIT_TESTS="$(want_check && echo ON || echo OFF)" \
		-DMUE_COMPILE_USE_SYSTEM_FLAC=ON \
		-DMUE_COMPILE_USE_SYSTEM_FREETYPE=ON \
		-DMUE_COMPILE_USE_SYSTEM_HARFBUZZ=ON \
		-DMUE_COMPILE_USE_SYSTEM_OPUS=ON \
		-DMUE_COMPILE_USE_SYSTEM_OPUSENC=ON \
		-DMUE_COMPILE_USE_SYSTEM_TINYXML=ON \
		-DMUE_DOWNLOAD_SOUNDFONT=OFF \
		-DNLOHMANN_JSON_MIN_VERSION=3.11.3 \
		-DUSE_SYSTEM_NLOHMANN_JSON=ON
	cmake --build build --target all MuseScore_lrelease
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

lang() {
	pkgdesc="Translations for $pkgname"
	install_if="$pkgname=$pkgver-r$pkgrel lang"

	amove usr/share/mscore-*/locale
}

