pkgname=py3-mastodon.py
_pkgreal=Mastodon.py
pkgver=2.2.1
pkgrel=0
pkgdesc="Python wrapper for the Mastodon API"
url="https://github.com/halcy/Mastodon.py"
arch="noarch"
license="MIT"
depends="python3 py3-requests py3-dateutil py3-magic py3-decorator py3-http-ece py3-cryptography py3-blurhash py3-graphemeu"
checkdepends="python3-dev py3-pytest py3-pytest-xdist py3-pytest-runner py3-pytest-cov py3-vcrpy py3-pytest-recording py3-pytest-mock py3-requests-mock py3-tz tzdata"
makedepends="py3-setuptools py3-gpep517"
subpackages="$pkgname-pyc"
source="$_pkgreal-$pkgver.tar.gz::https://github.com/halcy/Mastodon.py/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/$_pkgreal-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	pytest -n $JOBS
}

package() {
	gpep517 install-wheel --destdir "$pkgdir" \
		.dist/*.whl
}

sha512sums="
