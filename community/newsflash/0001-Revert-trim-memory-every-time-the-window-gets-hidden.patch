From cd604918e3dd55119c0360916d4b8138c78c4961 Mon Sep 17 00:00:00 2001
From: WrenIX <dev@wrenix.eu>
Date: Fri, 26 Jun 2026 18:55:11 +0200
Subject: [PATCH] Revert "trim memory every time the window gets hidden (fixes
 #897)"

This reverts commit e89473eb64e7c9334125d4c4ca0ef7e65ea33f9f.
---
 Cargo.toml | 1 -
 src/app.rs | 5 -----
 2 files changed, 6 deletions(-)

diff --git a/Cargo.toml b/Cargo.toml
index 91bce4be..459eca7c 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -56,7 +56,6 @@ ammonia = "4.1"
 clapper-player = { version = "0.10", features = ["v0_10"] }
 clapper-player-gtk = { version = "0.10", features = ["v0_10"] }
 glycin = { version = "3.1", features = ["gdk4", "async-io"] }
-libc = "0.2"
 
 [dependencies.news-flash]
 features = ["article-scraper", "image-downloader"]
diff --git a/src/app.rs b/src/app.rs
index fd1ce204..e9c9803e 100644
--- a/src/app.rs
+++ b/src/app.rs
@@ -264,11 +264,6 @@ mod imp {
             }
             if app.settings().general().keep_running_in_background() && win.is_page_visible(constants::CONTENT_PAGE) {
                 MainWindow::harvest_restore_relevant_state();
-                unsafe {
-                    if libc::malloc_trim(0) > 0 {
-                        tracing::info!("malloc_trim freed memory");
-                    }
-                }
                 return Propagation::Stop;
             }
 
