# Contributor: Alex McGrath <amk@amk.ie>
# Maintainer: Alex McGrath <amk@amk.ie>
pkgname=newsflash
pkgver=5.1.0
pkgrel=0
pkgdesc="An rss feed reader that supports various web based services"
url="https://gitlab.com/news-flash/news_flash_gtk/"
arch="all !s390x !armhf !armv7"
license="GPL-3.0-only"
depends="desktop-file-utils"
makedepends="
	bash
	blueprint-compiler
	cargo
	clang-dev
	clapper-dev
	gettext-dev
	gstreamer-dev
	gtksourceview5-dev
	libadwaita-dev
	meson
	openssl-dev>3
	sqlite-dev
	webkit2gtk-6.0-dev
	"
subpackages="$pkgname-lang"
source="
	https://gitlab.com/news-flash/news_flash_gtk/-/archive/v.$pkgver/news_flash_gtk-v.$pkgver.tar.gz
	0001-Revert-trim-memory-every-time-the-window-gets-hidden.patch
	"
options="net !check" # no tests
builddir="$srcdir/news_flash_gtk-v.$pkgver"

prepare() {
	default_prepare

	# Set version number
	sed -i "s/0.0.0/$pkgver/g" meson.build Cargo.toml
}

build() {
	abuild-meson . output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
	ln -s io.gitlab.news_flash.NewsFlash "$pkgdir"/usr/bin/newsflash
}

