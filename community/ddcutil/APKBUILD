maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=ddcutil
pkgver=2.2.7
pkgrel=1
pkgdesc="Query and change Linux monitor settings using DDC/CI and USB"
url="https://github.com/rockowitz/ddcutil"
arch="all"
license="GPL-2.0-only"
makedepends="
	acl-dev
	autoconf
	automake
	dbus-dev
	eudev-dev
	glib-dev
	i2c-tools-dev
	jansson-dev
	kmod-dev
	libdrm-dev
	libtool
	libusb-dev
	libxrandr-dev
	linux-headers
	"
subpackages="
	$pkgname-dev
	$pkgname-doc
	$pkgname-udev
	"
source="$pkgname-$pkgver-1.tar.gz::https://github.com/rockowitz/ddcutil/archive/v$pkgver.tar.gz
	0001-ddcutil-execinfo.patch
	"

prepare() {
	default_prepare
	NOCONFIGURE=1 ./autogen.sh
}

build() {
	./configure \
		--prefix=/usr \
		--mandir=/usr/share/man
	make
}

package() {
	make DESTDIR="$pkgdir" install
}

