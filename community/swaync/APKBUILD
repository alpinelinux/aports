# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=swaync
_projname=SwayNotificationCenter
pkgver=0.12.6
pkgrel=0
pkgdesc="Notification daemon with a GTK GUI for notifications and the control center"
url="https://github.com/ErikReider/SwayNotificationCenter"
arch="all"
license="GPL-3.0-only"
depends="dbus"
makedepends="
	blueprint-compiler
	gobject-introspection-dev
	granite7-dev
	gtk4.0-dev
	gtk4-layer-shell-dev
	json-glib-dev
	libadwaita-dev
	libgee-dev
	meson
	pulseaudio-dev
	sassc
	scdoc
	vala
	"
subpackages="
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="https://github.com/ErikReider/SwayNotificationCenter/archive/v$pkgver/swaync-$pkgver.tar.gz"
builddir="$srcdir/$_projname-$pkgver"
options="!check"  # no tests defined

build() {
	abuild-meson \
		-Db_lto=true \
		-Dsystemd-service=false \
		. output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
