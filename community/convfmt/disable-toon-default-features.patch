From b5603f3a73a0220705104fc4ec9ac6f30a60428f Mon Sep 17 00:00:00 2001
From: Jakub Jirutka <jakub@jirutka.cz>
Date: Sun, 24 May 2026 00:05:15 +0200
Subject: [PATCH] Disable toon-format default features

toon-format provides a CLI that is enabled by default. It's not used
here and just adds a huge tree of dependencies.

diff --git a/Cargo.toml b/Cargo.toml
index b218757..f170897 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -34,7 +34,7 @@ serde_json = "1.0.149"
 serde_yaml = "0.9.34"
 serde-hjson = "1.1.0"
 toml = "0.9.8"
-toon-format = "0.4.0"
+toon-format = { version = "0.4.5", default-features = false }
 
 [dev-dependencies]
 rstest = "0.26.1"
