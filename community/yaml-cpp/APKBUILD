# Contributor: Mark Riedesel <mark@klowner.com>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=yaml-cpp
pkgver=0.9.0
pkgrel=0
pkgdesc="YAML parser and emitter in C++ matching YAML 1.2 spec"
url="https://github.com/jbeder/yaml-cpp"
arch="all"
license="MIT"
checkdepends="gtest-dev"
makedepends="cmake samurai"
subpackages="$pkgname-dev"
source="https://github.com/jbeder/yaml-cpp/archive/yaml-cpp-$pkgver.tar.gz
	32-bit-precision.patch
	enable-pic.patch
	gtest.patch
	"
builddir="$srcdir/yaml-cpp-yaml-cpp-$pkgver"

build() {
	local _build_tests=ON
	if ! want_check; then
		_build_tests=OFF
	fi

	cmake -B build -G Ninja . \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_VERBOSE_MAKEFILE=ON \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DYAML_BUILD_SHARED_LIBS=ON \
		-DYAML_CPP_BUILD_TESTS=$_build_tests \
		-DYAML_USE_SYSTEM_GTEST=ON
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

