maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=qxmpp
pkgver=1.16.1
pkgrel=0
pkgdesc="Cross-platform C++ XMPP client and server library"
# armhf blocked by failing generation of documentation
arch="all !armhf"
url="https://invent.kde.org/libraries/qxmpp"
license="LGPL-2.1-or-later"
makedepends="
	extra-cmake-modules
	doxygen
	graphviz
	gstreamer-dev
	libomemo-c-dev
	qca-qt6-dev
	qt6-qt5compat-dev
	qt6-qtbase-dev
	qt6-qttools-dev
	samurai
	"
subpackages="
	$pkgname-dev
	$pkgname-doc
	"
source="https://download.kde.org/unstable/qxmpp/qxmpp-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_EXAMPLES=OFF \
		-DBUILD_DOCUMENTATION=ON \
		-DBUILD_OMEMO=ON \
		-DWITH_GSTREAMER=ON
	cmake --build build
}

check() {
	# tst_qxmppiceconnection and tst_qxmpptransfermanager require a network connection
	ctest --test-dir build -E "tst_qxmpp(iceconnection|transfermanager|callmanager|jinglemessageinitiationmanager)"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
b2a54e4ed35fadb8cc2666d886f3fe734c4205d4f75c6354e3d115de36b3c489e3de7fafb3607b0f1026383d9062ca86db45a4da6bb5f0fad6b6a9e47ca45951  qxmpp-1.16.1.tar.xz
"
