# Maintainer: Jordan Christiansen <xordspar0@gmail.com>
pkgname=acme-client
pkgver=1.3.7
pkgrel=0
pkgdesc="Client for issuing certificates from ACME-complaint servers"
url="https://git.wolfsden.cz/acme-client-portable"
arch="all"
license="GPL-2.0-only"
makedepends="openssl-dev>3 byacc automake autoconf"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://files.wolfsden.cz/releases/acme-client/acme-client-$pkgver.tar.gz"
options="!check" # Tests require modifying /etc/hosts

prepare() {
	default_prepare
	autoreconf -fvi
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var
	make
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
