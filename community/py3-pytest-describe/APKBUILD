maintainer="Hoang Nguyen <folliekazetani@protonmail.com>"
pkgname=py3-pytest-describe
pkgver=3.1.0
pkgrel=0
pkgdesc="Describe-style plugin for pytest"
url="https://github.com/pytest-dev/pytest-describe"
arch="noarch"
license="MIT"
depends="python3 py3-pytest"
makedepends="py3-setuptools py3-gpep517 py3-uv-build"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/pytest-dev/pytest-describe/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/pytest-describe-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
6ae2fc713efe1fd0bc657528e7b0775dcf4e92909dba5dfc7c43c88045f3ed0bde9011cd4f44480ad89d8f857f09af48df74ed12ad0ddcf65b0ef5d8ad84b76f  py3-pytest-describe-3.1.0.tar.gz
"
