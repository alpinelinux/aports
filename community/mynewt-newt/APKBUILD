# Contributor: Oleg Titov <oleg.titov@gmail.com>
# Maintainer: Oleg Titov <oleg.titov@gmail.com>
pkgname=mynewt-newt
pkgver=1.14.0
_ver=${pkgver//./_}_tag
pkgrel=0
pkgdesc="Apache Newt is a smart build and package management tool for Apache Mynewt Operating System"
url="https://mynewt.apache.org"
arch="all"
license="Apache-2.0"
options="!check net" # unreleased test suite in separate repository, go
depends="git"
makedepends="go"
subpackages="$pkgname-doc"
source="mynewt-newt-$pkgver.tar.gz::https://github.com/apache/mynewt-newt/archive/mynewt_$_ver.tar.gz"
builddir="$srcdir/mynewt-newt-mynewt_$_ver"

export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

build() {
	./build.sh
}

package() {
	install -Dm 755 newt/newt "$pkgdir/usr/bin/newt"

	install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" README.md
}

sha512sums="
94910e70b288aa3bdd90f29e517651198b5f19711fdf6d829e49676f72482d88627cda864eda1a53d6b2d76c3c262ea325eaa1bf694f6ca657c31bb346891619  mynewt-newt-1.14.0.tar.gz
"
