From: =?UTF-8?q?Sebastian=20Dr=C3=B6ge?= <sebastian@centricular.com>
Date: Mon, 6 Apr 2026 15:54:27 +0300
Subject: [PATCH] raptorq: Downgrade to 2.0.0

2.0.1 adds 32-bit ARM assembly but the types / intrinsics are not stable
yet so compilation fails.

See https://github.com/cberner/raptorq/issues/216
---
 Cargo.lock | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index a6b9c5b39..ec341c129 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -9449,9 +9449,9 @@ checksum = "ca45419789ae5a7899559e9512e58ca889e41f04f1f2445e9f4b290ceccd1d08"
 
 [[package]]
 name = "raptorq"
-version = "2.0.1"
+version = "2.0.0"
 source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "4d4215fb79ef19442a0c71616aabb0715a386e6a16ed9031775ee3e3f20e7502"
+checksum = "90b1b1fad69672f0b901b5004863ea4307f03d168a3db5f2bcba4d3dfed88e97"
 
 [[package]]
 name = "rav1e"
