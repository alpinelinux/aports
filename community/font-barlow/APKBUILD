pkgname=font-barlow
pkgver=1.422
pkgrel=2
pkgdesc="Barlow is a slightly rounded, low-contrast, grotesk font superfamily"
url="https://tribby.com/fonts/barlow/"
arch="noarch"
license="OFL-1.1"
# Original url temporarily unavailable, use official GitHub repo
# source="https://tribby.com/fonts/barlow/download/barlow-$pkgver.zip"
source="$pkgname-$pkgver.zip::https://github.com/jpt/barlow/archive/$pkgver/barlow-$pkgver.zip"
options="!check" # No code to test
builddir="$srcdir/barlow-$pkgver/fonts/otf"

package() {
	install -Dm644 ./*.otf -t "$pkgdir"/usr/share/fonts/barlow
}

sha512sums="
