# Contributor: Krassy Boykinov <kboykinov@teamcentrixx.com>
maintainer="team/phosh <achill@achill.org>"
pkgname=livi
pkgver=0.5.0
pkgrel=0
pkgdesc="Small video player targeting mobile devices"
url="https://gitlab.gnome.org/guidog/livi"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	desktop-file-utils
	gst-plugins-bad-dev
	gst-plugins-base-dev
	gstreamer-dev
	gtk4.0-dev
	libadwaita-dev
	meson
	"
checkdepends="appstream-glib"
subpackages="$pkgname-lang"
source="https://sources.phosh.mobi/releases/livi/livi-$pkgver.tar.xz"

build() {
	abuild-meson \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
e1f293c422279306c25ff89954880fc7f9fdc692e9c985efb0c87ef488263e3d0a67177d7e3cf2aa251542437bae74dc4d431686b7dbd1c04531e1959efc28fd  livi-0.5.0.tar.xz
"
