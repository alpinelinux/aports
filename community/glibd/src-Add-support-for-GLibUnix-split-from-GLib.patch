From 5f158f022f2765eae09f9decdf715f49dfead46b Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Marco=20Trevisan=20=28Trevi=C3=B1o=29?= <mail@3v1n0.net>
Date: Fri, 27 Feb 2026 00:42:29 +0100
Subject: [PATCH] src: Add support for GLibUnix split from GLib

Since GLib 2.87.3 GLibUnix had been moved out from GLib typelib
and gir files, so we need to reflect this in the D bindings.
---
 src/APILookup.txt         |  1 +
 src/APILookupGLib.txt     | 20 +++++++++++---------
 src/APILookupGLibUnix.txt | 39 +++++++++++++++++++++++++++++++++++++++
 3 files changed, 51 insertions(+), 9 deletions(-)
 create mode 100644 src/APILookupGLibUnix.txt

diff --git a/src/APILookup.txt b/src/APILookup.txt
index 0022444..8f7df5f 100644
--- a/src/APILookup.txt
+++ b/src/APILookup.txt
@@ -49,5 +49,6 @@ license: end
 outputRoot: generated
 copy: gtkd
 lookup: APILookupGLib.txt
+lookup: APILookupGLibUnix.txt
 lookup: APILookupGObject.txt
 lookup: APILookupGio.txt
diff --git a/src/APILookupGLib.txt b/src/APILookupGLib.txt
index 053893f..91b680c 100644
--- a/src/APILookupGLib.txt
+++ b/src/APILookupGLib.txt
@@ -2092,15 +2092,17 @@ version 2.52: move: utf8_make_valid Unicode
 version 2.60: move: utf8_validate_len Unicode
 
 version !Windows: start
-	move: unix_error_quark UnixUtils error_quark
-	move: unix_fd_add UnixUtils fd_add
-	move: unix_fd_add_full UnixUtils fd_add_full
-	move: unix_fd_source_new UnixUtils fd_source_new
-	move: unix_open_pipe UnixUtils open_pipe
-	move: unix_set_fd_nonblocking UnixUtils set_fd_nonblocking
-	move: unix_signal_add UnixUtils signal_add
-	move: unix_signal_add_full UnixUtils signal_add_full
-	move: unix_signal_source_new UnixUtils signal_source_new
+	version <2.87.3: start
+		move: unix_error_quark UnixUtils error_quark
+		move: unix_fd_add UnixUtils fd_add
+		move: unix_fd_add_full UnixUtils fd_add_full
+		move: unix_fd_source_new UnixUtils fd_source_new
+		move: unix_open_pipe UnixUtils open_pipe
+		move: unix_set_fd_nonblocking UnixUtils set_fd_nonblocking
+		move: unix_signal_add UnixUtils signal_add
+		move: unix_signal_add_full UnixUtils signal_add_full
+		move: unix_signal_source_new UnixUtils signal_source_new
+	version: end
 version: end
 
 move: filename_from_uri URI
diff --git a/src/APILookupGLibUnix.txt b/src/APILookupGLibUnix.txt
new file mode 100644
index 0000000..0414af8
--- /dev/null
+++ b/src/APILookupGLibUnix.txt
@@ -0,0 +1,39 @@
+# This file is part of gtkD.
+#
+# gtkD is free software; you can redistribute it and/or modify
+# it under the terms of the GNU Lesser General Public License as published by
+# the Free Software Foundation; either version 2.1 of the License, or
+# (at your option) any later version.
+#
+# gtkD is distributed in the hope that it will be useful,
+# but WITHOUT ANY WARRANTY; without even the implied warranty of
+# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+# GNU Lesser General Public License for more details.
+#
+# You should have received a copy of the GNU Lesser General Public License
+# along with gtkD; if not, write to the Free Software
+# Foundation, Inc., 59 Temple Place, Suite 330, Boston, MA  02111-1307  USA
+#
+
+#########################################
+### Definitions for wrapping GLibUnix ###
+#########################################
+
+# must start with wrap
+wrap: glib_unix
+
+version !Windows: start
+    version 2.87.3: start
+        file: GLibUnix-2.0.gir
+
+        move: error_quark UnixUtils error_quark
+        move: fd_add UnixUtils fd_add
+        move: fd_add_full UnixUtils fd_add_full
+        move: fd_source_new UnixUtils fd_source_new
+        move: open_pipe UnixUtils open_pipe
+        move: set_fd_nonblocking UnixUtils set_fd_nonblocking
+        move: signal_add UnixUtils signal_add
+        move: signal_add_full UnixUtils signal_add_full
+        move: signal_source_new UnixUtils signal_source_new
+    version: end
+version: end
-- 
2.54.0

