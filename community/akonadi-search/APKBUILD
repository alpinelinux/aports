403bb846770befc00bc0fa32b5938021f099cac1749330e0d9d03bf438bc6d348e18a36d3e33fd6c0f3a6c721d700113b6ea1d5fd9d627fd62e3582e2ba8d90c  0001-akonadi-search-KMime-from-KF6.patch
"
