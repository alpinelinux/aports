ea6814a5af2fa3721ec18d11a3dde0f640b7d9dee937afeac88edc4d79b90a57a5d1f111c55acde2fc66089968c71dc23ad93963855d17d3d8897f6f9b7fdd7e  no-sse4.patch
"
