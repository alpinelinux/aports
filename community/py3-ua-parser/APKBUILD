# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-ua-parser
_pyname=ua-parser
pkgver=1.0.2
_uapcorever=383604dfd6c7518c152e3bd9b7eda67662b1b343
pkgrel=0
arch="noarch"
pkgdesc="Python port of Browserscope's user agent parser"
url="https://pypi.python.org/project/ua-parser"
license="Apache-2.0"
depends="
	py3-pyaml
	"
makedepends="
	jq
	py3-setuptools
	py3-gpep517
	py3-wheel
	py3-hatchling
	"
checkdepends="
	py3-pytest
	"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/ua-parser/uap-python/archive/refs/tags/$pkgver.tar.gz
	$pkgname-core-$_uapcorever.tar.gz::https://github.com/ua-parser/uap-core/archive/$_uapcorever.tar.gz
	builtins_version.patch
	"
builddir="$srcdir"/uap-python-$pkgver
subpackages="$pkgname-pyc"

prepare() {
	default_prepare
	rmdir "$builddir"/uap-core
	ln -s "$srcdir"/uap-core-$_uapcorever "$builddir"/uap-core

	# ua-parser depends on versioningit py module that isn't packaged. Workaround by patching
	# out those logics and setting upa_core version manually
	local _uapcorever=$(jq -r '.version' "$builddir"/uap-core/package.json)
	sed -i "s|@@UAP_VERSION@@|$_uapcorever|" "$builddir"/ua-parser-builtins/hatch_build.py
}

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2

	(
		cd ua-parser-builtins
		gpep517 build-wheel \
			--wheel-dir .dist \
			--output-fd 3 3>&1 >&2
	)
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	(
		cd ua-parser-builtins
		../.testenv/bin/python3 -m installer .dist/*.whl
	)
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
	(
		cd ua-parser-builtins
		python3 -m installer -d "$pkgdir" .dist/*.whl
	)
}

sha512sums="
46eeacaa93e84f4e6f0f567819caab9c01a87c27a051ea2954a136670155e799c4e31851ff0fe3021bcc9027ef7e8f332415b21e6ea6dca3b19e2d4f27990d2b  py3-ua-parser-1.0.2.tar.gz
846c9e53acb94ff5e347cad83a82d1261bfec2460cf0b40b09ef5abb8ac42f2ff83c33cbf8f2337c12c031fc0e7dfb234dc9fb6ce38786bf0efcd75e8f471299  py3-ua-parser-core-383604dfd6c7518c152e3bd9b7eda67662b1b343.tar.gz
75ecdb6706353b4e36b1d4f342ca6c5b3fa92904fcc7aa2ff885700755cc7c640f8c6ecfc5bc345b1e7c8958dd89a5680a84e1cfdc1c128e057d079eaf4870f5  builtins_version.patch
"
