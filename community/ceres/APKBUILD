# Contributor: Leon Marz <main@lmarz.org>
# Maintainer: Leon Marz <main@lmarz.org>
pkgname=ceres
pkgver=2.2.0
pkgrel=0
pkgdesc="Large scale non-linear optimization library"
url="https://ceres-solver.org"
arch="all"
license="BSD-3-Clause AND Apache-2.0"
makedepends="
	cmake
	eigen-dev
	glog-dev
	lapack-dev
	samurai
	"
depends_dev="
	eigen-dev
	glog-dev
	"
subpackages="$pkgname-dev"
source="https://github.com/ceres-solver/ceres-solver/archive/$pkgver/ceres-$pkgver.tar.gz"
builddir="$srcdir/ceres-solver-$pkgver"

build() {
	cmake -B build \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=Release \
		-DSUITESPARSE=OFF \
		-DBUILD_EXAMPLES=OFF \
		-DBUILD_BENCHMARKS=OFF

	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
d4cefe5851e25bd3c7b76352092d8d549eb371af2e35a325736554c54fe58a3523658697c3e2d65af660fe6895ae3d96fe31bd1875870474fc4b6fed3bbdfae9  ceres-2.2.0.tar.gz
"
