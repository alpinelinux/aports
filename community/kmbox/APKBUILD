beb75aae55374d7fd10dea37b499648716dad3e7b8cb01f2dff7e2073d6df1363277bc67ab0a0f5cc713ebdc4c56d9ee91b2166bee594fabd00ceaae2ae0516e  0001-kmbox-KMime-from-KF6.patch
"
