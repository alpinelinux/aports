From bdc1c36a1edca7af577516d1194be2224983a38c Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Sat, 18 Apr 2026 17:14:59 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt          |  6 +++++-
 KPimMboxConfig.cmake.in | 19 +++++++++++++++----
 src/CMakeLists.txt      |  2 +-
 3 files changed, 21 insertions(+), 6 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index e2bbce0..f21630a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -104,7 +104,11 @@ ecm_setup_version(PROJECT VARIABLE_PREFIX KMBOX
 )
 
 ########### Find packages ###########
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 
 add_definitions(-DQT_NO_CONTEXTLESS_CONNECT)
 ecm_set_disabled_deprecation_versions(QT 6.12.0 KF 6.25.0 KMIME 6.7.0)
diff --git a/KPimMboxConfig.cmake.in b/KPimMboxConfig.cmake.in
index 6f3d234..7b697d6 100644
--- a/KPimMboxConfig.cmake.in
+++ b/KPimMboxConfig.cmake.in
@@ -4,8 +4,19 @@
 @PACKAGE_INIT@
 
 include(CMakeFindDependencyMacro)
-find_dependency(
-    KPim6Mime
-    "@KMIME_LIB_VERSION@"
-)
+if(@KF6Mime_FOUND@)
+    find_dependency(
+        KF6Mime
+        "@KF_MIN_VERSION@"
+    )
+else()
+    find_dependency(
+        KPim6Mime
+        "@KMIME_LIB_VERSION@"
+    )
+    if(NOT TARGET KF6::Mime)
+        add_library(KF6::Mime ALIAS KPim6::Mime)
+    endif()
+endif()
+
 include("${CMAKE_CURRENT_LIST_DIR}/KPim6MboxTargets.cmake")
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index 3242e53..82bfb28 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -39,7 +39,7 @@ ecm_generate_export_header(KPim6Mbox
 target_include_directories(KPim6Mbox INTERFACE "$<INSTALL_INTERFACE:${KDE_INSTALL_INCLUDEDIR}/KPim6/KMbox>")
 target_include_directories(KPim6Mbox PUBLIC "$<BUILD_INTERFACE:${KMbox_SOURCE_DIR}/src;${KMbox_BINARY_DIR}/src>")
 
-target_link_libraries(KPim6Mbox PUBLIC KPim6::Mime)
+target_link_libraries(KPim6Mbox PUBLIC KF6::Mime)
 
 set_target_properties(
     KPim6Mbox
-- 
