db74c9b8019099090211eff98364dd7f09c081d84bfd20d98a5981841e9a788a2ff23f7a011600d00e4c53776b6c4c7d709bea363d36c73b436cddd931e4d89c  remove-six.patch
3cf6f1c077dc9b778de0d8a5e0ebb03f7c8aa65b3ee7d0771b06a18101d72f944707817f107706b6e318c2f148f9b381b64bb40f41d982ba52e25c8d4116085e  setuptools-82.patch
"
