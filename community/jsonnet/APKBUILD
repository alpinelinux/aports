e4bef775079c47d03942349a65263f138450e1dea0ba15e9bc93dfaf5b4779e5910cc7cbba87518ec836a52d6c6f218165575e5aa7386bff68cdf9ea555f5553  remove-rc2-version-tag-1.patch
9f48386f3105a3d256ec0cfd333409b5d37395b1c2c49bc1cf1bf6947c12080a1b459f8b24026f1c2c3ea4bffacd7a265ec286b252e1ff8a26783cdae266592e  rapidyaml-loongarch64.patch
