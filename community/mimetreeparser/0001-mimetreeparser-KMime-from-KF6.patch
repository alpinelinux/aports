From 690a45a45f3937f3f3f69dd56b1fa8d164c66494 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Wed, 22 Apr 2026 17:12:31 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt                                 | 6 +++++-
 src/core/CMakeLists.txt                        | 2 +-
 src/core/KPimMimeTreeParserCoreConfig.cmake.in | 9 ++++++++-
 src/widgets/CMakeLists.txt                     | 2 +-
 4 files changed, 15 insertions(+), 4 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 706e5d6..cda9ed5 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -72,7 +72,11 @@ find_package(KF6I18n ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6CalendarCore ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6ColorScheme ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6WidgetsAddons ${KF_MIN_VERSION} CONFIG)
-find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KPim6Mbox ${KPIM_MBOX_VERSION} CONFIG REQUIRED)
 find_package(KPim6Libkleo ${KPIM_LIBKLEO_VERSION} CONFIG REQUIRED)
 find_package(Gpgmepp ${GPGME_REQUIRED_VERSION} CONFIG REQUIRED)
diff --git a/src/core/CMakeLists.txt b/src/core/CMakeLists.txt
index e0bad16..dd36837 100644
--- a/src/core/CMakeLists.txt
+++ b/src/core/CMakeLists.txt
@@ -68,7 +68,7 @@ target_include_directories(
 
 target_link_libraries(
     KPim6MimeTreeParserCore
-    PUBLIC KPim6::Mime KPim6::Libkleo Gpgmepp Qt::Gui
+    PUBLIC KF6::Mime KPim6::Libkleo Gpgmepp Qt::Gui
     PRIVATE KPim6::Mbox KF6::I18n
 )
 
diff --git a/src/core/KPimMimeTreeParserCoreConfig.cmake.in b/src/core/KPimMimeTreeParserCoreConfig.cmake.in
index 39ea9d8..6e02ea1 100644
--- a/src/core/KPimMimeTreeParserCoreConfig.cmake.in
+++ b/src/core/KPimMimeTreeParserCoreConfig.cmake.in
@@ -5,7 +5,14 @@
 include(CMakeFindDependencyMacro)
 
 find_dependency(KF6I18n "@KF_MIN_VERSION@")
-find_dependency(KPim6Mime "@KPIM_MIME_VERSION@")
+if(@KF6Mime_FOUND@)
+    find_dependency(KF6Mime "@KF_MIN_VERSION@")
+else()
+    find_dependency(KPim6Mime "@KPIM_MIME_VERSION@")
+    if(NOT TARGET KF6::Mime)
+        add_library(KF6::Mime ALIAS KPim6::Mime)
+    endif()
+endif()
 find_dependency(KPim6Mbox "@KPIM_MBOX_VERSION@")
 
 include("${CMAKE_CURRENT_LIST_DIR}/KPim6MimeTreeParserCoreTargets.cmake")
diff --git a/src/widgets/CMakeLists.txt b/src/widgets/CMakeLists.txt
index c002a73..cf08724 100644
--- a/src/widgets/CMakeLists.txt
+++ b/src/widgets/CMakeLists.txt
@@ -55,7 +55,7 @@ target_include_directories(
 
 target_link_libraries(
     KPim6MimeTreeParserWidgets
-    PUBLIC Qt::Widgets KPim6::Mime
+    PUBLIC Qt::Widgets KF6::Mime
     PRIVATE
         KPim6::MimeTreeParserCore
         Qt::PrintSupport
-- 
