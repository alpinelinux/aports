From 26518af3667ab521fa5c808b7720cd6d3583b805 Mon Sep 17 00:00:00 2001
From: Allen Winter <winter@kde.org>
Date: Sun, 3 May 2026 10:03:55 -0400
Subject: [PATCH] KPimMimeTreeParserWidgetsConfig.cmake.in - KMime forward
 compatibility

add forward compatiblity with KMime from KDE Frameworks
---
 src/widgets/KPimMimeTreeParserWidgetsConfig.cmake.in | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/src/widgets/KPimMimeTreeParserWidgetsConfig.cmake.in b/src/widgets/KPimMimeTreeParserWidgetsConfig.cmake.in
index ffd2122..537c3af 100644
--- a/src/widgets/KPimMimeTreeParserWidgetsConfig.cmake.in
+++ b/src/widgets/KPimMimeTreeParserWidgetsConfig.cmake.in
@@ -5,7 +5,14 @@
 include(CMakeFindDependencyMacro)
 
 find_dependency(KF6I18n "@KF_MIN_VERSION@")
-find_dependency(KPim6Mime "@KPIM_MIME_VERSION@")
+if(@KF6Mime_FOUND@)
+    find_dependency(KF6Mime "@KF_MIN_VERSION@")
+else()
+    find_dependency(KPim6Mime "@KPIM_MIME_VERSION@")
+    if(NOT TARGET KF6::Mime)
+        add_library(KF6::Mime ALIAS KPim6::Mime)
+    endif()
+endif()
 find_dependency(KPim6MimeTreeParserCore "@PIM_VERSION@")
 
 include("${CMAKE_CURRENT_LIST_DIR}/KPim6MimeTreeParserWidgetsTargets.cmake")
-- 
