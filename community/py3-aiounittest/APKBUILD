# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-aiounittest
_pkgreal=aiounittest
pkgver=1.5.0
pkgrel=1
pkgdesc="Test python asyncio-based code with ease"
url="https://github.com/kwarunek/aiounittest"
arch="noarch"
license="MIT"
depends="py3-wrapt"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-coverage
	py3-pytest
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/kwarunek/aiounittest/archive/refs/tags/$pkgver.tar.gz
	python-3.14.patch
	"
builddir="$srcdir/$_pkgreal-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
