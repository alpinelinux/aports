From 4d6a6415b7b43e42998d89d5a3c42967f9d3739f Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Mon, 20 Apr 2026 17:14:14 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt          | 6 +++++-
 src/mail/CMakeLists.txt | 2 +-
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 03487b643..c799fa601 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -137,7 +137,11 @@ find_package(KPim6MailCommon ${MAILCOMMON_LIB_VERSION} REQUIRED)
 find_package(KPim6MailTransport ${MAILTRANSPORT_LIB_VERSION} REQUIRED)
 find_package(KPim6MimeTreeParserCore ${MIMETREEPARSER_LIB_VERSION} REQUIRED)
 find_package(KPim6Mbox ${KMBOX_LIB_VERSION} REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KPim6Libkdepim ${LIBKDEPIM_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6PimCommonAkonadi ${PIMCOMMON_LIB_VERSION} CONFIG REQUIRED)
 find_package(KF6Holidays ${KF_MIN_VERSION} REQUIRED)
diff --git a/src/mail/CMakeLists.txt b/src/mail/CMakeLists.txt
index 00e709aa4..b97615bcc 100644
--- a/src/mail/CMakeLists.txt
+++ b/src/mail/CMakeLists.txt
@@ -68,7 +68,7 @@ target_link_libraries(merkuro_mail_static
         KPim6::AkonadiSearchPIM
         KPim6::IdentityManagementQuick
         KPim6::Mbox
-        KPim6::Mime
+        KF6::Mime
         KPim6::Libkdepim
         KPim6::PimCommonAkonadi
         KPim6::MimeTreeParserCore
