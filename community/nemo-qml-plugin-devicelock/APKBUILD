maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=nemo-qml-plugin-devicelock
pkgver=0.4.8
pkgrel=0
pkgdesc="Nemo QML devicelock plugin"
url="https://github.com/sailfishos/nemo-qml-plugin-devicelock"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="BSD-3-Clause"
depends_dev="
	elogind-dev
	nemo-keepalive-dev
	nemo-qml-plugin-dbus-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	"
makedepends="$depends_dev"
subpackages="
	$pkgname-dev
	$pkgname-systemd
	"
source="https://github.com/sailfishos/nemo-qml-plugin-devicelock/archive/$pkgver/nemo-qml-plugin-devicelock-$pkgver.tar.gz"

build() {
	qmake6
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install

	mkdir -p "$pkgdir"/usr/share/dbus-1/system.d/
	mv "$pkgdir"/etc/dbus-1/system.d/* "$pkgdir"/usr/share/dbus-1/system.d/
}

sha512sums="
c30aed074373a7cdf15070904a6f837a7aa7c8fc5fedaf1787cbac6cd6c8dabd30d82efbc8cfcddce0728947d63bbdf5bcb29e5c13b3aa4455ff4131dce61def  nemo-qml-plugin-devicelock-0.4.8.tar.gz
"
