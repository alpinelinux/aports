667463cf66db0f2558571bce8eac90f2b4adccad3187f7b2e2f3faedc4ae38a10a4ae6d7e6692519040e015a6508754ba5264c8851928e54dd27e99a22ca0531  0001-nemo-qml-plugin-devicelock-Qt6.10.patch
