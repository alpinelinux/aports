# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=mousepad
pkgver=0.7.0
pkgrel=0
pkgdesc="Simple Text Editor for Xfce4"
url="https://gitlab.xfce.org/apps/mousepad"
arch="all"
license="GPL-2.0-or-later"
makedepends="abuild-meson glib-dev gspell-dev gtk+3.0-dev gtksourceview4-dev intltool libxfce4ui-dev polkit-dev xfconf-dev"
depends="desktop-file-utils"
subpackages="$pkgname-lang"
source="https://archive.xfce.org/src/apps/mousepad/${pkgver%.*}/mousepad-$pkgver.tar.xz"

build() {
	abuild-meson \
		-Dtest-plugin=enabled \
		. output
	meson compile -C output
}

check() {
	meson test -v -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
ac89e64b48e60643a3d261f80732551d014426ac851fc2f58cefc96f11b85ea0b2dcf6d890b257bbe02b79bf68e3204990b436da6c34deaa9bb676d399b310bb  mousepad-0.7.0.tar.xz
"
