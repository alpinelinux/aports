# Contributor: Luca Weiss <luca@lucaweiss.eu>
# Maintainer: Luca Weiss <luca@lucaweiss.eu>
pkgname=libayatana-appindicator-glib
pkgver=2.0.3
pkgrel=0
pkgdesc="Ayatana Application Indicators Shared Library"
url="https://github.com/AyatanaIndicators/libayatana-appindicator-glib"
arch="all"
license="GPL-3.0-only"
checkdepends="
	dbus-test-runner
	"
makedepends="
	cmake
	cmake-extras
	gi-docgen
	glib-dev
	gobject-introspection-dev
	samurai
	vala
	"
subpackages="$pkgname-dev $pkgname-doc"
source="https://github.com/AyatanaIndicators/libayatana-appindicator-glib/archive/$pkgver/libayatana-appindicator-glib-$pkgver.tar.gz"

build() {
	cmake -B build \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=None \
		-DENABLE_TESTS=ON
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
