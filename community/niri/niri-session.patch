niri-session is a wrapper over systemctl/dinitctl to start a user service;
however, it's being used for display managers in /usr/share/wayland-sessions,
so instead we should launch niri directly when there's no user service detected

diff --git a/resources/niri-session b/resources/niri-session
index 49dc4c9..8773bca 100755
--- a/resources/niri-session
+++ b/resources/niri-session
@@ -67,5 +67,6 @@ elif hash dinitctl >/dev/null 2>&1; then
     # Start niri
     dinitctl --user start niri
 else
-    echo "No systemd or dinit detected, please use niri --session instead."
+    echo "No systemd or dinit detected, launching niri --session instead."
+    exec niri --session
 fi
