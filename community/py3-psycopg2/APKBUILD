# Contributor: Fabian Affolter <fabian@affolter-engineering.ch>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-psycopg2
pkgver=2.9.12
pkgrel=0
pkgdesc="PostgreSQL adapter for python"
url="http://initd.org/psycopg"
arch="all"
license="LGPL-2.0-or-later"
makedepends="
	libpq-dev
	python3-dev
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/psycopg2/psycopg2-$pkgver.tar.gz"
builddir="$srcdir/psycopg2-$pkgver"
options="!check" # Requires running database

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	make check
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
0d37b51408298baad8b2b095af24b1c0d0b67ba99a2532ed7344a931c6f4d431be9c21c94811eace1b4418899f070f80e80266bfe0386aac2e64289ab1b8862e  psycopg2-2.9.12.tar.gz
"
