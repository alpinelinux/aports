# Maintainer: Haelwenn (lanodan) Monnier <contact+alpine@hacktivis.me>
pkgname=py3-graphemeu
pkgver=0.10.0
pkgrel=0
pkgdesc="Unicode grapheme helpers"
url="https://github.com/timendum/grapheme"
arch="noarch"
license="MIT"
depends="python3"
makedepends="py3-gpep517 py3-hatchling"
checkdepends="py3-pytest py3-pytest-cov"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://files.pythonhosted.org/packages/source/g/graphemeu/graphemeu-$pkgver.tar.gz"
builddir="$srcdir/graphemeu-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
a204ccfc3d9d3133d48dd80daf9d1fe66e2098f36e860f39df7de118ade0e0ae3d714086ae09b4a85c11d2a2447fcbbaf4be678b4bd540bd1bc449c2e0571b1e  py3-graphemeu-0.10.0.tar.gz
"
