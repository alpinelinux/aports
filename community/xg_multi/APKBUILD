# Contributor: macmpi <spam@ipik.org>
# Maintainer: macmpi <spam@ipik.org>
pkgname=xg_multi
pkgver=1.0
pkgrel=0
pkgdesc="Extended Multifunction USB-gadget"
url="https://github.com/macmpi/xg_multi"
arch="noarch"
license="MIT"
source="$pkgname-$pkgver.tar.gz::https://github.com/macmpi/xg_multi/archive/refs/tags/v$pkgver.tar.gz"
# does not have any tests
options="!check"
subpackages="$pkgname-doc $pkgname-openrc $pkgname-systemd:systemd:noarch"

package() {
	install -D -m755 "$builddir"/$pkgname "$pkgdir"/usr/bin/$pkgname
	install -D -m755 "$builddir"/services/openrc/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -D -m644 "$builddir"/services/openrc/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
	install -D -m644 "$builddir"/LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

systemd() {
	pkgdesc="$pkgdesc (systemd files)"
	install_if="systemd $pkgname=$pkgver-r$pkgrel"
	
	install -D -m644 "$builddir"/services/systemd/$pkgname.service "$subpkgdir"/usr/lib/systemd/system/$pkgname.service
	install -D -m644 "$builddir"/services/systemd/$pkgname.default "$subpkgdir"/etc/default/$pkgname
}

sha512sums="
180054af847942f57784f19706ea0742bf2760d36cfc51c274100caa3774485efdac76d56211e0f57eab59b71474265673d45fa87756a4d9af9649eadf6b7618  xg_multi-1.0.tar.gz
"

