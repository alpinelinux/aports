# Maintainer: qaqland <qaq@qaq.land>
maintainer="qaqland <qaq@qaq.land>"
pkgname=serie
pkgver=0.8.0
pkgrel=0
pkgdesc="A rich git commit graph in your terminal"
url="https://github.com/lusingander/serie"
arch="all"
license="MIT"
depends="git"
makedepends="cargo cargo-auditable"
subpackages="$pkgname-doc"
source="https://github.com/lusingander/serie/archive/v$pkgver/serie-$pkgver.tar.gz"
options="net" # cargo fetch

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin
	install -Dm644 README.md -t "$pkgdir"/usr/share/doc/$pkgname
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname
}

sha512sums="
64dd7f0220b8b97344ecfed50037224b8cf688b2a6a1a5c4ad88219ed1a90116ce609d98a54223ee58be89be484a42b8ced17d33754cdedae2ac77c44f714653  serie-0.8.0.tar.gz
"
