# Contributor: knuxify <knuxify@gmail.com>
# Maintainer: knuxify <knuxify@gmail.com>
pkgname=memray
pkgver=1.19.3
pkgrel=0
pkgdesc="Memray is a memory profiler for Python"
url="https://bloomberg.github.io/memray/"
arch="x86_64 aarch64"  # segfault in test suite or test failures on other arches, TODO
license="Apache-2.0"
depends="py3-jinja2 py3-rich py3-textual"
makedepends="npm py3-setuptools cython python3-dev py3-gpep517 py3-wheel py3-pkgconfig libunwind-dev lz4-dev"
checkdepends="py3-greenlet py3-pytest py3-pytest-textual-snapshot ipython"
subpackages="$pkgname-pyc"
_libbacktrace_commit="7e2b7da3d6568d2e4e78658f22e701746a48d7e1"
source="https://github.com/bloomberg/memray/archive/v$pkgver/memray-$pkgver.tar.gz
	https://github.com/ianlancetaylor/libbacktrace/archive/$_libbacktrace_commit/libbacktrace-$_libbacktrace_commit.tar.gz
	no-debuginfod.patch
	npm-ci.patch
	"

prepare() {
	default_prepare
	rm -r "$builddir"/src/vendor/libbacktrace
	mv "$srcdir"/libbacktrace-$_libbacktrace_commit "$builddir"/src/vendor/libbacktrace

	# Apply vendored libbacktrace patches... except for the debuginfod one
	rm "$builddir"/src/vendor/libbacktrace-patches/0002-Add-debuginfod-support-to-libbacktrace.patch
	cd "$builddir"/src/vendor/libbacktrace
	local f; for f in "$builddir"/src/vendor/libbacktrace-patches/*.patch; do
		patch -p1 -i "$f"
	done
}

build() {
	make
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl

	make check-js

	# test_attach.py: requires elevated privileges
	# test_hybrid_stack_*: likely fail due to memray not seeing debug symbols?
	# test_tui_reporter, TestTUILooks: flaky
	.testenv/bin/python3 -m pytest -v --log-cli-level=info \
		--ignore=tests/integration/test_attach.py \
		--ignore=tests/unit/test_tui_reporter.py \
		--deselect=tests/integration/test_native_tracking.py::test_hybrid_stack_in_pure_python \
		--deselect=tests/integration/test_native_tracking.py::test_hybrid_stack_in_pure_python_with_callbacks \
		--deselect=tests/integration/test_native_tracking.py::test_hybrid_stack_of_allocations_inside_ceval \
		--deselect=tests/integration/test_native_tracking.py::test_hybrid_stack_in_recursive_python_c_call \
		--deselect=tests/integration/test_native_tracking.py::test_hybrid_stack_in_a_thread \
		--deselect=tests/integration/test_native_tracking.py::test_hybrid_stack_of_python_thread_starts_with_native_frames \
		--deselect=tests/unit/test_tree_reporter.py::TestTUILooks \
		tests
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

