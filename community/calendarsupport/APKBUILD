b2fc18427fd3c2053d2cf16e029c58f35728a0319a72d10871e16046dfef65e1616befde67d89e2f41be1e2f030365641212a530cfedc263acd3dbd5d4d9f7ae  0001-calendarsupport-KMime-from-KF6.patch
"
