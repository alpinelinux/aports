From 950617864d47753c44b157f55b15e3eb504007dd Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Sun, 3 May 2026 12:51:47 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt                     |  6 +++++-
 KPimCalendarSupportConfig.cmake.in | 15 ++++++++++++++-
 src/CMakeLists.txt                 |  2 +-
 3 files changed, 20 insertions(+), 3 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 6945115..4f55043 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -91,7 +91,11 @@ find_package(
 find_package(KF6I18n ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6GuiAddons ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6KIO ${KF_MIN_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KF6Codecs ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KPim6CalendarUtils ${CALENDARUTILS_LIB_VERSION} CONFIG REQUIRED)
 find_package(KF6CalendarCore ${KF_MIN_VERSION} CONFIG REQUIRED)
diff --git a/KPimCalendarSupportConfig.cmake.in b/KPimCalendarSupportConfig.cmake.in
index af609b6..dae5bc4 100644
--- a/KPimCalendarSupportConfig.cmake.in
+++ b/KPimCalendarSupportConfig.cmake.in
@@ -3,7 +3,20 @@
 
 @PACKAGE_INIT@
 include(CMakeFindDependencyMacro)
-find_dependency(KPim6Mime "@KMIME_LIB_VERSION@")
+if(@KF6Mime_FOUND@)
+    find_dependency(
+        KF6Mime
+        "@KF_MIN_VERSION@"
+    )
+else()
+    find_dependency(
+        KPim6Mime
+        "@KPIM_MIME_VERSION@"
+    )
+    if(NOT TARGET KF6::Mime)
+        add_library(KF6::Mime ALIAS KPim6::Mime)
+    endif()
+endif()
 find_dependency(KPim6IdentityManagementCore "@IDENTITYMANAGEMENT_LIB_VERSION@")
 find_dependency(KPim6AkonadiCalendar "@AKONADICALENDAR_LIB_VERSION@")
 find_dependency(Qt6PrintSupport "@QT_REQUIRED_VERSION@")
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index dd4a628..750c4e6 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -103,7 +103,7 @@ target_include_directories(
 target_link_libraries(
     KPim6CalendarSupport
     PUBLIC
-        KPim6::Mime
+        KF6::Mime
         KPim6::IdentityManagementCore
         KPim6::AkonadiCalendar
         KF6::ConfigGui
-- 
2.54.0

