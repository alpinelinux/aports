From d796008fb297e1c3ee6f1847913daf2487566e83 Mon Sep 17 00:00:00 2001
From: Matt Wozniski <mwozniski@bloomberg.net>
Date: Wed, 24 Dec 2025 11:37:12 -0500
Subject: [PATCH] Include `resources` package when building wheels

This had been included when building the sdist with `poetry-core` 1.x,
but is not included in the built wheel if `poetry-core` 2.x is used.

Per the `poetry` documentation, `include` defaults to including files
only in the sdist, not in the wheel.

Patch-Source: https://github.com/Textualize/pytest-textual-snapshot/pull/26
--- knuxify: removed version bump ---
---
 pyproject.toml | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/pyproject.toml b/pyproject.toml
index a36204b..fd877c3 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -26,7 +26,9 @@ classifiers = [
     "Operating System :: OS Independent",
     "License :: OSI Approved :: MIT License"
 ]
-include = ["resources/**/*"]
+include = [
+    { path = "resources/**/*", format = ["sdist", "wheel"] }
+]
 
 [tool.poetry.dependencies]
 python = "^3.8.1"
-- 
2.53.0

