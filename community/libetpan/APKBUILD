# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=libetpan
pkgver=1.10
pkgrel=0
pkgdesc="a portable middleware for email access"
url="http://www.etpan.org/"
arch="all"
license="custom:etpan"
subpackages="$pkgname-dev $pkgname-doc"
makedepends="cyrus-sasl-dev curl-dev expat-dev gnutls-dev libgcrypt-dev
	libgpg-error-dev autoconf automake libtool zlib-dev"
depends_dev="cyrus-sasl-dev"
source="libetpan-$pkgver.tar.gz::https://github.com/dinhviethoa/libetpan/archive/$pkgver.tar.gz
	fix-build.patch
	"

# secfixes:
#   1.9.4-r1:
#     - CVE-2020-15953

prepare() {
	default_prepare
	touch README
	autoreconf -fi
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--with-gnutls=yes \
		--with-openssl=no \
		--with-gnutls \
		--disable-static
	make
}

check() {
	make check
}

package() {
	cd "$srcdir"/$pkgname-$pkgver
	make DESTDIR="$pkgdir" install
	install -Dm644 COPYRIGHT "$pkgdir"/usr/share/licenses/$pkgname/license.txt
}

