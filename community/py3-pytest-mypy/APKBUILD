maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-pytest-mypy
pkgver=1.0.1
pkgrel=0
pkgdesc="Pytest plugin for mypy"
url="https://github.com/realpython/pytest-mypy"
arch="noarch"
license="MIT"
depends="
	py3-attrs
	py3-filelock
	py3-mypy
	py3-pytest
	"
makedepends="
	py3-gpep517
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="
	py3-pexpect
	py3-pytest-xdist
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/realpython/pytest-mypy/archive/refs/tags/v$pkgver.tar.gz
	timeout.patch
	"
builddir="$srcdir/pytest-mypy-$pkgver"

build() {
	SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver \
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -k "not (encoding_warnings or py_typed or looponfail)" -n auto
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1234fcb16b6fca7c9323d1e9c105177e2cd9aac078454ee18b004f8a31bcd7d1b999bf4d6d6db74bec2c6a70c86cad5893dade9cac7aacb85080b40e081b6653  py3-pytest-mypy-1.0.1.tar.gz
4c156b044d189ff51b4efb0fdad1f60fb73bdddfc026da94df0e7f774df31f3e54b0b6471c1bd625a7c481b4f410c2a08567676856e1ce44782bae273391782b  timeout.patch
"
