# Maintainer: Peter Shkenev <santurysim@gmail.com>
pkgname=execline-man-pages
pkgver=2.9.8.1.3
pkgrel=0
pkgdesc="Unofficial mdoc versions of the execline documentation"
url="https://git.sr.ht/~humm/execline-man-pages"
arch="noarch"
license="ISC"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~humm/execline-man-pages/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-v$pkgver"
options="!check" # no tests
install_if="execline>=${pkgver%.*} docs"

package() {
	make DESTDIR="$pkgdir" install

	find "$pkgdir" -type f ! -name "*.gz" \
		-exec gzip -9 {} \;
}

sha512sums="
a4b4a0b4cd3a85dc2d2b916260e1d8641afc422c41781578232037cb90f709a0df7ed2cf33cf05c08793c5076dc49cb694ae45206a390690e15b450b90a508a8  execline-man-pages-2.9.8.1.3.tar.gz
"
