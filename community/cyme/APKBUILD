# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=cyme
pkgver=2.3.0
pkgrel=0
pkgdesc="modern lsusb that attempts to maintain compatibility, but also adds new features"
url="https://github.com/tuna-f1sh/cyme"
license="GPL-3.0-or-later"
# s390x runtime error: Nusb Error: /sys/bus/usb/devices/ not found (errno 2)
arch="all !s390x"
makedepends="cargo cargo-auditable eudev-dev"
subpackages="$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/tuna-f1sh/cyme/archive/refs/tags/v$pkgver.tar.gz"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen --no-default-features \
		--features  nusb,udevlib,regex_icon,watch,bin
	# the above are the default but with udevliv
	# as pure rust udev fails to build
}

check() {
	cargo test --frozen --no-default-features \
		--features  nusb,udevlib,regex_icon,watch,bin
}

package() {
	install -Dm0755 -t "$pkgdir"/usr/bin/ target/release/"$pkgname"


	install -Dm0755 -t "$pkgdir"/usr/share/doc/"$pkgname"/ \
		doc/cyme_example_config.json
	install -Dm0755 -t "$pkgdir"/usr/share/man/man1/ doc/"$pkgname".1

	install -Dm0644 doc/"$pkgname".bash \
		"$pkgdir"/usr/share/bash-completion/completions/"$pkgname"
	install -Dm0644 -t "$pkgdir"/usr/share/fish/vendor_completions.d/ \
		doc/"$pkgname".fish
	install -Dm0644 -t "$pkgdir"/usr/share/zsh/site-functions/ \
		doc/_"$pkgname"
}

sha512sums="
934e042dcc5292354a01f8884ca56b09a553c800fa1997270fd28b7288c1f4d1af481f5361f2b45ffdee6f1b636b9ac3ed7974b8932e436f90bc3d67ad78a6fa  cyme-2.3.0.tar.gz
"
