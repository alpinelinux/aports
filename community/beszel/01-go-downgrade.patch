From a906c87bd5ac6cc630b3c373429ec1b3cc9069d2 Mon Sep 17 00:00:00 2001
From: minoplhy <c@3qx.nl>
Date: Tue, 7 Apr 2026 03:50:22 +0700
Subject: [PATCH] Downgrade Go code format to below 1.26.0

Go 1.26 has update some of its code format that made it not compatible with Go version 1.25.5 .

This patch is based on commit : https://github.com/henrygd/beszel/commit/04600d83cc01b1c009f4f8dccb60d4c7754a7bd
---
 agent/smart.go | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/agent/smart.go b/agent/smart.go
index 9de1e8f4..ab2baab9 100644
--- a/agent/smart.go
+++ b/agent/smart.go
@@ -6,7 +6,6 @@ package agent
 import (
 	"context"
 	"encoding/json"
-	"errors"
 	"fmt"
 	"log/slog"
 	"os"
@@ -493,7 +492,7 @@ func (sm *SmartManager) CollectSmart(deviceInfo *DeviceInfo) error {
 	output, err := cmd.CombinedOutput()
 
 	// Check if device is in standby (exit status 2)
-	if exitErr, ok := errors.AsType[*exec.ExitError](err); ok && exitErr.ExitCode() == 2 {
+	if exitErr, ok := err.(*exec.ExitError); ok && exitErr.ExitCode() == 2 {
 		if hasExistingData {
 			// Device is in standby and we have cached data, keep using cache
 			return nil
-- 
2.53.0

