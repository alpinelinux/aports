# Maintainer: Peter Shkenev <santurysim@gmail.com>
pkgname=tipidee-man-pages
pkgver=0.0.7.1.3
pkgrel=0
pkgdesc="Unofficial mdoc versions of the tipidee documentation"
url="https://git.sr.ht/~humm/tipidee-man-pages"
arch="noarch"
license="ISC"
options="!check" # no tests
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~humm/tipidee-man-pages/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-v$pkgver"
install_if="tipidee>=${pkgver%.*} docs"

package() {
	make DESTDIR="$pkgdir" install

	find "$pkgdir" -type f ! -name "*.gz" \
		-exec gzip -9 {} \;
}

sha512sums="
