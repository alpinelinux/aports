# Contributor: Anjandev Momi <anjan@momi.ca>
# Maintainer: Adam Thiede <me@adamthiede.com>
pkgname=river
pkgver=0.4.5
pkgrel=0
pkgdesc="Non-monolithic Wayland compositor"
url="https://codeberg.org/river/river"
arch="x86_64 aarch64" # limited by zig aport
license="GPL-3.0-only"
makedepends="
	libevdev-dev
	libxkbcommon-dev
	pixman-dev
	scdoc
	wayland-dev
	wayland-protocols
	wlroots0.20-dev
	zig
	"
depends="xwayland seatd"
subpackages="
	$pkgname-dev
	$pkgname-doc
	"
options="net"
source="
	https://codeberg.org/river/river/releases/download/v$pkgver/river-$pkgver.tar.gz
	"

_buildzigflags="-Dpie -Dxwayland -Dllvm -Dcpu=baseline"

build() {
	# This installs it to $builddir/out
	DESTDIR="$builddir/out" zig build \
		-Doptimize=ReleaseSafe \
		$_buildzigflags \
		--prefix /usr install
}

check() {
	zig build test $_buildzigflags
}

package() {
	mkdir -p "$pkgdir"
	cp -r out/* "$pkgdir"

	# Fix location of pkgconfig files, must be fixed upstream
	mkdir -p "$pkgdir"/usr/lib
	mv "$pkgdir"/usr/share/pkgconfig "$pkgdir"/usr/lib
}

dev() {
	default_dev
	amove usr/share/river-protocols
}

sha512sums="
30e7f0a1d881f5208e6f4f028d03c75d2c6ab86e10fcfee324fc89594a57385207d6ba003082cb8797c6d6b0091ac47f9bb03f07a9c6e1a05b8675413916ee8e  river-0.4.5.tar.gz
"
