Patch-Source: https://github.com/protocolbuffers/protobuf/pull/25363
From 714383464de5bafdafafa7e5b0ad3a9c92287b45 Mon Sep 17 00:00:00 2001
From: Jonathan Albrecht <jonathan.albrecht@ibm.com>
Date: Thu, 15 Jan 2026 16:08:46 -0500
Subject: [PATCH 1/2] Fix an endian problem in upb that caused protoc plugins
 to crash on big endian platforms

---
 upb/wire/decode.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/upb/wire/decode.c b/upb/wire/decode.c
index 55420a3a128e7..9b050866b45ea 100644
--- a/upb/wire/decode.c
+++ b/upb/wire/decode.c
@@ -938,6 +938,7 @@ const char* _upb_Decoder_DecodeWireValue(upb_Decoder* d, const char* ptr,
           *op = kUpb_DecodeOp_UnknownField;
           return ptr;
         }
+        _upb_Decoder_MungeInt32(val);
       } else {
         _upb_Decoder_Munge(field, val);
       }

From bf11f031572636578749e1bb6421f6f07000a7a6 Mon Sep 17 00:00:00 2001
From: Jonathan Albrecht <jonathan.albrecht@ibm.com>
Date: Tue, 3 Feb 2026 15:07:37 -0500
Subject: [PATCH 2/2] Fix an endian problem when memcpying in
 _upb_Decoder_DecodeEnumPacked

---
 upb/wire/decode.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/upb/wire/decode.c b/upb/wire/decode.c
index 9b050866b45ea..0810ba3e6116b 100644
--- a/upb/wire/decode.c
+++ b/upb/wire/decode.c
@@ -359,6 +359,7 @@ static const char* _upb_Decoder_DecodeEnumPacked(
       _upb_Decoder_AddEnumValueToUnknown(d, msg, field, &elem);
       continue;
     }
+    _upb_Decoder_MungeInt32(&elem);
     if (_upb_Decoder_Reserve(d, arr, 1)) {
       out = UPB_PTR_AT(upb_Array_MutableDataPtr(arr),
                        arr->UPB_PRIVATE(size) * 4, void);
