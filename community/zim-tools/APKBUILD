# Contributor: Oleg Titov <oleg.titov@gmail.com>
# Maintainer: Oleg Titov <oleg.titov@gmail.com>
pkgname=zim-tools
pkgver=3.7.0
pkgrel=0
pkgdesc="Various ZIM command line tools"
url="https://github.com/openzim/zim-tools"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	docopt-cpp-dev
	file-dev
	gtest-dev
	gumbo-parser-dev
	libzim-dev
	meson
	mustache
	zlib-dev
	"
replaces="zimwriterfs"
provides="zimwriterfs=$pkgver-r$pkgrel"
subpackages="$pkgname-doc"
source="zim-tools-$pkgver.tar.gz::https://github.com/openzim/zim-tools/archive/$pkgver.tar.gz"

build() {
	abuild-meson . output
	meson compile -C output
}

check() {
	meson test -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output

	install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}

sha512sums="
c6ef75b3627146db801b1da025749a1245ec7b40eb13105b87c5fef6f853e0134869bdf3fc2895f0036eb391a31bc4663e8b86c922461190b23b8dca1cad6432  zim-tools-3.7.0.tar.gz
"
