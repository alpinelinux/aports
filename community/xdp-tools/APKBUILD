356614cb02cfd3b1abb7f8b5eca60b8dc7ae92b30818419ae7998b77ef06ed5302a99828b8bd0382642711ca71cd4f2b87d59a5af10e59926dfce4b027c258e2  musl-fix-ethhdr-redefinition.patch
"
