maintainer="Wiktor Kwapisiewicz <wiktor@metacode.biz>"
pkgname=py3-pysequoia
pkgver=0.1.33
pkgrel=0
pkgdesc="Python bindings for the Sequoia PGP library"
url="https://github.com/wiktor-k/pysequoia"
arch="all"
license="Apache-2.0"
makedepends="
	cargo
	py3-gpep517
	py3-maturin
	py3-wheel
	python3-dev
	"
checkdepends="
	py3-pytest
	"
subpackages="$pkgname-pyc"
source="
	$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz
	"
builddir="$srcdir/pysequoia-$pkgver"
options="net" # cargo

prepare() {
	default_prepare

	cargo fetch --locked
}

build() {
	# Increase stack size to avoid cargo build failure
	# see: https://github.com/RustCrypto/elliptic-curves/issues/1097#issuecomment-2435508686
	export RUST_MIN_STACK="4194304"

	gpep517 build-wheel \
		--wheel-dir .dist \
		--config-json '{"build-args": "--frozen"}' \
		--output-fd 3 3>&1 >&2
}

check() {
	# RustCrypto crates are extremely slow unoptimized so run the tests in release mode
	cargo test --release
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
d23ef22b3f1a0c802a08b5ef9d38ab1037b37c56ec79475954a2e8194626aed0cf419ba5dbfdd11f4162f2e61a7138844504eedee0655ab9a0a20b3a1f9b20b6  py3-pysequoia-0.1.33.tar.gz
"
