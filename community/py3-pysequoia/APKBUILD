maintainer="Wiktor Kwapisiewicz <wiktor@metacode.biz>"
pkgname=py3-pysequoia
pkgver=0.1.34
pkgrel=0
pkgdesc="Python bindings for the Sequoia PGP library"
url="https://github.com/wiktor-k/pysequoia"
arch="all"
license="Apache-2.0"
makedepends="
	cargo
	py3-gpep517
	py3-maturin
	py3-wheel
	python3-dev
	"
checkdepends="
	py3-pytest
	"
subpackages="$pkgname-pyc"
source="
	$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz
	"
builddir="$srcdir/pysequoia-$pkgver"
options="net" # cargo

# secfixes:
#   0.1.34-r0:
#     - CVE-2026-2625

prepare() {
	default_prepare

	cargo fetch --locked
}

build() {
	# Increase stack size to avoid cargo build failure
	# see: https://github.com/RustCrypto/elliptic-curves/issues/1097#issuecomment-2435508686
	export RUST_MIN_STACK="4194304"

	gpep517 build-wheel \
		--wheel-dir .dist \
		--config-json '{"build-args": "--frozen"}' \
		--output-fd 3 3>&1 >&2
}

check() {
	# RustCrypto crates are extremely slow unoptimized so run the tests in release mode
	cargo test --release
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
460ca8079d087aa80678b3ff3d592fa0c06ca2c1c4ef64a85df7b3c6ab7594471badb1f786cacf6b41d4a9f0d154a004a4914857a5fa5837fbdef7fcc0d57780  py3-pysequoia-0.1.34.tar.gz
"
