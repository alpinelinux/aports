d3c7fb3c253aa1385fb696407c2d11b0e7d455abbb752fd3725e8e1f28fe2bfffd97faaaac56ad03e8ca3444aa63d75d780ac21e7322001561efdbb4a21f341b  ignore-asyncio-iscoroutinefunction-deprecation.patch
"
