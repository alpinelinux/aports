# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=py3-aiofiles
_pkgname=aiofiles
pkgver=25.1.0
pkgrel=0
pkgdesc="File support for asyncio"
url="https://github.com/Tinche/aiofiles"
arch="noarch"
license="Apache-2.0"
depends="python3"
makedepends="py3-gpep517 py3-hatchling py3-installer py3-hatch-vcs"
checkdepends="py3-pytest py3-pytest-asyncio"
subpackages="$pkgname-pyc"
source="$_pkgname-$pkgver.tar.gz::https://github.com/Tinche/aiofiles/archive/v$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
75ef47b4dc5af0158a51bbb83235f3acd90d51ec09583ddbc67da2bda5815354b02ba1769fac6b5f64572804c0436387de927de7a507101df5adb85a55817d04  aiofiles-25.1.0.tar.gz
"
