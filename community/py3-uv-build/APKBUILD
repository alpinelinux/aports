# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-uv-build
pkgver=0.11.26
pkgrel=0
pkgdesc="An extremely fast Python build backend written in Rust"
url="https://github.com/astral-sh/uv"
arch="all"
license="MIT or Apache-2.0"
depends="python3"
makedepends="py3-gpep517 py3-wheel py3-installer py3-maturin cargo"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/u/uv-build/uv_build-$pkgver.tar.gz"
builddir="$srcdir/uv_build-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -c "import uv_build; print('uv_build imported successfully')"
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
3331e4195fc72543fb546f4a86e2eeb036277ceebba37151a3faaefb921c8508d99e8bc25dacd57eb26a8744b1b76f2b90df4dff97450e97518fcd5ca80fe287  uv_build-0.11.26.tar.gz
"
