# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=weasyprint
pkgver=69.0
pkgrel=0
pkgdesc="A visual rendering engine for HTML and CSS that can export to PDF"
url="https://weasyprint.org"
arch="noarch"
license="BSD-3-Clause"
depends="
	harfbuzz-subset
	pango
	py3-brotli
	py3-cffi
	py3-cssselect2
	py3-fonttools
	py3-pillow
	py3-pydyf
	py3-pyphen
	py3-tinycss2
	py3-tinyhtml5
	py3-zopfli
	"
makedepends="
	py3-flit-core
	py3-gpep517
	"
checkdepends="
	font-dejavu
	ghostscript
	py3-pytest
	"
replaces="py-weasyprint py3-weasyprint"  # for backward compatibility
provides="py-weasyprint=$pkgver-r$pkgrel py3-weasyprint=$pkgver-r$pkgrel"  # for backward compatibility
subpackages="$pkgname-pyc"
source="
	https://files.pythonhosted.org/packages/source/w/weasyprint/weasyprint-$pkgver.tar.gz
	"

# secfixes:
#   69.0-r0:
#     - CVE-2026-49452

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	# FIXME test_api.py fails on s390x
	# the gradient tests fails with ghostscript 10.07.0
	pytest \
		--deselect tests/test_api.py::test_to_unicode_rtl \
		--deselect tests/draw/svg/test_bounding_box.py::test_bounding_box_circle \
		--deselect tests/draw/svg/test_bounding_box.py::test_bounding_box_ellipse \
		--deselect tests/draw/svg/test_gradients.py::test_linear_gradient_transform_repeat \
		--deselect tests/draw/svg/test_gradients.py::test_linear_gradient_transform_repeat_userspace \
		--deselect tests/draw/svg/test_gradients.py::test_radial_gradient_repeat \
		--deselect tests/draw/svg/test_gradients.py::test_radial_gradient_reflect \
		--deselect tests/draw/test_background.py::test_canvas_background_size \
		--deselect tests/draw/test_gradient.py::test_linear_gradients_5 \
		--deselect tests/draw/test_gradient.py::test_radial_gradients_negative

}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/weasyprint-$pkgver-py3-none-any.whl
}

sha512sums="
fb56d7f6173f8a67f8ef4c31408c03625b0a774d0efde003f779e3da054737c88afe9f44ee40b6dda5fc92cfacfa5709d4d96bf1a112862d309eaf2d93881ef6  weasyprint-69.0.tar.gz
"
