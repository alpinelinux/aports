b38aaf0dd9db0daffcb0a9d289ea3b3860ab5b00c33522b8024ec7505cb264c7ddfc7e6a8c9f11df9f7ab86b08b17c22074bbdd5d5c8a2dcfb24aa6e92f25b85  completion-rename-to-go-task.patch
bb0b65b6cfe5dfce91904bb6b639b26272db60a030d3361fba672278c946116174fe4e25048747aa1381fc7de9a7ba565d5e2dec7a051f81ad084f06a7a36943  test-failfast-task-fix-race-condition.patch
"
