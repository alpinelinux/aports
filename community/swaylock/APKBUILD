# Contributor: Henrik Riomar <henrik.riomar@gmail.com>
maintainer="Michał Polański <michal@polanski.me>"
pkgname=swaylock
pkgver=1.8.6
pkgrel=0
pkgdesc="Screen locker for Wayland"
url="https://swaywm.org/"
license="MIT"
arch="all"
pkggroups="shadow"
makedepends="cairo-dev
	gdk-pixbuf-dev
	libxkbcommon-dev
	linux-pam-dev
	meson
	ninja
	scdoc
	wayland-dev
	wayland-protocols
	"
provider_priority=100  # highest (other provider is swaylock-effects)
subpackages="
	$pkgname-dbg
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	$pkgname-shadow
	$pkgname-openrc
	"
source="https://github.com/swaywm/swaylock/archive/v$pkgver/swaylock-$pkgver.tar.gz
	swaylock.initd
	"
# !check: no test suite
# suid: -shadow subpackage
options="!check $pkgname-shadow::suid"

# secfixes:
#   1.6-r0:
#     - CVE-2022-26530

prepare() {
	default_prepare
	sed -i 's/login/base-auth/g' \
		pam/swaylock

	cat <<-__EOF__ >> pam/swaylock

	# Unlock GNOME Keyring if available
	-auth       optional     pam_gnome_keyring.so
	-session    optional     pam_gnome_keyring.so auto_start

	# Unlock KWallet if available
	-auth    optional        pam_kwallet5.so
	-session optional        pam_kwallet5.so auto_start
	__EOF__
}

build() {
	abuild-meson . output
	meson compile -C output

	abuild-meson -Dpam=disabled . output-shadow
	ninja -C output-shadow swaylock
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output

	install -Dm755 "$srcdir"/swaylock.initd "$pkgdir"/etc/user/init.d/swaylock
}

shadow() {
	pkgdesc="$pkgdesc (shadow backend)"
	provides="$pkgname=$pkgver-r$pkgrel"
	# Never select this backend automatically
	provider_priority=0

	install -D -m2755 -g shadow "$builddir"/output-shadow/swaylock "$subpkgdir"/usr/bin/swaylock
}

sha512sums="
