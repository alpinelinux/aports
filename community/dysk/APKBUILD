maintainer="Michał Polański <michal@polanski.me>"
pkgname=dysk
pkgver=3.6.0
_pkgver=${pkgver}b # release tag has "b" suffix for some reason
pkgrel=0
pkgdesc="Get information on your mounted disks"
url="https://github.com/Canop/dysk"
license="MIT"
arch="all"
makedepends="cargo cargo-auditable"
subpackages="
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="https://github.com/Canop/dysk/archive/v$_pkgver/dysk-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$_pkgver"
options="net" # cargo fetch

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --locked
}

check() {
	cargo test --locked
}

package() {
	cd target/release

	install -Dm755 $pkgname -t "$pkgdir"/usr/bin/

	install -Dm644 build/*/out/$pkgname.1 "$pkgdir"/usr/share/man/man1/$pkgname.1

	install -Dm644 build/*/out/$pkgname.bash "$pkgdir"/usr/share/bash-completion/completions/$pkgname
	install -Dm644 build/*/out/$pkgname.fish "$pkgdir"/usr/share/fish/vendor_completions.d/$pkgname.fish
	install -Dm644 build/*/out/_$pkgname "$pkgdir"/usr/share/zsh/site-functions/_$pkgname
}

sha512sums="
37c8ec3eac4b8304583a9961543223a6609dd7ab892348af42832ff113b7ec457fcbab8784d300ff3401718e31ad1597f4c9d3cab1655ddbc7be7fbe788897ba  dysk-3.6.0.tar.gz
"
