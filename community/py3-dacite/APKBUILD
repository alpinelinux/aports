pkgname=py3-dacite
_pyname=dacite
pkgver=1.9.2
pkgrel=1
arch="noarch"
pkgdesc="This module simplifies creation of data classes (PEP 557) from dictionaries."
url="https://pypi.python.org/project/dacite"
license="MIT"
makedepends="
	py3-setuptools
	py3-gpep517
	py3-wheel
	"
checkdepends="
	py3-pytest
	py3-pytest-benchmark
	py3-pytest-cov
	py3-coveralls
	"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/konradhalas/dacite/archive/refs/tags/v$pkgver.tar.gz
	291_py314-support.patch
	"
builddir="$srcdir"/$_pyname-$pkgver
subpackages="$pkgname-pyc"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
