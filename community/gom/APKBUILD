# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=gom
pkgver=0.5.6
pkgrel=0
pkgdesc="GObject Data Mapper"
url="https://gitlab.gnome.org/GNOME/gom"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	gdk-pixbuf-dev
	glib-dev
	gobject-introspection-dev
	meson
	py3-gobject3
	sqlite-dev
	vala
	"
subpackages="$pkgname-dev $pkgname-pyc"
source="https://download.gnome.org/sources/gom/${pkgver%.*}/gom-$pkgver.tar.xz"

# gom-stress seems to segfault with new glib
options="!check"

build() {
	abuild-meson . output
	meson compile -C output
}

check() {
	# gom-stress tests takes a LOOOONG time
	meson test -C output -t 10
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
230813b70d8ba3aa42c0dd200dcaa8c0308d697eb87b09be244f766a3526b1f31869d069b374329bc6ceedd851c900faa44710a6a97b4ce678304bb39f3e0636  gom-0.5.6.tar.xz
"
