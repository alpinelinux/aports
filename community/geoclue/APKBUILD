# Contributor: Leo <thinkabit.ukim@gmail.com>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=geoclue
pkgver=2.8.1
pkgrel=0
pkgdesc="dbus geolocation service"
url="https://gitlab.freedesktop.org/geoclue/geoclue/-/wikis/home"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	avahi-dev
	gobject-introspection-dev
	json-glib-dev
	libnotify-dev
	libsoup3-dev
	meson
	modemmanager-dev
	vala
	"
subpackages="$pkgname-dev $pkgname-doc $pkgname-systemd"
install="$pkgname.pre-install"
source="https://gitlab.freedesktop.org/geoclue/geoclue/-/archive/$pkgver/geoclue-$pkgver.tar.bz2"

build() {
	abuild-meson \
		-Db_lto=true \
		-Ddbus-srv-user=geoclue \
		-Ddbus-sys-dir=/usr/share/dbus-1/system.d \
		-Dgtk-doc=false \
		-Dintrospection=true \
		-Ddefault-wifi-url=https://api.beacondb.net/v1/geolocate \
		-Ddefault-wifi-submit-url=https://api.beacondb.net/v2/geosubmit \
		-Dsystemd-system-unit-dir=/usr/lib/systemd/system \
		build
	meson compile -C build
}

check() {
	meson test --print-errorlogs -C build
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C build
}

sha512sums="
