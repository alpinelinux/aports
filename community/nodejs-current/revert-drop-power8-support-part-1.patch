From 2697a74ad65054c14cd0133152eef516ed17e79d Mon Sep 17 00:00:00 2001
From: Aelin <aelin@postmarketos.org>
Date: Thu, 11 Jun 2026 04:41:14 +0200
Subject: [PATCH 1/2] Revert "PPC: drop power8 support part 1"

This reverts commit 36b27d42ebd3dd0101d2cd18f344d554a135181f.
---
 deps/v8/src/base/cpu.cc                  | 8 ++++++++
 deps/v8/src/base/cpu.h                   | 2 +-
 deps/v8/src/codegen/cpu-features.h       | 1 +
 deps/v8/src/codegen/ppc/assembler-ppc.cc | 4 ++++
 4 files changed, 14 insertions(+), 1 deletion(-)

diff --git a/deps/v8/src/base/cpu.cc b/deps/v8/src/base/cpu.cc
index f64e1e71bed..519fdba5c14 100644
--- a/deps/v8/src/base/cpu.cc
+++ b/deps/v8/src/base/cpu.cc
@@ -25,6 +25,9 @@
 #endif
 #if V8_OS_AIX
 #include <sys/systemcfg.h>  // _system_configuration
+#ifndef POWER_8
+#define POWER_8 0x10000
+#endif
 #ifndef POWER_9
 #define POWER_9 0x20000
 #endif
@@ -1018,6 +1021,8 @@ CPU::CPU()
       part_ = kPPCPower10;
     } else if (strcmp(auxv_cpu_type, "power9") == 0) {
       part_ = kPPCPower9;
+    } else if (strcmp(auxv_cpu_type, "power8") == 0) {
+      part_ = kPPCPower8;
     }
   }
 
@@ -1029,6 +1034,9 @@ CPU::CPU()
     case POWER_9:
       part_ = kPPCPower9;
       break;
+    case POWER_8:
+      part_ = kPPCPower8;
+      break;
   }
 #endif  // V8_OS_AIX
 #endif  // !USE_SIMULATOR
diff --git a/deps/v8/src/base/cpu.h b/deps/v8/src/base/cpu.h
index 62c65e54031..a6f4971e079 100644
--- a/deps/v8/src/base/cpu.h
+++ b/deps/v8/src/base/cpu.h
@@ -64,7 +64,7 @@ class V8_BASE_EXPORT CPU final {
   static const int kNvidiaDenverV10 = 0x002;
 
   // PPC-specific part codes
-  enum { kPPCPower9, kPPCPower10, kPPCPower11 };
+  enum { kPPCPower8, kPPCPower9, kPPCPower10, kPPCPower11 };
 
   // General features
   bool has_fpu() const { return has_fpu_; }
diff --git a/deps/v8/src/codegen/cpu-features.h b/deps/v8/src/codegen/cpu-features.h
index 0c9afa5c612..da6168b13ed 100644
--- a/deps/v8/src/codegen/cpu-features.h
+++ b/deps/v8/src/codegen/cpu-features.h
@@ -78,6 +78,7 @@ enum CpuFeature {
   LASX,
 
 #elif V8_TARGET_ARCH_PPC64
+  PPC_8_PLUS,
   PPC_9_PLUS,
   PPC_10_PLUS,
   PPC_11_PLUS,
diff --git a/deps/v8/src/codegen/ppc/assembler-ppc.cc b/deps/v8/src/codegen/ppc/assembler-ppc.cc
index 2c9b33f3d84..94c03ac9f95 100644
--- a/deps/v8/src/codegen/ppc/assembler-ppc.cc
+++ b/deps/v8/src/codegen/ppc/assembler-ppc.cc
@@ -100,6 +100,8 @@ void CpuFeatures::ProbeImpl(bool cross_compile) {
 #endif
   } else if (cpu.part() == base::CPU::kPPCPower9) {
     supported_.Add(PPC_9_PLUS);
+  } else if (cpu.part() == base::CPU::kPPCPower8) {
+    supported_.Add(PPC_8_PLUS);
   }
 #if V8_OS_LINUX
   if (cpu.icache_line_size() != base::CPU::kUnknownCacheLineSize) {
@@ -109,6 +111,7 @@ void CpuFeatures::ProbeImpl(bool cross_compile) {
 #endif
   if (supported_.contains(PPC_11_PLUS)) supported_.Add(PPC_10_PLUS);
   if (supported_.contains(PPC_10_PLUS)) supported_.Add(PPC_9_PLUS);
+  if (supported_.contains(PPC_9_PLUS)) supported_.Add(PPC_8_PLUS);
 
   // Set a static value on whether Simd is supported.
   // This variable is only used for certain archs to query SupportWasmSimd128()
@@ -124,6 +127,7 @@ void CpuFeatures::PrintTarget() {
 }
 
 void CpuFeatures::PrintFeatures() {
+  printf("PPC_8_PLUS=%d\n", CpuFeatures::IsSupported(PPC_8_PLUS));
   printf("PPC_9_PLUS=%d\n", CpuFeatures::IsSupported(PPC_9_PLUS));
   printf("PPC_10_PLUS=%d\n", CpuFeatures::IsSupported(PPC_10_PLUS));
   printf("PPC_11_PLUS=%d\n", CpuFeatures::IsSupported(PPC_11_PLUS));
-- 
2.54.0

