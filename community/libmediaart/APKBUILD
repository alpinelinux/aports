# Contributor: Rasmus Thomsen <oss@cogitri.dev>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=libmediaart
pkgver=1.9.7
pkgrel=1
pkgdesc="Media art extraction and cache management library"
url="https://gitlab.gnome.org/GNOME/libmediaart"
arch="all"
license="LGPL-2.1-or-later"
makedepends="meson glib-dev libglycin-dev vala gobject-introspection-dev"
subpackages="$pkgname-dev"
source="https://download.gnome.org/sources/libmediaart/${pkgver%.*}/libmediaart-$pkgver.tar.xz
	add-glycin.patch
	"

build() {
	abuild-meson \
		-Dimage_library=glycin \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

