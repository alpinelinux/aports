From f3cae9cf4c63e07e848b182075ea093b3c4bc53d Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Fri, 17 Apr 2026 17:53:30 +0200
Subject: [PATCH] Add forward compatibility for KMime from KDE Frameworks

---
 CMakeLists.txt                                              | 6 +++++-
 .../messageviewer/bodypartformatter/calendar/CMakeLists.txt | 2 +-
 .../messageviewer/bodypartformatter/gnupgwks/CMakeLists.txt | 2 +-
 plugins/messageviewerheaderplugins/autotests/CMakeLists.txt | 4 ++--
 plugins/messageviewerplugins/autotests/CMakeLists.txt       | 6 +++---
 .../externalscriptplugin/autotests/CMakeLists.txt           | 2 +-
 6 files changed, 13 insertions(+), 9 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 3af7d8bef..1cf8c699b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -138,7 +138,11 @@ set(KPIMITINERARY_LIB_VERSION "6.7.3")
 set(KPIM_MIME_VERSION "6.7.3")
 set(KLDAP_LIB_VERSION "6.7.3")
 
-find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KF6CalendarCore ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KPim6CalendarUtils ${CALENDAR_UTILS_VERSION} CONFIG REQUIRED)
 find_package(KPim6WebEngineViewer ${MESSAGELIB_LIB_VERSION} CONFIG REQUIRED)
diff --git a/plugins/messageviewer/bodypartformatter/calendar/CMakeLists.txt b/plugins/messageviewer/bodypartformatter/calendar/CMakeLists.txt
index ef795ca5b..195dd76ec 100644
--- a/plugins/messageviewer/bodypartformatter/calendar/CMakeLists.txt
+++ b/plugins/messageviewer/bodypartformatter/calendar/CMakeLists.txt
@@ -46,7 +46,7 @@ target_link_libraries(
     Qt::Core
     KF6::CalendarCore
     KPim6::CalendarUtils
-    KPim6::Mime
+    KF6::Mime
     KPim6::IdentityManagementCore
     KPim6::AkonadiMime
     KPim6::MailTransport
diff --git a/plugins/messageviewer/bodypartformatter/gnupgwks/CMakeLists.txt b/plugins/messageviewer/bodypartformatter/gnupgwks/CMakeLists.txt
index e0b8b6235..d2059a9e5 100644
--- a/plugins/messageviewer/bodypartformatter/gnupgwks/CMakeLists.txt
+++ b/plugins/messageviewer/bodypartformatter/gnupgwks/CMakeLists.txt
@@ -51,7 +51,7 @@ target_link_libraries(
     KPim6::MailTransport
     KPim6::GrantleeTheme
     KF6::I18n
-    KPim6::Mime
+    KF6::Mime
     KPim6::IdentityManagementCore
     KF6::TextTemplate
     Gpgmepp
diff --git a/plugins/messageviewerheaderplugins/autotests/CMakeLists.txt b/plugins/messageviewerheaderplugins/autotests/CMakeLists.txt
index 34ef5bc4e..f474f7d9c 100644
--- a/plugins/messageviewerheaderplugins/autotests/CMakeLists.txt
+++ b/plugins/messageviewerheaderplugins/autotests/CMakeLists.txt
@@ -23,7 +23,7 @@ macro(add_messageviewer_header_unittest _source _additional)
         KPim6::Libkleo
         Qt::Test
         KF6::KIOCore
-        KPim6::Mime
+        KF6::Mime
         KPim6::AkonadiCore
         KF6::CalendarCore
         KPim6::GrantleeTheme
@@ -49,7 +49,7 @@ macro(add_messageviewer_header_class_unittest _source)
         KPim6::Libkleo
         Qt::Test
         KF6::KIOCore
-        KPim6::Mime
+        KF6::Mime
         KPim6::AkonadiCore
         KF6::CalendarCore
         KPim6::GrantleeTheme
diff --git a/plugins/messageviewerplugins/autotests/CMakeLists.txt b/plugins/messageviewerplugins/autotests/CMakeLists.txt
index eb4f4cb28..e9f955b0e 100644
--- a/plugins/messageviewerplugins/autotests/CMakeLists.txt
+++ b/plugins/messageviewerplugins/autotests/CMakeLists.txt
@@ -10,7 +10,7 @@ macro(add_kdepim_addons_viewerplugin_unittest _source _additional)
     ecm_add_test(${_test} ${_name}.h
                  TEST_NAME ${_name}
                  NAME_PREFIX "kdepim-addons-"
-                 LINK_LIBRARIES KPim6::MessageViewer KPim6::Libkleo Qt::Test KF6::KIOCore KPim6::Mime
+                 LINK_LIBRARIES KPim6::MessageViewer KPim6::Libkleo Qt::Test KF6::KIOCore KF6::Mime
                  KPim6::AkonadiCore KF6::CalendarCore KPim6::GrantleeTheme KPim6::IncidenceEditor
                  KPim6::AkonadiWidgets KF6::XmlGui KPim6::CalendarSupport KF6::TextTranslator
     )
@@ -29,7 +29,7 @@ macro(add_kdepim_addons_viewerplugin_class_unittest _source)
             KF6::CalendarCore
             KPim6::MessageViewer
             KPim6::Libkleo
-            KPim6::Mime
+            KF6::Mime
             KPim6::AkonadiCore
             KPim6::GrantleeTheme
             KPim6::AkonadiWidgets
@@ -49,7 +49,7 @@ macro(add_kdepim_addons_viewerplugin_widget_unittest _source _additional)
             KF6::CalendarCore
             KPim6::MessageViewer
             KPim6::Libkleo
-            KPim6::Mime
+            KF6::Mime
             KPim6::AkonadiCore
             KPim6::GrantleeTheme
             KPim6::IncidenceEditor
diff --git a/plugins/messageviewerplugins/externalscriptplugin/autotests/CMakeLists.txt b/plugins/messageviewerplugins/externalscriptplugin/autotests/CMakeLists.txt
index 0e2dbf9e3..22573c66f 100644
--- a/plugins/messageviewerplugins/externalscriptplugin/autotests/CMakeLists.txt
+++ b/plugins/messageviewerplugins/externalscriptplugin/autotests/CMakeLists.txt
@@ -18,7 +18,7 @@ macro(
     ecm_add_test(${_test}
                  TEST_NAME ${_name}
                  NAME_PREFIX "messageviewerplugins-"
-                 LINK_LIBRARIES KPim6::MessageViewer Qt::Test KF6::KIOCore KPim6::Mime KPim6::AkonadiCore KF6::I18n KF6::XmlGui KPim6::PimCommon KF6::KIOWidgets KPim6::Libkdepim
+                 LINK_LIBRARIES KPim6::MessageViewer Qt::Test KF6::KIOCore KF6::Mime KPim6::AkonadiCore KF6::I18n KF6::XmlGui KPim6::PimCommon KF6::KIOWidgets KPim6::Libkdepim
     )
 endmacro()
 
