From: Jakub Jirutka <jakub@jirutka.cz>
Date: Tue, 09 Jun 2026 22:06:41 +0200
Subject: [PATCH] Fix client test on musl libc

This patch fixes the test `Returns error when host cannot be resolved`
on musl libc.

diff --git a/tests/client_test.c b/tests/client_test.c
index 4d2f477..1508491 100644
--- a/tests/client_test.c
+++ b/tests/client_test.c
@@ -1067,6 +1067,7 @@ static void test_blocking_connection_errors(void) {
              strcmp(c->errstr, "Temporary failure in name resolution") == 0 ||
              strcmp(c->errstr, "hostname nor servname provided, or not known") == 0 ||
              strcmp(c->errstr, "no address associated with name") == 0 ||
+             strcmp(c->errstr, "Name has no usable address") == 0 ||
              strcmp(c->errstr, "No such host is known. ") == 0));
         valkeyFree(c);
     } else {
