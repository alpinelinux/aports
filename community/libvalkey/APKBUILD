# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=libvalkey
pkgver=0.5.0
pkgrel=0
pkgdesc="Valkey client library in C"
url="https://github.com/valkey-io/libvalkey"
arch="all"
license="BSD-3-Clause"
makedepends="openssl-dev"
checkdepends="
	libevent-dev
	valkey
	"
subpackages="
	$pkgname-tls
	$pkgname-dev
	"
source="https://github.com/valkey-io/libvalkey/archive/$pkgver/libvalkey-$pkgver.tar.gz
	client_test-musl-compat.patch
	"

case "$CARCH" in
	# Tests fail on MPTCP - Protocol not supported.
	loongarch64 | ppc64le | riscv64) options="!check";;
esac

build() {
	make USE_TLS=1 \
		TEST_ASYNC="$(want_check && echo 1 || echo 0)" \
		OPTIMIZATION= \
		CFLAGS="${CFLAGS/-Os/-O2}"
}

check() {
	cd tests
	./test.sh
}

package() {
	make install USE_TLS=1 DESTDIR="$pkgdir" PREFIX=/usr
}

tls() {
	pkgdesc="$pkgdesc (TLS support)"

	amove usr/lib/libvalkey_tls.so.*
}

sha512sums="
d33b98bdb36acb4f85843b54429d3cd398dc79e28a50a7fa0b4601b36bd328e3b9dcbd9dfbe6f41c4803bdbafe3dfd246dd4f569ac9fc5260f877556f04a4e09  libvalkey-0.5.0.tar.gz
06fd14d51d6415de0fb78d747b39500ced387946afcd469ce6a104c9afd25e51067085187e515099c1a9a6e39ef525581e2509f227189a6c9ec855e517cd833a  client_test-musl-compat.patch
"
