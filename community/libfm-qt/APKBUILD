# Contributor: Zachary Lee Andrews <zcrayfish@gmail.com>
maintainer="Antoni Aloy <aaloytorrens@gmail.com>"
pkgname=libfm-qt
pkgver=2.4.0
pkgrel=0
pkgdesc="Qt port of libfm"
url="https://github.com/lxqt/libfm-qt"
arch="all"
license="LGPL-2.0-or-later"
depends="lxqt-menu-data"
depends_dev="
	perl
	libfm-dev
	libexif-dev
	lxqt-build-tools
	menu-cache-dev
	qt6-qtbase-dev
	qt6-qttools-dev
	"
makedepends="
	$depends_dev
	cmake
	samurai
	qt6-qtbase-private-dev
	"
subpackages="$pkgname-dev $pkgname-lang"
options="!check" # No testsuite
source="https://github.com/lxqt/libfm-qt/releases/download/$pkgver/libfm-qt-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=True
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

lang() {
	install_if="lang $pkgname=$pkgver-r$pkgrel"
	amove usr/share/libfm-qt6/translations
}

sha512sums="
10bac2515311665b05589a4ffab31119d0842aaf25a00a64f56ab5848a12cd6766af1e52537b367fa03a1117ef4608d9eabfdd8e8ed9ddc80177212a7b3a9277  libfm-qt-2.4.0.tar.xz
"
