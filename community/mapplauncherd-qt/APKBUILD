maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=mapplauncherd-qt
pkgver=1.2.0
pkgrel=0
pkgdesc="Application launch boosters for Qt6"
url="https://github.com/sailfishos/mapplauncherd-qt"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-only"
depends_dev="
	libxml2-dev
	mapplauncherd-dev
	qt6-qtbase-dev
	qt6-qtbase-private-dev
	qt6-qtdeclarative-dev
	"
makedepends="$depends_dev"
subpackages="
	$pkgname-dev
	$pkgname-systemd
	"
source="https://github.com/sailfishos/mapplauncherd-qt/archive/$pkgver/mapplauncherd-qt-$pkgver.tar.gz
	0001-mapplauncherd-qt-Qt6.patch
	"
options="!check" # No tests

build() {
	qmake6 \
		PREFIX=/usr
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install
}
