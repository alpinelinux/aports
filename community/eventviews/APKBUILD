62e4e0634c5c0d3689c798545cee775564d1eb6a9b4699afcb71d70b3002fbd6bb2e7b8cc2d43169138e95ce009e8c46feaf63fd4d3df96327e315fbaaac1c4a  0001-eventviews-Remove-unused-KMime-dependency.patch
"
