# Contributor: Michał Adamski <michal@ert.pl>
# Contributor: Rdbo <rdbodev@gmail.com>
maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=electrum
pkgver=4.7.1
pkgrel=0
pkgdesc="Lightweight Bitcoin Wallet"
url="https://electrum.org/"
# loongarch64: test fails: 499500000000 != 499520000000
arch="noarch !loongarch64"
license="MIT"
depends="
	libsecp256k1
	py3-aiohttp
	py3-aiohttp-socks
	py3-aiorpcx
	py3-attrs
	py3-certifi
	py3-dnspython
	py3-electrum-aionostr
	py3-jsonpatch
	py3-protobuf
	py3-pycryptodomex
	py3-cryptography
	py3-qrcode
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-pyaes
	py3-pytest-xdist
"
subpackages="$pkgname-pyc"
source="
	electrum-$pkgver.tar.gz::https://github.com/spesmilo/electrum/archive/refs/tags/$pkgver.tar.gz
	0001-apk-add-instead-of-apt-get-install.patch
"

case "$CARCH" in
armhf)
	# no py3-qt6 (gui and tests depend on it)
	options="$options !check"
	;;
*)
	subpackages="$subpkgname $pkgname-gui"
	checkdepends="$checkdepends py3-qt6"
	;;
esac

gui() {
	pkgdesc="GUI for $pkgname"
	install_if="$pkgname=$pkgver-r$pkgrel" # The GUI will be installed by default, and can
	                                       # be disabled with !electrum-gui
	depends="$pkgname=$pkgver-r$pkgrel py3-qt6"

	mkdir -p "$subpkgdir"
}

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -n auto \
		--ignore tests/test_qml_types.py \
		tests
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
acd797aaa65574ea7aaf191cb633add47c43b698008cbdc4a6479427b938b248965e882b9a45bc310777052ad5692e18540b7d6321c1efd66654549f3722a83f  electrum-4.7.1.tar.gz
ff38247c87e88389e426b2a3dd94c6142c1b505d7d517a9fda0092003749290757e7bf7d74daf3d6dc8846aee9c8b161d8e5c832b35506c24e85ac130b490e23  0001-apk-add-instead-of-apt-get-install.patch
"
