# Contributor: Rasmus Thomsen <oss@cogitri.dev>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=glibmm2.66
pkgver=2.66.9
pkgrel=0
# NOTE: Upgrade only to even-numbered versions (e.g. 1.18.x, 1.20.x)!
pkgdesc="C++ wrapper for the GLib toolkit"
url="https://www.gtkmm.org/"
arch="all"
license="LGPL-2.1-or-later"
makedepends="glib-dev libsigc++-dev perl meson m4"
subpackages="$pkgname-dev"
source="https://download.gnome.org/sources/glibmm/${pkgver%.*}/glibmm-$pkgver.tar.xz"
builddir="$srcdir/glibmm-$pkgver"
replaces="glibmm"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dbuild-documentation=false \
		-Dbuild-examples=false \
		. output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

dev() {
	amove usr/lib/glibmm-*
	default_dev
}

sha512sums="
0983d606f3bac6271699fcfed22c63937778e024c7666a55b03d831ebd8637c385ce1c6bef78ece4d0f73ec05e8e9bfa47df2f524c9bd34ccf6d8192f6717610  glibmm-2.66.9.tar.xz
"
