# Contributor: Francesco Colista <fcolista@alpinelinux.org>
maintainer="team/gnome <achill@achill.org>"
pkgname=evolution-ews
pkgver=3.60.0
pkgrel=0
# NOTE: Upgrade only to even-numbered versions (e.g. 1.18.x, 1.20.x)!
pkgdesc="MS Exchange integration through Exchange Web Services"
url="https://gitlab.gnome.org/GNOME/evolution/-/wikis/home"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	cmake
	evolution-data-server-dev
	evolution-dev
	gettext-dev
	glib-dev
	gtk-doc
	intltool
	libmspack-dev
	libsoup3-dev
	samurai
	uhttpmock-dev
	"
options="!check" # fail in docker due to port restrictions
subpackages="$pkgname-lang"
source="$pkgname-$pkgver.tar.gz::https://github.com/GNOME/evolution-ews/archive/refs/tags/$pkgver.tar.gz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DSYSCONF_INSTALL_DIR=/etc \
		-DENABLE_TESTS=OFF
	cmake --build build
}

check() {
	cd build
	ctest
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
