# Contributor: Leo <thinkabit.ukim@gmail.com>
# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=appstream
pkgver=1.1.2
pkgrel=0
pkgdesc="Provides a standard for creating app stores across distributions"
url="https://distributions.freedesktop.org/wiki/AppStream"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	bash-completion-dev
	cairo-dev
	curl-dev
	fontconfig-dev
	gdk-pixbuf-dev
	glib-dev
	gobject-introspection-dev
	gperf
	itstool
	libfyaml-dev
	librsvg-dev
	libxml2-dev
	libxmlb-dev
	meson
	pango-dev
	qt6-qtbase-dev
	vala
	yaml-dev
	"
triggers="$pkgname.trigger=/usr/share/app-info/*:/var/cache/swcatalog/xml"
install="$pkgname.post-install $pkgname.post-upgrade"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	$pkgname-doc
	$pkgname-qt
	$pkgname-compose
	$pkgname-lang
	"
source="https://www.freedesktop.org/software/appstream/releases/AppStream-$pkgver.tar.xz
	"
builddir="$srcdir/AppStream-$pkgver"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dqt=true \
		-Dsystemd=false \
		-Ddocs=false \
		-Dapidocs=false \
		-Dinstall-docs=false \
		-Dstemming=false \
		-Dvapi=true \
		-Dapt-support=false \
		-Dgir=true \
		-Dcompose=true \
		. output
	meson compile -C output
}

check() {
	XDG_RUNTIME_DIR="$builddir" \
	meson test --print-errorlogs -C output \
		AppStream:as-validate_metainfo.cli \
		AppStream:as-validate_metainfo.compose \
		AppStream:as-test_basic \
		AppStream:as-test_xml \
		AppStream:as-test_pool \
		AppStream:as-test_validate \
		AppStream:as-test_perf \
		AppStream:as-test_misc \
		AppStream:as-test_qt-pool \
		AppStream:as-test_qt-misc
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output

	# Remove installed-tests, there is no switch to disable installing them
	rm -rf "$pkgdir"/usr/share/installed-tests
}

compose() {
	pkgdesc="Building blocks to compose AppStream metadata"

	amove usr/lib/libappstream-compose*
	amove usr/lib/girepository-*/AppStreamCompose*

	# Needs so:libappstream-compose.so and thus needs
	# to be moved to prevent a recursive dependency.
	amove usr/libexec/appstreamcli-compose
}

qt() {
	pkgdesc="Qt5 interface for AppStream"

	amove usr/lib/libAppStreamQt.so.*
}

sha512sums="
62c158810aa9facf6b0a7b629827a01312e12189f01bea9e79cb8d2eb501df50112c9c949410e21190611720dcbb5b80a156b23c0f9d4b92131da37769d39913  AppStream-1.1.2.tar.xz
"
