# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=pueue
pkgver=4.0.4
pkgrel=0
pkgdesc="Manage your shell commands"
url="https://github.com/nukesor/pueue"
arch="all"
license="MIT"
checkdepends="bash"
makedepends="cargo cargo-auditable"
subpackages="
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="https://github.com/Nukesor/pueue/archive/v$pkgver/pueue-$pkgver.tar.gz"
options="net"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen

	mkdir -p target/completion
	local sh; for sh in bash fish zsh; do
		./target/release/pueue completions $sh target/completion/
	done
}

check() {
	# kill tests fail in CI and builders due to PID 1 reaping behavior
	local _skip_tests="--skip process_helper::unix::tests::test_normal_command_children_are_killed \
			--skip process_helper::unix::tests::test_shell_command_children_are_killed \
			--skip process_helper::unix::tests::test_shell_command_is_killed \
			--skip process_helper::unix::tests::test_shell_command_is_killed_with_signal"

	case "$CARCH" in
	loongarch64)
		# flaky timeout/race-sensitive tests on slow hardware
		_skip_tests="$_skip_tests \
			--skip client::integration::wait::multiple_tasks \
			--skip client::integration::wait::single_task_target_status \
			--skip client::integration::wait::success_failure \
			--skip client::integration::wait::success_success \
			--skip client::integration::wait::target_status \
			--skip daemon::integration::stashed::test_delayed_tasks"
		;;
	riscv64)
		# flaky timeout/race-sensitive tests on slow hardware
		_skip_tests="$_skip_tests \
			--skip client::integration::follow::default::case_1"
		;;
	esac

	cargo test --frozen -- $_skip_tests
}

package() {
	cd target

	install -D -m755 release/pueue -t "$pkgdir"/usr/bin/
	install -D -m755 release/pueued -t "$pkgdir"/usr/bin/

	install -D -m644 completion/$pkgname.bash "$pkgdir"/usr/share/bash-completion/completions/$pkgname
	install -D -m644 completion/*.fish -t "$pkgdir"/usr/share/fish/vendor_completions.d/
	install -D -m644 completion/_* -t "$pkgdir"/usr/share/zsh/site-functions/
}

sha512sums="
