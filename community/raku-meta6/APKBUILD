# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer:
pkgname=raku-meta6
pkgver=0.0.31
pkgrel=0
pkgdesc="Work with Raku META files"
url="https://github.com/jonathanstowe/META6"
arch="all"
license="Artistic-2.0"
depends="
	rakudo
	raku-json-class
	raku-json-name
	"
makedepends="moarvm-dev rakudo-dev"
checkdepends="perl-utils raku-json-fast"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/jonathanstowe/META6/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/META6-$pkgver"
options="!archcheck" # Precompiled arch dependent files included (quiet noarch warning)

build() {
	RAKUDO_RERESOLVE_DEPENDENCIES=0 \
	/usr/share/rakudo/tools/install-dist.raku \
		--to=output --for=vendor
}

check() {
	prove -e 'raku -Ilib'
}

package() {
	mkdir -p "$pkgdir"/usr/share/rakudo
	cp -RT output "$pkgdir"/usr/share/rakudo/vendor

	install -Dvm644 META6.json README.md \
		-t "$pkgdir"/usr/share/doc/$pkgname/
}

sha512sums="
c3fe63c611c024169c8833d54415793e564a1c251b05af31096b91c3423047e0bbedfa5a5ec3fa1562b3b98aef447f9dc451e97e5e0054c73411c21de6f04798  raku-meta6-0.0.31.tar.gz
"
