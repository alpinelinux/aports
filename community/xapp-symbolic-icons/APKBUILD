maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=xapp-symbolic-icons
pkgver=1.0.9
pkgrel=0
pkgdesc="Symbolic icons for GTK applications and projects"
url="https://github.com/xapp-project/xapp-symbolic-icons"
arch="noarch"
license="GPL-3.0-only AND LGPL-3.0-only"
depends="hicolor-icon-theme python3"
makedepends="meson"
provides="xsi-symbolic-icons=$pkgver-r$pkgrel"
source="$pkgname-$pkgver.tar.gz::https://github.com/xapp-project/xapp-symbolic-icons/archive/refs/tags/$pkgver.tar.gz"

build() {
	abuild-meson . output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

