# Contributor: Zachary Lee Andrews <zcrayfish@gmail.com>
maintainer="Antoni Aloy <aaloytorrens@gmail.com>"
pkgname=lxqt-policykit
pkgver=2.4.0
pkgrel=0
pkgdesc="LXQt PolicyKit agent"
url="https://github.com/lxqt/lxqt-policykit"
# armhf blocked by liblxqt-dev
arch="all !armhf"
license="LGPL-2.0-or-later"
makedepends="
	cmake
	kwindowsystem-dev
	liblxqt-dev
	lxqt-build-tools
	polkit-qt-dev
	qt6-qttools-dev
	samurai
	"
subpackages="$pkgname-doc $pkgname-lang"
source="https://github.com/lxqt/lxqt-policykit/releases/download/$pkgver/lxqt-policykit-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=True
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

lang() {
	install_if="lang $pkgname=$pkgver-r$pkgrel"
	amove usr/share/lxqt/translations/$pkgname-agent
}

sha512sums="
f814691b83901873bf54862c00d5439de633878ba9bb33a69e51930de031d04c1c3a2d2e433ad642488601fa3bd0b39f6eb1cf1ae174743362a3a95857add3cc  lxqt-policykit-2.4.0.tar.xz
"
