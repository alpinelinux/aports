7314dae8d6b2e758fff9de38bf03e4464fb4cd4743c4a31d68c09de919caf45f62c9aeb1f7eb284ddb41a4f4c850a079ca4d603cfe47e499b25c43b23f1a700e  clojure-tools-1.12.5.1654.tar.gz
"
