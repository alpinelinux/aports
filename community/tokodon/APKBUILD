# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-applications
maintainer="team/kde <bribbers@disroot.org>"
pkgname=tokodon
pkgver=26.04.3
pkgrel=1
pkgdesc="A Mastodon client for Plasma and Plasma Mobile"
url="https://invent.kde.org/network/tokodon/"
# armhf blocked by qt6-qtdeclarative -> kirigami
# x86, armv7, riscv64 and s390x blocked by qt6-qtwebengine -> qt6-qtwebview
arch="all !armhf !x86 !armv7 !riscv64 !s390x"
license="GPL-3.0-only AND CC0-1.0"
depends="
	kdeclarative
	kirigami
	kirigami-addons
	kitemmodels
	purpose
	qqc2-desktop-style
	"
makedepends="
	extra-cmake-modules
	kconfig-dev
	kcoreaddons-dev
	kdbusaddons-dev
	ki18n-dev
	kio-dev
	kirigami-addons-dev
	kirigami-dev
	knotifications-dev
	kunifiedpush-dev
	mpvqt-dev
	purpose-dev
	qqc2-desktop-style-dev
	qcoro-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-private-dev
	qt6-qtmultimedia-dev
	qt6-qtsvg-dev
	qt6-qtwebsockets-dev
	qtkeychain-dev
	samurai
	"
subpackages="
	$pkgname-dbg
	$pkgname-lang
	"
_repo_url="https://invent.kde.org/network/tokodon.git"
source="https://download.kde.org/stable/release-service/$pkgver/src/tokodon-$pkgver.tar.xz
	0001-Fix-crash-when-adding-a-second-account-through-the-b.patch
	0002-Fix-log-out-prompt-dialog-opening-in-the-wrong-windo.patch
	"
# No tests
options="!check"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

