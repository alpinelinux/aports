# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-syncer
_pyname="syncer"
pkgver=2.0.3
pkgrel=2
arch="noarch"
pkgdesc="Async to sync converter"
url="https://pypi.python.org/project/syncer"
license="BSD-3-Clause"
makedepends="
	py3-setuptools
	py3-gpep517
	py3-wheel
	"
checkdepends="
	py3-pytest-runner
	py3-xfail
	"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/miyakogi/syncer/archive/refs/tags/v$pkgver.tar.gz
	use-asyncio-new-event-loop.patch
	"
builddir="$srcdir"/$_pyname-$pkgver
subpackages="$pkgname-pyc"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	PYTHONPATH="$builddir"/src pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}
sha512sums="
