# Contributor: vinymeuh <vinymeuh@gmail.com>
# Maintainer: Luca Weiss <luca@lucaweiss.eu>
pkgname=libgpiod
pkgver=2.3.1
pkgrel=0
pkgdesc="C library and tools for interacting with the linux GPIO character device"
url="https://git.kernel.org/pub/scm/libs/libgpiod/libgpiod.git/"
arch="all"
license="LGPL-2.1-or-later"
options="!check" # Running test suite needs special setup
makedepends="
	catch2-3
	doxygen
	glib-dev
	gobject-introspection-dev
	help2man
	kmod-dev
	libgudev-dev
	linux-headers
	meson
	py3-build
	py3-pip
	python3-dev
	util-linux-dev
	"
subpackages="$pkgname-dev $pkgname-doc py3-$pkgname:_py3"
source="https://git.kernel.org/pub/scm/libs/libgpiod/libgpiod.git/snapshot/libgpiod-$pkgver.tar.gz"

build() {
	abuild-meson \
		output . \
		-Dbindings-python=enabled
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

_py3() {
	pkgdesc="Python bindings for libgpiod"
	depends="python3"
	mkdir -p "$subpkgdir"/usr/lib
	mv "$pkgdir"/usr/lib/python* "$subpkgdir"/usr/lib/
}

sha512sums="
f76c11cbcda695e770d65a1dc78c035e90bdbb8411ab2f73f1aed786f62361f4190be3372245dec42146e1755bd4c465fb3833e1c4d08c0549abc954af1270b2  libgpiod-2.3.1.tar.gz
"
