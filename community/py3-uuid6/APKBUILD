# Contributor: Leon White <badfunkstripe@gmail.com>
maintainer="Leon White <badfunkstripe@gmail.com>"
pkgname=py3-uuid6
_pkgname=uuid6-python
pkgver=2025.0.1
pkgrel=0
pkgdesc="New time-based UUID formats which are suited for use as a database key"
url="https://github.com/oittaa/uuid6-python"
arch="noarch"
license="MIT"
makedepends="
	py3-gpep517
	py3-installer
	py3-setuptools
	py3-setuptools_scm
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://github.com/oittaa/uuid6-python/archive/refs/tags/$pkgver/uuid6-python-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# test_time is timing-sensitive and flaky in containers
	.testenv/bin/python3 -m pytest \
		--deselect test/test_uuid6.py::UUIDTests::test_time
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
2922c85dac748d966f1a9330482f24280df03cf4ea6e5f7e9b6198280675412952305dd2b71fb68bdefab8eafa58d3da53bc63cff91d025b0ff47379afd41c35  uuid6-python-2025.0.1.tar.gz
"
