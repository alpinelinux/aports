# Contributor: Bart Ribbers <bribbers@disroot.org>
# Maintainer: Bart Ribbers <bribbers@disroot.org>
pkgname=py3-curio
pkgver=1.6
pkgrel=3
pkgdesc="Curio is a coroutine-based library for concurrent systems programming"
url="https://github.com/dabeaz/curio"
arch="noarch"
license="BSD-3-Clause"
depends="python3"
makedepends="
	py3-setuptools
	py3-sphinx
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="
	https://pypi.python.org/packages/source/c/curio/curio-$pkgver.tar.gz
	363_add-support-py312.patch
	c2c2f4f_remove-skipped-flaky-tests.patch
	751b0d3_remove-dependency-telnetlib.patch
	"
builddir="$srcdir/curio-$pkgver"

build() {
	python3 setup.py build
}

check() {
	# https://github.com/dabeaz/curio/issues/368
	PYTHONPATH="$PWD/build/lib" pytest -m "not internet" -k "not test_cpu"
}

package() {
	python3 setup.py install --skip-build --root="$pkgdir"
}

