e8f7be3923940c8c09d56422729b5285762d2c670be3c601fa99bfd95d5db71099b320f6f7d3e818fccb1fde0d870bf3be9b93ca7df298c1148d9bd78e04e3bc  quickstart.adoc.patch
cbd4be38e794be1b1fefb38ba3a6dc98cde4d6b329c052f67fb9ed9b845d3410c55defc5c1f17ab757a6d398ef6ce72137b43be9e5ba4c0e75b422266dc6fb65  fix-audit.patch
"
