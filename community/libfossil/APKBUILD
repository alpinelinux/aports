# Contributor: Celeste <cielesti@protonmail.com>
maintainer=""
pkgname=libfossil
pkgver=0.20260419.1145
_fslhash=489f068f2e89cf8d
pkgrel=0
pkgdesc="Unofficial Fossil SCM library"
url="https://fossil.wanderinghorse.net/r/libfossil"
arch="all"
license="BSD-2-Clause"
makedepends="bash tcl zlib-dev"
subpackages="$pkgname-apps $pkgname-dev"
source="https://fossil-scm.org/libfossil/tarball/$_fslhash/libfossil-$_fslhash.tar.gz"
builddir="$srcdir/$pkgname-$_fslhash"
options="!check" # no tests provided

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--soname=version \
		--disable-c++ \
		--no-debug \
		--no-fnc
	make
}

package() {
	make DESTDIR="$pkgdir" install

	install -Dvm644 include/*.h -t "$pkgdir"/usr/include/
	install -Dvm644 include/fossil-scm/*.h -t "$pkgdir"/usr/include/fossil-scm/
}

apps() {
	pkgdesc="$pkgdesc (command-line apps)"
	depends="$pkgname=$pkgver-r$pkgrel"

	amove usr/bin
}

sha512sums="
9be8d73cdb49ef436513efbdc286f3c60d879c9cf31c8e596eeb57d910321f1165fbeedba765abbc72ca418bd0e2172ee94b3c4ce51b9e0f3218db969c21e199  libfossil-489f068f2e89cf8d.tar.gz
"
