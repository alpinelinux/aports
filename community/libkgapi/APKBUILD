# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-applications
maintainer="team/kde <bribbers@disroot.org>"
pkgname=libkgapi
pkgver=26.04.2
pkgrel=0
pkgdesc="LibKGAPI is a KDE-based library for accessing various Google services via their public API"
# armhf blocked by qt6-qtdeclarative -> kio
# x86, armv7, s390x and riscv64 blocked by qt6-qtwebengine
arch="all !armhf !x86 !armv7 !s390x !riscv64"
url="https://community.kde.org/KDE_PIM"
license="LGPL-2.1-only OR LGPL-3.0-only"
depends_dev="
	cyrus-sasl-dev
	kcalendarcore-dev
	kcontacts-dev
	kio-dev
	kwallet-dev
	kwindowsystem-dev
	qt6-qtbase-dev
	qt6-qtwebengine-dev
	"
makedepends="$depends_dev
	doxygen
	extra-cmake-modules
	graphviz
	qt6-qttools-dev
	samurai
	"
checkdepends="xwayland-run"
subpackages="$pkgname-dev $pkgname-doc $pkgname-lang"
_repo_url="https://invent.kde.org/pim/libkgapi.git"
source="https://download.kde.org/stable/release-service/$pkgver/src/libkgapi-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_TESTING=ON \
		-DBUILD_QCH=ON
	cmake --build build
}

check() {
	# calendar-event-*: UTC+02 != UTC+02:00
	wlheadless-run -- ctest --test-dir build -E "calendar-(event*job|calendardeletejobtest|eventdeletejobtest)"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
346fa560e854b8bbb8ef627dea07711009a02e34aceaabacb6c1ab7864f190e2b3ded161c054cb310259990e3d5e6295ff6db8b053b85864154c8ddcc8451026  libkgapi-26.04.2.tar.xz
"
