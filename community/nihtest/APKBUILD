# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=nihtest
pkgver=1.11.1
pkgrel=0
pkgdesc="Testing tool for command line utilities"
url="https://github.com/nih-at/nihtest"
arch="noarch"
license="BSD-3-Clause"
makedepends="
	py3-gpep517
	py3-setuptools
	"
checkdepends="
	cmake
	py3-pip
	samurai
	"
subpackages="$pkgname-doc $pkgname-pyc"
source="https://github.com/nih-at/nihtest/releases/download/v$pkgver/nihtest-$pkgver.tar.gz
	0001-alpine-venv.patch
	"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=None
	cmake --build build
	ctest --test-dir build --output-on-failure
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	install -Dm644 manpages/nihtest-case.man \
		"$pkgdir"/usr/share/man/man5/nihtest-case.5
	install -Dm644 manpages/nihtest.conf.man \
		"$pkgdir"/usr/share/man/man5/nihtest.conf.5
	install -Dm644 manpages/nihtest.man \
		"$pkgdir"/usr/share/man/man1/nihtest.1
}

sha512sums="
c86ec102a1c2035211c32c779ae42aa316281f5b5ee41d46a0f191388d0cfe0a1cedd5e9dbdf28f1ba78b34d6843c946a46c3cad5c4e94fbbf72986eafc82091  nihtest-1.11.1.tar.gz
c9faece4ade2b941b52278dd53afc79b98c74848f099878be3d809201abc8a27b516b0d24279fe77fb6a036dbfab0f1a351d3f78a669825e189ea3b68072c7f4  0001-alpine-venv.patch
"
