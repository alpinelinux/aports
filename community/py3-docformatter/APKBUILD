# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-docformatter
pkgver=1.7.8
pkgrel=0
pkgdesc="Formats docstrings to follow PEP 257"
url="https://github.com/PyCQA/docformatter"
arch="noarch"
license="MIT"
depends="
	py3-charset-normalizer
	py3-untokenize
	"
makedepends="
	py3-gpep517
	py3-poetry-core
	"
checkdepends="
	black
	py3-mock
	py3-pytest
	py3-pytest-xdist
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/PyCQA/docformatter/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/docformatter-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	VIRTUAL_ENV="$builddir"/.testenv .testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
f7f30544a107cf2ecb6968c179e70b810c93822bdd13d04a3b089dff5b8732f8bcdb7a5e9e584e2aa9783ed47b69ee28b69c100a01e309e70602311f0e05d4ea  py3-docformatter-1.7.8.tar.gz
"
