From 6da2e6cfecfa7121cd0176a503a24a9f259ff82c Mon Sep 17 00:00:00 2001
From: Coco Liliace <coco@liliace.dev>
Date: Sun, 24 May 2026 14:12:43 +0800
Subject: [PATCH] Initialize locale without NLS

setlocale() is required for ncurses to render UTF-8 text correctly.
It must not depend on gettext/NLS support being enabled.
---
 src/calcurse.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/calcurse.c b/src/calcurse.c
index 7787467..398d36a 100644
--- a/src/calcurse.c
+++ b/src/calcurse.c
@@ -34,6 +34,7 @@
  *
  */
 
+#include <locale.h>
 #include <stdlib.h>
 
 #include "calcurse.h"
@@ -696,8 +697,8 @@ cleanup:
  */
 int main(int argc, char **argv)
 {
-#if ENABLE_NLS
 	setlocale(LC_ALL, "");
+#if ENABLE_NLS
 	bindtextdomain(PACKAGE, LOCALEDIR);
 	textdomain(PACKAGE);
 #endif /* ENABLE_NLS */
-- 
2.54.0

