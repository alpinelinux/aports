# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=gnome-weather
pkgver=50.0
pkgrel=0
pkgdesc="GNOME Weather application"
url="https://apps.gnome.org/Weather"
# armhf blocked by gjs
arch="noarch !armhf"
license="GPL-2.0-only"
depends="
	geoclue
	gjs
	gobject-introspection
	gtk4.0
	libadwaita
	libgweather4
	"
makedepends="
	geoclue-dev
	gjs-dev
	glib-dev
	gobject-introspection-dev
	gtk4.0-dev
	libadwaita-dev
	libgweather4-dev
	meson
	typescript
	"
checkdepends="appstream-glib desktop-file-utils"
subpackages="$pkgname-lang"
source="https://download.gnome.org/sources/gnome-weather/${pkgver%.*}/gnome-weather-$pkgver.tar.xz"

build() {
	abuild-meson . output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
