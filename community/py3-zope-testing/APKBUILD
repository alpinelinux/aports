pkgname=py3-zope-testing
pkgver=6.2
pkgrel=0
pkgdesc="Zope testing helpers"
url="https://github.com/zopefoundation/zope.testing"
arch="noarch"
license="ZPL-2.1"
depends="python3 py3-setuptools"
makedepends="py3-gpep517 py3-wheel"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/z/zope_testing/zope_testing-$pkgver.tar.gz"
builddir="$srcdir/zope_testing-$pkgver"
options="!check" # fail for some reason

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
a42beacb21452d04a9aed5f368341272fb759302e871dc0c117d1051429cf3e7c0a38dfbc0249fdd10b3840fd7dca1c70d76efbf34d4969126f21cc33fa13fa0  zope_testing-6.2.tar.gz
"
