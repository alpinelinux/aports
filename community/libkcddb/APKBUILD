# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-applications
maintainer="team/kde <bribbers@disroot.org>"
pkgname=libkcddb
pkgver=26.04.2
pkgrel=0
# armhf blocked by qt6-qtdeclarative -> ki18n
arch="all !armhf"
url="https://www.kde.org/applications/multimedia/"
pkgdesc="KDE CDDB library"
license="LGPL-2.0-or-later AND GPL-2.0-or-later"
makedepends="
	extra-cmake-modules
	kcmutils-dev
	kcodecs-dev
	kconfig-dev
	kdoctools-dev
	ki18n-dev
	kio-dev
	kwidgetsaddons-dev
	libmusicbrainz-dev
	qt6-qtbase-dev
	samurai
	"
checkdepends="
	dbus
	xwayland-run
	"
subpackages="$pkgname-dev $pkgname-doc $pkgname-lang"
_repo_url="https://invent.kde.org/multimedia/libkcddb.git"
source="https://download.kde.org/stable/release-service/$pkgver/src/libkcddb-$pkgver.tar.xz"
options="net" # Required for tests

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_TESTING=ON
	cmake --build build
}

check() {
	# musicbrainztest-severaldiscs fails due to utf16/8 (?)
	# synchttplookuptest hangs
	# asyncmusicbrainztest and musicbrainztest require network access
	dbus-run-session -- wlheadless-run -- ctest --test-dir build \
		-E "(asyncmusicbrainztest|synchttplookuptest|musicbrainztest-severaldiscs|synccddblookuptest|asynchttpsubmittest|synchttpsubmittest|sitestest|utf8test|musicbrainztest)"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
2876e4b9bb7e12f4a30a45c3632137f4e4a1eda8ae33a33724acbd629de649fa093f11fe046f1b425b57fb2456b42178b90fc0455a89a208d5af2a75f3484a4e  libkcddb-26.04.2.tar.xz
"
