maintainer="team/phosh <achill@achill.org>"
pkgname=phosh-tour
pkgver=0.56.0
pkgrel=0
pkgdesc="Simple introduction to Phosh"
url="https://gitlab.gnome.org/World/Phosh/phosh-tour"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	meson
	gtk4.0-dev
	libadwaita-dev
	gmobile-dev
	desktop-file-utils
	"
subpackages="$pkgname-lang $pkgname-systemd"
source="https://sources.phosh.mobi/releases/phosh-tour/phosh-tour-${pkgver/_/.}.tar.xz"
builddir="$srcdir/$pkgname-${pkgver/_/.}"

build() {
	abuild-meson \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
1680f5df78518337f312792cba14bff6a268710417edd9cd5e48ca6fc0241b2a6e312adc79a0ce86bc07663f09110ea6f859c01e586cd417b4371ab470114110  phosh-tour-0.56.0.tar.xz
"
