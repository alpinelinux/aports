From 2556c0831414c72a028656da8cbd055dcdb0d51b Mon Sep 17 00:00:00 2001
From: Milan Crha <mcrha@redhat.com>
Date: Tue, 9 Jun 2026 09:15:32 +0200
Subject: [PATCH] contact-provider: Correct vCard attributes fetch for
 evolution-data-server 3.60.x

This fixes a regression after https://gitlab.gnome.org/World/Chatty/-/merge_requests/1481 ,
which used incorrect function to get vCard attribute names, it returned
GObject property name instead, which not always matches the vCard attribute.

Closes https://gitlab.gnome.org/World/Chatty/-/work_items/998

Part-of: <https://gitlab.gnome.org/World/Chatty/-/merge_requests/1492>
---
 src/chatty-contact-provider.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/chatty-contact-provider.c b/src/chatty-contact-provider.c
index 2cf1810a..72e9bf38 100644
--- a/src/chatty-contact-provider.c
+++ b/src/chatty-contact-provider.c
@@ -200,7 +200,7 @@ chatty_eds_load_contact (ChattyEds     *self,
 
   /* Only container should be freed, attribute is freed in ChattyContact */
   #if EDS_CHECK_VERSION(3, 59, 1)
-  attributes = e_vcard_get_attributes_by_name (E_VCARD (contact), e_contact_field_name (field_id));
+  attributes = e_vcard_get_attributes_by_name (E_VCARD (contact), e_contact_vcard_attribute (field_id));
   #else
   attributes = e_contact_get_attributes (contact, field_id);
   #endif
