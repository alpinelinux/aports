# Contributor: Iztok Fister, Jr. <iztok@iztok-jr-fister.eu>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-pyforgejo
pkgver=2.0.7
pkgrel=0
pkgdesc="A client library for accessing the Forgejo API"
url="https://codeberg.org/harabat/pyforgejo"
arch="noarch"
license="MIT"
depends="
	py3-httpx
	py3-attrs
	py3-dateutil
	"
makedepends="py3-gpep517 py3-poetry-core"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver-1.tar.gz::https://codeberg.org/harabat/pyforgejo/archive/$pkgver.tar.gz"
builddir="$srcdir/pyforgejo"
options="!check" # no tests

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
