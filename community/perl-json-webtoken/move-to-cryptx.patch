See:
    https://github.com/xaicron/p5-JSON-WebToken/issues/16
    https://github.com/xaicron/p5-JSON-WebToken/pull/17

From 4fcf2aafe5622d66825a77c25b6711443c7341c0 Mon Sep 17 00:00:00 2001
From: Timothy Legge <timlegge@gmail.com>
Date: Sun, 8 Mar 2026 11:32:58 -0300
Subject: [PATCH] Fixes #16 OpenSSL error: illegal or unsupported padding mode

Convert to use Crypt::PK::RSA instead of Crypt::OpenSSL::RSA
---
 README.md                                     |  2 +-
 lib/JSON/WebToken.pm                          |  2 +-
 lib/JSON/WebToken/Crypt/RSA.pm                | 26 ++++++++++--------
 t/02_rsa.t                                    |  9 ++++---
 ...jose-json-web-signature-08-A2.rsa_sha256.t | 27 ++++++++++---------
 tmp/MEMO                                      |  8 +++---
 tmp/spec.t                                    | 22 ++++++++-------
 7 files changed, 52 insertions(+), 44 deletions(-)

diff --git a/README.md b/README.md
index c86385b..dc57d16 100644
--- a/README.md
+++ b/README.md
@@ -57,7 +57,7 @@ Default encryption algorithm is `HS256`. You can change algorithm as following:
 
     my $claims = JSON::WebToken->decode($jwt, $public_key_string);
 
-When you use RS256, RS384 or RS512 algorithm then, We need [Crypt::OpenSSL::RSA](https://metacpan.org/pod/Crypt::OpenSSL::RSA).
+When you use RS256, RS384 or RS512 algorithm then, We need [Crypt::PK::RSA](https://metacpan.org/pod/Crypt::PK::RSA).
 
 If you want to create a `Plaintext JWT`, should be specify `none` for the algorithm.
 
diff --git a/lib/JSON/WebToken.pm b/lib/JSON/WebToken.pm
index 62d48f0..dbe33dd 100644
--- a/lib/JSON/WebToken.pm
+++ b/lib/JSON/WebToken.pm
@@ -333,7 +333,7 @@ Default encryption algorithm is C<< HS256 >>. You can change algorithm as follow
 
   my $claims = JSON::WebToken->decode($jwt, $public_key_string);
 
-When you use RS256, RS384 or RS512 algorithm then, We need L<< Crypt::OpenSSL::RSA >>.
+When you use RS256, RS384 or RS512 algorithm then, We need L<< Crypt::PK::RSA >>.
 
 If you want to create a C<< Plaintext JWT >>, should be specify C<< none >> for the algorithm.
 
diff --git a/lib/JSON/WebToken/Crypt/RSA.pm b/lib/JSON/WebToken/Crypt/RSA.pm
index 5f7d846..935546e 100644
--- a/lib/JSON/WebToken/Crypt/RSA.pm
+++ b/lib/JSON/WebToken/Crypt/RSA.pm
@@ -4,31 +4,35 @@ use strict;
 use warnings;
 use parent 'JSON::WebToken::Crypt';
 
-use Crypt::OpenSSL::RSA ();
+use Crypt::PK::RSA ();
 
 our $ALGORITHM2SIGNING_METHOD_MAP = {
-    RS256  => 'use_sha256_hash',
-    RS384  => 'use_sha384_hash',
-    RS512  => 'use_sha512_hash',
-    RSA1_5 => 'use_pkcs1_padding',
+    RS256  => 'SHA256',
+    RS384  => 'SHA384',
+    RS512  => 'SHA512',
+    RSA1_5 => 'v1.5',
 };
 
 sub sign {
     my ($class, $algorithm, $message, $key) = @_;
 
-    my $private_key = Crypt::OpenSSL::RSA->new_private_key($key);
+    my $pk = Crypt::PK::RSA->new();
+    my $private_key = $pk->import_key(\$key);
+
     my $method = $ALGORITHM2SIGNING_METHOD_MAP->{$algorithm};
-    $private_key->$method;
-    return $private_key->sign($message);
+    my $padding = $ALGORITHM2SIGNING_METHOD_MAP->{'RSA1_5'};
+    return $private_key->sign_message($message, $method, $padding);
 }
 
 sub verify {
     my ($class, $algorithm, $message, $key, $signature) = @_;
 
-    my $public_key = Crypt::OpenSSL::RSA->new_public_key($key);
+    my $pk = Crypt::PK::RSA->new();
+    my $public_key = $pk->import_key(\$key);
     my $method = $ALGORITHM2SIGNING_METHOD_MAP->{$algorithm};
-    $public_key->$method;
-    return $public_key->verify($message, $signature) ? 1 : 0;
+    my $padding = $ALGORITHM2SIGNING_METHOD_MAP->{'RSA1_5'};
+
+    return $public_key->verify_message($signature, $message, $method, $padding);
 }
 
 1;
