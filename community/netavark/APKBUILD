# Contributor: Michał Polański <michal@polanski.me>
# Maintainer: Michał Polański <michal@polanski.me>
pkgname=netavark
pkgver=1.17.2
pkgrel=0
pkgdesc="Container network stack"
url="https://github.com/containers/netavark"
license="Apache-2.0"
arch="all"
makedepends="cargo go-md2man protoc cargo-auditable"
subpackages="$pkgname-doc"
source="https://github.com/containers/netavark/archive/v$pkgver/netavark-$pkgver.tar.gz
	nix-s390x.patch
	nix-statfs-s390x.patchsrc
	nix-statfs-s390x-0.29.patchsrc
	"
options="net"

case $CARCH in
	riscv64) options="$options !check" ;; # rustc OOM in CI
esac

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked

	case $CARCH in
		s390x)
			local nixdir patchfile
			for nixdir in "$CARGO_HOME"/registry/src/*/nix-*; do
				[ -d "$nixdir" ] || continue
				case "${nixdir##*/}" in
					nix-0.29.*) patchfile="nix-statfs-s390x-0.29.patchsrc" ;;
					nix-0.30.*) patchfile="nix-statfs-s390x.patchsrc" ;;
					*) continue ;; # 0.31+ already has the fix
				esac
				patch -Np1 -i "$srcdir/$patchfile" -d "$nixdir"
			done
			;;
	esac
}

build() {
	cargo auditable build --release --frozen --bin netavark

	go-md2man -in docs/netavark.1.md -out docs/netavark.1
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/netavark \
		-t "$pkgdir"/usr/libexec/podman/
	install -Dm644 docs/netavark.1 \
		-t "$pkgdir"/usr/share/man/man1/
}

