# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-edit
pkgver=1.0.14
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Text editor for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-edit"
# 32-bit: mismatched types in compio-driver-0.9.0 crate
# riscv64: too slow to build
arch="all !armhf !armv7 !x86 !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	glib-dev
	just
	libxkbcommon-dev
	oniguruma-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-edit/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	export VERGEN_GIT_COMMIT_DATE="$(date -d @"$SOURCE_DATE_EPOCH" '+%Y-%m-%d')"
	export VERGEN_GIT_SHA="unknown"

	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
83924d1e8bfa192c6acea5c43646d596d8ae2dca45a72495f7535faf18877a16ba8df30f7a41741992307e0be4bffc9fbea9163d35826cd79548960c7d168d87  cosmic-edit-1.0.14.tar.gz
"
