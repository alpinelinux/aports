# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-edit
pkgver=1.2.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Text editor for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-edit"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	glib-dev
	just
	libxkbcommon-dev
	oniguruma-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-edit/archive/refs/tags/epoch-$_upstreamver.tar.gz
	wgpu.patch
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	export VERGEN_GIT_COMMIT_DATE="$(date -d @"$SOURCE_DATE_EPOCH" '+%Y-%m-%d')"
	export VERGEN_GIT_SHA="unknown"

	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
ff29114e25dc8dc42778cd152019860fd5173ee0f5c3d09ccd51758974f674d149dd856adb5d2455407b7fbc592c431e9bd3e5d479b2ad74e789ec0a09c745a9  cosmic-edit-1.2.0.tar.gz
c35a3aac83c6a6f9533e40be02888a9cdf1fc43b9bf1c7fc34e41d1d9dce798c1e46512d0c62fbb22511f052913138c6cd3ff20dce142236f81bc24f8f41d902  wgpu.patch
"
