pkgname=hfsfuse
pkgver=0.425
pkgrel=0
pkgdesc="FUSE driver for HFS+ filesystems"
url="https://github.com/0x09/hfsfuse"
arch="all"
license="MIT BSD-2-Clause"
makedepends="
	fuse3-dev
	linux-headers
	utf8proc-dev
	zlib-dev
	"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/0x09/hfsfuse/archive/refs/tags/$pkgver.tar.gz
	use-standard-u16-type.patch
	"
options="!check"  # no tests provided

prepare() {
	default_prepare

	rm -rf lib/utf8proc
}

build() {
	make WITH_UBILIO=local WITH_UTF8PROC=system
}

package() {
	mkdir -p "$pkgdir"/usr/bin
	make install PREFIX="$pkgdir/usr" WITH_UBILIO=local WITH_UTF8PROC=system
}

