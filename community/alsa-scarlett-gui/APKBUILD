pkgname=alsa-scarlett-gui
pkgver=0.5.1
pkgrel=0
pkgdesc="control panel for Focusrite Scarlett audio interfaces"
url="https://github.com/geoffreybennett/alsa-scarlett-gui"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	alsa-lib-dev
	gtk4.0-dev
	openssl-dev
"
source="https://github.com/geoffreybennett/alsa-scarlett-gui/archive/$pkgver/alsa-scarlett-gui-$pkgver.tar.gz"
builddir="$srcdir/alsa-scarlett-gui-$pkgver"
options="!check"

build() {
	make -C src
}

package() {
	make -C src DESTDIR="$pkgdir" PREFIX=/usr install
}

