# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=orca
pkgver=50.0.2
pkgrel=0
pkgdesc="Orca is an extensible screen reader"
url="https://orca.gnome.org"
arch="noarch"
license="LGPL-2.1-or-later"
depends="
	at-spi2-core
	gst-plugins-good
	gtk+3.0
	libatk-1.0
	py3-atspi
	py3-dasbus
	py3-gobject3
	py3-xdg
	python3
	"
makedepends="
	at-spi2-core-dev
	gstreamer-dev
	gtk-update-icon-cache
	intltool
	itstool
	meson
	py3-gobject3-dev
	"
subpackages="
	$pkgname-lang
	$pkgname-doc
	$pkgname-pyc
	$pkgname-systemd
	"
source="https://download.gnome.org/sources/orca/${pkgver%%.*}/orca-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
