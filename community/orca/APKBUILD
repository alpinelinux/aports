# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=orca
pkgver=50.0.5
pkgrel=0
pkgdesc="Orca is an extensible screen reader"
url="https://orca.gnome.org"
arch="noarch"
license="LGPL-2.1-or-later"
depends="
	at-spi2-core
	gst-plugins-good
	gtk+3.0
	libatk-1.0
	py3-atspi
	py3-dasbus
	py3-gobject3
	py3-xdg
	python3
	"
makedepends="
	at-spi2-core-dev
	gstreamer-dev
	gtk-update-icon-cache
	intltool
	itstool
	meson
	py3-gobject3-dev
	"
subpackages="
	$pkgname-lang
	$pkgname-doc
	$pkgname-pyc
	$pkgname-systemd
	"
source="https://download.gnome.org/sources/orca/${pkgver%%.*}/orca-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
4e5ac5283cd85504783ddc3730475c16324427489c9aac439362d901936007dff4ee481817b9ddfd5132efaa71d8f85c29ea618f4e60bffc97213f1e755a1744  orca-50.0.5.tar.xz
"
