# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=orca
pkgver=50.0.4
pkgrel=0
pkgdesc="Orca is an extensible screen reader"
url="https://orca.gnome.org"
arch="noarch"
license="LGPL-2.1-or-later"
depends="
	at-spi2-core
	gst-plugins-good
	gtk+3.0
	libatk-1.0
	py3-atspi
	py3-dasbus
	py3-gobject3
	py3-xdg
	python3
	"
makedepends="
	at-spi2-core-dev
	gstreamer-dev
	gtk-update-icon-cache
	intltool
	itstool
	meson
	py3-gobject3-dev
	"
subpackages="
	$pkgname-lang
	$pkgname-doc
	$pkgname-pyc
	$pkgname-systemd
	"
source="https://download.gnome.org/sources/orca/${pkgver%%.*}/orca-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
826e8133fa4504d06becd925639d3c16d402bbdf7acde7c142d336204d4e778fe778cc7ae42471b82ba9b5e89fbbf7a89311fb688244c0ad6089c30ccdf630b0  orca-50.0.4.tar.xz
"
