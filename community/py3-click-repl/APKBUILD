a7c9d40e7dcda2f83da6a7cfda80a24db0eec718c786c0b0f630faa69c6689977de6465ae944cdba2908de135864d8b072e06f8a3c3cfe3387dc9b9cd6c14efd  132_py314-click82-support.patch
"
