maintainer="Michał Polański <michal@polanski.me>"
pkgname=committed
pkgver=1.1.11
pkgrel=0
pkgdesc="Nitpicking your commit history"
url="https://github.com/crate-ci/committed"
license="MIT OR Apache-2.0"
arch="all"
makedepends="cargo libgit2-dev cargo-auditable"
source="https://github.com/crate-ci/committed/archive/v$pkgver/committed-$pkgver.tar.gz"
options="net" # fetch dependencies

export LIBGIT2_NO_VENDOR=1 # use system libgit2

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	cargo test --frozen -- \
		--skip in_repo
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin/
}

sha512sums="
bcacd744b5c9920e7d6993ea2098b4394d85298c27a3dfc6ec019cb1364dc8663c2122b14b83f5e7b614c38d9e71871e38b1f8797725d7c498b49b65c1de2f80  committed-1.1.11.tar.gz
"
