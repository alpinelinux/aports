# Maintainer: André Klitzing <aklitzing@gmail.com>
pkgname=pcsc-cyberjack
pkgver=3.99.5_p17
_filever=${pkgver%_p*}final.SP${pkgver#*_p}
pkgrel=0
pkgdesc="PCSC driver for Reiner SCT cyberjack card reader"
url="https://help.reiner-sct.com/en/support/solutions/articles/101000480008"
arch="all"
license="GPL-2.0-only"
depends="pcsc-lite"
makedepends="autoconf automake libtool pcsc-lite-dev libusb-dev"
subpackages="$pkgname-udev"
options="!check"
source="pcsc-cyberjack_$_filever.tar.bz2::https://support.reiner-sct.de/downloads/LINUX/V${pkgver/_p/_SP}/pcsc-cyberjack-$_filever.tar.bz2
	60-libifd-cyberjack6.rules
	"
builddir="$srcdir/$pkgname-$_filever"

prepare() {
	default_prepare
	autoreconf -vif
}

build() {
	./configure \
		--prefix=/usr \
		--disable-static \
		--mandir=/usr/share/man/man8 \
		--sysconfdir=/etc/"$pkgname"  \
		--enable-udev \
		--with-usbdropdir="$(pkg-config libpcsclite --variable=usbdropdir)"
	make
}

package() {
	make DESTDIR="$pkgdir" install
	install -Dm644 "$srcdir"/60-libifd-cyberjack6.rules -t "$pkgdir"/usr/lib/udev/rules.d/
}

sha512sums="
