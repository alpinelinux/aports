maintainer="Dominic <git@msrd0.de>"
pkgname=cargo-doc2readme
pkgver=0.7.2
pkgrel=0
pkgdesc="Cargo subcommand to create a readme file containing the rustdoc comments from your code"
url="https://codeberg.org/msrd0/cargo-doc2readme"
arch="all"
license="Apache-2.0"
# cargo is a (non-make) dependency: cargo-doc2readme will call cargo metadata
depends="cargo"
makedepends="cargo-auditable"
subpackages="$pkgname-bash-completion $pkgname-fish-completion $pkgname-zsh-completion"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/msrd0/cargo-doc2readme/archive/$pkgver.tar.gz"
builddir="$srcdir/$pkgname"

# net: needed for downloading dependencies
options="net"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --target="$CTARGET" --release --frozen
}

check() {
	cargo test --release --frozen
}

package() {
	install -Dm755 "target/$CTARGET/release/$pkgname" -t "$pkgdir"/usr/bin/

	install -d "$pkgdir"/usr/share/bash-completion/completions
	"target/$CTARGET/release/$pkgname" completion bash > "$pkgdir/usr/share/bash-completion/completions/$pkgname"

	install -d "$pkgdir"/usr/share/fish/vendor_completions.d
	"target/$CTARGET/release/$pkgname" completion fish > "$pkgdir/usr/share/fish/vendor_completions.d/$pkgname.fish"

	install -d "$pkgdir"/usr/share/zsh/site-functions
	"target/$CTARGET/release/$pkgname" completion zsh > "$pkgdir/usr/share/zsh/site-functions/_$pkgname"
}

sha512sums="
12a7d93e0ee4270a7b098a2dc04af3f6b0e63b3e792bbca7c582ded2c64179023a0dbb32b9a7d2dab31cd78ede6719fcafd72e074e41c97d85c1956cec951727  cargo-doc2readme-0.7.2.tar.gz
"
