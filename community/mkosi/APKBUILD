maintainer="Clayton Craft <clayton@craftyguy.net>"
pkgname=mkosi
pkgver=26_git20260424
pkgrel=0
_commit="693cb8fffa193fd1de3e9aa09224b13f8d9f93ab"
pkgdesc="Build Bespoke OS Images"
url="https://mkosi.systemd.io/"
arch="noarch"
license="LGPL-2.1-or-later"
depends="
	$pkgname-sandbox
	coreutils
	distribution-gpg-keys
	python3
	"
makedepends="
	go-md2man
	py3-gpep517
	py3-setuptools
	"
checkdepends="py3-pytest"
subpackages="
	$pkgname-pyc
	$pkgname-doc
	$pkgname-sandbox
	"
source="$pkgname-$_commit.tar.gz::https://github.com/systemd/mkosi/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit"
options="!check" # fails in CI, works locally with rootbld

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2

	for manpage in mkosi-addon.1.md  mkosi-initrd.1.md  mkosi-sandbox.1.md  mkosi.1.md  mkosi.news.7.md; do
		go-md2man -in mkosi/resources/man/"$manpage" -out mkosi/resources/man/"${manpage%.md}"
	done

}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	gpep517 install-wheel --destdir .testenv .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	gpep517 install-wheel --destdir "$pkgdir" \
		.dist/*.whl

	install -Dm644 mkosi/resources/man/*.1 -t "$pkgdir/usr/share/man/man1/"
	install -Dm644 mkosi/resources/man/*.7 -t "$pkgdir/usr/share/man/man7/"
}

sandbox() {
	pkgdesc="$pkgname (sandboxing utility)"
	depends="python3"

	amove usr/bin/mkosi-sandbox
	amove usr/lib/python*/site-packages/mkosi/sandbox.py
}

sha512sums="
478ce91ab45f47167a9a7b7fc6f17b629c240627cf6b753ec54776ef92a7a10ad58703fffbbda4071324187570f85206fd1e60536f7f74c86133b29d0c9e3ea9  mkosi-693cb8fffa193fd1de3e9aa09224b13f8d9f93ab.tar.gz
"
