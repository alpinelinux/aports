maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=rustls-ffi
pkgver=0.15.3
pkgrel=2
pkgdesc="Use Rustls from any language"
url="https://github.com/rustls/rustls-ffi"
arch="all"
license="Apache-2.0 AND MIT AND ISC"
makedepends="
	cargo
	cargo-auditable
	cargo-c
	cmake
	rust-bindgen
	clang-dev
	samurai
	"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/rustls/rustls-ffi/archive/refs/tags/v$pkgver.tar.gz"
options="net" # crates.io

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	CMAKE_POLICY_VERSION_MINIMUM=3.5 \
	cargo auditable cinstall --release --frozen \
		--features=aws-lc-rs \
		--destdir=build --prefix=/usr
}

check() {
	# crypto_provider::random_data needs a prior test to install the default provider
	case "$CARCH" in
	arm*|aarch64) export RUST_TEST_THREADS=1 ;;
	esac

	CMAKE_POLICY_VERSION_MINIMUM=3.5 \
	cargo ctest --frozen --features=aws-lc-rs
}

package() {
	install -Dm0644 -t "$pkgdir"/usr/include/ build/usr/include/rustls.h
	mv "$builddir"/build/usr/lib "$pkgdir"/usr/
}

sha512sums="
1d91af8a0f3d8ae99eac979ec0d053f884180f6da1d6d6da7f7eb8a931d150a9bb8684ff76bffced4a4c99cb09114d48c8685cd0cb02fab4cbe8ceca401f5453  rustls-ffi-0.15.3.tar.gz
"
