# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-other
maintainer="team/kde <bribbers@disroot.org>"
pkgname=krita-kseexpr
pkgver=4.0.4.0
pkgrel=3
pkgdesc="Krita fork of the KSeExpr embedded evaluation engine"
url="https://github.com/KDE/kseexpr"
arch="all"
license="Apache-2.0"
depends_dev="
	ki18n5-dev
	qt5-qtbase-dev
	"
makedepends="$depends_dev
	bison
	cmake
	doxygen
	extra-cmake-modules
	flex
	graphviz
	qt5-qttools-dev
	samurai
	"
checkdepends="gtest-dev"
subpackages="
	$pkgname-dev
	$pkgname-lang
	"
_repo_url="https://invent.kde.org/graphics/kseexpr.git"
source="$pkgname-$pkgver.tar.gz::https://download.kde.org/Attic/kseexpr/${pkgver%.*}/kseexpr-$pkgver.tar.gz"
builddir="$srcdir/kseexpr-$pkgver"
options="!check" # the tests use some glibc features, todo

build() {
	CFLAGS="$CFLAGS -O2 -flto=auto -DNDEBUG" \
	CXXFLAGS="$CXXFLAGS -O2 -flto=auto -DNDEBUG" \
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DBUILD_TESTS="$(want_check && echo ON || echo OFF)"
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
bed94fbc3f7e30e7864df021bb3a00b6fff12be3a6a709458e3e0fc037e51e971088672ca035108da76b281803a7b529441d90d67a269b5a168a632a6ba4c5ac  krita-kseexpr-4.0.4.0.tar.gz
"
