maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=py3-electrum-ecc
_pkgname=electrum-ecc
pkgver=0.0.7
pkgrel=0
pkgdesc="Library for libsecp256k1 using ctypes"
url="https://github.com/spesmilo/electrum-ecc"
arch="noarch"
license="MIT"
depends="
	libsecp256k1
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="py3-pytest-xdist"
subpackages="$pkgname-pyc"
source="electrum-ecc-$pkgver.tar.gz::https://github.com/spesmilo/electrum-ecc/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

build() {
	export ELECTRUM_ECC_DONT_COMPILE=1
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -n auto tests
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
9f7b91a5933b92ddf516b565780ebbeeccf917e75a28885cfd91502b676010754221d75440118ec6de82d0a7cdd1583b68332b308c5cd3d671eb0eb9a2951a78  electrum-ecc-0.0.7.tar.gz
"
