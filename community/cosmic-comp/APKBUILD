# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-comp
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Compositor for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-comp"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# s390x: DO NOT RE-ENABLE! Arch is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !s390x !x86"
license="GPL-3.0-only"
makedepends="
	cargo-auditable
	fontconfig-dev
	libdisplay-info-dev
	libinput-dev
	libseat-dev
	libxcb-dev
	libxkbcommon-dev
	mesa-dev
	pixman-dev
	wayland-dev
"
options="net"  # fetch dependencies
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-comp/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
15f3768d8d7f9797f86508ce9e3123245d6e99ad9bcda90c269f6b288a19fbe82f180024378a08f66be8a774c5261e630feec6210bce7c61327253ad9f8723d9  cosmic-comp-1.4.0.tar.gz
"
