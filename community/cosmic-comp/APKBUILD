# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-comp
pkgver=1.0.14
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Compositor for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-comp"
# s390x: nix
# riscv64: too slow to build
arch="all !s390x !riscv64"
license="GPL-3.0-only"
makedepends="
	cargo-auditable
	fontconfig-dev
	libdisplay-info-dev
	libinput-dev
	libseat-dev
	libxcb-dev
	libxkbcommon-dev
	mesa-dev
	pixman-dev
	wayland-dev
"
options="net"  # fetch dependencies
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-comp/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
d5bf61409d2203fb7e0ebe8dad672c2e322828eabaeff24237ce56d700509aaa66545fbc704c32e2b8180c1e80bae9cefc758c19da0754276a8b991907ab8de1  cosmic-comp-1.0.14.tar.gz
"
