maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=libgsystemservice
pkgver=0.3.0
pkgrel=0
pkgdesc="Common components for building system services to be exposed on the D-Bus system bus"
url="https://gitlab.gnome.org/pwithnall/libgsystemservice"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	glib-dev
	gtk-doc
	meson
	polkit-dev
	"
checkdepends="dbus"
subpackages="$pkgname-dev $pkgname-doc"
source="https://gitlab.gnome.org/pwithnall/libgsystemservice/-/archive/$pkgver/libgsystemservice-$pkgver.tar.gz
	no-sd-notify.patch
	"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

