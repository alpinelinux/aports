pkgname=cosmic-sound-theme
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="sound theme for the COSMIC desktop environment"
url="https://github.com/pop-os/cosmic-sound-theme"
arch="noarch"
license="CC-BY-SA-4.0"
makedepends="meson"
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-screenshot/archive/refs/tags/epoch-$_upstreamver.tar.gz"
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-sound-theme/archive/refs/tags/epoch-$_upstreamver.tar.gz"
options="!check"  # no tests
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

