# Contributor: Carlo Landmeter <clandmeter@alpinelinux.org>
# Maintainer: Johannes Heimansberg <git@jhe.dedyn.io>
pkgname=domoticz
pkgver=2026.2
pkgrel=0
pkgdesc="Open source Home Automation System"
url="https://www.domoticz.com/"
arch="all"
license="GPL-3.0-or-later"
options="!check" # missing pytest_bdd module
pkgusers="$pkgname"
pkggroups="$pkgname"
makedepends="
	boost-dev
	cereal
	cmake
	curl-dev
	jsoncpp-dev
	libjwt-dev
	libusb-compat-dev
	lua5.3-dev
	minizip-dev
	mosquitto-dev
	openssl-dev>3
	python3-dev
	samurai
	sqlite-dev
	zlib-dev
	"
checkdepends="py3-pytest"
subpackages="$pkgname-openrc"
install="$pkgname.pre-install"
source="domoticz-$pkgver.tar.gz::https://github.com/domoticz/domoticz/releases/download/2026.2/domoticz_src_2026.18004.tar.gz
	luafix.patch
	domoticz.confd
	domoticz.initd
	"
builddir=$srcdir/domoticz

build() {
	cmake -B build -G Ninja \
		-DBUILD_SHARED_LIBS=True \
		-DUSE_STATIC_LIBSTDCXX=OFF \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr/share/domoticz \
		-DUSE_BUILTIN_SQLITE=OFF \
		-DUSE_BUILTIN_MINIZIP=OFF \
		-DUSE_BUILTIN_JSONCPP=OFF \
		-DUSE_STATIC_BOOST=NO \
		-DUSE_STATIC_LIBSTDCXX=NO \
		-DUSE_LUA_STATIC=NO \
		-DUSE_OPENSSL_STATIC=NO \
		-DUSE_BUILTIN_JWTCPP=NO \
		-DGIT_SUBMODULE=NO
	cmake --build build
}

check() {
	pytest -rA --tb=no test/gherkin/
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	mkdir -p \
		"$pkgdir"/usr/bin \
		"$pkgdir"/usr/share/$pkgname
	mv "$pkgdir"/usr/share/domoticz/domoticz \
		"$pkgdir"/usr/bin/
	rm -f "$pkgdir"/usr/share/domoticz/updatedomo

	install -D -m755 "$srcdir/domoticz/build/extern/libwebem/libwebem.so.1" \
		"$pkgdir/usr/lib/libwebem.so.1"
	install -D -m755 "$srcdir"/$pkgname.initd \
		"$pkgdir"/etc/init.d/$pkgname
	install -D -m644 "$srcdir"/$pkgname.confd \
		"$pkgdir"/etc/conf.d/$pkgname
}
