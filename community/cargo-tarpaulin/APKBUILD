maintainer="Leon White <badfunkstripe@gmail.com>"
pkgname=cargo-tarpaulin
pkgver=0.37.0
pkgrel=0
pkgdesc="Code coverage tool for Rust projects"
url="https://github.com/xd009642/tarpaulin"
arch="all"
license="Apache-2.0 OR MIT"
depends="cargo"
makedepends="
	cargo-auditable
	openssl-dev
	"
source="https://github.com/xd009642/tarpaulin/archive/refs/tags/$pkgver/cargo-tarpaulin-$pkgver.tar.gz
	fix-u32-overflow.patch
	update-cargo-libc.patch
	"
builddir="$srcdir/tarpaulin-$pkgver"
options="net"
case "$CARCH" in
	x86|s390x) options="$options !check" ;; # FIXME: many tests fail on these arches
esac

export LIBSSH2_SYS_USE_PKG_CONFIG=1

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	# Tests requiring ASLR fail on aarch64 in container environments
	case "$CARCH" in
	aarch64)
		skip_tests="--skip process_handling::linux::tests::can_disable_aslr \
			--skip ptrace_follow_exec_sanity_test \
			--skip ptrace_sanity_test \
		"
		;;
	*)
		skip_tests=""
	;;
	esac

	# Tests passed in CI but fail on the builders
	# error_if_no_git: assertion failed: get_git_info(&manifest).is_err()
	# git_info_correct: assertion `left == right` failed
	skip_tests="$skip_tests
		--skip report::coveralls::tests::error_if_no_git \
		--skip report::coveralls::tests::git_info_correct \
	"
	cargo test --frozen -- $skip_tests
}

package() {
	install -Dm755 target/release/cargo-tarpaulin \
		-t "$pkgdir"/usr/bin
}

