From 323f21d3f4b28d57d0e8a14aed9dfd8f901d3933 Mon Sep 17 00:00:00 2001
From: Tomer Nosrati <tomer.nosrati@gmail.com>
Date: Sun, 26 Apr 2026 22:43:47 +0000
Subject: [PATCH] fix(defaults,rpc): RabbitMQ 4.3.0 compatibility for transient
 queues (#10290)

RabbitMQ 4.3.0 disables transient non-exclusive queues by default,
rejecting declarations with durable=False and exclusive=False.

Changes:
- Default control_queue_exclusive and event_queue_exclusive to True
  in celery/app/defaults.py (was False)
- Change RPC backend reply queue to durable=True in
  celery/backends/rpc.py (exclusive=True is not viable due to
  multi-connection architecture)
- Update docs to reflect new defaults with versionchanged:: 5.7
  notes and official RabbitMQ reference link
---
 celery/app/defaults.py           |  4 ++--
 celery/backends/rpc.py           |  2 +-
 docs/userguide/configuration.rst | 18 +++++++++++++++---
 docs/userguide/monitoring.rst    |  2 +-
 t/unit/backends/test_rpc.py      |  2 +-
 5 files changed, 20 insertions(+), 8 deletions(-)

diff --git a/celery/app/defaults.py b/celery/app/defaults.py
index 006b78f98b8..1ecbbb5aa24 100644
--- a/celery/app/defaults.py
+++ b/celery/app/defaults.py
@@ -151,7 +151,7 @@ def __repr__(self):
     control=Namespace(
         queue_ttl=Option(300.0, type='float'),
         queue_expires=Option(10.0, type='float'),
-        queue_exclusive=Option(False, type='bool'),
+        queue_exclusive=Option(True, type='bool'),
         queue_durable=Option(False, type='bool'),
         exchange=Option('celery', type='string'),
     ),
@@ -182,7 +182,7 @@ def __repr__(self):
         queue_expires=Option(60.0, type='float'),
         queue_ttl=Option(5.0, type='float'),
         queue_prefix=Option('celeryev'),
-        queue_exclusive=Option(False, type='bool'),
+        queue_exclusive=Option(True, type='bool'),
         queue_durable=Option(False, type='bool'),
         serializer=Option('json'),
         exchange=Option('celeryev', type='string'),
diff --git a/celery/backends/rpc.py b/celery/backends/rpc.py
index 577eb7d404f..40fd973a084 100644
--- a/celery/backends/rpc.py
+++ b/celery/backends/rpc.py
@@ -390,7 +390,7 @@ def __reduce__(self, args=(), kwargs=None):
     def binding(self):
         return self.Queue(
             self.oid, self.exchange, self.oid,
-            durable=False,
+            durable=True,
             auto_delete=True,
             expires=self.expires,
         )
diff --git a/docs/userguide/configuration.rst b/docs/userguide/configuration.rst
index 348ef00a4a4..7eead50239e 100644
--- a/docs/userguide/configuration.rst
+++ b/docs/userguide/configuration.rst
@@ -3797,10 +3797,16 @@ If enabled, the event receiver's queue will be marked as *durable*, meaning it w
 :transports supported: ``amqp``
 .. versionadded:: 5.6
 
-Default: ``False``
+Default: ``True``
 
 If enabled, the event queue will be *exclusive* to the current connection and automatically deleted when the connection closes.
 
+.. versionchanged:: 5.7
+
+   The default was changed from ``False`` to ``True`` for compatibility with RabbitMQ 4.3.0,
+   which no longer permits transient non-exclusive queues by default.
+   See `RabbitMQ Deprecated Features List <https://www.rabbitmq.com/release-information/deprecated-features-list>`_.
+
 .. warning::
 
    You **cannot** set both ``event_queue_durable`` and ``event_queue_exclusive`` to ``True`` at the same time.
@@ -3977,10 +3983,16 @@ If set to ``True``, the control exchange and queue will be durable — they will
 ``control_queue_exclusive``
 ---------------------------
 
-- **Default:** ``False``
+- **Default:** ``True``
 - **Type:** ``bool``
 
-If set to ``True``, the control queue will be exclusive to a single connection. This is generally not recommended in distributed environments.
+If set to ``True``, the control queue will be exclusive to a single connection.
+
+.. versionchanged:: 5.7
+
+   The default was changed from ``False`` to ``True`` for compatibility with RabbitMQ 4.3.0,
+   which no longer permits transient non-exclusive queues by default.
+   See `RabbitMQ Deprecated Features List <https://www.rabbitmq.com/release-information/deprecated-features-list>`_.
 
 .. warning::
 
