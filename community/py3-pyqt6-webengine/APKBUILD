# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-pyqt6-webengine
pkgver=6.11.0
pkgrel=0
pkgdesc="Python bindings for the Qt6 WebEngine framework"
url="https://pypi.org/project/PyQt6-WebEngine/"
# armhf: blocked by qt6-qtdeclarative
# others blocked by qt6-qtwebengine
arch="all !riscv64 !s390x !armhf !armv7 !x86"
license="GPL-3.0-only"
depends="py3-qt6"
makedepends="
	py3-pyqt-builder
	py3-sip
	python3-dev
	qt6-qtwebengine-dev
	"
source="https://pypi.python.org/packages/source/P/PyQt6-WebEngine/pyqt6_webengine-$pkgver.tar.gz"
builddir="$srcdir/pyqt6_webengine-$pkgver"

build() {
	sip-build \
		--no-make \
		--qmake=/usr/bin/qmake6
	make -C build
}

package() {
	make -C build INSTALL_ROOT="$pkgdir" install
}

sha512sums="
9c1602a97721f91640b2479e80662b3c342c28ed156ccafc6d1d0fef2c57beba6d8cb466dc770ca445cd2fd19361f03302e5d0bb1bd554cea5209a45319ce38c  pyqt6_webengine-6.11.0.tar.gz
"
