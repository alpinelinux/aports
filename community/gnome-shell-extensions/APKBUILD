# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=gnome-shell-extensions
pkgver=50.0
pkgrel=0
pkgdesc="collection of extensions for GNOME Shell"
url="https://apps.gnome.org/Extensions"
arch="noarch"
license="GPL-2.0-or-later"
depends="
	gnome-menus
	libgtop
	"
makedepends="
	gettext-dev
	glib-dev
	meson
	sassc
	"
subpackages="
	$pkgname-lang
	$pkgname-systemd
	"
source="https://download.gnome.org/sources/gnome-shell-extensions/${pkgver%.*}/gnome-shell-extensions-$pkgver.tar.xz"

build() {
	abuild-meson \
		-Dextension_set=all \
		-Dclassic_mode=true \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
5405fe2a3b8a40b5baa2603d16aca2744b928a271b76410195b6c0619163101a2da1df69047325a76b3546dcbd87cb9ca57773ea02cb640a7d6c6d3f67f38ac4  gnome-shell-extensions-50.0.tar.xz
"
