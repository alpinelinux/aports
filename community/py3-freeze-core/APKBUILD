# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=py3-freeze-core
pkgver=0.6.1
pkgrel=0
pkgdesc="Core dependency for cx_Freeze"
url="https://github.com/marcelotduarte/freeze-core"
arch="all"
license="MIT"
depends="
	py3-filelock
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	python3-dev
	"
checkdepends="
	py3-pytest
	"
subpackages="$pkgname-dev $pkgname-pyc"
source="https://github.com/marcelotduarte/freeze-core/archive/$pkgver/freeze-core-$pkgver.tar.gz"
builddir="$srcdir/freeze-core-$pkgver"
options="!check" # 0.6.1 has Windows-only tests

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# test_winmsvcr*: Windows-only tests not automatically skipped in some envs
	.testenv/bin/python3 -m pytest \
		--deselect tests/test_winmsvcr.py \
		--deselect tests/test_winmsvcr_repack.py
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
47e3e8976e02aa2d954993a324cda37c7b04a683a0f9752642752a3c0c4fc0ee8c954a0c893163732782adc6735e6784f594f127fb718f60f45d045b6e95ecd3  freeze-core-0.6.1.tar.gz
"
