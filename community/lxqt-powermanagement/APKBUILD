# Contributor: Zachary Lee Andrews <zcrayfish@gmail.com>
maintainer="Antoni Aloy <aaloytorrens@gmail.com>"
pkgname=lxqt-powermanagement
pkgver=2.4.0
pkgrel=0
pkgdesc="Power management module for LXQt"
url="https://github.com/lxqt/lxqt-powermanagement"
# armhf blocked by extra-cmake-modules -> kwindowsystem-dev
arch="all !armhf"
license="LGPL-2.0-or-later"
makedepends="
	cmake
	samurai
	kidletime-dev
	kwindowsystem-dev
	liblxqt-dev
	lxqt-build-tools
	lxqt-globalkeys-dev
	perl
	qt6-qttools-dev
	solid-dev
	"
options="!check" # No testsuite
subpackages="$pkgname-lang"
source="https://github.com/lxqt/lxqt-powermanagement/releases/download/$pkgver/lxqt-powermanagement-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=True
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

lang() {
	install_if="lang $pkgname=$pkgver-r$pkgrel"
	amove usr/share/lxqt/translations/$pkgname
}

sha512sums="
59a3e979a5656b12fca83cd6006da4105903a3c7024ea05b20e0cf9abf6f85e6b300e6baaeffabf452c04adc0cbe09b476e6f7d74ef45276d64d8dcf14cc1d24  lxqt-powermanagement-2.4.0.tar.xz
"
