# Maintainer: kpcyrd <git@rxv.cc>
pkgname=wasm-bindgen
pkgver=0.2.118
pkgrel=0
pkgdesc="Interoperating JS and Rust code"
url="https://github.com/rustwasm/wasm-bindgen"
arch="all"
license="Apache-2.0"
depends="cargo nodejs rust-wasm"
makedepends="
	cargo-auditable
	"
source="https://github.com/rustwasm/wasm-bindgen/archive/refs/tags/$pkgver/wasm-bindgen-$pkgver.tar.gz
	Cargo.lock
	tests.patch
	"
options="net"

prepare() {
	# https://github.com/rustwasm/wasm-bindgen/issues/1819
	cp "$srcdir/Cargo.lock" .

	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cd crates/cli
	cargo auditable build --release --frozen
}

check() {
	cd crates/cli

	case "$CARCH" in
	arm*|s390x|x86)
		RUSTFLAGS= \
		cargo test --frozen \
			--no-fail-fast \
			|| true # FIXME most tests fail
		;;
	*)
		RUSTFLAGS= \
		cargo test --frozen -- \
			--skip no_duplicate_wasm_export_in_node_esm_atomics_debug \
			--skip termination_abort_handler \
			--skip termination_reinit
		# the above tests make use of the -Z flag, only available in rust nightly
	esac
}

package() {
	install -Dm755 -t "$pkgdir"/usr/bin \
		target/release/wasm-bindgen \
		target/release/wasm-bindgen-test-runner \
		target/release/wasm2es6js
}

