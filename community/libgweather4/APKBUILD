# Contributor: Rasmus Thomsen <oss@cogitri.dev>
# Maintainer: Newbyte <newbie13xd@gmail.com>
pkgname=libgweather4
pkgver=4.6.0
pkgrel=0
# NOTE: Upgrade only to even-numbered versions (e.g. 1.18.x, 1.20.x)!
pkgdesc="GNOME weather library"
url="https://gitlab.gnome.org/GNOME/libgweather"
arch="all"
license="LGPL-2.1-or-later"
depends="tzdata gsettings-desktop-schemas gweather-locations"
makedepends="
	font-cantarell
	geocode-glib-dev>=3.26.4-r1
	gi-docgen
	glib-dev
	gobject-introspection-dev
	gweather-locations-dev
	json-glib-dev
	libsoup3-dev
	libxml2-dev
	meson
	py3-gobject3
	vala
	"
options="!check" # Fail due to musl locale support
subpackages="$pkgname-dev $pkgname-doc $pkgname-lang"
source="https://download.gnome.org/sources/libgweather/${pkgver%.*}/libgweather-$pkgver.tar.xz"
builddir="$srcdir/libgweather-$pkgver"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dgtk_doc=true \
		-Denable_vala=true \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
1ca6ffe7cc8b6cf98b39137a7bf50c3e065def32c31ba40431b82020fc8f62da5e9903a27c850d234760581430bccc0eeb9c74b495e7c7f3312252c31cbbb8d6  libgweather-4.6.0.tar.xz
"
