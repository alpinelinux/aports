From 95513d1c3637647f476e1032f61da72b03247824 Mon Sep 17 00:00:00 2001
From: Clayton Craft <clayton@craftyguy.net>
Date: Sun, 19 Apr 2026 10:59:16 -0700
Subject: [PATCH] Add systemd-units option to install units without systemd
 integration

Downstream distributions, like postmarketOS, may build and package
Plymouth in an environment (Alpine Linux) where systemd is unavailable,
while still wanting to ship systemd units at runtime. This adds a new
systemd-units option allows installing units without requiring systemd
at build time or enabling the daemon's systemd integration code.

Co-authored-by: Achill Gilgenast <achill@achill.org>
---
 meson.build               | 16 ++++++++++++----
 meson_options.txt         |  5 +++++
 systemd-units/meson.build |  2 +-
 3 files changed, 18 insertions(+), 5 deletions(-)

diff --git a/meson.build b/meson.build
index 98699ec2..22c9c45a 100644
--- a/meson.build
+++ b/meson.build
@@ -39,12 +39,20 @@ libevdev_dep = dependency('libevdev')
 xkbcommon_dep = dependency('xkbcommon')
 xkeyboard_config_dep = dependency('xkeyboard-config')
 
-if get_option('systemd-integration')
-  systemd_dep = dependency('systemd')
+if get_option('systemd-integration') or get_option('systemd-units')
+  systemd_dep = dependency('systemd', required: get_option('systemd-integration'))
   systemd_unit_dir = systemd_dep.get_variable('systemdsystemunitdir',
     pkgconfig_define: [ 'rootprefix', get_option('prefix') ],
+    default_value: '/usr/lib/systemd/system',
   )
-  systemd_ask_password_agent = find_program('systemd-tty-ask-password-agent')
+  systemd_ask_password_agent = find_program('systemd-tty-ask-password-agent',
+    required: get_option('systemd-integration')
+  )
+  if systemd_ask_password_agent.found()
+    systemd_ask_password_agent_path = systemd_ask_password_agent.full_path()
+  else
+    systemd_ask_password_agent_path = '/usr/bin/systemd-tty-ask-password-agent'
+  endif
 endif
 
 if get_option('upstart-monitoring')
@@ -96,7 +104,7 @@ subdir('po')
 subdir('src')
 subdir('themes')
 subdir('scripts')
-if get_option('systemd-integration')
+if get_option('systemd-integration') or get_option('systemd-units')
   subdir('systemd-units')
 endif
 if get_option('docs')
diff --git a/meson_options.txt b/meson_options.txt
index 4f601bb0..875ddf3a 100644
--- a/meson_options.txt
+++ b/meson_options.txt
@@ -53,6 +53,11 @@ option('systemd-integration',
   value: true,
   description: 'Coordinate boot up with systemd',
 )
+option('systemd-units',
+  type: 'boolean',
+  value: false,
+  description: 'Install systemd units without enabling systemd integration in the daemon'
+)
 option('udev',
   type: 'feature',
   value: 'auto',
diff --git a/systemd-units/meson.build b/systemd-units/meson.build
index 06379312..a291b0b0 100644
--- a/systemd-units/meson.build
+++ b/systemd-units/meson.build
@@ -21,7 +21,7 @@ foreach unit_templ : systemd_unit_templates
       'PLYMOUTH_CLIENT_DIR': get_option('prefix') / get_option('bindir'),
       'PLYMOUTH_DAEMON_DIR': get_option('prefix') / get_option('sbindir'),
       'plymouthruntimedir': plymouth_runtime_dir,
-      'SYSTEMD_ASK_PASSWORD_AGENT': systemd_ask_password_agent.full_path(),
+      'SYSTEMD_ASK_PASSWORD_AGENT': systemd_ask_password_agent_path,
     },
     install: true,
     install_dir: systemd_unit_dir,
