maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=pimsync
pkgver=0.5.7
pkgrel=1
pkgdesc="Synchronise calendars and contacts using CalDAV, CardDAV and others"
url="https://pimsync.whynothugo.nl/"
arch="all"
license="EUPL-1.2"
makedepends="cargo sqlite-dev"
subpackages="
	$pkgname-doc
	$pkgname-zsh-completion
	$pkgname-openrc
	"
source="
	pimsync-$pkgver.tar.gz::https://git.sr.ht/~whynothugo/pimsync/archive/v$pkgver.tar.gz
	pimsync.initd
	"
builddir="$srcdir/$pkgname-v$pkgver"
options="net" # fetch dependencies

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	export PIMSYNC_VERSION=v$pkgver-r$pkgrel
	mkdir target
	make build
}

check() {
	cargo test --frozen
	# Ensure that the system sqlite is being dynamically linked.
	ldd target/release/pimsync | grep libsqlite3.so
}

package() {
	DESTDIR="$pkgdir" PREFIX="/usr" make install --trace
	install -Dm755 "$srcdir"/pimsync.initd "$pkgdir"/etc/user/init.d/pimsync
}

sha512sums="
111b31bf0246dccdece619c88debea1be352bc9a0b57a1d8a8a5503685ce34ed749bcc587a5fe7ab3ec77d417256846e36ba6b8523ce7b99a46f981ed0bb9cf2  pimsync-0.5.7.tar.gz
6280a8965f6a66261157aff3469912d64cc775c7ae739f4957719da325266463cde7ae5265233a74905a432424c3728c3d2d5088ad6c7156a4920472512d1c2d  pimsync.initd
"
