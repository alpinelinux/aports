From 27a8d03c7e2b72c79efd7d8f7bba0163eea7e98c Mon Sep 17 00:00:00 2001
From: LN Liberda <lauren@selfisekai.rocks>
Date: Fri, 3 Apr 2026 17:44:15 +0200
Subject: [PATCH] Zig 0.16: What did you do to IO?

---
 build.zig             | 16 +++++++----
 src/args.zig          | 12 ++++----
 src/gitversiontag.zig |  4 +--
 src/main.zig          | 65 ++++++++++++++++++++++++-------------------
 4 files changed, 55 insertions(+), 42 deletions(-)

diff --git a/build.zig b/build.zig
index 7f2cb72..c464502 100644
--- a/build.zig
+++ b/build.zig
@@ -4,16 +4,22 @@ const gitVersionTag = @import("src/gitversiontag.zig").gitVersionTag;
 pub fn build(b: *std.Build) void {
     // write src/version.zig
     const alloc = std.heap.page_allocator;
-    const gvs = gitVersionTag(alloc);
+    var threaded = std.Io.Threaded.init(alloc, .{});
+    defer threaded.deinit();
+    const io = threaded.io();
+    const gvs = gitVersionTag(alloc, io);
     const efmt = "WARNING: could not write src/version.zig:\n   {t}\n";
     var stderr_buffer: [512]u8 = undefined;
-    var stderr_writer = std.fs.File.stderr().writer(&stderr_buffer);
+    var stderr_writer = std.Io.File.stderr().writer(io, &stderr_buffer);
     const stderr = &stderr_writer.interface;
-    if (std.fs.cwd().createFile("src/version.zig", .{})) |file| {
-        defer file.close();
+    if (std.Io.Dir.cwd().createFile(io, "src/version.zig", .{})) |file| {
+        defer file.close(io);
         const zigfmt = "pub const version_string = \"{s}\";";
         if (std.fmt.allocPrint(alloc, zigfmt, .{gvs})) |strline| {
-            if (file.writeAll(strline)) {} else |e| {
+            var file_buffer: [512]u8 = undefined;
+            var writer = file.writer(io, &file_buffer);
+            defer writer.end() catch unreachable;
+            if (writer.interface.writeAll(strline)) {} else |e| {
                 stderr.print(efmt, .{e}) catch unreachable;
             }
         } else |err| {
