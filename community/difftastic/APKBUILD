maintainer="Michał Polański <michal@polanski.me>"
pkgname=difftastic
pkgver=0.69.0
pkgrel=0
pkgdesc="Diff tool that understands syntax"
url="https://difftastic.wilfred.me.uk/"
license="MIT"
arch="all"
makedepends="cargo cargo-auditable openssl-dev"
subpackages="$pkgname-doc"
options="net"
source="https://github.com/Wilfred/difftastic/archive/$pkgver/difftastic-$pkgver.tar.gz"

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/difft -t "$pkgdir"/usr/bin/
	install -Dm644 difft.1 -t "$pkgdir"/usr/share/man/man1/
}

sha512sums="
eb39e8601ca2a1699327a32d3f6d5a338d694da7eaa6d0c5decb571b87ac26e6477294f5dce46b1ef316f3ced2f30cf27795af9f844326ffb9d9e8e2bbbb052c  difftastic-0.69.0.tar.gz
"
