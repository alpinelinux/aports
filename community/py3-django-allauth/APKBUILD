# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-django-allauth
_pyname="django-allauth"
pkgver=65.15.0
pkgrel=0
arch="noarch"
pkgdesc="Integrated set of Django applications addressing SSO"
url="https://pypi.python.org/project/django-allauth"
license="MIT"
# missing opt depends: python3-openid
depends="
	py3-python3-saml
	py3-qrcode
	py3-django
	py3-openid
	py3-requests
	py3-requests-oauthlib
	py3-jwt
	py3-cryptography
	py3-fido2
	"
makedepends="
	py3-setuptools
	py3-gpep517
	py3-wheel
	"
checkdepends="
	py3-pytest
	py3-pytest-asyncio
	py3-pytest-django
	py3-django-rest-framework
	py3-psycopg2
	py3-django-ninja
	py3-yaml
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/pennersr/$_pyname/archive/$pkgver.tar.gz"
builddir="$srcdir"/$_pyname-$pkgver
subpackages="$pkgname-pyc"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer --destdir="$pkgdir" .dist/*.whl
}

sha512sums="
2c302fa0487388a82943268a4837a7a62666388cd1d4595a2d79d5d7feca00f48fd3c7a0f0f8857f50073239bf8609667acb484943d63afe02d89f21378eff0b  py3-django-allauth-65.15.0.tar.gz
"
