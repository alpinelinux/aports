maintainer="Zach DeCook <zachdecook@librem.one>"
pkgname=hyprgraphics
pkgver=0.5.1
pkgrel=1
pkgdesc="Hyprland graphics / resource utilities"
url="https://github.com/hyprwm/hyprgraphics"
arch="all"
license="BSD-3-Clause"
source="
	https://github.com/hyprwm/hyprgraphics/archive/v$pkgver/hyprgraphics-v$pkgver.tar.gz
	big-endian-jpeg.patch
	drop-tests-that-occasionally-fail.patch
	"
subpackages="$pkgname-doc $pkgname-dev"
makedepends="
	cairo-dev
	cmake
	file-dev
	hyprutils-dev
	libdrm-dev
	libheif-dev
	libjpeg-turbo-dev
	libjxl-dev
	libpng-dev
	librsvg-dev
	libwebp-dev
	mesa-dev
	samurai
	pixman-dev
	"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_BUILD_TYPE=None
	cmake --build build
}

check() {
	cd build
	ctest
}

package() {
	DESTDIR="$pkgdir" cmake --install build
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}


