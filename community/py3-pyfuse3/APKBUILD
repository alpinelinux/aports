# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=py3-pyfuse3
pkgver=3.4.2
pkgrel=0
pkgdesc="Python 3 bindings for libfuse 3 with asynchronous API"
url="https://github.com/libfuse/pyfuse3"
arch="all"
license="LGPL-2.0-or-later"
depends="
	py3-trio
	python3
	"
makedepends="
	cython
	fuse3-dev
	linux-headers
	py3-setuptools
	py3-gpep517
	python3-dev
	"
checkdepends="
	cmd:fusermount3
	py3-pytest
	py3-pytest-trio
	"
subpackages="$pkgname-pyc"
source="https://github.com/libfuse/pyfuse3/releases/download/v$pkgver/pyfuse3-$pkgver.tar.gz"
builddir="$srcdir/pyfuse3-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
b858fd1b77c22ca064daafeba52f3b6c545c0c9f54393f7c795219de0d53093bee1bf1f31a6491f2db883721a0aeeedbb9e478e937eb3801a175cffe8b5a95ce  pyfuse3-3.4.2.tar.gz
"
