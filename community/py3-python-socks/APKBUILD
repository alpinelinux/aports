# Maintainer: Michał Adamski <michal@ert.pl>
pkgname=py3-python-socks
pkgver=2.8.1
pkgrel=0
pkgdesc="Core proxy client (SOCKS4, SOCKS5, HTTP) functionality for Python"
options="!check" # Testsuite ships their own GLIBC version of 3proxy
url="https://github.com/romis2012/python-socks"
arch="noarch"
license="Apache-2.0"
depends="python3"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-curio py3-trio py3-pytest py3-yarl"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/python-socks/python_socks-$pkgver.tar.gz"
builddir="$srcdir/python_socks-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
4d4980285fb0dd01f8185b8ae2f86e478c40923895a8fb59827c43cd3177620d0f6f39dc1f0472b0f4e8c795077a069db2aeabf638f10265d13dce3e7a24198e  python_socks-2.8.1.tar.gz
"
