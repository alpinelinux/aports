# Contributor: Wen Heping <wenhepingalpine@sohu.com>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=py3-baize
pkgver=0.23.1
pkgrel=0
# _pkgreal is used by apkbuild-pypi to find modules at PyPI
_pkgreal=baize
pkgdesc="Powerful and exquisite WSGI/ASGI framework/toolkit."
url="https://pypi.org/project/baize/"
arch="noarch"
license="Apache-2.0"
makedepends="py3-gpep517 py3-setuptools py3-wheel py3-pdm-backend"
checkdepends="py3-pytest py3-pytest-asyncio py3-httpx py3-starlette"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/b/baize/baize-$pkgver.tar.gz"
builddir="$srcdir/$_pkgreal-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
2c0cba97f856edeb13402fdfacfc5757c5ed12297f9144178f4e874bbcc01c937158f190624019706d3dc0c3d7f606224498959e7e203ba007f3817042e5ec14  baize-0.23.1.tar.gz
"
