# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=arti
pkgver=2.3.0
pkgrel=0
pkgdesc="An implementation of Tor, in Rust"
url="https://tpo.pages.torproject.net/core/arti/"
license="GPL-3.0-or-later"
# s390x: merlin crate doesn't support big-endian targets
arch="all !s390x"
makedepends="cargo
	cargo-auditable
	curl
	openssl-dev>3
	sqlite-dev
	xz-dev
	zstd-dev
	"
subpackages="$pkgname-doc $pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://gitlab.torproject.org/tpo/core/arti/-/archive/arti-v$pkgver/arti-arti-v$pkgver.tar.gz
	arti-example-config.patch
	disable-access_symlink-test.patch
	no-journald-build.patch
	tor-rpcbase-dep.patch
	32b_arti_example_config_patch
	32b_time_conversion_tests_patch
	32b_tor-memquota_patch
	arti.initd
	"
builddir="$srcdir/$pkgname-$pkgname-v$pkgver"
install="$pkgname.pre-install $pkgname.pre-upgrade"
pkgusers="arti"
pkggroups="arti"

case "$CARCH" in
arm*|loongarch64|ppc64le|riscv64|x86)
	# for aws-lc-sys
	checkdepends="$checkdepends cmake clang-dev"
	;;
esac

export OPENSSL_NO_VENDOR=1

prepare() {
	default_prepare

	case "$CARCH" in
	arm*|x86)
		patch crates/arti/src/arti-example-config.toml \
			"$srcdir"/32b_arti_example_config_patch
		patch crates/tor-hsservice/src/time_store.rs \
			"$srcdir"/32b_time_conversion_tests_patch
		patch crates/tor-memquota/src/config.rs \
			"$srcdir"/32b_tor-memquota_patch
		;;
	esac

	cargo fetch --target="$CTARGET" --locked

	# Build against system-provided libs
	mkdir -p .cargo
	cat >> .cargo/config.toml <<-EOF
		[target.$CHOST]
		zstd = { rustc-link-lib = ["zstd"] }
	EOF
}

build() {
	RUST_BACKTRACE=full \
	cargo auditable build --release --frozen --features=full --package arti
}

check() {
	case "$CARCH" in
	arm*|x86)
		# https://gitlab.torproject.org/tpo/core/arti/-/issues/2084
		cargo test --frozen --workspace --exclude tor-memquota -- \
			--skip "cfg::test::memquota" \
			--skip "time_store::test::system_time_conversions"
		;;
	riscv64)
		# https://gitlab.torproject.org/tpo/core/arti/-/issues/1398
		cargo build --tests --frozen --keep-going
		RUST_BACKTRACE=full cargo test --tests --frozen --no-fail-fast || true
		# NOTE: we're currently allowing tests to fail here
		;;
	*)
		cargo test --frozen
		;;
	esac
}

package() {
	install -Dm755 -t "$pkgdir"/usr/bin/ target/release/arti
	install -dm0755 "$pkgdir"/etc/"$pkgname"/
	install -dm755 -o "$pkgusers" -g "$pkggroups" \
		"$pkgdir"/var/lib/"$pkgname"/
	install -dm750 -o "$pkgusers" -g "$pkggroups" \
		"$pkgdir"/var/log/"$pkgname"/

	install -Dm755 -t "$pkgdir"/usr/share/doc/"$pkgname"/ \
		doc/bridges.md \
		doc/Compatibility.md \
		doc/FAQ.md \
		doc/OnionService.md \
		doc/SupportPolicy.md \
		CHANGELOG.md README.md \
		crates/arti/src/arti-example-config.toml

	install -Dm755 "$srcdir"/"$pkgname".initd \
		"$pkgdir"/etc/init.d/"$pkgname"
}

