# Contributor: jane400 <alpine@j4ne.de>
maintainer="team/gnome <newbyte@postmarketos.org>"
pkgname=gnome-text-editor
pkgver=50.1
pkgrel=0
pkgdesc="A simple text editor for GNOME"
url="https://apps.gnome.org/TextEditor"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	desktop-file-utils
	editorconfig-dev
	enchant2-dev
	glib-dev
	gtk4.0-dev
	gtksourceview5-dev
	itstool
	libadwaita-dev
	libspelling-dev
	meson
	"
checkdepends="
	appstream-glib
	"
subpackages="$pkgname-doc $pkgname-lang"
source="https://gitlab.gnome.org/GNOME/gnome-text-editor/-/archive/$pkgver/gnome-text-editor-$pkgver.tar.gz"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dbugreport_url="https://gitlab.alpinelinux.org/alpine/aports/-/issues" \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
2a2dbe8de9a32fb003efad9bd9715f4af663a0a153eb35b0cc36bccbdbce0678ba85dce0782c1234d9c4d95d7815aa57a6d01c7d7e92a30f310cef6ff2d4c90f  gnome-text-editor-50.1.tar.gz
"
