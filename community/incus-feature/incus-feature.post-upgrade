#!/bin/sh

ver_new="$1"
ver_old="$2"

if [ $(apk version -t "$ver_old" '6.22.0-r1') = '<' ]; then
	cat >&2 <<-EOF
	*
	* Please note that the init 'quit' command has been removed and
	* 'quit' has become the default behaviour when the daemon is stopped.
	* Instances are now stopped by 'incus-features-instances' init.
	* Please add 'incus-features-instances' to autostart and start it:
	*
	*     'rc-update add incus-features-instances'
	*     'rc-service incus-features-instances start'
	*
	EOF
fi
