From 5c470a0933d4dcd291fb38f62cff1a504277762a Mon Sep 17 00:00:00 2001
From: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
Date: Tue, 17 Feb 2026 11:43:11 +0100
Subject: [PATCH] Remove reference to obsolete pkg_resources

Fixes: https://github.com/pimutils/vdirsyncer/issues/1062
---
 docs/conf.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/docs/conf.py b/docs/conf.py
index 4b2c93b0..d553d98f 100644
--- a/docs/conf.py
+++ b/docs/conf.py
@@ -3,7 +3,7 @@
 import datetime
 import os
 
-from pkg_resources import get_distribution
+import vdirsyncer
 
 extensions = ["sphinx.ext.autodoc"]
 
@@ -17,7 +17,7 @@
     datetime.date.today().strftime("%Y")
 )
 
-release = get_distribution("vdirsyncer").version
+release = vdirsyncer.__version__
 version = ".".join(release.split(".")[:2])  # The short X.Y version.
 
 rst_epilog = f".. |vdirsyncer_version| replace:: {release}"
