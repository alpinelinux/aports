# Contributor: Marian Buschsieweke <marian.buschsieweke@posteo.net>
# Maintainer: Marian Buschsieweke <marian.buschsieweke@posteo.net>
pkgname=py3-qtgraph
pkgver=0.14.0
pkgrel=0
pkgdesc="Scientific Graphics and GUI Library for Python"
url="https://www.pyqtgraph.org/"
arch="noarch"
license="MIT"
depends="
	py3-colorama
	py3-numpy
	py3-opengl
	py3-scipy
	python3
	"
case "$CARCH" in
armhf) ;;
*) depends="$depends py3-qt6" ;;
esac
makedepends="
	py3-gpep517
	py3-setuptools
	"
checkdepends="
	py3-pytest
	xwayland-run
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/pyqtgraph/pyqtgraph/archive/pyqtgraph-$pkgver.tar.gz
	numpy.patch
	"
builddir="$srcdir/pyqtgraph-pyqtgraph-$pkgver"

case "$CARCH" in
# tests fail
armhf|riscv64) options="!check" ;;
esac

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	xwfb-run -- .testenv/bin/python3 -m pytest \
		--ignore tests/exporters/test_svg.py \
		--deselect tests/graphicsItems/test_ErrorBarItem.py::test_ErrorBarItem_defer_data
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
f9c973d5dbfd79ef34652a5eb8eadbc1b0215aa1c30773e5c58148bae6a6d79d3e21a904b1a6dd8ff6eb7fe15debf6c1d45c8a9cce96cbcc60495bc9814259f7  py3-qtgraph-0.14.0.tar.gz
054c43761cd5f7c0cad98c28d4e2d88697caf44d8fa18d89b9148cb396701f81591119090ad8388f479668362be478afd581780a497f099d965d5e1f45446a86  numpy.patch
"
