maintainer="Michał Polański <michal@polanski.me>"
pkgname=gfold
pkgver=2026.3.0
pkgrel=0
pkgdesc="CLI tool to help keep track of Git repositories"
url="https://github.com/nickgerace/gfold"
license="Apache-2.0"
arch="all"
makedepends="cargo cargo-auditable"
subpackages="$pkgname-doc"
source="https://github.com/nickgerace/gfold/archive/$pkgver/gfold-$pkgver.tar.gz"
options="net" # Cargo crates

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen

	target/release/gfold --generate-man
}

check() {
	git init # needed for the integration test
	cargo test --frozen --workspace
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin/

	install -Dm644 $pkgname.1 -t "$pkgdir"/usr/share/man/man1/
}

sha512sums="
684aa66e07b314b4ebe5436644b64446317da918e1b2f8e6fb493f75d27848cb3a2c357d7a9968feb49e44df4420b0d5dd950c3fdf92762d7457ea232bfb5b2f  gfold-2026.3.0.tar.gz
"
