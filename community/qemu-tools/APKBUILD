# Contributor: Valery Kartel <valery.kartel@gmail.com>
# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=qemu-tools
pkgver=11.0.1
pkgrel=0
pkgdesc="QEMU support tools"
url="https://qemu.org/"
# only where qemu is not supported
arch="armhf armv7 x86"
license="GPL-2.0-only AND LGPL-2.1-only"
makedepends="
	bash
	curl-dev
	glib-dev
	gnutls-dev
	libaio-dev
	libxkbcommon-dev
	liburing-dev
	meson
	numactl-dev
	python3
	zlib-dev
	zstd-dev
	"
pkggroups="qemu"

# net: pip install(?)
# !check: many tests expect a qemu-system-* executable
options="net !check"

subpackages="
	qemu-guest-agent:_guest
	qemu-guest-agent-openrc
	qemu-img
	"

source="https://download.qemu.org/qemu-$pkgver.tar.xz
	0006-linux-user-signal.c-define-__SIGRTMIN-MAX-for-non-GN.patch
	xattr_size_max.patch
	MAP_SYNC-fix.patch
	fix-sockios-header.patch
	musl-initialise-msghdr.patch
	liburing.patch

	qemu-guest-agent.confd
	qemu-guest-agent.initd
	bridge.conf
	"
builddir="$srcdir/qemu-$pkgver"

build() {
	./configure \
		--prefix=/usr \
		--localstatedir=/var \
		--sysconfdir=/etc \
		--libexecdir=/usr/lib/qemu \
		--python=/usr/bin/python3 \
		--enable-guest-agent \
		--enable-tools \
		--disable-plugins \
		--target-list=""
	make
}

package() {
	make DESTDIR="$pkgdir" install

	# remove firmware and other unrelated files
	rm -r \
		"${pkgdir:?}"/usr/share \
		"${pkgdir:?}"/var \
		"${pkgdir:?}"/usr/lib \
		"${pkgdir:?}"/usr/bin/qemu-*-helper

	install -Dm755 "$srcdir"/qemu-guest-agent.initd \
		"$pkgdir"/etc/init.d/qemu-guest-agent
	install -Dm644 "$srcdir"/qemu-guest-agent.confd \
		"$pkgdir"/etc/conf.d/qemu-guest-agent
}

img() {
	pkgdesc="QEMU command line tool for manipulating disk images"
	depends=""

	amove \
		usr/bin/qemu-img \
		usr/bin/qemu-io \
		usr/bin/qemu-nbd \
		usr/bin/qemu-storage-daemon
}

_guest() {
	pkgdesc="QEMU guest agent"
	depends=""
	options=""

	amove usr/bin/qemu-ga
}

