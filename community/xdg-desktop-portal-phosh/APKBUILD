maintainer="team/phosh <achill@achill.org>"
pkgname=xdg-desktop-portal-phosh
pkgver=0.56.0
pkgrel=0
pkgdesc="xdg-desktop-portal implementation using GTK/GNOME/Phosh"
url="https://gitlab.gnome.org/World/Phosh/xdg-desktop-portal-phosh"
arch="all"
license="GPL-3.0-or-later"
depends="
	gsettings-desktop-schemas
	xdg-desktop-portal
	"
makedepends="
	cargo
	gnome-desktop-dev
	libadwaita-dev
	meson
	py3-docutils
	xdg-desktop-portal-dev
	"
subpackages="
	$pkgname-doc
	$pkgname-lang
	$pkgname-systemd
	"
source="https://sources.phosh.mobi/releases/xdg-desktop-portal-phosh/xdg-desktop-portal-phosh-${pkgver/_/.}.tar.xz"
options="!check net" # no tests, cargo modules for pfs
builddir="$srcdir/$pkgname-${pkgver/_/.}"

prepare() {
	default_prepare
	sed -i 's/\.rc/_rc/' meson.build
}

build() {
	abuild-meson \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
bbaa099232f73f8e6f53af2baf4fa642449cead8a56692616aaaf645831efc25a02378e4ab55770748f9c0b2a3e193bc1b51e2cf53a0feda4d473f617322a682  xdg-desktop-portal-phosh-0.56.0.tar.xz
"
