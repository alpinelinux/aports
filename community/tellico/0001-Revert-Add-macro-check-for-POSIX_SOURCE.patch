From 6a6b049a0efdbb6f1c4120b789e15284baa0e411 Mon Sep 17 00:00:00 2001
From: Bart Ribbers <bart@iconica.nl>
Date: Tue, 21 Jul 2026 08:59:16 +0200
Subject: [PATCH] Revert "Add macro check for POSIX_SOURCE"

This reverts commit e500b13c0f1c0707141d8e7754c69aab74953c09.
---
 src/3rdparty/btparse/btparse.h | 14 --------------
 1 file changed, 14 deletions(-)

diff --git a/src/3rdparty/btparse/btparse.h b/src/3rdparty/btparse/btparse.h
index 74d809629..61865de8e 100644
--- a/src/3rdparty/btparse/btparse.h
+++ b/src/3rdparty/btparse/btparse.h
@@ -21,10 +21,6 @@
 #ifndef BTPARSE_H
 #define BTPARSE_H
 
-#ifdef _POSIX_C_SOURCE
-  #define TEMP_SAVE_POSIX_C_SOURCE _POSIX_C_SOURCE
-  #undef _POSIX_C_SOURCE
-#endif
 #define _POSIX_C_SOURCE 200809L
 
 #include <sys/types.h>                  /* probably supplies 'ushort' */
@@ -356,14 +352,4 @@ char * bt_format_name (bt_name * name, bt_name_format * format);
 }
 #endif
 
-// Wipe out the temporary version we just used
-#undef _POSIX_C_SOURCE
-
-// If POSIX_SOURCE existed before, bring back the saved value
-#undef _POSIX_C_SOURCE
-#ifdef TEMP_SAVE_POSIX_C_SOURCE
-    #define _POSIX_C_SOURCE TEMP_SAVE_POSIX_C_SOURCE
-    #undef TEMP_SAVE_POSIX_C_SOURCE
-#endif
-
 #endif /* BTPARSE_H */
