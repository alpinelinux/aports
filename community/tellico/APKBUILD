maintainer="team/kde <bribbers@disroot.org>"
pkgname=tellico
pkgver=4.2.1
pkgrel=0
pkgdesc="Collection management software, free and simple"
# armhf, x86, s390x and riscv64 blocked by qt6-qtwebengine
# armv7 blocked by test failure, 17 - documenttest (ILLEGAL)
arch="all !armhf !x86 !s390x !riscv64 !armv7"
url="https://tellico-project.org/"
license="GPL-2.0-only"
makedepends="
	exempi-dev
	extra-cmake-modules
	karchive-dev
	kcodecs-dev
	kconfig-dev
	kconfigwidgets-dev
	kcoreaddons-dev
	kcrash-dev
	kdoctools-dev
	kfilemetadata-dev
	kguiaddons-dev
	ki18n-dev
	kiconthemes-dev
	kio-dev
	kitemmodels-dev
	kjobwidgets-dev
	knewstuff-dev
	ktextwidgets-dev
	kwallet-dev
	kwidgetsaddons-dev
	kwindowsystem-dev
	kxmlgui-dev
	libcdio-dev
	libkcddb-dev
	libksane-dev
	poppler-qt6-dev
	qt6-qtbase-dev
	qt6-qtcharts-dev
	qt6-qtwebengine-dev
	samurai
	solid-dev
	sonnet-dev
	taglib-dev
	"
checkdepends="xwayland-run"
subpackages="
	$pkgname-doc
	$pkgname-lang
	"
_repo_url="https://invent.kde.org/office/tellico.git"
source="https://tellico-project.org/files/tellico-$pkgver.tar.xz
	0001-Revert-Add-macro-check-for-POSIX_SOURCE.patch
	"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

check() {
	wlheadless-run -- ctest --test-dir build -E "(newstuff|htmlexporter|cite|fieldwidget|pdf|document)test"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
