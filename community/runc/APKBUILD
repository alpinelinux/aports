build() {
	# libpathrs is not yet packaged in Alpine
	make \
		COMMIT="$_commit" \
		RUNC_BUILDTAGS="-libpathrs"
	make man
}

package() {
	install -Dsm755 runc "$pkgdir"/usr/bin/runc
	install -Dm644 "$builddir"/man/man8/* -t "$pkgdir"/usr/share/man/man8/
}

