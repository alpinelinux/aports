maintainer="team/phosh <achill@achill.org>"
pkgname=phosh-session-services
pkgver=0.2.0
pkgrel=0
pkgdesc="Various Rust based services for Phosh's session"
url="https://gitlab.gnome.org/World/Phosh/phosh-session-services"
arch="all"
license="GPL-3.0-only"
depends="phosh-os-updater syncbus"
makedepends="
	cargo-auditable
	desktop-file-utils
	gtk-update-icon-cache
	meson
	xz
	"
subpackages="
	phosh-os-updater-systemd:os_updater_systemd
	phosh-os-updater:os_updater
	syncbus
	syncbus-systemd:syncbus_systemd
	"
source="https://sources.phosh.mobi/releases/phosh-session-services/phosh-session-services-$pkgver.tar.xz"
options="net" # cargo

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

syncbus() {
	pkgdesc="D-Bus server for Syncthing"
	depends="syncbus"

	amove usr/libexec/phosh-syncbus
	amove usr/share/dbus-1/interfaces/mobi.phosh.syncbus.Folder.xml
	amove usr/share/dbus-1/interfaces/mobi.phosh.syncbus.Manager.xml
	amove usr/share/dbus-1/services/mobi.phosh.syncbus.service
}

syncbus_systemd() {
	pkgdesc="D-Bus server for Syncthing (systemd files)"
	depends=""
	install_if="systemd syncbus=$pkgver-r$pkgrel"

	amove usr/lib/systemd/user/phosh-syncbus.service
}

os_updater() {
	pkgdesc="Phosh OS update checker service"
	depends=""

	amove usr/libexec/phosh-os-updater
	amove usr/share/applications/mobi.phosh.OsUpdater.desktop
	amove usr/share/icons/hicolor/symbolic/apps/mobi.phosh.OsUpdater-symbolic.svg
}

os_updater_systemd() {
	pkgdesc="Phosh OS update checker service (systemd files)"
	depends=""
	install_if="systemd phosh-os-updater=$pkgver-r$pkgrel"

	amove usr/lib/systemd/user/phosh-os-updater.service
}


sha512sums="
