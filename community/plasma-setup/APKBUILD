823cc6c52532839969e5a83ed046976ac52286c9bdfe04b3b5884d865489713cb266d2418e7551647e5574857eca48201ce016fbb0a41ceaaeaede28c2b1d7e3  0001-sysuser.conf-change-plasma-setup-user-shell-to-bin-s.patch
"
