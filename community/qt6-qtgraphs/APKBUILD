# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=qt6
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=qt6-qtgraphs
pkgver=6.11.1
pkgrel=0
pkgdesc="Provides a set of easy to use chart components"
url="https://qt.io/"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-only AND LGPL-3.0-only AND GPL-3.0-only AND Qt-GPL-exception-1.0"
depends_dev="qt6-qtdeclarative-private-dev"
makedepends="$depends_dev
	cmake
	perl
	qt6-qtbase-dev
	qt6-qtbase-private-dev
	qt6-qtdeclarative-private-dev
	qt6-qtquick3d-dev
	samurai
	"
subpackages="$pkgname-dev"
options="!check" # No tests
builddir="$srcdir/qtgraphs-everywhere-src-${pkgver/_/-}"

case $pkgver in
*_alpha* | *_beta* | *_rc*) _rel=development_releases ;;
*) _rel=official_releases ;;
esac
source="https://download.qt.io/$_rel/qt/${pkgver%.*}/${pkgver/_/-}/submodules/qtgraphs-everywhere-src-${pkgver/_/-}.tar.xz"

build() {
	export CFLAGS="$CFLAGS -g1 -flto=auto"
	export CXXFLAGS="$CXXFLAGS -g1 -flto=auto"
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

dev() {
	default_dev

	amove usr/lib/qt6/sbom
}

sha512sums="
e9fef9b7f65c51ee3076e269fc5b8ed139ecf01295dd7e8d763e380ded1935f6224d3e7957a2ca705877aac83647a49c74573dd69ab067b49535454148fa313b  qtgraphs-everywhere-src-6.11.1.tar.xz
"
