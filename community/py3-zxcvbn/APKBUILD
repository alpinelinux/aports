# Contributor: Anjandev Momi <anjan@momi.ca>
# Maintainer: Anjandev Momi <anjan@momi.ca>
pkgname=py3-zxcvbn
_pkgreal=zxcvbn
pkgver=4.5.0
pkgrel=0
pkgdesc="Python implementation of Dropbox's realistic password strength estimator"
url="https://pypi.org/project/zxcvbn"
arch="noarch"
license="MIT"
depends="python3"
checkdepends="py3-pytest"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
_pypiprefix="${_pkgreal%"${_pkgreal#?}"}"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/dwolfhub/zxcvbn-python/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/$_pkgreal-python-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
8c6887da9d4084060011a37f705528b24bf6d69452b92280df99290ac108934d93aeb7eec827381787e78753a5c6c3af486cf4cdceb0ff8726c96a60aa36d5e2  py3-zxcvbn-4.5.0.tar.gz
"
