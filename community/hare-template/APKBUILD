pkgname=hare-template
pkgver=0.26.0.4
pkgrel=0
pkgdesc="Templating library for Hare"
url="https://sr.ht/~stacyharper/hare-template"
arch="all !armhf !ppc64le !s390x !armv7 !x86 !loongarch64" # hare
license="MPL-2.0"
depends="hare-lex hare-streams haredo"
makedepends="hare"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~stacyharper/hare-template/archive/$pkgver.tar.gz"

build() {
	haredo
}

check() {
	haredo check
}

package() {
	DESTDIR="$pkgdir" PREFIX=/usr haredo install
}

