8a3b6095f9f4199b772cb534dddc86fd61db7dae68122f3b0e172664e3b1f7a21b1a7237b2a01b8235d8cda80c71885b074f7c35385bd0d88fa2c6ebad8cb691  python-3.14-ast.patch
"
