-		iVec = _mm256_sub_ps ( iVec, iMinVec );
-		iVec = _mm256_mul_ps ( iVec, iDivVec );
-		iVec = _mm256_round_ps ( iVec, _MM_FROUND_TO_NEAREST_INT );
-		iVec = _mm256_cvtps_epi32(iVec);       
