a5205737fce3a677ed63b051b243f4a860f20105da803e6741efacf45e589bdacfe172b58e05e43a048c62513e820ff5e8895fac985d952fdfd62724502cb1ab  0001-no-check-for-updates.patch
1173df6cf2942321fb411815567ecf20f0e3fc8cd9a159ecfadbc9b35e90c5f5071b14c96bc3926170283277ee6d2b1629703cf557a1ef6722f4146ce29417d9  0002-no-self-update.patch
