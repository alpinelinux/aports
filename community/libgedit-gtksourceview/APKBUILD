# Maintainer: mio <miyopan@e.email>
maintainer="mio <miyopan@e.email>"
pkgname=libgedit-gtksourceview
pkgver=299.7.1
pkgrel=0
pkgdesc="Gedit Technology — source code editing widget"
url="https://gitlab.gnome.org/World/gedit/libgedit-gtksourceview"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	docbook-xsl-nons
	gobject-introspection-dev
	gtk-doc
	gtk+3.0-dev
	libgedit-amtk-dev
	libgedit-gfls-dev
	meson
	"
checkdepends="xvfb-run"
subpackages="$pkgname-dev $pkgname-doc $pkgname-lang"
source="https://gitlab.gnome.org/World/gedit/libgedit-gtksourceview/-/archive/$pkgver/libgedit-gtksourceview-$pkgver.tar.gz"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dgobject_introspection=true \
		-Dgtk_doc=true \
		. output
	meson compile -C output
}

check() {
	xvfb-run -a meson test -v -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
b4c778e3713afecc758d216f87267e28b302be26206ef150b9515f399d0eb78ea0fe6fef1dbbde933c8b6382c51603bfe88458c5dff407a98f9f8b53bdfd7b36  libgedit-gtksourceview-299.7.1.tar.gz
"
