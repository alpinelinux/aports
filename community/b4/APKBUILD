# Contributor: knuxify <knuxify@gmail.com>
# Maintainer: knuxify <knuxify@gmail.com>
pkgname=b4
pkgver=0.15.2
pkgrel=0
pkgdesc="Tool to help with email-based patch workflows"
url="https://b4.docs.kernel.org/"
arch="noarch"
license="GPL-2.0-or-later"
depends="py3-requests git git-email git-filter-repo py3-dnspython py3-patatt py3-dkimpy py3-textual"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest py3-pytest-asyncio"
subpackages="$pkgname-pyc $pkgname-doc"
source="https://git.kernel.org/pub/scm/utils/b4/b4.git/snapshot/b4-$pkgver.tar.gz"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl

	# test_tui_tracking.py::TestTargetBranch: flaky test (intermittent failures)
	.testenv/bin/python3 -m pytest src/tests \
		--deselect=src/tests/test_tui_tracking.py::TestTargetBranch
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl

	install -Dvm644 src/b4/man/b4.1 \
		-t "$pkgdir"/usr/share/man/man5/
}

sha512sums="
783e984a1def64a46da8411edefc716b8722b3ee9935119598cd82a1d0d582e559ea8e765300e5c1abfe285508c9e6cd482037499c92aa8044a23f41ebf534ee  b4-0.15.2.tar.gz
"
