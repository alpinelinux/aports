# Maintainer: Simon Rupf <simon@rupf.net>
pkgname=dar
pkgver=2.8.5
pkgrel=0
pkgdesc="Disk ARchive"
url="http://dar.linux.free.fr/"
arch="all"
license="GPL-2.0-or-later"
options="!check" # the provided "make check" requires root permissions
makedepends="argon2-dev bzip2-dev curl-dev e2fsprogs-dev gettext-dev gpgme-dev
	libgcrypt-dev libssh-dev librsync-dev libthreadar-dev lz4-dev lzo-dev
	rhash-dev xz-dev zlib-dev zstd-dev"
subpackages="$pkgname-doc $pkgname-lang $pkgname-libs $pkgname-dev"
source="https://downloads.sourceforge.net/dar/dar-$pkgver.tar.gz"

build() {
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--disable-dar-static \
		--disable-static \
		--disable-upx \
		--disable-dependency-tracking
	make
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
642f6f4a1c9bd05521a4c28d4e8c389d0da9ddbc73cfb7062779476a5b7696e4fba1361ab7ff65f61ffa1e198f58eb526eb52e04f148e445b604dce4fc0d49ff  dar-2.8.5.tar.gz
"
