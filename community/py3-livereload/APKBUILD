# Contributor: Carlo Landmeter <clandmeter@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=py3-livereload
_pyname=livereload
pkgver=2.7.1
pkgrel=0
pkgdesc="livereload server in python"
url="https://github.com/lepture/python-livereload"
arch="noarch"
license="BSD-3-Clause"
replaces="py-livereload" # for backwards compatibility
provides="py-livereload=$pkgver-r$pkgrel" # for backwards compatibility
depends="py3-tornado"
makedepends="py3-setuptools py3-gpep517 py3-wheel"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/lepture/python-livereload/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir"/python-$_pyname-$pkgver

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# Upstream knows about it, does not know how to fix yet
	.testenv/bin/python3 -m pytest \
		--deselect tests/test_watcher.py::TestWatcher::test_watch_multiple_dirs
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
a0c5a316ad5d34518b6ca44cddff51ba45d60a8ba24de767e791aa529e4ab22accf15916321fea755e67f4fd0aecb1e0ed840142662c27c8eaa6cad5dc2a7399  py3-livereload-2.7.1.tar.gz
"
