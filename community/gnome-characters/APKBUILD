# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=gnome-characters
pkgver=50.0
pkgrel=0
pkgdesc="A simple utility application to find and insert unusual characters"
url="https://apps.gnome.org/Characters"
# armhf blocked by gjs
arch="all !armhf"
license="BSD-3-Clause AND GPL-2.0-or-later"
depends="
	gjs
	gnome-desktop
	gtk4.0
	libadwaita
	"
makedepends="
	desktop-file-utils
	gjs-dev
	glib-dev
	gobject-introspection-dev
	gtk4.0-dev
	libadwaita-dev
	meson
	pango-dev
	"
options="!check" # no tests
subpackages="$pkgname-lang"
source="https://download.gnome.org/sources/gnome-characters/${pkgver%.*}/gnome-characters-$pkgver.tar.xz"

build() {
	abuild-meson . output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
