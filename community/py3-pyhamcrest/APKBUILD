2395288df3947e2a6be2f668416f0b6c0cb49d2f46ca45cb9cb4f5f6c9c3ac089a2d230fa9bb5618573696dba4d73fea31b8883a884b57f4271ef9a3d8a6b431  0001-use-asyncio.new_event_loop-in-tests-for-compatibilit.patch
"
