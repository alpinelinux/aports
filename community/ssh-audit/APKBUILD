# Contributor: Michał Polański <michal@polanski.me>
# Maintainer: Michał Polański <michal@polanski.me>
pkgname=ssh-audit
pkgver=3.9.0
pkgrel=0
pkgdesc="SSH server and client configuration auditing"
url="https://github.com/jtesta/ssh-audit"
license="MIT"
arch="noarch"
depends="python3"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest"
subpackages="$pkgname-doc $pkgname-pyc"
source="https://github.com/jtesta/ssh-audit/archive/v$pkgver/ssh-audit-$pkgver.tar.gz"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
	install -Dm644 -t "$pkgdir"/usr/share/man/man1 ssh-audit.1
}

sha512sums="
97e671bb00abd37eef879e60a6011a56deaae4c89965696597693e5af9eb9bf62c44aa14b077193a5f251e6f7deb97bfebd0a02891200d5f6aaed8e1b151d00d  ssh-audit-3.9.0.tar.gz
"
