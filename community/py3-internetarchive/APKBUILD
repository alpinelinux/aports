# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-internetarchive
pkgver=5.10.1
pkgrel=0
pkgdesc="Python interface to archive.org"
url="https://github.com/jjjake/internetarchive"
arch="noarch"
license="AGPL-3.0-only"
depends="
	py3-jsonpatch
	py3-requests
	py3-tqdm
	py3-urllib3
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-pytest
	py3-responses
	"
subpackages="$pkgname-pyc ia"
_pyname=internetarchive
source="$_pyname-$pkgver.tar.gz::https://github.com/jjjake/$_pyname/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/$_pyname-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m pytest -v \
		--ignore=tests/cli/test_ia_download.py
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

ia() {
	pkgdesc="Command-line tool for archive.org"
	depends="$pkgname"
	amove usr/bin/ia
}

sha512sums="
e1c7949dc3ceac6cf9911d70ba342085b1cf2a77f4eeb1805a58d1c1120436a5496eb60e4995b4c16b10bbc98add1000975ee48ee7b16cd80b7e13eacc93458f  internetarchive-5.10.1.tar.gz
"
