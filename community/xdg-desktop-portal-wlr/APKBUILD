# Maintainer: Marian Buschsieweke <marian.buschsieweke@posteo.net>
pkgname=xdg-desktop-portal-wlr
pkgver=0.8.2
pkgrel=0
pkgdesc="wlroots implementation of xdg-desktop-portal"
url="https://github.com/emersion/xdg-desktop-portal-wlr"
arch="all"
license="MIT"
depends="
	pipewire
	xdg-desktop-portal
	"
makedepends="
	basu-dev
	inih-dev
	mesa-dev
	meson
	pipewire-dev
	scdoc
	wayland-dev
	wayland-protocols-dev
	xdg-desktop-portal-dev
	"
options="!check"  # no tests provided
subpackages="$pkgname-doc $pkgname-dbg $pkgname-openrc $pkgname-systemd"
source="https://github.com/emersion/xdg-desktop-portal-wlr/releases/download/v$pkgver/xdg-desktop-portal-wlr-$pkgver.tar.gz
	config
	xdg-desktop-portal-wlr.initd
	default-systemd-user_unit_dir.patch
	"

# useful since people pulling in xdg-desktop-portal will want this backend
install_if="xdg-desktop-portal wlroots"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dsystemd=enabled \
		-Dsd-bus-provider=basu \
		. build
	meson compile -C build
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C build

	install -Dm644 "$srcdir"/config "$pkgdir"/etc/xdg/xdg-desktop-portal-wlr/config

	install -Dm755 "$srcdir"/xdg-desktop-portal-wlr.initd "$pkgdir"/etc/user/init.d/xdg-desktop-portal-wlr
}

