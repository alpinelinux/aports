# Contributor: Leo <thinkabit.ukim@gmail.com>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=buku
pkgver=5.1
pkgrel=0
pkgdesc="Cmdline bookmark management utility"
url="https://github.com/jarun/Buku"
arch="noarch"
license="GPL-3.0-or-later"
depends="python3 py3-urllib3 py3-cryptography py3-html5lib py3-beautifulsoup4
	py3-certifi"
makedepends="
	py3-gpep517
	py3-installer
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-hypothesis
	py3-pytest
	py3-pytest-recording
	py3-pytest-timeout
	py3-vcrpy
	py3-yaml
	"
subpackages="$pkgname-pyc
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/jarun/Buku/archive/v$pkgver.tar.gz"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest tests/ \
		--timeout=120 \
		--ignore=tests/test_server.py \
		--ignore=tests/test_views.py
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	install -Dm644 "$builddir"/auto-completion/bash/buku-completion.bash \
		"$pkgdir"/usr/share/bash-completion/completions/buku
	install -Dm644 "$builddir"/auto-completion/zsh/_buku \
		"$pkgdir"/usr/share/zsh/site-functions/_buku
	install -Dm644 "$builddir"/auto-completion/fish/buku.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/buku.fish
}
sha512sums="
2f1965682c03145c1ac9838e3987af61f063408c96b7f99509b17cd8d62f05494a5b132b8beb12f6a93b0d3e495691e34eb3ed1e1a9af7f787fa7e722e7a96cf  buku-5.1.tar.gz
"
