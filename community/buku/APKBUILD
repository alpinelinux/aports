# Contributor: Leo <thinkabit.ukim@gmail.com>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=buku
pkgver=5.1.1
pkgrel=0
pkgdesc="Cmdline bookmark management utility"
url="https://github.com/jarun/Buku"
arch="noarch"
license="GPL-3.0-or-later"
depends="python3 py3-urllib3 py3-cryptography py3-html5lib py3-beautifulsoup4
	py3-certifi"
makedepends="
	py3-gpep517
	py3-installer
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-hypothesis
	py3-pytest
	py3-pytest-recording
	py3-pytest-timeout
	py3-vcrpy
	py3-yaml
	"
subpackages="$pkgname-pyc
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/jarun/Buku/archive/v$pkgver.tar.gz
	fix-version.patch
	"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest tests/ \
		--timeout=120 \
		--ignore=tests/test_server.py \
		--ignore=tests/test_views.py
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	install -Dm644 "$builddir"/auto-completion/bash/buku-completion.bash \
		"$pkgdir"/usr/share/bash-completion/completions/buku
	install -Dm644 "$builddir"/auto-completion/zsh/_buku \
		"$pkgdir"/usr/share/zsh/site-functions/_buku
	install -Dm644 "$builddir"/auto-completion/fish/buku.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/buku.fish
}

sha512sums="
358bf1cc4e8ee773ce1c077332ff27b8e47f035c432a31ae8ae51f8755f39e0c5fb7f1f85083cebd41ce00a43f1db8b1356a6959f593166777aac0700b703fb7  buku-5.1.1.tar.gz
4a36e105a0ef07190787b49721d77cc387ee74f4cd40502d8670d7914e11a73e7401486b8847722131fe49f3269ff53eb6206fc20a0804aca4c187c3ca936b70  fix-version.patch
"
