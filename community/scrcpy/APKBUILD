7ebaf385aaafc0251ab506b4850a9b508c1a3da3b7b49f59c1bd54a72f1e7080a01f1270cc7fa8a6060f4b15621e5567ebb228128ad35ec44a7286622bbddb46  scrcpy-server-v4.0
"
