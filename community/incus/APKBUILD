pkgname=incus
pkgver=7.0.0 #LTS releases only
pkgrel=3
pkgdesc="Powerful system container and virtual machine manager"
url="https://github.com/lxc/incus"
arch="all"
license="Apache-2.0"
depends="acl
	attr
	ca-certificates
	dbus
	dnsmasq
	lxc>=6.0.0
	iproute2
	netcat-openbsd
	nftables
	rsync
	squashfs-tools
	shadow-subids
	tar
	xz
	"
makedepends="acl-dev
	autoconf
	automake
	cowsql-dev
	raft-cowsql-dev
	eudev-dev
	gettext-dev
	go
	intltool
	libcap-dev
	libtool
	libuv-dev
	linux-headers
	lxc-dev
	lz4-dev
	sqlite-dev
	tcl-dev
	"
subpackages="$pkgname-client
	$pkgname-agent
	$pkgname-agent-openrc:agent_openrc:noarch
	$pkgname-user
	$pkgname-user-openrc:user_openrc:noarch
	$pkgname-openrc
	$pkgname-conversion
	$pkgname-utils
	$pkgname-bash-completion:bashcomp:noarch
	$pkgname-vm:vm:noarch
	"
install="$pkgname.pre-install $pkgname.post-upgrade"
options="net"
if [ "$CARCH" = "loongarch64" ]; then
	options="$options !check" # random test failures on loongarch64
fi
source="$pkgname-$pkgver.tar.gz::https://github.com/lxc/incus/archive/refs/tags/v$pkgver.tar.gz
	incusd.confd
	incusd.initd
	$pkgname-agent.initd
	$pkgname-user.initd

	0001-statically-build-incus-agent-and-incus-migrate.patch
	reintroduce-core-scheduling-detection.patch
	"

_tools="fuidshift
	generate-config
	generate-database
	incus
	incus-benchmark
	incus-migrate
	incus-simplestreams
	lxc-to-incus
	lxd-to-incus
	mini-oidc
	sysinfo
	tls2jwt
	"

_project="github.com/lxc/incus"

export GOFLAGS="$GOFLAGS -tags=libsqlite3"
export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"
export GOPATH="$srcdir"

