# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=tinysparql
pkgver=3.11.1
pkgrel=0
pkgdesc="Personal search tool and storage system"
url="https://tracker.gnome.org/"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	asciidoc
	bash
	bash-completion-dev
	dbus-dev
	docbook-xsl-nons
	glib-dev
	gobject-introspection-dev
	icu-dev
	json-glib-dev
	libsoup3-dev
	libstemmer-dev
	libxml2-dev
	meson
	py3-gobject3
	py3-setuptools
	sqlite-dev
	networkmanager-dev
	vala
	gi-docgen
	graphviz
	"
checkdepends="
	dbus
	mandoc
	"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	$pkgname-doc
	$pkgname-lang
	lib$pkgname:libs
	$pkgname-bash-completion
	$pkgname-systemd
	"
source="https://download.gnome.org/sources/tinysparql/${pkgver%.*}/tinysparql-$pkgver.tar.xz
	fix-aggregate-float-out.patch
	disable-functional-test-portal.patch
	"

[ "$CARCH" = "riscv64" ] && options="$options !check" # fails on builder because of SIGTRAP, but not on CI

# for backwards compatibility
replaces="tracker"
provides="tracker=$pkgver-r$pkgrel"

build() {
	abuild-meson \
		-Db_lto=true \
		-Ddocs=true \
		-Dman=true \
		-Dsystemd_user_services_dir=/usr/lib/systemd/user \
		-Dintrospection=enabled \
		-Dtests="$(want_check && echo true || echo false)" \
		. output
	meson compile -C output
}

check() {
	XDG_RUNTIME_DIR="$(mktemp -p "$builddir" -d)" \
	MANPATH="$builddir"/output/docs \
	dbus-run-session -- \
	meson test -t 10 --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

libs() {
	default_libs
	replaces="libtracker"
	provides="libtracker=$pkgver-r$pkgrel"
	amove usr/lib/girepository-1.0
}

