# Contributor: ScrumpyJack <scrumpyjack@st.ilet.to>
# Maintainer: ScrumpyJack <scrumpyjack@st.ilet.to>
pkgname=geeqie
pkgver=2.7
pkgrel=0
pkgdesc="Gtk+ based image viewer and organiser"
url="http://www.geeqie.org/"
arch="all"
license="GPL-2.0-only"
makedepends="
	doxygen
	exiv2-dev
	graphviz-dev
	gtk+3.0-dev
	lcms2-dev
	libarchive-dev
	lua5.3-dev
	meson
	xxd
	"
subpackages="
	$pkgname-bash-completion
	$pkgname-doc
	$pkgname-lang
	"
source="https://github.com/BestImageViewer/geeqie/releases/download/v$pkgver/geeqie-$pkgver.tar.xz"
options="!check" # no tests

build() {
	abuild-meson \
		-Db_lto=true \
		. output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
3cf6aeb9a4e337d608c0ef5309079bcfaae2c67cd7ac3cac285f935d8b7330cecbdf5c4b644af44bd00e1b7c9cc271f9658daf913ca2a008efaeb489154359ee  geeqie-2.7.tar.xz
"
