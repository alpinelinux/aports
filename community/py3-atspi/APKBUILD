# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=py3-atspi
pkgver=2.58.2
pkgrel=0
pkgdesc="Python client bindings for D-Bus AT-SPI"
url="https://gitlab.gnome.org/GNOME/pyatspi2"
arch="noarch"
license="GPL-2.0-or-later"
depends="
	py3-gobject3
	python3
	"
makedepends="
	meson
	py3-gobject3-dev
	python3-dev
	"
subpackages="$pkgname-pyc"
source="https://download.gnome.org/sources/pyatspi/${pkgver%.*}/pyatspi-$pkgver.tar.xz"
builddir="$srcdir/pyatspi-$pkgver"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
2e6fb18b3bd4bcad4ee25eb53cf4fade0030a1921a861e0a39c89a492dd382cd20071af93207033d9eaed59ae15319245e3e9221678aba5f8cf1790865057a9c  pyatspi-2.58.2.tar.xz
"
