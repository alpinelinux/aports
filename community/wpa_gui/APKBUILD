# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=wpa_gui
pkgver=2.11
pkgrel=0
pkgdesc="Grafical User Interface for wpa_supplicant"
url="https://w1.fi/wpa_supplicant/"
arch="all"
license="BSD-3-Clause"
makedepends="dbus-dev qt6-qtbase-dev"
options="!check"
source="https://w1.fi/releases/wpa_supplicant-$pkgver.tar.gz
	qt6.patch
	"
builddir="$srcdir"/wpa_supplicant-"$pkgver"/wpa_supplicant/wpa_gui-qt4

build() {
	qmake6
	make
}

package() {
	install -d "$pkgdir"/usr/bin
	install -m 0755 wpa_gui "$pkgdir"/usr/bin/wpa_gui
}

