8520d989ba1c5dd8fb2188f6b760f60af87f708473ce3c5bbf60ad4552c0491f6328c94e2420629bcb1ce3ffba89feae603dfde84919da9b62df1d992c280502  test.patch
a40beef05be615891e31eaccdeb3e48afea48bf2c45d268d1fc840ec56ad51400d4dc4c7a5543c7c2793e6674bd0d9f953f04891d3e95d3a82711c34ecdfb852  musl-fix.patch
"
