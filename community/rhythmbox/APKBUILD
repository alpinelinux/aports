# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=rhythmbox
pkgver=3.4.9
pkgrel=1
pkgdesc="GNOME audio player"
url="https://gitlab.gnome.org/GNOME/rhythmbox"
arch="all"
license="GPL-2.0-or-later"
depends_dev="gnome-desktop-dev libpeas-dev"
makedepends="
	$depends_dev
	appstream-glib
	brasero-dev
	cmake
	desktop-file-utils
	docbook-xml
	docbook-xsl
	gmime-dev
	grilo-dev
	gst-plugins-base-dev
	gstreamer-dev
	itstool
	json-glib-dev
	libgpod-dev
	libgudev-dev
	libmtp-dev
	libnotify-dev
	libsecret-dev
	libsoup3-dev
	libxml2-utils
	libxslt
	meson
	py3-gobject3-dev
	tdb-dev
	totem-pl-parser-dev
	"
subpackages="$pkgname-dev $pkgname-doc $pkgname-lang"
source="https://download.gnome.org/sources/rhythmbox/${pkgver%.*}/rhythmbox-$pkgver.tar.xz"

build() {
	abuild-meson \
		-Db_lto=true \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
cdcf4184c7368a38c5d4b63a527d8b47f93cc8f9dd5288b25889664588e0d79569ed4f7341557e729c7ec5a0328da0a2f92c1022adc636524ebc2cabe37d2dac  rhythmbox-3.4.9.tar.xz
"
