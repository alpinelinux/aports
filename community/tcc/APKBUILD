# Contributor: Hinata Yanagi <hinasssan@gmail.com>
# Maintainer: mio <miyopan@e.email>
maintainer="mio <miyopan@e.email>"
pkgname=tcc
pkgver=0.9.27_git20260714
pkgrel=0
_commit=d9d02c56401e43be43760b63f7d82f771a7ed1f6
pkgdesc="Tiny C Compiler"
url="https://repo.or.cz/w/tinycc.git"
# loongarch64, ppc64le, s390x: Unsupported CPU
arch="all !loongarch64 !ppc64le !s390x"
license="LGPL-2.1-or-later"
depends="$pkgname-libs=$pkgver-r$pkgrel"
depends_dev="$pkgname-libs=$pkgver-r$pkgrel"
makedepends="texinfo"
subpackages="
	$pkgname-libs
	$pkgname-libs-static
	$pkgname-dev
	$pkgname-doc
	"
source="$pkgname-$pkgver.tar.gz::https://dev.alpinelinux.org/archive/tcc/tcc-$_commit.tar.gz
	libtcc.pc.in
	stddef-guard-base-typedefs.patch
	"
builddir="$srcdir/tinycc-${_commit:0:7}"

case "$CARCH" in
x86_64) ;;
# various tests fail
*) options="$options !check" ;;
esac

build() {
	./configure \
		--cpu="$CARCH" \
		--targetos=Linux \
		--prefix=/usr \
		--disable-static \
		--config-musl
	make

	sed 's/@VERSION@/'"$pkgver"'/' "$srcdir"/libtcc.pc.in > libtcc.pc
}

check() {
	make test
}

package() {
	make DESTDIR="$pkgdir" install

	install -Dvm644 libtcc.pc -t "$pkgdir"/usr/lib/pkgconfig/
	install -Dvm644 Changelog CodingStyle README TODO \
		-t "$pkgdir"/usr/share/doc/$pkgname/
}

libs() {
	default_libs

	amove usr/lib/libtcc.so
}

sha512sums="
