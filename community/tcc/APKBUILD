3e6311ef2b93ef5bcc17eb33077e2d79526c1592bb28189d1d12f1835d3af8234fe33cf49372c3c9ca703bb7cebebbdbbeb3db9864e18a76510e67b52b173e3a  libtcc.pc.in
00ffabaf9b3f4a55cad2e322f79244f09fefb687ff24ea8b671e6d053a6e456336d09d313671a3a7de1cdaf6890f79f64d7396f047764545020cfc4b431b8704  stddef-guard-base-typedefs.patch
"
