# Contributor: Sören Tempel <soeren+alpine@soeren-tempel.net>
# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=glances
pkgver=4.5.0.5
pkgrel=1
pkgdesc="CLI curses based monitoring tool"
url="https://nicolargo.github.io/glances/"
arch="noarch"
license="LGPL-3.0-or-later"
depends="
	py3-batinfo
	py3-bottle
	py3-defusedxml
	py3-docker-py
	py3-jinja2
	py3-packaging
	py3-psutil
	py3-snmp
	py3-ujson
	python3
	"
checkdepends="
	py3-pytest
	"
makedepends="py3-setuptools py3-gpep517"
subpackages="$pkgname-doc"
source="glances-$pkgver.tar.gz::https://github.com/nicolargo/glances/archive/v$pkgver.tar.gz"
options="!check"  # tests fail on builder infra due to env. limitations

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
33c508679b1531e70adc6f221045dad22b8f540e71aa7ab31ab75f977df2b5d2eb082d843655dec17f25ab70b62892c560780c54697f46835c5dd89f50f8b1f1  glances-4.5.0.5.tar.gz
"
