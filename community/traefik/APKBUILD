pkgname=traefik
pkgver=3.7.7
pkgrel=0
pkgdesc="The Cloud Native Edge Router"
url="https://traefik.io/"
arch="all"
license="MIT"
makedepends="go"
checkdepends="tzdata"
install="$pkgname.pre-install"
pkgusers="$pkgname"
pkggroups="$pkgname"
subpackages="$pkgname-doc $pkgname-openrc"
options="net setcap chmod-clean"
source="$pkgname-$pkgver.tar.gz::https://github.com/traefik/traefik/releases/download/v$pkgver/traefik-v$pkgver.src.tar.gz
	traefik.initd
	traefik.confd
	traefik.yaml
	logs_tests.patch
	"
builddir="$srcdir"

# secfixes:
#   3.7.7-r0:
#     - CVE-2026-48020
#     - CVE-2026-48491
#     - CVE-2026-53622
#     - CVE-2026-54761
#     - CVE-2026-54762
#     - CVE-2026-54763
#     - CVE-2026-54764
#     - CVE-2026-54765
#   3.1.3-r0:
#     - CVE-2024-45410
#   2.9.10-r0:
#     - CVE-2023-29013
#     - CVE-2023-24534
#   2.9.6-r0:
#     - CVE-2022-23469
#     - CVE-2022-46153
#   2.2.8-r0:
#     - CVE-2020-15129

# Tests are broken on most architectures.
if [ "$CARCH" != x86_64 ]; then
	options="$options !check"
fi

build() {
	local builddate="$(date -u "+%Y-%m-%dT%TZ" ${SOURCE_DATE_EPOCH:+-d @$SOURCE_DATE_EPOCH})"

	go generate -v
	go build -v -ldflags "-s -w -extldflags \"$LDFLAGS\" \
			-X github.com/traefik/traefik/v3/pkg/version.Codename=cheddar \
			-X github.com/traefik/traefik/v3/pkg/version.Version=$pkgver \
			-X github.com/traefik/traefik/v3/pkg/version.BuildDate=$builddate" \
		-o bin/ ./cmd/$pkgname
}

check() {
	# skipping:
	# proxy/fast: fails on CI (maybe DNS: Failed to resolve destination 'backend.localhost')
	local filter="proxy/fast"
	# shellcheck disable=2046
	# Skipping tests due to environment-specific UDP MTU limits
	go test -timeout 30m -cover "-coverprofile=cover.out" \
		$(go list ./pkg/... ./cmd/... | grep -Ev "pkg/($filter)") \
		-run '.*' \
		-skip 'TestReadLoopMaxDataSize|TestTracing|TestTracerProvider|TestLog|TestOpenTelemetry|TestBasicAuthConcurrentHashOnce|TestOTelAccessLog|TestBalancerPropagate|TestIngressEndpointPublishedService|TestSemConvServerMetrics|TestObservabilityRoundTripper_metrics|TestServiceTCPHealthChecker_Launch|TestRedisRateLimit|Test_Routing|TestTTFBMeasurement|TestTimeoutWithRead|TestTimeoutWithoutRead|TestInMemoryRateLimit'
}

package() {
	install -Dm755 bin/$pkgname "$pkgdir"/usr/sbin/$pkgname
	install -Dm644 LICENSE.md -t "$pkgdir"/usr/share/licenses/$pkgname/
	install -dm775 -o $pkgname -g $pkgname "$pkgdir"/var/log/$pkgname
	install -dm750 -o $pkgname -g $pkgname "$pkgdir"/etc/$pkgname
	install -m644 -o $pkgname -g $pkgname "$srcdir"/traefik.yaml \
		-t "$pkgdir"/etc/$pkgname/

	install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -Dm644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

