b2c9d0bf35b75f4b52f9db9e243912d356e224afac55348c9702349b74d603d3c659b22f808e59f2e8e45d605c8c244d7c07484186a31e7a3fe3ca72a1715e1e  50-i2c.rules
3b3b96dbe64e986c4d27afebb658b4e59c77c4147fb5a0ec2affafa1644856adb3fc83564fe7c2e0d95a8c908cca84e4a8200f31ed954d30a73b54138a01b665  skip-wake-displays-test-without-uinput.patch
"
