# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
maintainer="Will Sinatra <wpsinatra@gmail.com>"
pkgname=py3-syrupy
pkgver=5.5.3
pkgrel=0
pkgdesc="Pytest Snapshot Test Utility"
url="https://github.com/syrupy-project/syrupy"
license="MIT"
arch="noarch"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	py3-installer
	py3-poetry-core
	py3-attrs
	py3-hatchling"
depends="python3 py3-pytest py3-hypothesis"
checkdepends="
	py3-pytest-benchmark
	py3-pytest-xdist
	py3-pydantic
	py3-coverage
	py3-invoke"
subpackages="$pkgname-pyc $pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/syrupy-project/syrupy/archive/v$pkgver.tar.gz"
builddir="$srcdir/syrupy-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	install -D -m 644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
7de7d911d0a06ed195d7cc566b053d71135dedd12a0f0f2c0e88ed623f4b6704afbb89ab6d961c316e7ed69d8a380c5d9b176370e59944c15bb71336f260a7de  py3-syrupy-5.5.3.tar.gz
"
