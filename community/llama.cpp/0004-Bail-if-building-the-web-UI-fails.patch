From c04b6501228834fe0fac45f10a5dc3788a6e80d4 Mon Sep 17 00:00:00 2001
From: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
Date: Mon, 8 Jun 2026 19:15:39 +0200
Subject: [PATCH 4/4] Bail if building the web UI fails

If building the web UI fails (e.g.: due to some network glitch), the
build process emits a warning and continues, producing binaries where
the web UI doesn't work.

Bail instead of producing broken binaries.
---
 scripts/ui-assets.cmake | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/scripts/ui-assets.cmake b/scripts/ui-assets.cmake
index f85c562bd..5cc9e75cc 100644
--- a/scripts/ui-assets.cmake
+++ b/scripts/ui-assets.cmake
@@ -306,6 +306,10 @@ if(BUILD_UI)
     endif()
 endif()
 
+if(NOT provisioned)
+    message(FATAL_ERROR, "UI: npm failed, bailing.")
+endif()
+
 # ---------------------------------------------------------------------------
 # 3. Priority 3: HF Bucket download (if npm did not produce assets and HF_ENABLED=ON)
 # ---------------------------------------------------------------------------
