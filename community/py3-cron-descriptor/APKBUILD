# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-cron-descriptor
_pyname="cron-descriptor"
pkgver=2.0.8
# doesn't always tag releases
_gittag=$pkgver
pkgrel=0
arch="noarch"
pkgdesc="A Python library that converts cron expressions into human readable strings."
url="https://pypi.python.org/project/cron-descriptor"
license="MIT"
depends="py3-typing-extensions"
makedepends="
	py3-setuptools
	py3-gpep517
	py3-wheel
	"
checkdepends="py3-pytest"
source="$pkgname-$_gittag.tar.gz::https://github.com/Salamek/cron-descriptor/archive/$_gittag.tar.gz"
builddir="$srcdir"/$_pyname-$_gittag
subpackages="$pkgname-pyc"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .test-env
	.test-env/bin/python3 -m installer .dist/*.whl
	.test-env/bin/python3 -m pytest -v
}

package() {
	python3 -m installer --destdir="$pkgdir" .dist/*.whl
}

sha512sums="
af623f185e5ffef6cde963588023691ccb3950418dcfdfa1a51725326bab33c6ba9c39fb35e275aab705ae425e2f8eb741cd677a71ec48a484f6f21ebbee2776  py3-cron-descriptor-2.0.8.tar.gz
"
