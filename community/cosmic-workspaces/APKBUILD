# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-workspaces
pkgver=1.0.11
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Workspace component for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-workspaces"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-or-later"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	eudev-dev
	desktop-file-utils
	just
	libinput-dev
	libxkbcommon-dev
	mesa-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-workspaces-epoch/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
4b47d17541c68243fab69080f0c6af848a6d343234afb7d074d96a25abeff8cbc25b83c8c05ad5d1b839b464ba65cd3380d0778f2eca0c197d947e4521cf1f76  cosmic-workspaces-1.0.11.tar.gz
"
