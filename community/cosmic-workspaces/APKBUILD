# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-workspaces
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Workspace component for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-workspaces"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armhf !armv7 !riscv64 !x86"
license="GPL-3.0-or-later"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	eudev-dev
	desktop-file-utils
	just
	libinput-dev
	libxkbcommon-dev
	mesa-dev
	wayland-dev
	wayland-protocols
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-workspaces-epoch/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
2259d78f678bb2fc0b37a31c2ad337b9d4bbfabc2e559204acf3b876fa9e1f926aac67c0eac028996dd14b305fc360a64a3b097d4de40ceff684c5d02799c702  cosmic-workspaces-1.4.0.tar.gz
"
