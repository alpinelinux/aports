# Contributor: Robert Sacks <robert@sacks.email>
# Maintainer: Robert Sacks <robert@sacks.email>
pkgname=py3-requests-mock
pkgver=1.12.1
pkgrel=0
pkgdesc="Mock out responses from the requests package"
url="https://pypi.org/project/requests-mock/"
arch="noarch"
license="Apache-2.0"
depends="python3 py3-requests"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-fixtures py3-purl py3-pytest py3-sphinx py3-testtools"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/r/requests-mock/requests-mock-$pkgver.tar.gz
	fix-assert-equals.patch"
builddir="$srcdir/requests-mock-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# test_threaded_sessions requires requests_futures (currently not packaged)
	.testenv/bin/python3 -m pytest -k "not test_threaded_sessions"
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
be1f4afa800811025e3c7b14a65759851ef2d56a3e4bf155368dc6772440fe0fcc5d01f62b1b029d0cabd7a57fe35074e3ba0791240f95f43b62109a00f96120  requests-mock-1.12.1.tar.gz
1cbf5131d3fef9d5fe57d502f73856347b9910a2fffba45305df4c835717f945e97ac95f776408869780912ae3d84106c0824e08fcd88ff1cb97f742dfc48686  fix-assert-equals.patch
"
