maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=libselinux
pkgver=3.11
pkgrel=0
pkgdesc="SELinux library and simple utilities"
url="https://github.com/SELinuxProject/selinux/wiki"
arch="all"
license="Public-Domain"
# we need coreutils for ln --relative
makedepends="
	coreutils
	libsepol-dev
	linux-headers
	musl-fts-dev
	pcre2-dev
	py3-build
	py3-pip
	py3-setuptools
	python3-dev
	swig
	"
subpackages="
	py3-$pkgname:py3
	$pkgname-static
	$pkgname-dev
	$pkgname-doc
	$pkgname-utils
	"
source="https://github.com/SELinuxProject/selinux/releases/download/$pkgver/libselinux-$pkgver.tar.gz"

build() {
	make SHLIBDIR="/usr/lib" FTS_LDLIBS="-lfts"
	make SHLIBDIR="/usr/lib" FTS_LDLIBS="-lfts" pywrap
}

package() {
	make SHLIBDIR="/usr/lib" DESTDIR="$pkgdir" install
	make SHLIBDIR="/usr/lib" DESTDIR="$pkgdir" install-pywrap
}

utils() {
	pkgdesc="SELinux libselinux utilies"

	amove usr/sbin
}

py3() {
	pkgdesc="$pkgdesc (python library)"
	depends=""

	amove usr/lib/python*
}

sha512sums="
49eb0b180b77b4b61505117ecd98ab9fdd79a36801b6d2216813ea370a02ba4f58a0f87a18e92a2d4eeffc11d9df67e4692d2d8f5d3ee77a2abd3f606196aaad  libselinux-3.11.tar.gz
"
