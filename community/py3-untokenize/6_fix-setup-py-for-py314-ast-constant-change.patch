From 61475faf31ddae43ae794266b2cb8e3bb5d9e318 Mon Sep 17 00:00:00 2001
From: Emmanuel Arias <eamanu@yaerobi.com>
Date: Fri, 19 Dec 2025 14:10:12 -0300
Subject: [PATCH] Fix setup.py for py3.14 ast.Constant change

Python3.8+ replaced ast.Str with ast.Const. Accessing `.s` breaks
under Python3.14. Update version parsing to handle ast.Constant.

Orignally reported here: https://bugs.debian.org/1122468
---
 setup.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/setup.py b/setup.py
index 206c57e..b925e7a 100755
--- a/setup.py
+++ b/setup.py
@@ -11,7 +11,7 @@ def version():
     with open('untokenize.py') as input_file:
         for line in input_file:
             if line.startswith('__version__'):
-                return ast.parse(line).body[0].value.s
+                return ast.parse(line).body[0].value.value
 
 
 with open('README.rst') as readme:
