# Contributor: Bart Ribbers <bribbers@disroot.org>
# Maintainer: Bart Ribbers <bribbers@disroot.org>
pkgname=py3-url-normalize
pkgver=3.0.0
pkgrel=0
pkgdesc="URL normalization for Python"
url="https://github.com/niksite/url-normalize"
arch="noarch"
license="MIT"
depends="python3 py3-idna"
makedepends="py3-setuptools py3-gpep517"
checkdepends="
	py3-pytest
	py3-pytest-cov
	py3-pytest-socket
	py3-sortedcontainers
"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/niksite/url-normalize/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/url-normalize-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
5d1d4984788d09b88c191807760878391fa6a92b5930d1efe12985a7700126319750f6b1b29632071668f7d2dfe0977c782a0b859ccca10a9114698578cd7e4f  py3-url-normalize-3.0.0.tar.gz
"
