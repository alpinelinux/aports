# Contributor: Dmitry Zakharchenko <dmitz@disroot.org>
maintainer="Michał Polański <michal@polanski.me>"
pkgname=py3-pendulum
pkgver=3.2.0
pkgrel=0
pkgdesc="Python datetimes made easy"
url="https://pendulum.eustace.io"
license="MIT"
arch="all"
depends="py3-dateutil py3-pytzdata"
makedepends="cargo py3-gpep517 py3-maturin py3-setuptools"
checkdepends="py3-babel py3-freezegun py3-pytest py3-time-machine"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/python-pendulum/pendulum/archive/$pkgver.tar.gz"
builddir="$srcdir/pendulum-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--config-json '{"build-args": "--locked", "build-option": "--release"}' \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
9f935499ec8bc7ba0f5f8be293ac292c0538bfd01d15cea760f849dd154d04de700bdef08bde874dc2da5c472deb8fd176476a3fbf2cb3d0100eabf368cebc34  py3-pendulum-3.2.0.tar.gz
"
