# Maintainer: Iztok Fister, Jr. <iztok@iztok-jr-fister.eu>
pkgname=py3-arxiv
_pkgorig=arxiv.py
pkgver=4.0.0
pkgrel=0
pkgdesc="Python wrapper for the arXiv API"
url="https://github.com/lukasschwab/arxiv.py"
arch="noarch"
license="MIT"
depends="python3 py3-feedparser py3-requests py3-lxml"
makedepends="py3-gpep517 py3-hatchling py3-hatch-vcs py3-wheel"
checkdepends="py3-pytest-xdist py3-flake8"
subpackages="$pkgname-pyc"
source="arxiv-$pkgver.tar.gz::https://github.com/lukasschwab/arxiv.py/archive/$pkgver/$pkgver.tar.gz"
builddir="$srcdir/$_pkgorig-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -n auto
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
6e5242fee9edd3dca8b4d91ce23e350bf71e70a43c7b291c7a46cbda92620f8e720f045079bb70e17e1cd6d1230836b7fdfbc157aa530c4d7a8ea9cea7afef27  arxiv-4.0.0.tar.gz
"
