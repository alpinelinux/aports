From 0628d97e3f4bb52ebf3a14d8964d390bcf0e936e Mon Sep 17 00:00:00 2001
From: knuxify <knuxify@gmail.com>
Date: Tue, 17 Mar 2026 18:45:21 +0100
Subject: [PATCH 1/3] Revert "systemActions: Call into gnome-session for
 suspend"

This reverts commit 2e8eff96babbf47c76f208551d8ab55f89f9ad4b.
---
 .../org.freedesktop.login1.Manager.xml        |  6 ++++
 .../org.gnome.SessionManager.xml              |  4 ---
 js/misc/loginManager.js                       | 32 +++++++++++++++++++
 js/misc/systemActions.js                      | 18 ++++-------
 4 files changed, 45 insertions(+), 15 deletions(-)

diff --git a/data/dbus-interfaces/org.freedesktop.login1.Manager.xml b/data/dbus-interfaces/org.freedesktop.login1.Manager.xml
index acd49acb8..7e0fc225e 100644
--- a/data/dbus-interfaces/org.freedesktop.login1.Manager.xml
+++ b/data/dbus-interfaces/org.freedesktop.login1.Manager.xml
@@ -1,5 +1,11 @@
 <node>
   <interface name="org.freedesktop.login1.Manager">
+    <method name="Suspend">
+      <arg type="b" direction="in"/>
+    </method>
+    <method name="CanSuspend">
+      <arg type="s" direction="out"/>
+    </method>
     <method name="Inhibit">
       <arg type="s" direction="in"/>
       <arg type="s" direction="in"/>
diff --git a/data/dbus-interfaces/org.gnome.SessionManager.xml b/data/dbus-interfaces/org.gnome.SessionManager.xml
index 5c9ef11e3..628a4693b 100644
--- a/data/dbus-interfaces/org.gnome.SessionManager.xml
+++ b/data/dbus-interfaces/org.gnome.SessionManager.xml
@@ -5,16 +5,12 @@
     </method>
     <method name="Shutdown"/>
     <method name="Reboot"/>
-    <method name="Suspend"/>
     <method name="CanShutdown">
       <arg type="u" direction="out"/>
     </method>
     <method name="CanReboot">
       <arg type="u" direction="out"/>
     </method>
-    <method name="CanSuspend">
-      <arg type="u" direction="out"/>
-    </method>
     <method name="IsInhibited">
       <arg type="u" direction="in"/>
       <arg type="b" direction="out"/>
diff --git a/js/misc/loginManager.js b/js/misc/loginManager.js
index da989b5b1..a66ebed03 100644
--- a/js/misc/loginManager.js
+++ b/js/misc/loginManager.js
@@ -167,6 +167,20 @@ class LoginManagerSystemd extends Signals.EventEmitter {
         }
     }
 
+    async canSuspend() {
+        let canSuspend, needsAuth;
+
+        try {
+            const [result] = await this._proxy.CanSuspendAsync();
+            needsAuth = result === 'challenge';
+            canSuspend = needsAuth || result === 'yes';
+        } catch {
+            canSuspend = false;
+            needsAuth = false;
+        }
+        return {canSuspend, needsAuth};
+    }
+
     async canRebootToBootLoaderMenu() {
         let canRebootToBootLoaderMenu, needsAuth;
 
@@ -199,6 +213,10 @@ class LoginManagerSystemd extends Signals.EventEmitter {
         return new SystemdLoginSession(Gio.DBus.system, 'org.freedesktop.login1', objectPath);
     }
 
+    suspend() {
+        this._proxy.SuspendAsync(true);
+    }
+
     async inhibit(reason, cancellable) {
         const inVariant = new GLib.Variant('(ssss)',
             ['sleep', 'GNOME Shell', reason, 'delay']);
@@ -250,6 +268,13 @@ class LoginManagerDummy extends Signals.EventEmitter  {
         return new Promise(() => {});
     }
 
+    canSuspend() {
+        return new Promise(resolve => resolve({
+            canSuspend: false,
+            needsAuth: false,
+        }));
+    }
+
     canRebootToBootLoaderMenu() {
         return new Promise(resolve => resolve({
             canRebootToBootLoaderMenu: false,
@@ -268,6 +293,13 @@ class LoginManagerDummy extends Signals.EventEmitter  {
         return null;
     }
 
+    suspend() {
+        this._preparingForSleep = true;
+        this.emit('prepare-for-sleep', true);
+        this._preparingForSleep = false;
+        this.emit('prepare-for-sleep', false);
+    }
+
     get preparingForSleep() {
         return this._preparingForSleep;
     }
diff --git a/js/misc/systemActions.js b/js/misc/systemActions.js
index 75bada6a1..04a48c5b8 100644
--- a/js/misc/systemActions.js
+++ b/js/misc/systemActions.js
@@ -86,7 +86,6 @@ const SystemActions = GObject.registerClass({
         this._canHaveReboot = true;
         this._rebootNeedsAuth = false;
         this._canHaveSuspend = true;
-        this._suspendNeedsAuth = false;
 
         function tokenizeKeywords(keywords) {
             return keywords.split(';').map(keyword => GLib.str_tokenize_and_fold(keyword, null)).flat(2);
@@ -163,6 +162,7 @@ const SystemActions = GObject.registerClass({
         this._screenSaverSettings = new Gio.Settings({schema_id: SCREENSAVER_SCHEMA});
 
         this._session = new GnomeSession.SessionManager();
+        this._loginManager = LoginManager.getLoginManager();
         this._monitorManager = global.backend.get_monitor_manager();
 
         this._userManager = AccountsService.UserManager.get_default();
@@ -401,19 +401,15 @@ const SystemActions = GObject.registerClass({
     }
 
     async _updateHaveSuspend() {
-        try {
-            const [availability] = await this._session.CanSuspendAsync();
-            this._canHaveSuspend = availability !== GnomeSession.ActionAvailability.UNAVAILABLE;
-            this._suspendNeedsAuth = availability === GnomeSession.ActionAvailability.CHALLENGE;
-        } catch {
-            this._canHaveSuspend = false;
-            this._suspendNeedsAuth = false;
-        }
+        const {canSuspend, needsAuth} = await this._loginManager.canSuspend();
+        this._canHaveSuspend = canSuspend;
+        this._suspendNeedsAuth = needsAuth;
         this._updateSuspend();
     }
 
     _updateSuspend() {
-        const disabled = (Main.sessionMode.isLocked && this._suspendNeedsAuth) ||
+        const disabled = (Main.sessionMode.isLocked &&
+                        this._suspendNeedsAuth) ||
                        (Main.sessionMode.isGreeter &&
                         this._loginScreenSettings.get_boolean(DISABLE_RESTART_KEY));
         this._actions.get(SUSPEND_ACTION_ID).available = this._canHaveSuspend && !disabled;
@@ -506,7 +502,7 @@ const SystemActions = GObject.registerClass({
         if (!this._actions.get(SUSPEND_ACTION_ID).available)
             throw new Error('The suspend action is not available!');
 
-        this._session.SuspendAsync().catch(logErrorUnlessCancelled);
+        this._loginManager.suspend();
     }
 
     activateScreenshotUI() {
-- 
