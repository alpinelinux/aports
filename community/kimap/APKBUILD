779d1458ea41ff8a66dd5161e7150df11ebe5b51116b4d916b171fee93363278867cc438bb9c8a985c5677a3bb576a609e81a67e3e99f10000a56ae012d76408  0001-kimap-KMime-from-KF6.patch
"
