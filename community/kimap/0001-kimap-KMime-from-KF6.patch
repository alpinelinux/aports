From b45cc087e5fe0bae1589ce7d4812c74d4e3c42c9 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Fri, 17 Apr 2026 17:21:31 +0200
Subject: [PATCH] Add forward compatibility for KMime from KDE Frameworks

---
 CMakeLists.txt          |  6 +++++-
 KPimIMAPConfig.cmake.in | 19 +++++++++++++++----
 src/CMakeLists.txt      |  2 +-
 3 files changed, 21 insertions(+), 6 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index cd241f3..c357b03 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -124,7 +124,11 @@ set_package_properties(
 find_package(KF6CoreAddons ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6I18n ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6KIO ${KF_MIN_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIBS_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIBS_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 
 ########### CMake Config Files ###########
 set(CMAKECONFIG_INSTALL_DIR "${KDE_INSTALL_CMAKEPACKAGEDIR}/KPim6IMAP")
diff --git a/KPimIMAPConfig.cmake.in b/KPimIMAPConfig.cmake.in
index 233d7a8..f146c5f 100644
--- a/KPimIMAPConfig.cmake.in
+++ b/KPimIMAPConfig.cmake.in
@@ -13,8 +13,19 @@ find_dependency(
     KF6CoreAddons
     "@KF_MIN_VERSION@"
 )
-find_dependency(
-    KPim6Mime
-    "@KMIME_LIBS_VERSION@"
-)
+if(@KF6Mime_FOUND@)
+    find_dependency(
+        KF6Mime
+        "@KF_MIN_VERSION@"
+    )
+else()
+    find_dependency(
+        KPim6Mime
+        "@KMIME_LIBS_VERSION@"
+    )
+    if(NOT TARGET KF6::Mime)
+        add_library(KF6::Mime ALIAS KPim6::Mime)
+    endif()
+endif()
+
 include("${CMAKE_CURRENT_LIST_DIR}/KPim6IMAPTargets.cmake")
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index 1813e01..a06d739 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -138,7 +138,7 @@ endif()
 target_link_libraries(
     KPim6IMAP
     PUBLIC
-        KPim6::Mime
+        KF6::Mime
         KF6::CoreAddons
         Qt::Network
     PRIVATE
-- 
GitLab

