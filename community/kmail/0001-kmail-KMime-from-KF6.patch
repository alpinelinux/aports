From: Volker Krause <vkrause@kde.org>
Date: Sun, 19 Apr 2026 10:04:59 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt                              | 6 +++++-
 agents/followupreminderagent/CMakeLists.txt | 2 +-
 agents/mailfilteragent/CMakeLists.txt       | 2 +-
 agents/mailmergeagent/CMakeLists.txt        | 2 +-
 agents/sendlateragent/CMakeLists.txt        | 2 +-
 agents/unifiedmailboxagent/CMakeLists.txt   | 2 +-
 src/CMakeLists.txt                          | 2 +-
 src/autotests/CMakeLists.txt                | 2 +-
 src/kontactplugin/kmail/CMakeLists.txt      | 4 ++--
 9 files changed, 14 insertions(+), 10 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index fa71d2ec0..bb5cd0174 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -242,7 +242,11 @@ find_package(KPim6MailTransport ${KMAILTRANSPORT_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6TextEdit ${KPIMTEXTEDIT_LIB_VERSION} CONFIG REQUIRED)
 
 find_package(KPim6KontactInterface ${KONTACTINTERFACE_LIB_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 
 find_package(KPim6Gravatar ${LIBGRAVATAR_VERSION} CONFIG REQUIRED)
 find_package(KPim6Libkdepim ${LIBKDEPIM_LIB_VERSION} CONFIG REQUIRED)
