# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-model-bakery
_pyname="model_bakery"
pkgver=1.23.4
pkgrel=0
arch="noarch"
pkgdesc="Smart object creation facility for Django"
url="https://pypi.python.org/project/model-bakary"
license="Apache-2.0"
depends="py3-django"
makedepends="
	py3-hatchling
	py3-setuptools
	py3-gpep517
	py3-wheel
	"
checkdepends="
	black
	py3-pytest-django
	py3-coverage
	py3-pillow
	py3-mypy
	ruff
	"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/model-bakers/model_bakery/archive/refs/tags/$pkgver.tar.gz
	use-hatch-build.patch
	"
builddir="$srcdir"/$_pyname-$pkgver
subpackages="$pkgname-pyc"

prepare() {
	# drop version= in pyproject.toml to not have to rebase patch every release and set version
	sed '/version =/d' -i "$builddir"/pyproject.toml
	echo "__version__=\"$pkgver\"" > model_bakery/__about__.py

	default_prepare
}

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}
sha512sums="
f495d1b25ac0848d1f4dfbbc0626155d907311ba5cac48e4059c3946b97af1edacbcfcdbad3213db2214ea84018b8f564cbb3fd11ec9277e9f49ad0f42271c0e  py3-model-bakery-1.23.4.tar.gz
45202d1c0ff1defa4d8e65ebee87b80a03046f5e6ed57c898d998e06dc0ce06de871a1e2b33a6e09a81395ce11b58cee21b9c1ba82c39bf8f1e915febcf1a006  use-hatch-build.patch
"
