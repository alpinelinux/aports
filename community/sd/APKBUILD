# Contributor: Chloe Kudryavtsev <code@toast.bunkerlabs.net>
# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=sd
pkgver=1.1.0
pkgrel=0
pkgdesc="An intuitive find & replace CLI"
url="https://github.com/chmln/sd"
arch="all"
license="MIT"
options="net"
makedepends="cargo cargo-auditable"
source="$pkgname-$pkgver.tar.gz::https://github.com/chmln/sd/archive/v$pkgver.tar.gz
	version.patch
	"
subpackages="$pkgname-doc
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"

export CARGO_HOME="$srcdir"/cargo

build() {
	cargo auditable build \
		--release \
		--verbose
}

check() {
	cargo test --all \
		--release \
		--verbose
}

package() {
	install -Dm755 target/release/"$pkgname" "$pkgdir"/usr/bin/"$pkgname"

	# doc
	install -Dm644 gen/sd.1 -t "$pkgdir"/usr/share/man/man1

	# comp
	install -Dm644 gen/completions/sd.bash "$pkgdir"/usr/share/bash-completion/completions/sd
	install -Dm644 gen/completions/sd.fish "$pkgdir"/usr/share/fish/vendor_completions.d/sd.fish
	install -Dm644 gen/completions/_sd "$pkgdir"/usr/share/zsh/site-functions/_sd
}

sha512sums="
b4d580ce020df47f640809771c62ef73fa7cea0d04b900abcc76f9ccc5b6a274de77f62c4f98f9ac078d48233dedf034b4cd51cd49e40c2d4ccd8f17589251ab  sd-1.1.0.tar.gz
0708eaea9e7cfefdd7ed0934a8c433a90f65da5adf16e721c62be5595a01d35b37774768bdf346f5731ac1957135b7616b1fe9e083f9a6b10282744fc177e780  version.patch
"
