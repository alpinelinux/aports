# Maintainer: Laurent Bercot <ska-devel@skarnet.org>
pkgname=s6-overlay-helpers
pkgver=0.1.2.2
pkgrel=0
pkgdesc="Binary helpers for s6-overlay"
url="https://github.com/just-containers/s6-overlay-helpers"
arch="all"
license="ISC"
makedepends="skalibs-dev execline-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/just-containers/s6-overlay-helpers/archive/refs/tags/v$pkgver.tar.gz"

# s6-overlay-suexec is suid root.
# That's okay: it's only runnable as pid 1. (For use in USER containers.)
options="!check suid"

build() {
	./configure \
		--prefix=/usr \
		--sysconfdir=/etc \
		--libexecdir="/usr/libexec/$pkgname" \
		--enable-shared \
		--disable-allstatic \
		--with-pkgconfig
	make
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
cc44f994478c507138a4b570e6f9359145d24cdbacbbcca0323786531952dba2b899379ba535b638e37ed0b7155e86a1625e36098df1a3cbb153d1405b4b0cb5  s6-overlay-helpers-0.1.2.2.tar.gz
"
