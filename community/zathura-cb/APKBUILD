maintainer="omni <omni+alpine@hack.org>"
pkgname=zathura-cb
pkgver=2026.07.18
pkgrel=0
pkgdesc="Comic book support for zathura"
url="https://pwmt.org/projects/zathura-cb/"
arch="all"
license="Zlib"
depends="
	desktop-file-utils
	zathura
	"
makedepends="
	libarchive-dev
	gtk4.0-dev
	muon
	zathura-dev
	"
source="https://pwmt.org/projects/zathura-cb/download/zathura-cb-$pkgver.tar.xz"
options="!check" # no test suite

build() {
	abuild-muon build .
	ninja -C build
}

package() {
	DESTDIR="$pkgdir" muon -C build install
}

