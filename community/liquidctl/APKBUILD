# Contributor: Leo <thinkabit.ukim@gmail.com>
# Maintainer: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
pkgname=liquidctl
pkgver=1.16.0
pkgrel=1
pkgdesc="Liquid Cooler Control"
url="https://github.com/liquidctl/liquidctl"
options="!check" # Requires writable /var/run
arch="noarch"
license="GPL-3.0-or-later"
pkgusers="liquidctl"
pkggroups="liquidctl"
depends="
	py3-colorlog
	py3-crcmod
	py3-docopt
	py3-hidapi
	py3-pillow
	py3-smbus
	py3-usb
	"
makedepends="
	py3-gpep517
	py3-installer
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="py3-pytest"
install="$pkgname.pre-install $pkgname.pre-upgrade"
subpackages="$pkgname-doc $pkgname-pyc $pkgname-udev $pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/liquidctl/liquidctl/archive/v$pkgver.tar.gz
	liquidctl.initd
	liquidctl.confd
	"

prepare() {
	default_prepare

	# `uaccess` is (e)logind-specific (and too generous for this kind of permission).
	sed -i 's/TAG+="uaccess"/GROUP="liquidctl"/' extra/linux/71-liquidctl.rules
}

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
	install -Dm644 extra/linux/71-liquidctl.rules -t "$pkgdir/usr/lib/udev/rules.d/"
	install -Dm644 liquidctl.8 -t "$pkgdir/usr/share/man/man8/"
	install -Dm 755 "$srcdir/liquidctl.initd" "$pkgdir/etc/init.d/liquidctl"
	install -Dm 644 "$srcdir/liquidctl.confd" "$pkgdir/etc/conf.d/liquidctl"
}

sha512sums="
