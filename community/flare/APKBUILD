maintainer="Krassy Boykinov <kboykinov@teamcentrixx.com>"
pkgname=flare
pkgver=0.20.0
pkgrel=0
pkgdesc="Unofficial Signal GTK client"
url="https://gitlab.com/schmiddi-on-mobile/flare"
arch="all"
license="AGPL-3.0-only"
makedepends="
	blueprint-compiler
	cargo-auditable
	desktop-file-utils
	gettext-dev
	gtk4.0-dev
	gtksourceview5-dev
	libadwaita-dev
	libsecret-dev
	libspelling-dev
	meson
	openssl-dev
	protobuf-dev
	"
subpackages="$pkgname-lang"
source="https://gitlab.com/schmiddi-on-mobile/flare/-/archive/$pkgver/flare-$pkgver.tar.gz
	0001-no-cargo-home.patch
	0002-use-cargo-auditable.patch
	0003-use-system-wide-openssl.patch
	"
# no tests
options="!check net"


prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	abuild-meson . output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

