From 7c18856a08e44b878a31267a8a1cb891f82ef13f Mon Sep 17 00:00:00 2001
From: vad <vad.sol@proton.me>
Date: Sun, 15 Mar 2026 13:57:13 +0100
Subject: [PATCH] cargo: Use system-wide OpenSSL instead of vendored one

Pick up a change from pressage[0] that avoids vendoring OpenSSL.

https://github.com/Schmiddiii/presage/commit/8b40a2d35c610d04cb155076d2f68295793b1e49
---
 Cargo.lock | 27 ++-------------------------
 Cargo.toml |  4 ++--
 2 files changed, 4 insertions(+), 27 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 35d8fb9..74251ed 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -2575,7 +2575,6 @@ source = "registry+https://github.com/rust-lang/crates.io-index"
 checksum = "2e99fb7a497b1e3339bc746195567ed8d3e24945ecd636e3619d20b9de9e9149"
 dependencies = [
  "cc",
- "openssl-sys",
  "pkg-config",
  "vcpkg",
 ]
@@ -2998,28 +2997,6 @@ version = "0.3.1"
 source = "registry+https://github.com/rust-lang/crates.io-index"
 checksum = "c08d65885ee38876c4f86fa503fb49d7b507c2b62552df7c70b2fce627e06381"
 
-[[package]]
-name = "openssl-src"
-version = "300.5.5+3.5.5"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "3f1787d533e03597a7934fd0a765f0d28e94ecc5fb7789f8053b1e699a56f709"
-dependencies = [
- "cc",
-]
-
-[[package]]
-name = "openssl-sys"
-version = "0.9.111"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "82cab2d520aa75e3c58898289429321eb788c3106963d0dc886ec7a5f4adc321"
-dependencies = [
- "cc",
- "libc",
- "openssl-src",
- "pkg-config",
- "vcpkg",
-]
-
 [[package]]
 name = "ordered-stream"
 version = "0.2.0"
@@ -3341,7 +3318,7 @@ dependencies = [
 [[package]]
 name = "presage"
 version = "0.8.0-dev"
-source = "git+https://github.com/Schmiddiii/presage?rev=1dbd863bc3e9f467ae2002bc915ce122423ccc3c#1dbd863bc3e9f467ae2002bc915ce122423ccc3c"
+source = "git+https://github.com/Schmiddiii/presage?rev=8b40a2d35c610d04cb155076d2f68295793b1e49#8b40a2d35c610d04cb155076d2f68295793b1e49"
 dependencies = [
  "base64",
  "bytes",
@@ -3362,7 +3339,7 @@ dependencies = [
 [[package]]
 name = "presage-store-sqlite"
 version = "0.8.0-dev"
-source = "git+https://github.com/Schmiddiii/presage?rev=1dbd863bc3e9f467ae2002bc915ce122423ccc3c#1dbd863bc3e9f467ae2002bc915ce122423ccc3c"
+source = "git+https://github.com/Schmiddiii/presage?rev=8b40a2d35c610d04cb155076d2f68295793b1e49#8b40a2d35c610d04cb155076d2f68295793b1e49"
 dependencies = [
  "async-trait",
  "bytes",
diff --git a/Cargo.toml b/Cargo.toml
index 11fec80..45eaacd 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -24,8 +24,8 @@ tokio = { version = "1.48.0", features = ["rt", "macros", "rt-multi-thread", "ti
 regex = "1.12.2"
 lazy_static = "1.5.0"
 
-presage = { git = "https://github.com/Schmiddiii/presage", rev = "1dbd863bc3e9f467ae2002bc915ce122423ccc3c", default-features = false }
-presage-store-sqlite = { git = "https://github.com/Schmiddiii/presage", rev = "1dbd863bc3e9f467ae2002bc915ce122423ccc3c", default-features = false}
+presage = { git = "https://github.com/Schmiddiii/presage", rev = "8b40a2d35c610d04cb155076d2f68295793b1e49", default-features = false }
+presage-store-sqlite = { git = "https://github.com/Schmiddiii/presage", rev = "8b40a2d35c610d04cb155076d2f68295793b1e49", default-features = false}
 libsignal-service = { git = "https://github.com/whisperfish/libsignal-service-rs", rev = "3d07d8df33482b2d191c075fdc2b750738a89384", default-features = false, features = ["phonenumber"] }
 
 oo7 = { version = "0.5.0", default-features = false, features = ["native_crypto", "tokio"] }
-- 
2.53.0

