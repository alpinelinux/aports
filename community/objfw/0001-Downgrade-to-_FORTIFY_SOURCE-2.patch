From bb4a82ca13557c1a1e69c3731a20200339472c4a Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?J=2E=20Neusch=C3=A4fer?= <j.ne@posteo.net>
Date: Wed, 4 Mar 2026 11:10:25 +0100
Subject: [PATCH] Downgrade to _FORTIFY_SOURCE=2

_FORTIFY_SOURCE=3 currently causes issues with Clang:

  https://gitlab.alpinelinux.org/alpine/aports/-/issues/18015

Downgrade to _FORTIFY_SOURCE=2 to avoid these issues.
---
 configure.ac | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index 0f96cfd0d..adbd3ee15 100644
--- a/configure.ac
+++ b/configure.ac
@@ -342,7 +342,7 @@ AS_IF([test x"$with_nintendo_switch" = x"yes"], [
 
 CPP="$OBJCPP"
 CPPFLAGS="$CPPFLAGS $OBJCPPFLAGS -DOF_COMPILING_OBJFW"
-CPPFLAGS="$CPPFLAGS -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=3"
+CPPFLAGS="$CPPFLAGS -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=2"
 flags="-fexceptions -fobjc-exceptions -funwind-tables"
 flags="$flags -fconstant-string-class=OFConstantString"
 OBJCFLAGS="$OBJCFLAGS -Wall $flags"
-- 
2.51.0

