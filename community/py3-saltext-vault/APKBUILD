# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-saltext-vault
_pkgname=saltext_vault
pkgver=1.6.0
pkgrel=0
pkgdesc="Salt Extension for interacting with Vault"
url="https://pypi.org/project/saltext.vault/"
arch="noarch"
license="Apache-2.0"
depends="py3-cryptography"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/${_pkgname:0:1}/$_pkgname/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"
options="!check" # checks require a saltstack environment

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
b6941937dec2542ed675e2756ed19c93046aa3ca2124af13e50b0ddbb221f2690883e1a9435f6b9263471f9cd7a35409aae3903cda8cf5766ec970f07980fd33  saltext_vault-1.6.0.tar.gz
"
