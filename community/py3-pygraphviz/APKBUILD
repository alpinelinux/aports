# Contributor: Stuart Cardall <developer@it-offshore.co.uk>
# Maintainer: Stuart Cardall <developer@it-offshore.co.uk>
pkgname=py3-pygraphviz
pkgver=1.14
pkgrel=0
pkgdesc="Python interface to Graphviz"
url="https://pygraphviz.github.io/"
arch="all"
license="BSD-3-Clause"
depends="python3"
makedepends="python3-dev graphviz-dev py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest graphviz"
subpackages="$pkgname-pyc"
source="https://github.com/pygraphviz/pygraphviz/archive/pygraphviz-$pkgver.tar.gz
	test-import.patch
	"
builddir="$srcdir/pygraphviz-pygraphviz-$pkgver"

replaces="py-pygraphviz" # Backwards compatibility
provides="py-pygraphviz=$pkgver-r$pkgrel" # Backwards compatibility

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	mv pygraphviz/tests tests

	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	PYTHONSAFEPATH=1 .testenv/bin/python3 -m pytest --import-mode=importlib \
		--deselect tests/test_layout.py::test_layout_prog_arg \
		--deselect tests/test_layout.py::TestExperimentalGraphvizLibInterface::test_layout_prog_arg
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
469130dbddcbbe884af30fbf9bb41e901080f0fdf1774d25eea8fa8493607ea15973435e13291d7e6cac69568061ed47fc8e4d846a5dafc83d043aa7ee02ed9c  pygraphviz-1.14.tar.gz
506cff6b19f9225c7cb5ab7d13e531a9fa037160c91e2ae69e840d4b71c62b7c4b18534d8f95e042e1412af78e0c642393a2127d18e2308edcad510396f16f47  test-import.patch
"
