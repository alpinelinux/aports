# Contributor: Carlo Landmeter <clandmeter@alpinelinux.org>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=thin-provisioning-tools
pkgver=1.3.2
pkgrel=0
pkgdesc="suite of tools for manipulating the metadata of the dm-thin device-mapper target"
url="https://github.com/jthornber/thin-provisioning-tools"
# ucontext libc fs_type_t
arch="all"
license="GPL-3.0-only"
makedepends="
	cargo
	cargo-auditable
	clang-libclang
	eudev-dev
	gawk
	lvm2-dev
	"
subpackages="$pkgname-doc"
_dmrsver=0.34.6
source="$pkgname-$pkgver.tar.gz::https://github.com/jthornber/thin-provisioning-tools/archive/v$pkgver.tar.gz
	https://github.com/stratis-storage/devicemapper-rs/archive/refs/tags/devicemapper-v$_dmrsver.tar.gz
	nix-s390x.patch
	"
# tests do a ton of disk i/o for a while..
# they pass on x86_64, but a bit too destructive to constantly run
options="net !check"

prepare() {
	mv "$srcdir"/devicemapper-rs-devicemapper-v"$_dmrsver" \
		"$builddir"/vendored-devicemapper

	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --locked
}

package() {
	make DESTDIR="$pkgdir" install
}

