# Contributor: Alan Lacerda <alacerda@alpinelinux.org>
# Maintainer: Alan Lacerda <alacerda@alpinelinux.org>
pkgname=pluma
pkgver=1.28.1
pkgrel=0
pkgdesc="A small and lightweight UTF-8 text editor for the MATE"
url="https://github.com/mate-desktop/pluma"
arch="all"
license="GPL-2.0-or-later"
# tests require gsettings-schemas, gvfs-mount
options="!check"
depends="mate-desktop"
makedepends="
	gobject-introspection-dev
	dconf-dev
	enchant2-dev
	fortify-headers
	gsettings-desktop-schemas-dev
	gtk+3.0-dev
	gtksourceview-dev
	gtksourceview4-dev
	intltool
	iso-codes-dev
	itstool
	libpeas-dev
	libsm-dev
	libxml2-utils
	mate-desktop-dev
	"
subpackages="$pkgname-dev $pkgname-doc $pkgname-lang $pkgname-pyc"
source="https://github.com/mate-desktop/pluma/releases/download/v$pkgver/pluma-$pkgver.tar.xz"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--sysconfdir=/etc \
		--enable-static=no \
		--prefix=/usr
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

pyc() {
	default_pyc
	find usr/lib/pluma -type d -name __pycache__ | while IFS='
' read -r line; do
		amove $line
	done
}

sha512sums="
4b77aa4a1998354507514416c8c0542af78d4b3aef4d28fefc19b4e0ae7245246c16ca206279027932ee3638796d2a2873d82ca5bb5754b7cdecefd1055e80cc  pluma-1.28.1.tar.xz
"
