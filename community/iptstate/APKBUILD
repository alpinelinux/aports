# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=iptstate
pkgver=2.3.0
pkgrel=0
pkgdesc="Top-like interface to netfilter connection-tracking table"
url="https://www.phildev.net/iptstate/"
arch="all"
license="MIT"
makedepends="ncurses-dev libnetfilter_conntrack-dev libnfnetlink-dev linux-headers"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/jaymzh/iptstate/archive/refs/tags/v$pkgver.tar.gz"

build() {
	make
}

check() {
	./iptstate --help > /dev/null
}

package() {
	install -D -m755 $pkgname "$pkgdir"/usr/sbin/$pkgname
	install -D -m444 $pkgname.8 "$pkgdir"/usr/share/man/man8/$pkgname.8
	install -D -m644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

sha512sums="
355f48f45965ed7bf79a59249c20505c96ec51a06711cf9df02b5a32dcf4bfd5e90d2aa97c08ee9b19ae738583b4d16094050a469bece295910926253eb6acc7  iptstate-2.3.0.tar.gz
"
