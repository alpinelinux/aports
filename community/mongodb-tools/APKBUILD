# Contributor: Marc Vertes <mvertes@free.fr>
# Maintainer: Mikael Jenkler <mikael@jenkler.com>
pkgname=mongodb-tools
pkgver=100.14.1
pkgrel=1
pkgdesc="The MongoDB tools provide import, export, and diagnostic capabilities."
url="https://github.com/mongodb/mongo-tools"
arch="all"
license="Apache-2.0"
makedepends="
	go
	krb5-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/mongodb/mongo-tools/archive/$pkgver.tar.gz"
builddir="$srcdir/mongo-tools-$pkgver"
options="!check"

export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

build() {
	mkdir -p bin
	local bins="
		bsondump
		mongodump
		mongoexport
		mongofiles
		mongoimport
		mongorestore
		mongostat
		mongotop
		"
	for bin in $bins; do
		go build -o bin/$bin \
			-ldflags="-X main.VersionStr=$pkgver -X main.GitCommit=alpine" \
			-tags "ssl sasl gssapi failpoints" \
			$bin/main/$bin.go
	done
}

package() {
	install -Dm755 -t "$pkgdir"/usr/bin bin/*
}

sha512sums="
780e0ae82aaec98b6e2661fbb21d45971f593458b99f4baedd3f50002df01bcaa297d725b337f58f2fb272e2904adfa5e65b34ca4213eea249b9eec58c59ba64  mongodb-tools-100.14.1.tar.gz
"
