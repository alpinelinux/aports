# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=gnome-software
pkgver=50.0
pkgrel=0
pkgdesc="Software lets you install and update applications and system extensions"
url="https://apps.gnome.org/Software"
arch="all"
license="GPL-2.0-or-later"
depends="gnome-app-list"
makedepends="
	appstream-dev
	flatpak-dev
	gdk-pixbuf-dev
	glib-dev
	gsettings-desktop-schemas-dev
	gtk4.0-dev
	gtk-doc
	json-glib-dev
	libadwaita-dev
	libgudev-dev
	libsoup3-dev
	libxmlb-dev
	meson
	ostree-dev
	polkit-dev
	itstool
	fwupd-dev
	"
options="!check" # lots of failing tests
install="$pkgname.post-upgrade"
subpackages="
	$pkgname-bash-completion
	$pkgname-dbg
	$pkgname-dev
	$pkgname-doc
	$pkgname-lang
	$pkgname-lib
	$pkgname-plugin-flatpak:flatpak_plugin
	$pkgname-plugin-sysupdate:sysupdate_plugin
	$pkgname-systemd
	"
source="https://download.gnome.org/sources/gnome-software/${pkgver%.*}/gnome-software-$pkgver.tar.xz
	org.gnome.software.gschema.override
	"

build() {
	abuild-meson \
		-Dmalcontent=false \
		-Dpackagekit=false \
		-Dhardcoded_proprietary_webapps=false \
		-Dtests=false \
		-Dexternal_appstream=true \
		-Dfwupd=true \
		-Dsystemd-sysupdate=true \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
	install -Dm644 "$srcdir"/org.gnome.software.gschema.override \
		-t "$pkgdir"/usr/share/glib-2.0/schemas/
}

dev() {
	default_dev

	amove usr/lib/gnome-software/libgnomesoftware.so
}

lib() {
	pkgdesc="$pkgdesc (shared library)"
	depends=""

	amove usr/lib/gnome-software/libgnomesoftware.so.*
}

flatpak_plugin() {
	pkgdesc="$pkgdesc (flatpak plugin)"
	install_if="$pkgname=$pkgver-r$pkgrel flatpak"
	depends=""

	amove usr/lib/gnome-software/plugins-23/libgs_plugin_flatpak.so
	amove usr/share/metainfo/org.gnome.Software.Plugin.Flatpak.metainfo.xml
}

sysupdate_plugin() {
	pkgdesc="$pkgdesc (systemd sysupdate plugin)"
	depends=""

	amove usr/lib/gnome-software/plugins-23/libgs_plugin_systemd-sysupdate.so
}

sha512sums="
