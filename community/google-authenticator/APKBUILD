# Contributor: Fabio Napoleoni <f.napoleoni@gmail.com>
# Maintainer: r0eme <git@roeme.ch>
pkgname=google-authenticator
pkgver=1.11
pkgrel=0
pkgdesc="Google Authenticator PAM module"
options="checkroot !check" # 1 of 2 tests fail
url="https://github.com/google/google-authenticator-libpam"
arch="all"
license="Apache-2.0"
makedepends="autoconf automake libtool linux-pam-dev m4 openssl-dev>3"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/google/google-authenticator-libpam/archive/$pkgver.tar.gz"
builddir="$srcdir/$pkgname-libpam-$pkgver"

prepare() {
	default_prepare
	./bootstrap.sh
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info
	make
}

package() {
	make DESTDIR="$pkgdir" install
	mkdir -p "$pkgdir/etc/pam.d"
	printf 'auth\trequired\tpam_google_authenticator.so' \
		> "$pkgdir/etc/pam.d/google-authenticator"
}

check() {
	make check
}

sha512sums="5bbee53f293a67e6f92e956a24904a0197ba65270e096965e8b91f50e87c176ece9ba81c92392b199aa45f4fe5b38e77069b9c5e2f5800c6a5dbb6a35f20d21b  google-authenticator-1.11.tar.gz"
