# Contributor: Angelo Verlain <hey@vixalien.com>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=uxplay
pkgver=1.73.6
# NOTE: When upgrading, patch systemd service, see https://github.com/FDH2/UxPlay/commit/3ca7526387e894d6848b84c209de361c3bedd1ec
pkgrel=1
arch="all"
url="https://github.com/FDH2/UxPlay"
pkgdesc="AirPlay Unix mirroring server"
license="GPL-3.0-or-later"
depends="
	gst-libav
	gst-plugins-bad
	gst-plugins-good
	"
makedepends="
	avahi-dev
	cmake
	gst-plugins-base-dev
	gstreamer-dev
	libplist-dev
	openssl-dev
	samurai
	"
subpackages="$pkgname-doc $pkgname-systemd"
source="$pkgname-$pkgver.tar.gz::https://github.com/FDH2/UxPlay/archive/refs/tags/v$pkgver.tar.gz
	uxplay.desktop
	"
builddir="$srcdir/UxPlay-$pkgver"
options="!check" # no tests

build() {
	if [ "$CBUILD" != "$CHOST" ]; then
		local crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	fi
	cmake -B build \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=None \
		$crossopts
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	mkdir -p "$pkgdir"/usr/lib/systemd/user/
	mv "$pkgdir"/usr/share/doc/uxplay/systemd/uxplay.service "$pkgdir"/usr/lib/systemd/user/
	rm -r "$pkgdir"/usr/share/doc/uxplay/systemd/

	install -Dm644 "$srcdir"/uxplay.desktop -t "$pkgdir"/usr/share/applications/
}

sha512sums="
b8acd7737e5bbd5dd9f0a4dd08a5fe0eb73c7302f6d08167e4a86f9cc6834efd36320aaa8551ec0fd3597f8c5ebce60fe7abf4a2a0ca0f1957508cfe73bca9dd  uxplay-1.73.6.tar.gz
113ff76fa2761df54ec610f2ae2cdfc50ee6489102e82d2157c61d25b78e381406db94a3e1f119f4d8acd5fc34be3e97e56a693e3fc77086b42a67ca3168da17  uxplay.desktop
"
