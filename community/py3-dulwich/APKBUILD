b5f37e2790b3d8243b47749ca8b6a90b0a92fa44221d14b8a26b3faceb9dca4c82392514c516eb6a3d3f11534f3b106ed26d6a24ea9e9d278a5aa7879f10994c  skip-network-tests.patch
519405896d9cc8312118b74a765b3d3391187955c9944708764fced24d2c2aa632e936e786e54b76abed7c6697388083759b219a23811eb6281b1f523094516c  skip-git-daemon-tests.patch
"
