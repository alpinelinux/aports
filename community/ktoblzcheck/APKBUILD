# Maintainer: Sören Tempel <soeren+alpine@soeren-tempel.net>
pkgname=ktoblzcheck
pkgver=1.59
pkgrel=0
_dataver=20250515
pkgdesc="A library to check account numbers and bank codes of german banks"
url="https://ktoblzcheck.sourceforge.net/"
arch="all"
license="LGPL-2.1-or-later"
makedepends="cmake samurai python3 python3-dev py3-openpyxl sqlite-dev curl-dev"
subpackages="$pkgname-dev $pkgname-doc"
options="net"
source="https://downloads.sourceforge.net/sourceforge/ktoblzcheck/ktoblzcheck-$pkgver.tar.gz
	https://sourceforge.net/projects/ktoblzcheck/files/ktoblzcheck-data-$_dataver.tar.gz
	cmake_policy.patch"

build() {
	cmake -B build \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build

	if want_check; then
		# Build a test environment using data from srcdir
		cmake -B build-test \
			-DCMAKE_BUILD_TYPE=None \
			-DCMAKE_INSTALL_PREFIX=/usr \
			-DCMAKE_INSTALL_LIBDIR=lib \
			-DBANKDATA_PATH="$srcdir"/ktoblzcheck-data-$_dataver/data
		cmake --build build-test
	fi
}

check() {
	ctest --test-dir build-test
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	# Install data files
	install -Dm644 "$srcdir"/ktoblzcheck-data-$_dataver/data/* \
		-t "$pkgdir"/usr/share/ktoblzcheck/
}

