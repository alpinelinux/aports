# Maintainer: horizonwiki <horizondebug@email.com>
pkgname=fire-cli
pkgver=0.1.2
pkgrel=0
pkgdesc="Terminal fire animation written in Rust."
url="https://github.com/horizonwiki/fire"
arch="all"
license="Apache-2.0"
makedepends="cargo"
source="$pkgname-$pkgver.tar.gz::https://github.com/horizonwiki/fire/archive/$pkgver.tar.gz"
builddir="$srcdir/fire-$pkgver"

build() {
        cd "$builddir"
        cargo build --release
}

package() {
        install -Dm755 target/release/fire-cli "$pkgdir"/usr/bin/fire-cli
}
