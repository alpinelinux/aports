add -std=gnu11 to fix build failures on gcc 15 with c23 by default

This contains the relevant parts from the following commits:

* https://github.com/9fans/plan9port/commit/28690cd427d3caacc50f3df6a3ee901eba5c5dd0
* https://github.com/9fans/plan9port/commit/6df4828542ab7c679b0f826ee7d432330823de71
* https://github.com/9fans/plan9port/commit/564d45b5a55adeb48f69fdecb2bf4ed1f909850b

diff --git a/bin/9c b/bin/9c
index 0ebdfa01a8..ccfbe7e944 100755
--- a/bin/9c
+++ b/bin/9c
@@ -18,12 +18,12 @@ usegcc()
 		-Wno-stringop-truncation \
 		-Wno-stringop-overflow \
 		-Wno-format-truncation \
-		-Wno-deprecated-pragma \
 		-Wno-unused-but-set-variable \
 		-Wno-deprecated-declarations \
 		-fno-omit-frame-pointer \
 		-fsigned-char \
 		-fcommon \
+		-std=gnu11 \
 	"
 	# want to put -fno-optimize-sibling-calls here but
 	# that option only works with gcc3+ it seems
