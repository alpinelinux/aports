maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=mapplauncherd
pkgver=4.2.16
pkgrel=0
pkgdesc="A daemon that helps to launch applications faster"
url="https://github.com/sailfishos/mapplauncherd"
arch="all"
license="LGPL-2.1-only"
depends_dev="
	dbus-dev
	elogind-dev
	glib-dev
	libcap-dev
	ninja
	"
makedepends="$depends_dev
	extra-cmake-modules
	doxygen
	"
subpackages="
	$pkgname-dev
	$pkgname-doc
	$pkgname-systemd
	"
source="https://github.com/sailfishos/mapplauncherd/archive/$pkgver/mapplauncherd-$pkgver.tar.gz
	gcc14.patch
	"
options="!check" # No tests

build() {
	cmake3.5 -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DINSTALL_SYSTEMD_UNITS=ON
	cmake --build build
	cmake --build build --target doc
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
