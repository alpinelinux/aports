5026afd1ad54d6c00f6da0173335ac759c561612566dcf9f32d080ccad9f5b4a5f1b608a1edad8e43a2224bf762562a62b813a737b593bd925c530d2a5d5d565  75_replace-pipes-quote-with-shlex-py313.patch
b2e520517ab1faa1467dc5bb0cecb5a191d428f0e270483aa00e536e20fdc1822b15fbd96b8a5f686b6718203614b21485150f8596ca96b00080ee681ad7f801  replace-use-of-mock-with-unittest-mock.patch
"
