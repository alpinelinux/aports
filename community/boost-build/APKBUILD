9b5ca8ea9457060dc21a81c13520e223c53a85e86dd376c08f5f0d66ea4eb5618d1706e8bffdfe5b1903be227276ad2365ea583a969c36b5dacaf328383c9f61  fix-var-defines-empty-define.patch
"
