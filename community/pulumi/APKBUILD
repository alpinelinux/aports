# Contributor: Hoang Nguyen <folliekazetani@protonmail.com>
# Contributor: Fraser Waters <frassle@gmail.com>
maintainer="Hoang Nguyen <folliekazetani@protonmail.com>"
pkgname=pulumi
pkgver=3.243.0
pkgrel=0
pkgdesc="Infrastructure as Code SDK"
url="https://pulumi.com/"
# Tests show that pulumi's plugin system doesn't work on any other platforms
arch="x86_64 aarch64"
license="Apache-2.0"
makedepends="go"
# pulumi-tool-testplugin script generated during TestPluginRunCommand test case is marked with shebang #!/bin/bash
checkdepends="tzdata bash"
subpackages="
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	$pkgname-language-go:_go
	$pkgname-language-nodejs:_nodejs
	$pkgname-language-pcl:_pcl
	$pkgname-language-python:_python
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/pulumi/pulumi/archive/v$pkgver.tar.gz"
options="net" # download Go modules

export PULUMI_SKIP_UPDATE_CHECK=true

build() {
	local _goldflags="-X github.com/pulumi/pulumi/sdk/v${pkgver%%.*}/go/common/version.Version=v$pkgver"
	mkdir -p "$builddir"/bin

	cd "$builddir"/sdk/go
	go generate ./...
	go build -C pulumi-language-go -v \
		-o "$builddir"/bin/pulumi-language-go \
		-ldflags "$_goldflags" \
		-tags grpcnotrace

	for lang in python bun nodejs pcl; do
		local _dir="$lang"
		[ $lang = "bun" ] && _dir="nodejs"

		cd "$builddir"/sdk/$_dir/cmd/pulumi-language-$lang
		go build -v \
			-o "$builddir"/bin/pulumi-language-$lang \
			-ldflags "$_goldflags" \
			-tags grpcnotrace
	done

	cd "$builddir"/pkg
	go build -v \
		-o "$builddir"/bin/pulumi \
		-ldflags "$_goldflags" \
		./cmd/pulumi

	cd "$builddir"
	for shell in bash fish zsh; do
		./bin/pulumi gen-completion $shell > pulumi.$shell
	done
}

check() {
	cd "$builddir"/pkg

	# TestGenerateProgram/empty-list-property executes `go mod edit` command in
	# the test directory
	export GOFLAGS="$GOFLAGS -modcacherw"

	# Help TestGoModEdit find sdk/go.mod
	ln -s "$builddir" "$srcdir"/pulumi
	# Help TestPulumiPromptRuntimeOptions find bin/pulumi-language-python-exec
	ln -s "$builddir"/sdk/python/cmd/pulumi-language-python-exec \
		"$builddir"/bin/pulumi-language-python-exec

	# TestInfoXTerm checks terminal capabilities
	local skip_tests="TestInfoXTerm"

	# TestProgram_RendersStreamingPulumiResources_BeforeCommit can't capture rendered output
	# in the live buffer without a proper terminal
	skip_tests="$skip_tests|TestProgram_RendersStreamingPulumiResources_BeforeCommit"

	# TestProjectName{Overrides,Defaults}, TestPulumiNewOrgTemplate,
	# TestRunNewYesWithTemplate depend on pulumi-language-yaml (circular dep)
	skip_tests="$skip_tests|TestProjectName*|TestPulumiNewOrgTemplate|TestRunNewYesWithTemplate"

	# TestReadingGitRepo uses travis repo config, results in branch name mismatch
	skip_tests="$skip_tests|TestReadingGitRepo"

	# TestTemplatePublishCmd_{RelativePathBug,ArchiveCreation}
	# []string(nil) does not contain ".gitignore"
	skip_tests="$skip_tests|TestTemplatePublishCmd*"

	# TestRunNewYesWithAILanguage connects to Pulumi Cloud (requires
	# PULUMI_ACCESS_TOKEN set)
	skip_tests="$skip_tests|TestRunNewYesWithAILanguage"

	# codegen/go/gen_program_test/batch1: panic: test timed out after 10m0s
	# backend/diy: "invalid cross-device link" errors
	# testing/pulumi-test-language: Test killed with quit: ran too long (11m0s)

	# PATH enables pulumi* executables to be found
	# PULUMI_ACCEPT=true is required for TestProgressEvents test
	# PULUMI_DISABLE_AUTOMATIC_PLUGIN_ACQUISITION is set to work around GitHub
	# API's rate limit (ref: https://github.com/pulumi/pulumi/issues/15900)
	# shellcheck disable=2046
	PATH="$PATH:$builddir/bin" \
		PULUMI_ACCEPT=true \
		PULUMI_DISABLE_AUTOMATIC_PLUGIN_ACQUISITION=true \
		go test -skip "$skip_tests" \
		$(go list ./... | \
		grep -v -E "github.com/pulumi/pulumi/pkg/v${pkgver%%.*}/(backend|codegen|testing)/(diy|dotnet|go|nodejs|python|pulumi-test-language)")
}

package() {
	install -Dm755 bin/pulumi -t "$pkgdir"/usr/bin/

	install -Dm644 pulumi.bash \
		"$pkgdir"/usr/share/bash-completion/completions/pulumi
	install -Dm644 pulumi.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/pulumi.fish
	install -Dm644 pulumi.zsh \
		"$pkgdir"/usr/share/zsh/site-functions/_pulumi
}

_go() {
	pkgdesc="$pkgdesc (Go language provider)"

	install -Dm755 "$builddir"/bin/pulumi-language-go -t "$subpkgdir"/usr/bin/
}

_nodejs() {
	pkgdesc="$pkgdesc (NodeJS language provider)"
	depends="cmd:node"

	install -Dm755 -t "$subpkgdir"/usr/bin/ \
		"$builddir"/bin/pulumi-language-bun \
		"$builddir"/bin/pulumi-language-nodejs \
		"$builddir"/sdk/nodejs/dist/pulumi-resource-pulumi-nodejs
}

_pcl() {
	pkgdesc="$pkgdesc (PCL language provider)"

	install -Dm755 "$builddir"/bin/pulumi-language-pcl -t "$subpkgdir"/usr/bin/
}

_python() {
	pkgdesc="$pkgdesc (Python language provider)"
	depends="python3"

	install -Dm755 -t "$subpkgdir"/usr/bin/ \
		"$builddir"/bin/pulumi-language-python \
		"$builddir"/sdk/python/cmd/pulumi-language-python-exec \
		"$builddir"/sdk/python/dist/pulumi-resource-pulumi-python
}

