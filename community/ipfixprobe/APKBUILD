# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=ipfixprobe
pkgver=5.6.0
pkgrel=0
pkgdesc="High-performance net flow exporter"
url="https://github.com/CESNET/ipfixprobe"
# armhf,armv7,ppc64le,x86: not supported, fails to build
arch="all !armhf !armv7 !ppc64le !x86"
license="BSD-3-Clause"
# python is needed for init/config2args.py
depends="
	py3-jsonschema
	py3-pyaml
	python3
	"
makedepends="
	bsd-compat-headers
	cesnet-telemetry-dev
	cmake
	libpcap-dev
	libtool
	libunwind-dev
	linux-headers
	lz4-dev
	openssl-dev
	patchelf
	samurai
	"
checkdepends="bash"
install="$pkgname.pre-install"
subpackages="
	$pkgname-input-pcap:_input_pcap
	$pkgname-process-experimental:_process_experimental
	$pkgname-openrc
	"
source="https://github.com/CESNET/ipfixprobe/archive/v$pkgver/ipfixprobe-$pkgver.tar.gz
	lib64.patch
	ipfixprobed.patch
	link0.conf.patch
	$pkgname.initd
	$pkgname.confd
	"
options="!check"  # tests requires nemea-framework-dev

_enable_dpdk=OFF
case "$CARCH" in
# dpdk is supported only on these architectures:
aarch64 | riscv64 | x86_64)
	_enable_dpdk=ON
	makedepends="$makedepends dpdk-dev"
	subpackages="$subpackages $pkgname-input-dpdk:_input_dpdk"
esac

build() {
	local crossopts
	[ "$CBUILD" != "$CHOST" ] \
		&& crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DENABLE_INPUT_PCAP=ON \
		-DENABLE_INPUT_DPDK="$_enable_dpdk" \
		-DENABLE_INPUT_NFB=OFF \
		-DENABLE_PROCESS_EXPERIMENTAL=ON \
		-DENABLE_NEMEA=OFF \
		-DENABLE_RPMBUILD=OFF \
		-DENABLE_TESTS="$(want_check && echo ON || echo OFF)" \
		$crossopts
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	cd "$pkgdir"

	rm -rf usr/lib/systemd

	mv etc/ipfixprobe/link0.conf.example etc/ipfixprobe/link0.conf

	install -D -m755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -D -m644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname

	# Workaround for https://github.com/CESNET/ipfixprobe/issues/329
	local mod; for mod in bstats phists pstats quic tls; do
		patchelf --set-rpath '$ORIGIN/../output' \
			"usr/lib/ipfixprobe/process/libipfixprobe-process-$mod.so"
	done
}

_input_dpdk() {
	pkgdesc="ipfixprobe high-speed input plugin using DPDK"
	depends="$pkgname=$pkgver-r$pkgrel"
	provides="$pkgname-dpdk=$pkgver-r$pkgrel"  # backward compatibility (Alpine <3.23)

	amove usr/lib/ipfixprobe/input/libipfixprobe-input-dpdk.so
}

_input_pcap() {
	pkgdesc="ipfixprobe input plugin for PCAP files and live capture"
	depends="$pkgname=$pkgver-r$pkgrel"

	amove usr/lib/ipfixprobe/input/libipfixprobe-input-pcap.so
}

_process_experimental() {
	pkgdesc="ipfixprobe experimental process plugins"
	depends="$pkgname=$pkgver-r$pkgrel"

	local name; for name in nettisa sip rtsp mpls ntp; do
		amove usr/lib/ipfixprobe/process/libipfixprobe-process-$name.so
	done
}

