# Contributor: Fabian Affolter <fabian@affolter-engineering.ch>
# Maintainer: Fabian Affolter <fabian@affolter-engineering.ch>
pkgname=py3-ujson
pkgver=5.12.0
pkgrel=0
pkgdesc="Fast Python JSON encoder and decoder"
url="https://github.com/ultrajson/ultrajson"
arch="all"
license="BSD-3-Clause AND TCL"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	python3-dev
	"
checkdepends="
	py3-pytest
	py3-tz
	"
source="https://pypi.io/packages/source/u/ujson/ujson-$pkgver.tar.gz"
builddir="$srcdir/ujson-$pkgver"

# secfixes:
#   5.12.0-r0:
#     - CVE-2026-32874
#     - CVE-2026-32875
#   5.4.0-r0:
#     - CVE-2022-31116
#     - CVE-2022-31117
#   5.2.0-r0:
#     - CVE-2021-45958

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1424f30338194edf934f90a5a59a66f119e3121ecb57c134738cfd5ef52fbda786d7c98c3bba33e4ffb7858357be0ab69376e44d687202522645ccf7fd829969  ujson-5.12.0.tar.gz
"
