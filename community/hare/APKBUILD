9b0e03fd1810ffe86dabbf25d493f9fa249e15ff244dc86e7478d5a4e6238227a084759492c810a1a65123c0b09fbb86075c601deb4ce4f431fecebee8196191  0001-hare-parse-fix-crash-on-invalid-input.patch
