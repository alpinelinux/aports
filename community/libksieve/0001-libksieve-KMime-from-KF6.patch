From 3640517c75c9796a6ed8df9b8fecbe504ed50370 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Sun, 19 Apr 2026 10:14:08 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt                                   | 6 +++++-
 src/ksievecore/CMakeLists.txt                    | 2 +-
 src/ksievecore/vacation/autotests/CMakeLists.txt | 2 +-
 src/ksieveui/CMakeLists.txt                      | 2 +-
 src/ksieveui/vacation/autotests/CMakeLists.txt   | 2 +-
 5 files changed, 9 insertions(+), 5 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 0873c989..24ee35d2 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -155,7 +155,11 @@ find_package(KF6NewStuff ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6Archive ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6SyntaxHighlighting ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6Sonnet ${KF_MIN_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KPim6IdentityManagementCore ${IDENTITYMANAGEMENT_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6MailTransport ${KMAILTRANSPORT_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6IMAP ${KIMAP_LIB_VERSION} CONFIG REQUIRED)
diff --git a/src/ksievecore/CMakeLists.txt b/src/ksievecore/CMakeLists.txt
index 4c75cc25..8cd92419 100644
--- a/src/ksievecore/CMakeLists.txt
+++ b/src/ksievecore/CMakeLists.txt
@@ -98,7 +98,7 @@ target_link_libraries(
         KF6::I18n
         KF6::CoreAddons
         KPim6::MailTransport
-        KPim6::Mime
+        KF6::Mime
         KPim6::IdentityManagementCore
 )
 
diff --git a/src/ksievecore/vacation/autotests/CMakeLists.txt b/src/ksievecore/vacation/autotests/CMakeLists.txt
index d6d9e0c8..4e68e72e 100644
--- a/src/ksievecore/vacation/autotests/CMakeLists.txt
+++ b/src/ksievecore/vacation/autotests/CMakeLists.txt
@@ -18,7 +18,7 @@ macro(add_ksievecore_vacation_test _source)
         KPim6KSieveCore
         Qt::Test
         KF6::I18n
-        KPim6::Mime
+        KF6::Mime
     )
 endmacro()
 
diff --git a/src/ksieveui/CMakeLists.txt b/src/ksieveui/CMakeLists.txt
index 8ab20987..dc2697a5 100644
--- a/src/ksieveui/CMakeLists.txt
+++ b/src/ksieveui/CMakeLists.txt
@@ -373,7 +373,7 @@ target_link_libraries(
     PRIVATE
         KPim6::Libkdepim
         KF6::Archive
-        KPim6::Mime
+        KF6::Mime
         KF6::IconThemes
         KF6::IconWidgets
         KPim6::IdentityManagementCore
diff --git a/src/ksieveui/vacation/autotests/CMakeLists.txt b/src/ksieveui/vacation/autotests/CMakeLists.txt
index 85911d0b..bda7f9e3 100644
--- a/src/ksieveui/vacation/autotests/CMakeLists.txt
+++ b/src/ksieveui/vacation/autotests/CMakeLists.txt
@@ -16,7 +16,7 @@ macro(add_vacation_test _source)
         KPim6KSieveUi
         Qt::Test
         KPim6::IdentityManagementCore
-        KPim6::Mime
+        KF6::Mime
         KF6::I18n
         KPim6::MailTransport
         KPim6::Libkdepim
