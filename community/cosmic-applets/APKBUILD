# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-applets
pkgver=1.0.12
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Applets for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-applets"
# 32-bit: https://gitlab.freedesktop.org/pipewire/pipewire-rs/-/issues/111
# s390x: nix
# riscv64: too slow to build
arch="all !armhf !armv7 !x86 !s390x !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	clang-libclang
	dbus-dev
	findutils
	just
	libinput-dev
	libxkbcommon-dev
	pipewire-dev
	pulseaudio-dev
"
subpackages="$pkgname-systemd"
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-applets/archive/refs/tags/epoch-$_upstreamver.tar.gz"
options="net !check"  # fetch dependencies, no tests
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
19eaf14c7e9245fa89f9f2d4717752d834b3f0f13cd330e02a5d6da5a443171f2995a78d1481cd616a55cf498edf5db3db140a068ccf15103710ef33ff9d80ce  cosmic-applets-1.0.12.tar.gz
"
