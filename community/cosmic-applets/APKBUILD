# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-applets
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Applets for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-applets"
# armv7, armhf: std::bad_alloc <- deadly signal
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !x86"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	clang-libclang
	dbus-dev
	findutils
	just
	libinput-dev
	libxkbcommon-dev
	pipewire-dev
	pulseaudio-dev
"
subpackages="$pkgname-systemd"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-applets/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
options="net !check"  # fetch dependencies, no tests
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
ff8e7d4077a3235d0f24db70541542ef4d0937117b56dee394e9e7df7985b502044db775371a6aecda5a142e38b0943a6af2e70a14aff2ca25010385c40261ce  cosmic-applets-1.4.0.tar.gz
"
