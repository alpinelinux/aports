From 7fd410af8ca79b1726ea22d79c73f3b3da16b2fb Mon Sep 17 00:00:00 2001
From: Stefan Hansson <newbyte@postmarketos.org>
Date: Sun, 5 Apr 2026 01:51:07 +0200
Subject: [PATCH] data: Also install nobuiltins desktop file

Fixes 04bebde2c60cff079aa7e7b3f61f457ec273650c

Closes https://gitlab.gnome.org/World/Phosh/phosh-mobile-settings/-/issues/116

Signed-off-by: Stefan Hansson <newbyte@postmarketos.org>
Part-of: <https://gitlab.gnome.org/World/Phosh/phosh-mobile-settings/-/merge_requests/337>
---
 data/meson.build | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/data/meson.build b/data/meson.build
index 1abc7077..3bb0cefa 100644
--- a/data/meson.build
+++ b/data/meson.build
@@ -7,6 +7,17 @@ desktop_file = i18n.merge_file(
   install_dir: join_paths(get_option('datadir'), 'applications'),
 )
 
+if get_option('tweaks-data-dir') != ''
+  desktop_file_nobuiltins = i18n.merge_file(
+    input: 'mobi.phosh.MobileSettings.nobuiltins.desktop.in',
+    output: 'mobi.phosh.MobileSettings.nobuiltins.desktop',
+    type: 'desktop',
+    po_dir: '../po',
+    install: true,
+    install_dir: join_paths(get_option('datadir'), 'applications'),
+  )
+endif
+
 appstream_file = i18n.merge_file(
   input: 'mobi.phosh.MobileSettings.metainfo.xml.in',
   output: 'mobi.phosh.MobileSettings.metainfo.xml',
-- 
GitLab

