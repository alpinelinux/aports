From f7040f00730d97fc09f5114f521d05421ffbcaf8 Mon Sep 17 00:00:00 2001
From: Achill Gilgenast <achill@achill.org>
Date: Sun, 5 Jul 2026 10:57:17 +0200
Subject: [PATCH] libpms: Include libpms_enum_sources to libpms_dep

Otherwise building samurai instead of ninja throws off a race condition error:

	libpms.h:18:10: fatal error: libpms-enum-types.h: No such file or directory
---
 libpms/meson.build | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/libpms/meson.build b/libpms/meson.build
index dfabf135..3d975c01 100644
--- a/libpms/meson.build
+++ b/libpms/meson.build
@@ -89,7 +89,7 @@ install_headers(
 )
 
 libpms_dep = declare_dependency(
-  sources: libpms_generated_sources,
+  sources: libpms_generated_sources + [libpms_enum_sources[1]],
   link_with: libpms_lib,
   include_directories: include_directories('.'),
   dependencies: libpms_deps,
-- 
