From 173c73d92eff43a5d2214d44cfebc61d13a2e2b2 Mon Sep 17 00:00:00 2001
From: Stefan Hansson <newbyte@postmarketos.org>
Date: Fri, 10 Apr 2026 20:19:52 +0200
Subject: [PATCH] data: Remove DBusActivatable from nobuiltins desktop file

As there is no matching nobuiltins service file this does not work.

Fixes 04bebde2c60cff079aa7e7b3f61f457ec273650c

Closes https://gitlab.gnome.org/World/Phosh/phosh-mobile-settings/-/issues/119

Signed-off-by: Stefan Hansson <newbyte@postmarketos.org>
---
 data/mobi.phosh.MobileSettings.nobuiltins.desktop.in | 1 -
 1 file changed, 1 deletion(-)

diff --git a/data/mobi.phosh.MobileSettings.nobuiltins.desktop.in b/data/mobi.phosh.MobileSettings.nobuiltins.desktop.in
index 4e70ae26..4348318b 100644
--- a/data/mobi.phosh.MobileSettings.nobuiltins.desktop.in
+++ b/data/mobi.phosh.MobileSettings.nobuiltins.desktop.in
@@ -7,7 +7,6 @@ Terminal=false
 Type=Application
 Categories=GNOME;GTK;Settings;
 StartupNotify=true
-DBusActivatable=true
 # Translators: Search terms to find this application. Do NOT translate or localize the semicolons. The list MUST also end with a semicolon.
 Keywords=Mobile;Preferences;MobileSettings;
 NotShowIn=Phosh;
-- 
