# Contributor: Newbyte <newbie13xd@gmail.com>
maintainer="team/phosh <newbie13xd@gmail.com>"
pkgname=phosh-mobile-settings
pkgver=0.54.0
pkgrel=3
pkgdesc="Settings app for mobile specific things"
url="https://gitlab.gnome.org/World/Phosh/phosh-mobile-settings"
arch="all !armhf"
license="GPL-3.0-or-later"
depends="
	phoc-schemas
	phosh-schemas
	"
makedepends="
	cellbroadcastd-dev
	desktop-file-utils
	feedbackd-dev
	glib-dev>=2.62
	gmobile-dev
	gnome-desktop-dev
	gsound-dev
	gtk4.0-dev
	json-glib-dev
	libadwaita-dev
	libportal-dev
	lm-sensors-dev
	meson
	phosh-dev
	pulseaudio-dev
	yaml-dev
	"
checkdepends="xvfb-run gsettings-desktop-schemas phosh"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	$pkgname-lang
	$pkgname-libs
	"
source="https://sources.phosh.mobi/releases/phosh-mobile-settings/phosh-mobile-settings-${pkgver/_/.}.tar.xz
	install-nobuiltins-desktop-file.patch
	no-dbus-activate.patch
	schema.patch
	"
builddir="$srcdir/$pkgname-${pkgver/_/.}"

build() {
	abuild-meson \
		-Db_lto=true \
		-Dtweaks-data-dir=/usr/share/postmarketos-tweaks \
		. output
	meson compile -C output
}

check() {
	xvfb-run meson test --print-errorlogs --suite unit -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild --skip-subprojects -C output
}

