# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=py3-ldap
_pkgname=python-ldap
pkgver=3.4.7
pkgrel=0
pkgdesc="Python modules for implementing LDAP clients"
url="https://github.com/python-ldap/python-ldap"
arch="all"
license="Python-2.0 AND MIT"
depends="py3-asn1 py3-asn1-modules"
makedepends="
	openldap-dev
	py3-gpep517
	py3-setuptools
	python3-dev
	"
checkdepends="
	openldap
	openldap-back-mdb
	openldap-clients
	openldap-overlay-syncprov
	py3-pytest
	py3-sortedcontainers
	"
provides="py3-pyldap=$pkgver-r$pkgrel"  # for backward compatibility with Alpine <3.19
subpackages="$pkgname-pyc"
source="https://github.com/$_pkgname/$_pkgname/archive/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$_pkgname-$pkgver"

# secfixes:
#   3.4.5-r0:
#     - CVE-2025-61911
#     - CVE-2025-61912

case "$CARCH" in
	# FIXME: Some tests fail.
	s390x) options="!check";;
esac

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl

	# Suppress PytestUnraisableExceptionWarning ("Exception ignored while calling deallocator") by disabling warnings plugin
	.testenv/bin/python3 -m pytest -p no:warnings
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
ecf20c6a23b32fe21cde969407287f415a091d15dd0de49d986472de23de35e2d9dd590ceb7b26353e8eb3d4f2ee4fd9c9d8c9bd6c600cd45d80ab73bcd4c8df  python-ldap-3.4.7.tar.gz
"
