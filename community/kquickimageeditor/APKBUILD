maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=kquickimageeditor
pkgver=0.6.1
pkgrel=0
pkgdesc="Simple image editor for QtQuick applications"
url="https://invent.kde.org/libraries/kquickimageeditor"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="BSD-2-Clause AND LGPL-2.1-or-later"
depends_dev="
	kconfig-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	qt6-qtdeclarative-private-dev
	samurai
	"
subpackages="$pkgname-dev"
source="https://download.kde.org/stable/kquickimageeditor/kquickimageeditor-$pkgver.tar.xz"
options="!check" # No tests

build() {
	cmake -B build -G Ninja \
		-DBUILD_WITH_QT6=ON \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
9657c907d875be00790693e086225e3f83e836e52d3f2ecd7ebe44625dd69bc48d09c79b796b98fce77e8a21c5c28387a34259aa4d2b7eba63f39c58f72a9a05  kquickimageeditor-0.6.1.tar.xz
"
