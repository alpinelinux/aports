# Contributor: WrenIX <dev.alpine@wrenix.eu>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-wallpapers
pkgver=1.3.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Wallpapers for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-wallpapers"
# riscv64: too slow to build
arch="noarch !riscv64"
license="GPL-3.0-or-later AND CC-BY-SA-4.0"
options="!check"  # no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-wallpapers/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
