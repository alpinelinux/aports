# Maintainer: Willow Barraco <contact@willowbarraco.fr>
pkgname=hare-xkb
pkgver=0.26.0.0
pkgrel=0
pkgdesc="Hare interface to the xkbcommon library"
url="https://git.sr.ht/~stacyharper/hare-xkb"
# hare only supports x86_64 aarch64 riscv64
arch="noarch !armhf !armv7 !loongarch64 !ppc64le !s390x !x86"
license="MPL-2.0"
depends="libxkbcommon-dev"
makedepends="hare"
source="
	$pkgname-$pkgver.tar.gz::https://git.sr.ht/~stacyharper/hare-xkb/archive/$pkgver.tar.gz
"

build() {
	make -j1 PREFIX=/usr
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
}

sha512sums="
