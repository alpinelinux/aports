# Contributor: Peter Bui <pnutzh4x0r@gmail.com>
# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=py3-asn1
pkgver=0.6.4
pkgrel=0
pkgdesc="Python3 ASN1 library"
url="https://github.com/pyasn1/pyasn1"
arch="noarch"
license="BSD-2-Clause"
depends="python3"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/pyasn1/pyasn1-$pkgver.tar.gz"
builddir="$srcdir/pyasn1-$pkgver"

replaces="py-asn1" # Backwards compatibility
provides="py-asn1=$pkgver-r$pkgrel" # Backwards compatibility

# secfixes:
#   0.6.4-r0:
#     - CVE-2026-59886
#     - CVE-2026-59885
#     - CVE-2026-59884

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
ce04b28d42d41fc8fa20608b773bf6691b46427f73f3fc3fb1a81c06996133bd77dcb2b4f6ba8213e27222d4203adc90adf64eeb7096ec82bc7df6e2f307657d  pyasn1-0.6.4.tar.gz
"
