# Contributor: Danct12 <danct12@disroot.org>
maintainer="Jakko <jahau@rocketmail.com>"
pkgname=onboard
_pkgver=1.4.3-7
pkgver=${_pkgver/-/.}
pkgrel=0
pkgdesc="On-screen keyboard useful on tablet PCs or for mobility impaired users"
url="https://github.com/onboard-osk/onboard"
license="GPL-3.0-only"
arch="all"
depends="
	gsettings-desktop-schemas
	hunspell
	iso-codes
	librsvg
	ncurses
	py3-cairo
	py3-dbus
	py3-gobject3
	python3
	"
makedepends="
	bash
	bash-dev
	dconf-dev
	eudev-dev
	gtk+3.0-dev
	hunspell-dev
	intltool
	libcanberra-dev
	libxkbfile-dev
	py3-distutils-extra
	py3-gpep517
	py3-setuptools
	py3-wheel
	python3-dev
	"
source="$pkgname-$_pkgver.tar.gz::https://github.com/onboard-osk/onboard/archive/refs/tags/$_pkgver.tar.gz
	glibc-musl-error.patch
	"
builddir="$srcdir/$pkgname-$_pkgver"
options="!check" # cannot open display
subpackages="$pkgname-doc $pkgname-lang $pkgname-pyc"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

