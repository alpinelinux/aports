# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-app-library
pkgver=1.0.12
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Application launcher for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-applibrary"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	cargo-auditable
	just
	libxkbcommon-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-applibrary/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
315b6045b98404be88affdf9029dd97269d0dd1802a5721d3bd43ccf988ce7afd9b8df70930d00452a534a551bc5d77111d044e5e8f0dfc6790902bc6ef95a42  cosmic-app-library-1.0.12.tar.gz
"
