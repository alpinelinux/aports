# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=py3-pyasynchat
pkgver=1.0.5
pkgrel=0
# _pkgreal is used by apkbuild-pypi to find modules at PyPI
_pkgreal=pyasynchat
pkgdesc="Make asynchat available for Python 3.12 onwards"
url="https://pypi.org/project/pyasynchat/"
arch="noarch"
license="PSF-2.0"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
depends="py3-pyasyncore"
checkdepends="py3-pytest python3-tests"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/pyasynchat/pyasynchat-$pkgver.tar.gz"
builddir="$srcdir/$_pkgreal-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
bc6d49c52f9c1823c07da768b360a60eac38c97dc1f1501226dde56b2431de959c30b430f90c67dab2e0c2ef5d2c885d0abf28599360fdb362645aa09bd08011  pyasynchat-1.0.5.tar.gz
"
