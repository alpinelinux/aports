+def _parse_header(line):
+    """
+    Parse a Content-type like header, returning the value and a dict of parameters.
+
+    This is a replacement for the deprecated cgi.parse_header(), which was
+    removed in Python 3.13.
+    """
+    msg = Message()
+    msg["content-type"] = line
+    params = msg.get_params()
+    if params:
+        # First item is the value itself (e.g. 'text/html')
+        key = params[0][0]
+        pdict = dict(params[1:])
+        return key, pdict
+    return line, {}
+
