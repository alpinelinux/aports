pkgname=libopusenc
pkgver=0.3
pkgrel=0
pkgdesc="Library for encoding .opus audio files and live streams"
url="https://opus-codec.org"
arch="all"
license="BSD-3-Clause"
makedepends="opus-dev"
subpackages="$pkgname-dev $pkgname-doc"
source="https://downloads.xiph.org/releases/opus/libopusenc-$pkgver.tar.gz"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
