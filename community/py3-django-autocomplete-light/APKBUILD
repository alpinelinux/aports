# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-django-autocomplete-light
pkgver=4.0.1
pkgrel=0
# Upstream forgot to tag release
_gittag=48a48e09b5279036fa91a80f23e1193d2c6eceb5
#_pkgreal is used by apkbuild-pypi to find modules at PyPI
_pkgreal=django-autocomplete-light
pkgdesc="Fresh autocompletes for Django"
url="https://pypi.python.org/project/django-autocomplete-light"
arch="noarch"
license="MIT"
depends="
	py3-django-querysetsequence
	py3-django-taggit
	py3-django-extensions
	py3-django-nested-admin
	"
checkdepends="
	py3-pytest
	py3-flake8
	py3-pep8-naming
	py3-mccabe
	py3-pytest-django
"
makedepends="py3-setuptools py3-gpep517 py3-wheel"
source="$pkgname-$_gittag.tar.gz::https://github.com/yourlabs/django-autocomplete-light/archive/$_gittag.tar.gz"
builddir="$srcdir/$_pkgreal-$_gittag"
options="!check" # depends on py3-selenium, repackaged chrome
subpackages="$pkgname-pyc"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	cd "$builddir"/test_project
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer "$builddir"/.dist/*.whl
	DJANGO_SETTINGS_MODULE=settings.base .testenv/bin/python3 -m pytest -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
a3c62191f2ec6c174cd163adf307574fef341677b4453a0228aa6bcc0b36a32e3b77b0b0b4b654ae9247c84c3bbf52158ddbc5c26b40350fa0f47865d18c18ab  py3-django-autocomplete-light-48a48e09b5279036fa91a80f23e1193d2c6eceb5.tar.gz
"
