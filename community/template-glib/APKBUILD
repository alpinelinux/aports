# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=template-glib
pkgver=3.40.0
pkgrel=0
# NOTE: Upgrade only to even-numbered versions (e.g. 1.18.x, 1.20.x)!
pkgdesc="library for template expansion which supports calling into GObject Introspection from templates"
url="https://gitlab.gnome.org/GNOME/template-glib"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	bison
	flex
	glib-dev
	gobject-introspection-dev
	meson
	vala
	"
subpackages="$pkgname-dev $pkgname-lang"
source="https://download.gnome.org/sources/template-glib/${pkgver%.*}/template-glib-$pkgver.tar.xz"

build() {
	abuild-meson \
		-Db_lto=true \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
6d7d77d8bb2fdfcf23334941352589c1450443781d4b927d58a84000504939038d0098efa44642c3266b5394063110524decc6b5bbe352dffde8bf80ad5b2fa7  template-glib-3.40.0.tar.xz
"
