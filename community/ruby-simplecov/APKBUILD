# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=ruby-simplecov
_gemname=${pkgname#ruby-}
pkgver=1.0.2
pkgrel=0
pkgdesc="Code coverage for Ruby"
url="https://rubygems.org/gems/simplecov"
arch="noarch"
license="MIT"
depends="ruby"
checkdepends="ruby-rake ruby-bundler ruby-rspec"
depends="ruby-docile ruby-simplecov-html ruby-simplecov_json_formatter"
source="$pkgname-$pkgver.tar.gz::https://github.com/simplecov-ruby/simplecov/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/$_gemname-$pkgver"
subpackages="$pkgname-doc"
options="!check" #depends on rubocop

prepare() {
	default_prepare

	sed -i '/spec.signing_key/d' $_gemname.gemspec
}

build() {
	gem build $_gemname.gemspec
}

check() {
	rake test
}

package() {
	local gemdir="$pkgdir$(ruby -e 'puts Gem.default_dir')"

	gem install --local \
		--install-dir "$gemdir" \
		--ignore-dependencies \
		--no-document \
		--verbose \
		$_gemname

	mkdir -p "$pkgdir"/usr/share/doc/"$pkgname"/
	install -Dm644 "$builddir"/doc/*.md "$pkgdir"/usr/share/doc/"$pkgname"/

	rm -r "$gemdir"/cache \
		"$gemdir"/build_info

	cd "$gemdir/gems/$_gemname-$pkgver"
	rm -r README.md doc

	install -Dm644 "$builddir"/LICENSE "$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE
}

sha512sums="
b7575ba69e753aca2b9e35400d660702f8f63072da3b4ffbec917ff681f89aa5c0affc5f482e57bc3baeb42129991d3f3debd67c0610b955a465ef2396b76dad  ruby-simplecov-1.0.2.tar.gz
"
