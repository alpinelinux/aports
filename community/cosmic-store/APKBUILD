# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-store
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="App store for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-store"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armhf !armv7 !riscv64 !x86"
license="GPL-3.0-only"
depends="
	cosmic-icons
"
makedepends="
	appstream-dev
	cargo-auditable
	flatpak-dev
	glib-dev
	just
	libxkbcommon-dev
	openssl-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-store/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
c6e6055e336948fc6e83198d0447adb1fdd54bbfa480e4c0023cf757719ffe5492fd0a0cb0e60aeb35994fdaa5167c07814ca95e0a39c8fe9b024d13f24030f0  cosmic-store-1.4.0.tar.gz
"
