maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-findpython
pkgver=0.8.0
pkgrel=0
pkgdesc="Utility to find python versions on your system"
url="https://github.com/frostming/findpython/"
arch="all"
license="MIT"
depends="
	py3-packaging
	py3-platformdirs
	"
makedepends="
	py3-gpep517
	py3-pdm-backend
	py3-setuptools
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/frostming/findpython/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/findpython-$pkgver"

build() {
	export PDM_BUILD_SCM_VERSION=$pkgver
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
caabc85d8a1c51fd29d3dac548d68f15e412f5954958bf86a880c3a4d7bdc6aec961b6e1142254a6ba02a0e44591ac590f3e3a6da01cbe86b4beaf4e15623483  py3-findpython-0.8.0.tar.gz
"
