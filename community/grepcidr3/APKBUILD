pkgname=grepcidr3
pkgver=3.0.3
pkgrel=0
pkgdesc="High performance search for IP addresses and CIDR ranges"
url="https://github.com/jrlevine/grepcidr3"
arch="all"
options="!check" # no tests
license="GPL-2.0"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/jrlevine/grepcidr3/archive/refs/tags/$pkgver.tar.gz
fix-makefile.patch"

build() {
	make
}

package() {
	mkdir -p "$pkgdir"/usr/bin
	mkdir -p "$pkgdir"/usr/share/man/man1
	make INSTALLDIR="$pkgdir"/usr install
}

