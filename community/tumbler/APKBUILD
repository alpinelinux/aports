# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=tumbler
pkgver=4.20.1
pkgrel=0
pkgdesc="D-Bus thumbnail service"
url="https://gitlab.xfce.org/xfce/tumbler"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	curl-dev
	ffmpegthumbnailer-dev
	gst-plugins-base-dev
	libgepub-dev
	libgsf-dev
	libjpeg-turbo-dev
	libopenraw-dev
	libxfce4util-dev
	poppler-dev
	xfce4-dev-tools
	"
subpackages="$pkgname-dev $pkgname-lang $pkgname-doc"
source="https://archive.xfce.org/src/xfce/tumbler/${pkgver%.*}/tumbler-$pkgver.tar.bz2"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--localstatedir=/var
	make
}

package() {
	make DESTDIR="$pkgdir" install
	rm -r "$pkgdir"/usr/lib/systemd
}

sha512sums="
b4d4f92bcfaadcd9c8c9c78ac577ee4cfaf898895ebba0afde735bb5cf3cabc1a8a4d0a2fb6c382d3e8636ec70b22fa1b35d3e48e7ed215bdc4c3f86e543e018  tumbler-4.20.1.tar.bz2
"
