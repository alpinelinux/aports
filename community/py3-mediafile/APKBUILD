# Contributor: Sören Tempel <soeren+alpine@soeren-tempel.net>
# Maintainer: Sören Tempel <soeren+alpine@soeren-tempel.net>
pkgname=py3-mediafile
pkgver=0.17.0
pkgrel=0
pkgdesc="Simple interface to the metadata tags for many audio file formats"
url="https://github.com/beetbox/mediafile"
arch="noarch"
license="MIT"
depends="python3 py3-mutagen py3-filetype"
makedepends="py3-gpep517 py3-flit-core py3-installer"
checkdepends="py3-poetry-core py3-pytest"
subpackages="$pkgname-pyc"
# XXX: release on pypi does not include the tests.
source="$pkgname-$pkgver.tar.gz::https://github.com/beetbox/mediafile/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/mediafile-$pkgver"

build() {
	gpep517 build-wheel \
		--output-fd 3 3>&1 >&2 \
		--wheel-dir .dist
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/mediafile-*.whl
}

sha512sums="
743fb98cf68d64daf3ee32a5a2d12b8664b39519b248eb44fdf7f45cbee9de95e77cfe9ce9159d770d4050d4f77bca197148317e25b30f25cc30903adcc51bb7  py3-mediafile-0.17.0.tar.gz
"
