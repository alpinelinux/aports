pkgname=virglrenderer
pkgver=1.3.0
pkgrel=0
pkgdesc="A virtual 3D GPU library, that allows the guest operating system to use the host GPU to accelerate 3D rendering"
url="https://docs.mesa3d.org/drivers/virgl/"
options="!check"
arch="all"
license="MIT"
makedepends="
	check-dev
	libdrm-dev
	libepoxy-dev
	libva-glx-dev
	mesa-dev
	meson
	py3-yaml
	python3
	vulkan-loader-dev
"
subpackages="$pkgname-dev"
source="https://gitlab.freedesktop.org/virgl/virglrenderer/-/archive/virglrenderer-$pkgver/virglrenderer-virglrenderer-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgname-$pkgver"

# secfixes:
#   0.10.3-r0:
#     - CVE-2022-0135
#     - CVE-2022-0175
#   0.8.1-r0:
#     - CVE-2019-18388
#     - CVE-2019-18389
#     - CVE-2019-18390
#     - CVE-2019-18391

build() {
	case "$CARCH" in
	arm*|x86)	_renderers="" ;;
	ppc64le)	_renderers="-Ddrm-renderers=amdgpu-experimental" ;;
	*)		_renderers="-Ddrm-renderers=amdgpu-experimental,panfrost-experimental,asahi,msm,i915-experimental" ;;
	esac

	abuild-meson \
		-Db_lto=true \
		-Dtests=true \
		-Dvideo=true \
		-Dvenus=true \
		$_renderers \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

