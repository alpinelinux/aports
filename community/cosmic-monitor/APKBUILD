# Contributor: WrenIX <dev.alpine@wrenix.eu>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-monitor
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="System Monitor for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-monitor"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !x86"
license="GPL-3.0-only"
makedepends="
	cargo-auditable
	just
	libxkbcommon-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-monitor/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
1123a6bf615e23d80b3230aed42e9ff9b728cc3d868edbab8a7ff8734a24febbd0dd469830658858832e5d0d006201342dc07ad04e65034e0b413d2f0935a7ec  cosmic-monitor-1.4.0.tar.gz
"
