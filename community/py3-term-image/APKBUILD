5f78d5da304bed6d1e9e5e5fd0a372b43fe85fc149d9ce2ed2d9f7f467bd4c014957080b06677458310d86e663f1e4228fed168ce0663014a3e84f6a64069b39  pillow-12.1.0.patch
"
