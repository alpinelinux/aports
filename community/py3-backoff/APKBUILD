# Contributor: lauren n. liberda <lauren@selfisekai.rocks>
maintainer="lauren n. liberda <lauren@selfisekai.rocks>"
pkgname=py3-backoff
pkgver=2.3.1
pkgrel=0
pkgdesc="Function decorators for configurable backoff and retry"
url="https://github.com/python-backoff/backoff"
arch="noarch"
license="MIT"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-hatchling
	"
checkdepends="
	py3-pytest-asyncio
	py3-responses
	pytest
	"
subpackages="$pkgname-pyc $pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/python-backoff/backoff/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/backoff-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	install -Dm755 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
8a9dbf8290b94f7b3a655f119c5012a7c62653dcc9321a4760566574f4e6364a0971c72e05fc3e539c4599b02d67fb22c491ec25a0f4e785191701186a86a9a4  py3-backoff-2.3.1.tar.gz
"
