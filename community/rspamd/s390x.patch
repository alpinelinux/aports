From 104eecd3b2d6546f0167fdab754ee17391764f57 Mon Sep 17 00:00:00 2001
From: Duncan Bellamy <dunk@denkimushi.com>
Date: Thu, 11 Jun 2026 19:37:18 +0100
Subject: [PATCH] [Fix] unit test checks upstream rate limit state using a
 custom fake_clock

under a mock environment where the event loop (ev_run()) is never actually executed.
---
 test/rspamd_test_fake_time.hxx | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/test/rspamd_test_fake_time.hxx b/test/rspamd_test_fake_time.hxx
index 2aa7704528..627849314a 100644
--- a/test/rspamd_test_fake_time.hxx
+++ b/test/rspamd_test_fake_time.hxx
@@ -70,11 +70,17 @@ public:
 			seconds = 0.0;
 		}
 		now_ += seconds;
+		if (loop_) {
+			ev_now_resync(loop_);
+		}
 	}
 
 	void set(double t)
 	{
 		now_ = t;
+		if (loop_) {
+			ev_now_resync(loop_);
+		}
 	}
 
 	double now() const
