# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-saltext-incus
_pkgname=saltext_incus
pkgver=1.0.1
pkgrel=0
pkgdesc="Salt Extension that adds support for managing Incus nodes through salt"
url="https://github.com/salt-extensions/saltext-incus"
arch="noarch"
license="Apache-2.0"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/${_pkgname:0:1}/$_pkgname/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/${_pkgname//./_}-$pkgver"
options="!check" # checks require a saltstack environment

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
4975eb17da407115dd75884d755aaecb234df8cac9797fe9202d66933014349e1f741d63aa69442028c7415166817fe9a0efec6339c9037caab7acfcf0da51f5  saltext_incus-1.0.1.tar.gz
"
