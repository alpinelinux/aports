# Maintainer: Michał Polański <michal@polanski.me>
pkgname=gifski
pkgver=1.34.0
pkgrel=3
pkgdesc="Highest-quality GIF encoder based on pngquant"
url="https://gif.ski/"
license="AGPL-3.0-or-later"
arch="all"
makedepends="cargo clang21-dev ffmpeg-dev cargo-auditable"
source="https://github.com/ImageOptim/gifski/archive/$pkgver/gifski-$pkgver.tar.gz
	ffmpeg8.patch
	ffmpeg-next-crate-8.1.0.patch
	fix-tests.patch
	"
options="net" # fetch dependencies

_features="--features=video"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release $_features
}

check() {
	cargo test --frozen $_features
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin/
}

