# Contributor: Zach DeCook <zachdecook@librem.one>
maintainer="Zach DeCook <zachdecook@librem.one>"
pkgname=hyprutils
pkgver=0.13.1
pkgrel=0
pkgdesc="Hyprland utilities library used across the ecosystem"
url="https://github.com/hyprwm/hyprutils"
arch="all"
license="BSD-3-Clause"
source="
	https://github.com/hyprwm/hyprutils/archive/v$pkgver/hyprutils-v$pkgver.tar.gz
	"
makedepends="cmake samurai pixman-dev gtest-dev"
subpackages="$pkgname-doc $pkgname-dev"
options="!check" # Building with tests causes superfluous stderr output everywhere

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_BUILD_TYPE=None # Need to build Debug type to get tests
	cmake --build build
}

check() {
	cd build
	ctest
}

package() {
	DESTDIR="$pkgdir" cmake --install build
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}


sha512sums="
d090c2e30fe20afea6290f63a8ab4f695350cd61ab02e85b32e19fde02a928388883373dd1539135596091cbeaaac2d7cb2738173bb87c4d770584032f5f7b5a  hyprutils-v0.13.1.tar.gz
"
