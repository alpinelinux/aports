# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=etcd
pkgver=3.6.10
pkgrel=1
pkgdesc="A highly-available key value store for shared configuration and service discovery"
url="https://github.com/etcd-io/etcd"
license="Apache-2.0"
arch="all"
makedepends="go bash"
install="$pkgname.pre-install"
provides="etcd-api"
provider_priority=2
options="net chmod-clean"
pkgusers="etcd"
pkggroups="etcd"
subpackages="$pkgname-doc $pkgname-ctl $pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/etcd-io/etcd/archive/refs/tags/v$pkgver.tar.gz
	$pkgname.yaml
	$pkgname.confd
	$pkgname.initd
	"

# secfixes:
#   3.6.10-r0:
#     - CVE-2026-33343
#     - CVE-2026-33413
#   3.6.8-r0:
#     - CVE-2025-47914
#     - CVE-2025-58181
#     - CVE-2025-61726
#     - CVE-2025-61731
#     - CVE-2025-61732

build() {
	export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
	export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
	export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"
	export GOFLAGS="$GOFLAGS -mod=mod"
	export CGO_ENABLED=1
	export FORCE_HOST_GO=1

	GIT_SHA="$(git ls-remote https://github.com/coreos/etcd.git refs/tags/v$pkgver | awk '{print $1}')" \
		make
}

package() {
	install -d -o "$pkgusers" -g "$pkggroups" -m 700 "$pkgdir"/var/lib/$pkgname
	install -Dm755 bin/etcd "$pkgdir"/usr/bin/etcd
	install -Dm755 bin/etcdctl "$pkgdir"/usr/bin/etcdctl
	install -Dm644 $srcdir/$pkgname.yaml "$pkgdir"/etc/etcd/conf.yml
	install -Dm644 $srcdir/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
	install -Dm755 $srcdir/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

ctl() {
	pkgdesc="A command-line client for etcd"
	amove usr/bin/etcdctl
}

