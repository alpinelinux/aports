# Contributor: Fabian Affolter <fabian@affolter-engineering.ch>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=asciinema
pkgver=3.2.0
pkgrel=0
pkgdesc="Command line recorder for the asciinema.org service"
url="https://github.com/asciinema/asciinema"
arch="all"
license="GPL-3.0-or-later"
makedepends="cargo cargo-auditable"
checkdepends="python3"
subpackages="
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/asciinema/asciinema/archive/v$pkgver.tar.gz"
options="net" # cargo fetch

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	ASCIINEMA_GEN_DIR="$builddir/gen" \
		cargo auditable build --release --frozen
}

check() {
	cargo test --release --frozen
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin/

	install -Dm644 gen/man/*.1 -t "$pkgdir"/usr/share/man/man1/

	install -Dm644 gen/completion/$pkgname.bash \
		"$pkgdir"/usr/share/bash-completion/completions/$pkgname
	install -Dm644 gen/completion/$pkgname.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/$pkgname.fish
	install -Dm644 gen/completion/_$pkgname \
		"$pkgdir"/usr/share/zsh/site-functions/_$pkgname
}

sha512sums="
b4da704414877e5b5bb3abb51d5b9d517b55c84d52d663e0e36afe28cf155cee0674947302264c68e513fe58e6b7194936494f27080d41392141e5c599d2ffc8  asciinema-3.2.0.tar.gz
"
