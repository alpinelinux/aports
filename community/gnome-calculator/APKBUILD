# Contributor: Rasmus Thomsen <oss@cogitri.dev>
maintainer="team/gnome <achill@achill.org>"
pkgname=gnome-calculator
pkgver=50.0
pkgrel=0
pkgdesc="Calculator for solving mathematical equations"
url="https://apps.gnome.org/Calculator"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	blueprint-compiler
	glib-dev
	gtksourceview5-dev
	gtk4.0-dev
	itstool
	libadwaita-dev
	libgee-dev
	libsoup3-dev
	libxml2-dev
	meson
	mpc1-dev
	mpfr-dev
	vala
	"
subpackages="$pkgname-devhelp $pkgname-doc $pkgname-lang $pkgname-dev"
source="https://download.gnome.org/sources/gnome-calculator/${pkgver%%.*}/gnome-calculator-$pkgver.tar.xz"

build() {
	abuild-meson \
		-Db_lto=true \
		. output
	meson compile -C output
}

check() {
	# loongarch64, armhf, ppc64le and riscv64 timeouted number test with standard timeout
	meson test -t 10 --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
96db948eca34b2c9033b6aee87b60049b35fff6cf42afcb22481b0144e123ebd362fc7fe711ce8198964618ed6d4538f9cfeeaf3b6085a5a4d119137621cddaf  gnome-calculator-50.0.tar.xz
"
