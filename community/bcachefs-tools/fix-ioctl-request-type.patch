From 9e7f1300fe229332867442739dbe2dd7e75cd451 Mon Sep 17 00:00:00 2001
From: Robert Mongold <rtmongold@gmail.com>
Date: Mon, 27 Apr 2026 16:43:00 +0000
Subject: [PATCH] wrappers/bdev: infer ioctl request type

On musl targets, libc::ioctl expects request type libc::Ioctl (i32),
while BLKROTATIONAL resolves to c_ulong. Cast using `as _` so the
request value is coerced to the platform-specific type.
---
 src/wrappers/bdev.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/wrappers/bdev.rs b/src/wrappers/bdev.rs
--- a/src/wrappers/bdev.rs
+++ b/src/wrappers/bdev.rs
@@ -126,7 +126,7 @@ pub fn nonrot(fd: RawFd) -> bool {
     // md, loop devices, etc. uniformly.
     const BLKROTATIONAL: libc::c_ulong = 0x127E;
     let mut rotational: u16 = 0;
-    let ret = unsafe { libc::ioctl(fd, BLKROTATIONAL, &mut rotational) };
+    let ret = unsafe { libc::ioctl(fd, BLKROTATIONAL as _, &mut rotational) };
     ret == 0 && rotational == 0
 }
