-
-private:
-    TesseractRuntimeLoader();
-    ~TesseractRuntimeLoader();
-
-    bool loadLocked();
-    bool resolveSymbols();
-    bool validateLoadedVersion();
-    QStringList candidateLibraryNames() const;
-
-    Q_DISABLE_COPY_MOVE(TesseractRuntimeLoader)
-
-    mutable QMutex m_mutex;
-    bool m_loaded = false;
-    QLibrary m_library;
-    TesseractRuntimeApi m_api;
-};
