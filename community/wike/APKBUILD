maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=wike
_pkgname=Wike
pkgver=3.2.1
pkgrel=0
pkgdesc="Wikipedia Reader for the GNOME Desktop"
url="https://apps.gnome.org/Wike"
arch="noarch"
license="GPL-3.0-or-later"
depends="
	libadwaita
	py3-gobject3
	py3-requests
	webkit2gtk-6.0
	"
makedepends="
	desktop-file-utils
	meson
	glib-dev
	"
checkdepends="appstream"
subpackages="$pkgname-lang"
source="$pkgname-$pkgver.tar.gz::https://github.com/hugolabe/Wike/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

build() {
	abuild-meson . output
	meson compile -C output
}

check() {
	meson test -C output
}

package() {
	meson install -C output --destdir "$pkgdir"
}

