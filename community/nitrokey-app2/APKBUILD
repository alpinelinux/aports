maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=nitrokey-app2
pkgver=2.7.0
pkgrel=0
pkgdesc="Nitrokey management application"
url="https://github.com/Nitrokey/nitrokey-app2"
# armhf blocked by qt6-qtdeclarative -> py3-pyside6
arch="all !armhf"
license="Apache-2.0"
depends="
	py3-pynitrokey
	py3-pyside6
	py3-usb-monitor
	"
makedepends="
	poetry
	py3-flit-core
	py3-gpep517
	py3-installer
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/Nitrokey/nitrokey-app2/archive/refs/tags/v$pkgver.tar.gz"
options="!check" # No tests

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
aac3c55017c35fa322dc6b115ec1f82ed77f97a670995b043f887cc68668c67af301adfc5a27d6eee04fe144c7c7eae5917ef53aa1d9457df461b7dce77a7562  nitrokey-app2-2.7.0.tar.gz
"
