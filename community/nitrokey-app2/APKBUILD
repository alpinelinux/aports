maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=nitrokey-app2
pkgver=2.6.0
pkgrel=0
pkgdesc="Nitrokey management application"
url="https://github.com/Nitrokey/nitrokey-app2"
# armhf blocked by qt6-qtdeclarative -> py3-pyside6
arch="all !armhf"
license="Apache-2.0"
depends="
	py3-pynitrokey
	py3-pyside6
	py3-usb-monitor
	"
makedepends="
	poetry
	py3-flit-core
	py3-gpep517
	py3-installer
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/Nitrokey/nitrokey-app2/archive/refs/tags/v$pkgver.tar.gz"
options="!check" # No tests

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
310f0a0402d50b63b4976933343f56aeb5e11e4f59eed0b6b3fa2df0dc28b71fa6a375cded25f8e6d5980714a7f940fbdd52c4b78f2dcfdef8b7c9b3d86c6af0  nitrokey-app2-2.6.0.tar.gz
"
