maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=nitrokey-app2
pkgver=2.7.1
pkgrel=0
pkgdesc="Nitrokey management application"
url="https://github.com/Nitrokey/nitrokey-app2"
# armhf blocked by qt6-qtdeclarative -> py3-pyside6
arch="all !armhf"
license="Apache-2.0"
depends="
	py3-pynitrokey
	py3-pyside6
	py3-usb-monitor
	"
makedepends="
	poetry
	py3-flit-core
	py3-gpep517
	py3-installer
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/Nitrokey/nitrokey-app2/archive/refs/tags/v$pkgver.tar.gz"
options="!check" # No tests

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
533ae921fc3f8df29b3aebcfea5b151a18082351731ce96c72ca9ca706718caa918da3812cfcec7c9648fba8f26efc3287d7e87658ee0200517a61e7a30bcd77  nitrokey-app2-2.7.1.tar.gz
"
