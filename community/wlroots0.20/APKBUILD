# Contributor: Henrik Riomar <henrik.riomar@gmail.com>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=wlroots0.20
pkgver=0.20.1
_pkgver=${pkgver/_/-}
pkgrel=0
pkgdesc="Modular Wayland compositor library"
url="https://gitlab.freedesktop.org/wlroots/wlroots"
license="MIT"
arch="all"
makedepends="
	eudev-dev
	glslang-dev
	hwdata-dev
	libcap-dev
	libdisplay-info-dev
	libinput-dev
	libseat-dev
	libliftoff-dev
	libxcb-dev
	libxkbcommon-dev
	lcms2-dev
	mesa-dev
	meson
	ninja
	pixman-dev
	vulkan-loader-dev
	wayland-dev
	wayland-protocols
	xcb-util-image-dev
	xcb-util-renderutil-dev
	xcb-util-wm-dev
	xkeyboard-config-dev
	xwayland-dev
	"
# wlroots >= 0.18.0 does no longer ship a libwlroots.so symlink in the -dev
# subpackage. Hence, abuild's dependency tracing fails to identify that the
# -dev subpackage depends on the origin package and we need to add that
# manually. Otherwise, the wlroots shared object is not installed with -dev.
depends_dev="$pkgname=$pkgver-r$pkgrel"
subpackages="$pkgname-dbg $pkgname-static $pkgname-dev"
source="https://gitlab.freedesktop.org/wlroots/wlroots/-/archive/$_pkgver/wlroots-$_pkgver.tar.gz"
builddir="$srcdir/wlroots-$_pkgver"
options="!check" # no test suite

# whether this is the default version (latest stable wlroots)
_default="yes"

if [ "$_default" = yes ]; then
	provides="wlroots=$pkgver-r$pkgrel"
	replaces="wlroots"

	dev() {
		default_dev
		provides="wlroots-dev=$pkgver-r$pkgrel"
		replaces="wlroots-dev"
	}
fi

build() {
	abuild-meson \
		-Db_lto=true \
		-Dexamples=false \
		-Dcolor-management=enabled \
		-Ddefault_library=both \
		. build
	meson compile -C build
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C build
}

sha512sums="
871ff06c1910ed7e6d17e67f56220a68c8ad1a7346fd2792094a8dd661015c726e65974df4a266a44f28e2fdf305a07d4671d3a3dc4b5aed44886d6ba98e549a  wlroots-0.20.1.tar.gz
"
