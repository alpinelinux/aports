Patch-Source: https://github.com/pulumi/pulumi-yaml/commit/f7aa502d861f1a0c022bb2001c3b5bbe5be52cc7
---
From f7aa502d861f1a0c022bb2001c3b5bbe5be52cc7 Mon Sep 17 00:00:00 2001
From: Julien <julien@caffeine.lu>
Date: Wed, 8 Apr 2026 09:10:47 +0000
Subject: [PATCH] Workaround for TestPluginDownloadURLUsed (#1037)

See also https://github.com/pulumi/pulumi-yaml/issues/1036
---
 pkg/tests/integration_test.go                      | 3 +++
 pkg/tests/testdata/plugin-download-url/Pulumi.yaml | 1 +
 2 files changed, 4 insertions(+)

diff --git a/pkg/tests/integration_test.go b/pkg/tests/integration_test.go
index 4ebbd5fac..52eabe482 100644
--- a/pkg/tests/integration_test.go
+++ b/pkg/tests/integration_test.go
@@ -305,6 +305,9 @@ func TestPluginDownloadURLUsed(t *testing.T) {
 	e := ptesting.NewEnvironment(t)
 	defer e.DeleteIfNotFailed()
 
+	// TODO https://github.com/pulumi/pulumi-yaml/issues/1036
+	// The provider in our testadata pins the version to 1.30.0 of the pulumi-yaml repo to avoid breakage due to the
+	// addition of a symlink that the tar extraction code can't handle.
 	e.ImportDirectory(filepath.Join("testdata", "plugin-download-url"))
 
 	e.RunCommand("pulumi", "login", "--cloud-url", e.LocalURL())
diff --git a/pkg/tests/testdata/plugin-download-url/Pulumi.yaml b/pkg/tests/testdata/plugin-download-url/Pulumi.yaml
index a8e1ebd81..60fb42508 100644
--- a/pkg/tests/testdata/plugin-download-url/Pulumi.yaml
+++ b/pkg/tests/testdata/plugin-download-url/Pulumi.yaml
@@ -5,6 +5,7 @@ resources:
     type: pulumi:providers:random-plugin-component
     defaultProvider: true
     options:
+      version: 1.30.0
       pluginDownloadURL: git://github.com/pulumi/pulumi-yaml/pkg/tests/testdata/component/provider
   randomPet:
     type: random-plugin-component:index:randomPetGenerator
