maintainer="Sertonix <sertonix@posteo.net>"
pkgname=arcticons-icon-theme
pkgver=14.7.1.0
pkgrel=0
pkgdesc="Line-based icon pack"
url="https://codeberg.org/Arcticons/Arcticons-Linux"
arch="noarch"
license="GPL-3.0-or-later"
depends="$pkgname-light $pkgname-dark"
subpackages="$pkgname-light:_theme $pkgname-dark:_theme"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/Arcticons/Arcticons-Linux/archive/$pkgver.tar.gz"
builddir="$srcdir/arcticons-linux"
options="!check"

package() {
	install -d "$pkgdir/usr/share/icons"
	cp -r arcticons-dark arcticons-light -t "$pkgdir/usr/share/icons"
}

_theme() {
	depends=
	local variant="${subpkgname##"$pkgname"-}"
	pkgdesc="$pkgdesc (Version for $variant themes)"

	amove usr/share/icons/arcticons-"$variant"
}

sha512sums="
03d7ddd59a694290a37fc68a08ea6b77813d424865bb3ece4ee926781400f93206ac2e09fdf443dbf7737ace78518bff01140d9e6e86ba3c84fca3c35239803e  arcticons-icon-theme-14.7.1.0.tar.gz
"
