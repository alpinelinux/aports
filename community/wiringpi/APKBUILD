# Maintainer: Timo Teräs <timo.teras@iki.fi>
pkgname=wiringpi
pkgver=3.16
pkgrel=0
pkgdesc="command line interface for Raspberry Pi gpio"
url="https://github.com/WiringPi/WiringPi"
arch="aarch64 armhf armv7"
license="LGPL-3.0-or-later"
options="!check" # no testsuite
makedepends="linux-headers"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/WiringPi/WiringPi/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir"/WiringPi-$pkgver

build() {
	make -C wiringPi CFLAGS="$CFLAGS -std=gnu17 -fcommon -fpic -I." LDFLAGS="$LDFLAGS" WIRINGPI_SONAME_SUFFIX=".$pkgver"
	ln -sf libwiringPi.so.$pkgver wiringPi/libwiringPi.so
	make -C devLib CFLAGS="$CFLAGS -std=gnu17 -fpic -I../wiringPi" LDFLAGS="$LDFLAGS" WIRINGPI_SONAME_SUFFIX=".$pkgver"
	ln -sf libwiringPiDev.so.$pkgver devLib/libwiringPiDev.so
	make -C gpio CFLAGS="$CFLAGS -std=gnu17 -I../wiringPi -I../devLib" LDFLAGS="$LDFLAGS -L../wiringPi -L../devLib"
}

package() {
	install -d -m755 "$pkgdir"/usr/include
	install -D -m644 wiringPi/*.h devLib/*.h "$pkgdir"/usr/include
	install -D -m755 wiringPi/libwiringPi.so."$pkgver" "$pkgdir"/usr/lib/libwiringPi.so."$pkgver"
	ln -s libwiringPi.so."$pkgver" "$pkgdir"/usr/lib/libwiringPi.so
	install -D -m755 devLib/libwiringPiDev.so."$pkgver" "$pkgdir"/usr/lib/libwiringPiDev.so."$pkgver"
	ln -s libwiringPiDev.so."$pkgver" "$pkgdir"/usr/lib/libwiringPiDev.so
	install -D -m755 gpio/gpio "$pkgdir"/usr/bin/gpio
}

sha512sums="
4c6748c7e9af0641af8384cb2ed8389ee00c6cec5e7d444e3d47e8dc23f6c10cff9a433060ab2876f310cdaddb07308fbf19d6ffe2c62bf5fa2637168d8a21a0  wiringpi-3.16.tar.gz
"
