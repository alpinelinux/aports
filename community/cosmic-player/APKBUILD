# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-player
pkgver=1.4.0
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Media player for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-player"
# armv7, armhf, x86: DO NOT RE-ENABLE! 32-bit is problematic, often requires carrying patches to fix
# riscv64: too slow to build
arch="all !armv7 !armhf !riscv64 !x86"
license="GPL-3.0-only"
depends="
	gst-plugins-good
"
makedepends="
	cargo-auditable
	clang-libclang
	glib-dev
	gst-plugins-base-dev
	gstreamer-dev
	just
	libxkbcommon-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="
	$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-player/archive/refs/tags/epoch-$_upstreamver.tar.gz
"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
966b37ab8021f27d0169ec01a3269dc5c3c3f3425d7a6ef333ba113a6046aad7429e4b4387c5a5d11b9e1771bbd2e13924bd313b2cec85817bfb9b39c34db809  cosmic-player-1.4.0.tar.gz
"
