6ea905bd8da2913e6cc9a5cad7e953bde10e8f0380394415e5d4e191c0300bda01e74aecb377935e22ed5ce7ee0a62e2bd659ec929cbf0e9d5bf4f7c2bf06e57  wgpu.patch
"
