# Contributor: Clayton Craft <clayton@craftyguy.net>
# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=cosmic-player
pkgver=1.0.16
_upstreamver="${pkgver/_beta/-beta.}"
_upstreamver="${_upstreamver/_p/.}"
pkgrel=0
pkgdesc="Media player for the COSMIC Desktop Environment"
url="https://github.com/pop-os/cosmic-player"
# riscv64: too slow to build
arch="all !riscv64"
license="GPL-3.0-only"
depends="
	gst-plugins-good
"
makedepends="
	cargo-auditable
	clang-libclang
	glib-dev
	gst-plugins-base-dev
	gstreamer-dev
	just
	libxkbcommon-dev
	wayland-dev
"
options="net !check"  # fetch dependencies, no tests
source="$pkgname-$pkgver.tar.gz::https://github.com/pop-os/cosmic-player/archive/refs/tags/epoch-$_upstreamver.tar.gz"
builddir="$srcdir/$pkgname-epoch-$_upstreamver"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	just rootdir="$pkgdir" install
}

sha512sums="
7d9d0aede7d94b549702cb12663ac286a1714b94fe474636f60aeb1db72250067e617f3a585d3a211610b12fe3c12d9ae9f5b0cf73b2d75ea2128e7c3139f12e  cosmic-player-1.0.16.tar.gz
"
