fa0bd1746982e38732884bcf6a1783f8ffb4e9260e3c6b157f33659d9d91b2321662b5d51bf6f8ab41007d723b83f9f699006769166f4951a9c92a71e10ad6df  fix-incompatible-pointer-types-error.patch
"
