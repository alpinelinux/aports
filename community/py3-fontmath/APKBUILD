# Contributor: Rasmus Thomsen <oss@cogitri.dev>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=py3-fontmath
pkgver=0.10.0
pkgrel=0
pkgdesc="set of objects for performing math operations on font data"
url="https://github.com/robotools/fontMath"
arch="noarch"
license="MIT"
depends="py3-fonttools python3"
makedepends="
	py3-gpep517
	py3-installer
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/robotools/fontMath/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/fontMath-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/fontmath-*.whl
}

sha512sums="
5c4bda02a7038a4bc96478dd2504bd91258f8497aa989cdf0699a48eeb426bbf9cb4e5a4b20f7941f4ea3a3da61e92d915b691da61189276f71e658835866005  py3-fontmath-0.10.0.tar.gz
"
