From 3f8aa2b78868b275c61b1c582980f356cbbafec7 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Sun, 19 Apr 2026 10:18:59 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt                         | 6 +++++-
 src/mailimporterakonadi/CMakeLists.txt | 2 +-
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index a672f00..fde728a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -108,7 +108,11 @@ find_package(KF6CoreAddons ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6I18n ${KF_MIN_VERSION} CONFIG REQUIRED)
 
 find_package(KPim6Akonadi ${AKONADI_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KMIME_LIB_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KPim6AkonadiMime ${AKONADIMIME_LIB_VERSION} CONFIG REQUIRED)
 find_package(KPim6PimCommon ${PIMCOMMON_LIB_VERSION} CONFIG REQUIRED)
 ########### Targets ###########
diff --git a/src/mailimporterakonadi/CMakeLists.txt b/src/mailimporterakonadi/CMakeLists.txt
index 3aff7c5..50a7647 100644
--- a/src/mailimporterakonadi/CMakeLists.txt
+++ b/src/mailimporterakonadi/CMakeLists.txt
@@ -55,7 +55,7 @@ target_link_libraries(
         KPim6::MailImporter
         KPim6::AkonadiCore
     PRIVATE
-        KPim6::Mime
+        KF6::Mime
         KPim6::AkonadiMime
         KF6::I18n
 )
