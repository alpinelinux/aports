2ac3047b46161b5e9f36dd82b99ab2074f956083dd0eb8d51be4101877b0992575bb0944765cd194a6bc2bb479ce061c6971aa3df87bfd037225e2ad334ff26b  0001-mailimporter-KMime-from-KF6.patch
"
