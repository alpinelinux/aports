From b43c82977db5647d576a9cbba7fb027c45f3014c Mon Sep 17 00:00:00 2001
From: Bart Ribbers <bribbers@disroot.org>
Date: Thu, 19 Mar 2026 10:09:08 +0100
Subject: [PATCH] refactor: remove mlite dependency

mlite is only used to get the name of the application from the desktop
file but that's something Qt can do itself. This saves us a dependency.
---
 CMakeLists.txt          |  1 -
 src/app/CMakeLists.txt  |  2 +-
 src/app/asteroidapp.cpp | 18 +++++++++---------
 3 files changed, 10 insertions(+), 11 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 7071736..8ae0c73 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -21,7 +21,6 @@ set(ASTEROID_MODULES_INSTALL_DIR ${CMAKE_INSTALL_DATADIR}/asteroidapp/cmake)
 
 find_package(Qt5 ${QT_MIN_VERSION} COMPONENTS DBus Qml Quick Svg REQUIRED)
 if (WITH_ASTEROIDAPP)
-    find_package(Mlite5 MODULE REQUIRED)
     find_package(Mapplauncherd_qt5 MODULE REQUIRED)
 endif()
 
diff --git a/src/app/CMakeLists.txt b/src/app/CMakeLists.txt
index 333ffc5..13b6238 100644
--- a/src/app/CMakeLists.txt
+++ b/src/app/CMakeLists.txt
@@ -8,7 +8,7 @@ target_link_libraries(asteroidapp
 		Qt5::Qml
 		Qt5::Quick
 	PRIVATE
-		Mlite5::Mlite5
+		Qt5::Core
 		Mapplauncherd_qt5::Mapplauncherd_qt5)
 
 set_target_properties(asteroidapp PROPERTIES
diff --git a/src/app/asteroidapp.cpp b/src/app/asteroidapp.cpp
index 73e0d0a..8e3fbd9 100644
--- a/src/app/asteroidapp.cpp
+++ b/src/app/asteroidapp.cpp
@@ -26,14 +26,14 @@
 
 #include "asteroidapp.h"
 
-#include <QQuickView>
-#include <QQmlEngine>
+#include <MDeclarativeCache>
+#include <QFileInfo>
 #include <QGuiApplication>
+#include <QQmlEngine>
+#include <QQuickView>
 #include <QScreen>
-#include <QFileInfo>
-#include <MDesktopEntry>
+#include <QSettings>
 #include <QTranslator>
-#include <mdeclarativecache5/MDeclarativeCache>
 
 static QString applicationPath()
 {
@@ -79,10 +79,10 @@ namespace AsteroidApp {
     QQuickView *createView()
     {
         QQuickView *view = MDeclarativeCache::qQuickView();
-        MDesktopEntry entry("/usr/share/applications/" + appName() + ".desktop");
-        if (entry.isValid()) {
-            view->setTitle(entry.name());
-        }
+        QString path = "/usr/share/applications/" + appName() + ".desktop";
+        QSettings applicationSettings(path, QSettings::IniFormat);
+        auto applicationName = applicationSettings.value("Desktop Entry/Name");
+        view->setTitle(applicationName.toString());
 
         QObject::connect(view->engine(), &QQmlEngine::quit,
                          qApp, &QGuiApplication::quit);
-- 
2.53.0

