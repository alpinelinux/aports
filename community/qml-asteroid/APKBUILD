# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=qml-asteroid
pkgver=2.1_git20260414
pkgrel=0
_commit="02fe2871b30cd5871e093272638809e6b9781f85"
pkgdesc="QML components, styles and demos for AsteroidOS"
url="https://github.com/AsteroidOS/qml-asteroid"
# armhf blocked by qt5-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-only"
depends="
	qt6-qt5compat
	qt6-qtvirtualkeyboard
	"
# grep is required for the asteroid-generate-desktop.sh script, which is used by other packages
depends_dev="
	grep
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtsvg-dev
	qt6-qttools-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	mapplauncherd-qt-dev
	samurai
	"
subpackages="$pkgname-dbg $pkgname-dev"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/qml-asteroid/archive/$_commit.tar.gz
	0001-feat-remove-Qt5-support.patch
	"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DINSTALL_QML_IMPORT_DIR=/usr/lib/qt6/qml
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

dev() {
	default_dev

	amove usr/share/*/cmake
	amove usr/bin
}

sha512sums="
f9fc0e75cb4f78f17f33a416167cff8a50e532f8a0f6369280c3b8d8f1545d3bc1912104496fb72adee8cd07ff0eac87334abbca5819e0fd18db23ebb04427af  qml-asteroid-02fe2871b30cd5871e093272638809e6b9781f85.tar.gz
0dfefde4e67bd054392d7bf1e54de8355e935677dc3a1c53d14d02ecab297023879f779e841cde2020750587bde028b9285a842bfc8dec8ea3176fca855c639b  0001-feat-remove-Qt5-support.patch
"
