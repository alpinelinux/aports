# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=qml-asteroid
pkgver=2.1_git20260612
pkgrel=0
_commit="29ffc90d1cd7ae29a0de25606ca41b5e8bfe5171"
pkgdesc="QML components, styles and demos for AsteroidOS"
url="https://github.com/AsteroidOS/qml-asteroid"
# armhf blocked by qt5-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-only"
depends="
	qt6-qt5compat
	qt6-qtvirtualkeyboard
	"
# grep is required for the asteroid-generate-desktop.sh script, which is used by other packages
depends_dev="
	grep
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtsvg-dev
	qt6-qttools-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	mapplauncherd-qt-dev
	samurai
	"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/qml-asteroid/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DINSTALL_QML_IMPORT_DIR=/usr/lib/qt6/qml
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

dev() {
	default_dev

	amove usr/share/*/cmake
	amove usr/bin
}

sha512sums="
246ab9c38f09527e4045aa9c3827d830ce957693e710e1542dcf4b265663c890a18c278c81dbe9022f0a816272c423480884f466a0d92ed5cb553e4ec4f588d8  qml-asteroid-29ffc90d1cd7ae29a0de25606ca41b5e8bfe5171.tar.gz
"
