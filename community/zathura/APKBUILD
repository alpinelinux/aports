maintainer="omni <omni+alpine@hack.org>"
pkgname=zathura
pkgver=2026.05.11
pkgrel=0
pkgdesc="Highly customizable and functional document viewer"
url="https://pwmt.org/projects/zathura/"
arch="all"
license="Zlib"
makedepends="
	appstream
	check-dev
	desktop-file-utils
	file-dev
	girara-dev
	gtk+3.0-dev
	json-glib-dev
	libseccomp-dev
	muon
	ncurses
	py3-docutils
	py3-sphinx
	sqlite-dev
	"
checkdepends="
	dbus
	mesa-dri-gallium
	weston
	xvfb-run
	"
subpackages="
	$pkgname-doc
	$pkgname-dev
	$pkgname-lang
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"
source="https://pwmt.org/projects/zathura/download/zathura-$pkgver.tar.xz"

case "$CARCH" in
s390x)
	_synctex=disabled
	;;
*)
	makedepends="$makedepends texlive-dev"
	_synctex=enabled
	;;
esac

build() {
	abuild-muon \
		-Dsynctex=$_synctex \
		-Dseccomp=enabled \
		-Dlandlock=enabled \
		-Dmanpages=enabled \
		-Dtests="$(want_check && echo enabled || echo disabled)" \
		-Dconvert-icon=disabled \
		build .
	ninja -C build
}

check() {
	xvfb-run -a muon -C build test -j "${JOBS:-0}" -R -d dots
}

package() {
	DESTDIR="$pkgdir" muon -C build install
}

sha512sums="
