# Contributor: jane400 <alpine@j4ne.de>
maintainer="team/phosh <newbyte@postmarketos.org>"
pkgname=stevia
pkgver=0.55.0
pkgrel=0
pkgdesc="Alternative OSK for phosh"
arch="all !riscv64" # tests fail with SIGSEGV
url="https://gitlab.gnome.org/World/Phosh/stevia"
license="GPL-3.0-or-later"
depends="hunspell-en-us"
makedepends="
	cmd:rst2man
	dconf-dev
	elogind-dev
	feedbackd-dev
	fzf
	glib-dev
	gmobile-dev
	gnome-desktop-dev
	gtk+3.0-dev
	hunspell-dev
	json-glib-dev
	libhandy1-dev
	meson
	presage-dev
	wayland-dev
	wayland-protocols
	"
checkdepends="xvfb-run words-en"
subpackages="$pkgname-doc $pkgname-lang $pkgname-systemd $pkgname-dbg"
source="https://gitlab.gnome.org/World/Phosh/stevia/-/archive/v$pkgver/stevia-v$pkgver.tar.gz
	emoji-db.patch
	"
builddir="$srcdir/stevia-v$pkgver"

provides="phosh-keyboard=0 phosh-osk-stub=$pkgver-r$pkgrel"
provider_priority=1
replaces="phosh"

case "$CARCH" in
armhf|armv7) ;; # doesnt have community/uim
*) makedepends="$makedepends uim-dev"
esac

build() {
	abuild-meson \
		-Db_lto=true \
		-Dman=true \
		-Dwordlist=/usr/share/dict/american-english \
		. output
	meson compile -C output
}

check() {
	xvfb-run -a meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

