maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=poco
pkgver=1.15.3
pkgrel=0
pkgdesc="C++ class libraries for building network- and internet-based applications"
url="https://pocoproject.org/"
arch="all"
license="BSL-1.0"
depends_dev="
	expat-dev
	libpng-dev
	libpq-dev
	mariadb-connector-c-dev
	openssl-dev
	pcre2-dev
	sqlite-dev
	unixodbc-dev
	zlib-dev
	"
makedepends="$depends_dev
	chrpath
	cmake
	linux-headers
	samurai
	utf8proc-dev
	"
subpackages="
	$pkgname-bin
	$pkgname-dev
	"
source="https://pocoproject.org/releases/poco-$pkgver/poco-$pkgver-all.tar.gz"
options="!check" # No testsuite

builddir="$srcdir/$pkgname-$pkgver-all"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DPOCO_UNBUNDLED=ON
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

bin() {
	amove usr/bin
}

sha512sums="
091f16e9837a1ba32256a82b17a1417f616fc919f62c13c38de9fcde5f3ef7d118d9ff17eda07f8f52a25b9e62223d350a828812c0920f98bc5d6137eb6ed1c9  poco-1.15.3-all.tar.gz
"
