maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=poco
pkgver=1.15.2
pkgrel=0
pkgdesc="C++ class libraries for building network- and internet-based applications"
url="https://pocoproject.org/"
arch="all"
license="BSL-1.0"
depends_dev="
	expat-dev
	libpng-dev
	libpq-dev
	mariadb-connector-c-dev
	openssl-dev
	pcre2-dev
	sqlite-dev
	unixodbc-dev
	zlib-dev
	"
makedepends="$depends_dev
	chrpath
	cmake
	linux-headers
	samurai
	utf8proc-dev
	"
subpackages="
	$pkgname-bin
	$pkgname-dev
	"
source="https://pocoproject.org/releases/poco-$pkgver/poco-$pkgver-all.tar.gz"
options="!check" # No testsuite

builddir="$srcdir/$pkgname-$pkgver-all"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DPOCO_UNBUNDLED=ON
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

bin() {
	amove usr/bin
}

sha512sums="
c8389b5287467fe59d63c114428b1ee2585a55f2afec8249081c4c2b20427be0f9dc73c6268442bd2d2f8e2612615d46669f665f75415a6c183d5b5a044f28be  poco-1.15.2-all.tar.gz
"
