maintainer="Hoang Nguyen <folliekazetani@protonmail.com>"
pkgname=gallery-dl
pkgver=1.32.6
pkgrel=0
pkgdesc="CLI tool to download image galleries"
url="https://codeberg.org/mikf/gallery-dl"
arch="noarch"
license="GPL-2.0-or-later"
depends="py3-requests python3"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest yt-dlp"
subpackages="
	$pkgname-doc
	$pkgname-pyc
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"
source="$pkgname-$pkgver-1.tar.gz::https://codeberg.org/mikf/gallery-dl/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname"

build() {
	make man completion

	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	make test
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
3755e105526f7f58e858b9f53532376b01ee0e8a6a08229f5d93cfb9ba79ad13678f71b9a842b4c959af626f2d67d1f0c0ce6cf2281d1a570407229619371e11  gallery-dl-1.32.6-1.tar.gz
"
