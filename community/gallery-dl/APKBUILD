maintainer="Hoang Nguyen <folliekazetani@protonmail.com>"
pkgname=gallery-dl
pkgver=1.32.0
pkgrel=0
pkgdesc="CLI tool to download image galleries"
url="https://codeberg.org/mikf/gallery-dl"
arch="noarch"
license="GPL-2.0-or-later"
depends="py3-requests python3"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest yt-dlp"
subpackages="
	$pkgname-doc
	$pkgname-pyc
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/mikf/gallery-dl/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname"

build() {
	make man completion

	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	make test
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
dbf8a6ebd749b6bd54a1a5f3502e4cfb8210f3fef0fb64b7d08fdef6910a4e54dc7d45255129c115f91bd5e4d514b30392eb24b9f88b5b7aefc21238d489e9d7  gallery-dl-1.32.0.tar.gz
"
