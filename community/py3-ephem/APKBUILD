# Maintainer: Antoine Martin (ayakael) <dev@ayakael.net>
pkgname=py3-ephem
_pyname="pyephem"
pkgver=4.2.1
pkgrel=0
arch="all"
pkgdesc="Compute positions of the planets and stars"
url="https://pypi.python.org/project/ephem"
license="MIT"
makedepends="
	python3-dev
	py3-setuptools
	py3-gpep517
	py3-wheel
	py3-docutils
	"
checkdepends="
	py3-pytest
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/brandon-rhodes/pyephem/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir"/$_pyname-$pkgver
subpackages="$pkgname-pyc"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	cd build/lib.*
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer ../../.dist/*.whl
	.testenv/bin/python3 -m pytest -v \
		--ignore=ephem/tests/test_jpl.py
}

package() {
	python3 -m installer --destdir="$pkgdir" .dist/*.whl
	rm -Rf "$pkgdir"/usr/lib/python*/site-packages/ephem/tests
}

sha512sums="
3de83947475279d03256000eb8d604c04dcad28de4e5bba5268bc0073a96b1ccde16701792fbd923477070258d9bec305d1a68e5233ab6de5b90aa8641e95f47  py3-ephem-4.2.1.tar.gz
"
