# Contributor: George Hopkins <george-hopkins@null.net>
# Maintainer: Duncan Bellamy <dunk@denkimushi.com>
pkgname=genext2fs
pkgver=1.6.2
pkgrel=0
pkgdesc="Generate ext2 filesystems as a normal user"
url="https://genext2fs.sourceforge.net/"
arch="all"
license="GPL-2.0-only"
makedepends="autoconf automake libarchive-dev"
checkdepends="bash e2fsprogs-extra python3"
subpackages="$pkgname-doc"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/bestouff/genext2fs/archive/v$pkgver.tar.gz
	fix-tests.patch
	"

prepare() {
	default_prepare
	./autogen.sh
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--enable-libarchive
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
