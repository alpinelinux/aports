# Contributor: Matthias Ahouansou <matthias@ahouansou.cz>
# Maintainer: Matthias Ahouansou <matthias@ahouansou.cz>
pkgname=ripdrag
pkgver=0.4.12
pkgrel=0
pkgdesc="Drag and Drop utilty written in Rust and GTK4"
url="https://github.com/nik012003/ripdrag"
# loongarch64: blocked by libc crate
arch="all !loongarch64"
license="GPL-3.0-only"
makedepends="
	cargo
	cargo-auditable
	gtk4.0-dev
"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/nik012003/ripdrag/archive/refs/tags/v$pkgver.tar.gz
"
options="!check" # no tests

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen
}

package() {
	install -Dm 755 target/release/ripdrag "$pkgdir"/usr/bin/ripdrag
}

sha512sums="
301683bb1b7c01db3de0e424384bd7051c1294afdd1d617479db827aefd9fdfb773cf5f85a31eeb4f5962a015f629d6e67ed138afd03312bc9c2492087997126  ripdrag-0.4.12.tar.gz
"
