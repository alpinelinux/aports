# Contributor: Kay Thomas <kaythomas@pm.me>
# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=ergo
pkgver=2.18.0
pkgrel=0
pkgdesc="Modern IRC server (daemon/ircd) written in Go"
url="https://ergo.chat"
arch="all"
license="MIT"
options="!check net" # no test suite, fetch go modules
makedepends="go"
subpackages="$pkgname-doc $pkgname-openrc"
pkgusers="ergo"
pkggroups="ergo"
install="$pkgname.pre-install $pkgname.post-upgrade"
source="$pkgname-$pkgver.tar.gz::https://github.com/ergochat/ergo/archive/refs/tags/v$pkgver.tar.gz
	ergo.initd
	ergo.confd
	ergo.logrotate
	ircd.yaml_patch
	"

build() {
	make CGO_ENABLED=1 build

	patch default.yaml --input="$srcdir"/ircd.yaml_patch --output=ircd.yaml
}

package() {
	install -Dm755 ergo -t "$pkgdir"/usr/bin/

	install -Dm644 ircd.yaml \
		-t "$pkgdir"/etc/ergo/

	install -dm755 -o ergo -g ergo \
		"$pkgdir"/usr/share/languages

	install -Dm644 languages/*.yaml languages/*.json \
		-t "$pkgdir"/usr/share/languages/"$pkgname"/

	install -Dm644 CHANGELOG.md README \
				docs/API.md \
				docs/MANUAL.md \
				docs/MOTDFORMATTING.md \
				docs/USERGUIDE.md \
		-t "$pkgdir"/usr/share/doc/"$pkgname"/
	install -Dm644 default.yaml ergo.motd traditional.yaml \
		-t "$pkgdir"/usr/share/doc/"$pkgname"/examples/
	install -Dm644 LICENSE \
		-t "$pkgdir"/usr/share/licenses/"$pkgname"/

	# TODO: move closer to upstream
	install -Dm755 "$srcdir"/"$pkgname".initd \
		"$pkgdir"/etc/init.d/"$pkgname"
	install -Dm644 "$srcdir"/"$pkgname".confd \
		"$pkgdir"/etc/conf.d/"$pkgname"

	install -Dm644 "$srcdir"/"$pkgname".logrotate \
		"$pkgdir"/etc/logrotate.d/"$pkgname"
}

