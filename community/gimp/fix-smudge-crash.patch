 app/paint/gimpsmudge.c | 7 +++++--
 1 file changed, 5 insertions(+), 2 deletions(-)

diff --git a/app/paint/gimpsmudge.c b/app/paint/gimpsmudge.c
index 3ad5b0ac82e..003b70ede0f 100644
--- a/app/paint/gimpsmudge.c
