pkgname=gimp
pkgver=3.2.4
pkgrel=0
pkgdesc="GNU Image Manipulation Program"
url="https://www.gimp.org/"
# nobody is using this on s390x
arch="all !s390x"
license="GPL-3.0-or-later"
depends="
	py3-cairo
	py3-gobject3
	xdg-utils
	"
makedepends="
	appstream-dev
	babl-dev
	desktop-file-utils
	gegl-dev
	gexiv2-dev
	glib-networking
	gobject-introspection-dev
	gtk+3.0-dev
	intltool
	iso-codes-dev
	lcms2-dev
	libavif-dev
	libarchive-dev
	libexif-dev
	libheif-dev
	libjpeg-turbo-dev
	libjxl-dev
	libmypaint-dev
	libpng-dev
	librsvg-dev
	libxcursor-dev
	libxmu-dev
	libxpm-dev
	meson
	mypaint-brushes2-dev
	py3-gobject3
	py3-cairo
	python3
	poppler-data
	poppler-dev
	tiff-dev
	xz-dev
	"
subpackages="$pkgname-dev $pkgname-doc $pkgname-lang"
source="https://download.gimp.org/pub/gimp/v${pkgver%.*}/gimp-$pkgver.tar.xz
	bc7enc.patch
	"
options="!check"

# secfixes:
#   2.10.36-r0:
#     - CVE-2023-44441 ZDI-CAN-22093
#     - CVE-2023-44442 ZDI-CAN-22094
#     - CVE-2023-44443 ZDI-CAN-22096
#     - CVE-2023-44444 ZDI-CAN-22097
#   2.8.22-r2:
#     - CVE-2017-17784
#     - CVE-2017-17785
#     - CVE-2017-17786
#     - CVE-2017-17787
#     - CVE-2017-17788
#     - CVE-2017-17789

prepare() {
	default_prepare

	# bc7enc.c is a C++ source file with a .c extension, causing the linker
	# to fail with undefined reference to bc7enc_compress_block_params_init
	# when compiled as C. Rename it so meson uses the C++ compiler.
	mv "$builddir/plug-ins/file-dds/bc7enc_rdo/bc7enc.c" \
		"$builddir/plug-ins/file-dds/bc7enc_rdo/bc7enc.cpp"
}

build() {
	abuild-meson \
		-Dcheck-update=no \
		-Denable-console-bin=true \
		-Dopenmp=enabled \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

dev() {
	default_dev
	amove usr/bin/gimptool*
}

