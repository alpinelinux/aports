From: Pantelis Antoniou <pantelis.antoniou@konsulko.com>
Date: Thu, 26 Mar 2026 19:56:02 +0200
Subject: [PATCH] configure.ac: Fix stray fi

The previous patch left a stray fi

Signed-off-by: Pantelis Antoniou <pantelis.antoniou@konsulko.com>
---
 configure.ac | 1 -
 1 file changed, 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index d39a4db1..fd24d079 100644
--- a/configure.ac
+++ b/configure.ac
@@ -259,7 +259,6 @@ case "$ac_cv_search_trunc" in
 	no|yes|"none required") LIBM="" ;;
 	*) LIBM="$ac_cv_search_trunc" ;;
 esac
-fi
 AC_SUBST(LIBM)
 
 # check if there's a qsort_r available (musl does not have it)
