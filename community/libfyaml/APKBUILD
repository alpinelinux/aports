# Contributor: Lucas Ramage <ramage.lucas@protonmail.com>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=libfyaml
pkgver=0.9.6
pkgrel=0
pkgdesc="Fully feature complete YAML parser and emitter"
url="https://github.com/pantoniou/libfyaml"
arch="all"
license="MIT"
makedepends="
	bash
	libtool
	linux-headers
	m4
	"
checkdepends="check git"
subpackages="$pkgname-dev $pkgname-doc"
source="https://github.com/pantoniou/libfyaml/releases/download/v$pkgver/libfyaml-$pkgver.tar.gz
	vlsize_fix_size_t.patch
	fix_32bit_build.patch"
options="!check" # assumes bash

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--libdir=/usr/lib \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--disable-static
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

