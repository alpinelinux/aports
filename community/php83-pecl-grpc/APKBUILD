# Maintainer: Andy Postnikov <apostnikov@gmail.com>
pkgname=php83-pecl-grpc
_extname=grpc
pkgver=1.80.0
pkgrel=0
pkgdesc="PHP 8.3 extension provide a concrete implementation of the gRPC protocol, layered over HTTP/2."
url="https://pecl.php.net/package/grpc"
arch="all !s390x !ppc64le" # build failures
license="Apache-2.0"
_phpv=83
_php=php$_phpv
depends="$_php-common"
_clang_ver=22
makedepends="$_php-dev clang$_clang_ver openssl-dev linux-headers"
source="
	php-pecl-$_extname-$pkgver.tgz::https://pecl.php.net/get/$_extname-$pkgver.tgz
	boringssl.patch
	"
builddir="$srcdir"/$_extname-$pkgver

build() {
	export CC=clang-$_clang_ver
	export CXX=clang++-$_clang_ver
	# link against gcc libatomic on x86
	[ "$CARCH" = "x86" ] && export LDFLAGS="$LDFLAGS -latomic"
	phpize$_phpv
	./configure --prefix=/usr --with-php-config=php-config$_phpv
	make
}

check() {
	# Test suite is not a part of pecl release.
	$_php -d extension=modules/$_extname.so --ri $_extname
}

package() {
	make INSTALL_ROOT="$pkgdir" install
	local _confdir="$pkgdir"/etc/$_php/conf.d
	install -d $_confdir
	echo "extension=$_extname" > $_confdir/50_$_extname.ini
}

sha512sums="
461c9c4c9e4af32ea9216af7df69915392f494ad10bc7c2249940f2a00c2a152f74bc457a13df5d4c023a651cf76b55eca61e1fff764b6c3f849ac0c4cf92c67  php-pecl-grpc-1.80.0.tgz
6b551439ad5fd513720f1a267dab743b1c261f1662dd7a364080ec5e38a41eaf402e8950c8d8a5c3ef49297be8954f10d1ae9414da3ebce96a2dc8d87bee6bfd  boringssl.patch
"
