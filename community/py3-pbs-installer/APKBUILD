maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-pbs-installer
pkgver=2026.03.24
pkgrel=0
pkgdesc="Installer for python-build-standalone"
url="https://github.com/frostming/pbs-installer"
arch="noarch"
license="MIT"
makedepends="
	py3-gpep517
	py3-pdm-backend
	py3-setuptools
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/frostming/pbs-installer/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/pbs-installer-$pkgver"
options="!check" # no tests

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
df6258c0d43173e5b3e5272d7f04d9501d7c5aaae193a0c38c0e0676fe89944abeadd6dfad8f0a8f8f07d815bb75f8aff1dedbc3e6c4c3b4c2ddc9dfaed1e41e  py3-pbs-installer-2026.03.24.tar.gz
"
