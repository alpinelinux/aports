prepare() {
	default_prepare

	case "$CARCH" in
	loongarch64)
		update_config_sub
		;;
	esac
}

build() {
	./configure \
		--build="$CBUILD" \
		--host="$CHOST" \
		--prefix=/usr \
		--sysconfdir=/etc \
		--localstatedir=/var \
		--mandir=/usr/share/man \
		--enable-gpl \
		--disable-html-manual
	make
}

check() {
	case "$CARCH" in
	arm*)
		export TOR_SKIP_TESTCASES="$TOR_SKIP_TESTCASES \
			sandbox/chown_filename"
		# "Operation not permitted"
		;;
	loongarch64)
		export TOR_SKIP_TESTCASES="$TOR_SKIP_TESTCASES \
			sandbox/chown_filename \
			sandbox/chmod_filename"
		# "Operation not permitted"
		;;
	esac

	make test
}

package() {
	make DESTDIR="$pkgdir" install

	install -dm0755 -o "$pkgusers" \
		"$pkgdir"/var/lib/"$pkgname" \
		"$pkgdir"/var/log/"$pkgname"

	install -Dm0755 "$srcdir"/"$pkgname".initd \
		"$pkgdir"/etc/init.d/"$pkgname"
	install -Dm0644 "$srcdir"/"$pkgname".confd \
		"$pkgdir"/etc/conf.d/"$pkgname"
}

