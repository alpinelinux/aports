# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-frameworks
maintainer="team/kde <bribbers@disroot.org>"
pkgname=purpose
pkgver=6.25.0
pkgrel=0
pkgdesc="Framework for providing abstractions to get the developer's purposes fulfilled"
# armhf blocked by qt6-qtdeclarative -> kirigami
arch="all !armhf"
url="https://community.kde.org/Frameworks"
license="LGPL-2.1-or-later"
depends="
	kitemmodels
	prison
	"
depends_dev="
	kconfig-dev
	kcoreaddons-dev
	ki18n-dev
	kio-dev
	kirigami-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	"
case "$CARCH" in
	x86|s390x|riscv64|armv7|loongarch64) ;;
	*) depends_dev="$depends_dev kaccounts-integration-dev" ;;
esac
makedepends="$depends_dev
	extra-cmake-modules
	kcmutils
	qt6-qtdeclarative-private-dev
	samurai
	"
checkdepends="xwayland-run"
subpackages="$pkgname-dev $pkgname-lang"
_repo_url="https://invent.kde.org/frameworks/purpose.git"
source="https://download.kde.org/stable/frameworks/${pkgver%.*}/purpose-$pkgver.tar.xz"

replaces="purpose5"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_TESTING=ON
	cmake --build build
}

check() {
	wlheadless-run -- ctest --test-dir build -E 'menutest'
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
d8a64976e2bce6072c9d0b6254d38e5f195346e0637f397450088a51c2793be1207efb70002656cfa9a01421f4173e12e3f4673b75ec2d3e478ead40d77d54dd  purpose-6.25.0.tar.xz
"
