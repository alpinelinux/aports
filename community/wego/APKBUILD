# Contributor: omni <omni+alpine@hack.org>
# Maintainer: omni <omni+alpine@hack.org>
pkgname=wego
pkgver=2.4
pkgrel=0
pkgdesc="A weather app for the terminal"
url="https://github.com/schachmat/wego"
license="ISC"
arch="all"
makedepends="go"
subpackages="$pkgname-doc"
options="!check net" # no test files, go
source="$pkgname-$pkgver.tar.gz::https://github.com/schachmat/wego/archive/refs/tags/$pkgver.tar.gz"

build() {
	go build \
		-ldflags="-linkmode=external -extldflags \"$LDFLAGS\"" \
		-v .
}

package() {
	install -Dm0755 "$pkgname" -t "$pkgdir"/usr/bin

	install -Dm644 README.md -t "$pkgdir"/usr/share/doc/"$pkgname"/
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/"$pkgname"/
}

sha512sums="
ded9c29e3c55e165d58315f827e9b1f056d801dddd8c5be8e37986a13b7d177e9a39d06fb665144704277106297b00b600391b983d22de4a13cb7088a7d217b6  wego-2.4.tar.gz
"
