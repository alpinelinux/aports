2b1f3ae9bbb9dc9404c46509b091a294caa705ed24e79481ac65b7587fd31b51d48044b8080f8d15a1771eb1d41cdcea558845e18f46017bf243714b818705a1  pygments-2.19.patch
126b893e09c471b1ba5a6814141ce55bbb09a21dd2bf465c9453845e8d720413adb5ac2317957a0644240c395b0f3f06a2f92b31910dca8352db046e23e0b832  0001-Normalize-pygmented-test-output.patch
"
