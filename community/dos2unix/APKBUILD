pkgname=dos2unix
pkgver=7.5.6
pkgrel=0
pkgdesc="Text file format converters"
url="https://waterlander.net/dos2unix/"
arch="all"
license="BSD-2-Clause"
checkdepends="gettext-dev perl-utils"
subpackages="$pkgname-doc"
source="https://waterlander.net/dos2unix/files/dos2unix-$pkgver.tar.gz"

build() {
	make ENABLE_NLS= LDFLAGS_USER="$LDFLAGS"
}

check() {
	make check
}

package() {
	make prefix=/usr \
		docsubdir=$pkgname \
		ENABLE_NLS= \
		DESTDIR="$pkgdir" \
		install
}

sha512sums="
