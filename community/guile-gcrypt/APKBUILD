# Maintainer: Sören Tempel <soeren+alpine@soeren-tempel.net>
pkgname=guile-gcrypt
pkgver=0.5.0
pkgrel=1
pkgdesc="Guile Scheme bindings for libgcrypt"
url="https://codeberg.org/guile-gcrypt/guile-gcrypt"
arch="all"
license="GPL-3.0-or-later"
depends="guile libgcrypt-dev"
makedepends="automake autoconf guile-dev texinfo"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/guile-gcrypt/guile-gcrypt/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname"

prepare() {
	default_prepare
	./bootstrap.sh
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
eac0750b2c25971151f747ae8776ae798e8686a3d379e348f305024aca15cad9a86c5b868cb6000733020b2ba44d726dd7bb2b78f38366981967c4a50ff1f2c0  guile-gcrypt-0.5.0.tar.gz
"
