From 65caf06c12da7f19d3f90d1bf9cbb8b7c6f9f55d Mon Sep 17 00:00:00 2001
From: qaqland <anguoli@uniontech.com>
Date: Tue, 23 Jun 2026 09:45:21 +0800
Subject: [PATCH] igsc: test: fix uninitialized buffer_len in fwdata parser
 tests

Signed-off-by: qaqland <anguoli@uniontech.com>
---
 tests/fwdata_parser_tests.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/tests/fwdata_parser_tests.c b/tests/fwdata_parser_tests.c
index 25526a5..8dcddad 100644
--- a/tests/fwdata_parser_tests.c
+++ b/tests/fwdata_parser_tests.c
@@ -39,6 +39,9 @@ static int group_setup(void **state)
         goto fail;
     }
 
+    img->buffer = (const uint8_t *)header;
+    img->buffer_len = IMAGE_SIZE;
+
     img->layout.table[FWU_FPT_ENTRY_FW_DATA_IMAGE].content = (uint8_t *)header;
     img->layout.table[FWU_FPT_ENTRY_IMAGE_INFO].content = (uint8_t *)metadata;
     *state = img;
