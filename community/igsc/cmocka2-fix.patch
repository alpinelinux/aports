Allocation testing is deprecated and disabled by default since cmocka 2.0.0.
We need to define both the UNIT_TESTING and ALLOCATION_TESTING macros to
re-enable it.

Refs: https://api.cmocka.org/group__cmocka__alloc.html
Refs: https://gitlab.com/cmocka/cmocka/-/commit/e101ae8312c6fb0f9a11a2b9342002d8368ab71e

--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -25,7 +25,7 @@
                 SOURCES ../lib/igsc_lib.c ../lib/igsc_log.c ../lib/oprom.c igsc_tests.c ../lib/fw_data_parser.c ${POWER_SOURCES}
                 LINK_LIBRARIES ${CMOCKA_LIBRARIES} metee::metee
                 INCLUDE_DIRECTORIES ${IGCS_INCLUDE_DIRS} ${CMOCKA_INCLUDE_DIR}
-                COMPILE_OPTIONS ${DEFAULT_C_COMPILE_FLAGS} -Digsc_strdup=test_strdup -DUNIT_TESTING=1
+                COMPILE_OPTIONS ${DEFAULT_C_COMPILE_FLAGS} -Digsc_strdup=test_strdup -DUNIT_TESTING=1 -DALLOCATION_TESTING=1
                 LINK_OPTIONS  "-Wl,--wrap=_test_calloc -Wl,--wrap=image_oprom_parse")
 add_cmocka_test_environment(igsc_tests)
 
