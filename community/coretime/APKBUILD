# Maintainer: rahmanshaber <rahmanshaber@yahoo.com>
pkgname=coretime
pkgver=5.0.1
pkgrel=1
pkgdesc="Time related task manager from C-Suite"
arch="all !armhf"
url="https://gitlab.com/cubocore"
license="GPL-3.0-or-later"
depends="qt6-qtsvg"
makedepends="qt6-qtbase-dev libcprime-dev qt6-qtmultimedia-dev cmake ninja"
source="$pkgname-$pkgver-1.tar.gz::https://gitlab.com/cubocore/coreapps/coretime/-/archive/v$pkgver/coretime-v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-v$pkgver"
options="!check" # No test suite

build() {
	cmake -B build \
		-GNinja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_BUILD_TYPE=None
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
