6dc2a05948dd04338ae4a7034bb9407906be845fc72ba069cfc754b3983f4d7ff74296492e65764319aca79acf9ba0d20cc999fe8cddaad7e2bdb162bba758fb  0001-kitinerary-Use-KF6-KMime.patch
"
