maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=archlinux-keyring
pkgver=20260707.1
pkgrel=0
pkgdesc="Arch Linux PGP keyring"
url="https://gitlab.archlinux.org/archlinux/archlinux-keyring"
arch="noarch"
license="GPL-3.0-or-later"
makedepends="
	python3
	sequoia-sq
	"
source="https://gitlab.archlinux.org/archlinux/archlinux-keyring/-/archive/$pkgver/archlinux-keyring-$pkgver.tar.gz"
options="!check" # no tests

build() {
	./keyringctl -v build
}

package() {
	install -Dm644 build/* -t "$pkgdir"/usr/share/pacman/keyrings
}

