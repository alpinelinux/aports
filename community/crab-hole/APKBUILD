maintainer="Dominic <git@msrd0.de>"
pkgname=crab-hole
pkgver=0.2.0
pkgrel=0
_poemver=3.1.12
pkgdesc="A DNS level ad and spy blocker"
url="https://github.com/LuckyTurtleDev/crab-hole"
arch="all"
license="AGPL-3.0-or-later"
makedepends="cargo cargo-auditable"
subpackages="$pkgname-openrc"
source="https://github.com/LuckyTurtleDev/crab-hole/archive/refs/tags/v$pkgver/crab-hole-$pkgver.tar.gz
	poem-$_poemver.tar.gz::https://crates.io/api/v1/crates/poem/$_poemver/download
	vendor-poem-bump-nix.patch
	$pkgname.initd
	$pkgname.confd
	"
install="$pkgname.pre-install"
# net: needed for downloading dependencies
options="net"

# we use aws-lc-rs as crypto provider because it supports more architectures
_crypto=aws-lc-rs
_cargo_opts="--no-default-features --features $_crypto,native-roots"

prepare() {
	# vendor poem to bump nix crate for s390x
	mv "$srcdir/poem-$_poemver" vendored-poem
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen $_cargo_opts
}

check() {
	cargo test --frozen $_cargo_opts
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin/

	install -Dm644 example-config.toml "$pkgdir"/etc/$pkgname.toml

	install -D -m755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -D -m644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

