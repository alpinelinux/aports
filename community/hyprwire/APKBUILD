maintainer="Zach DeCook <zachdecook@librem.one>"
pkgname=hyprwire
pkgver=0.3.1
pkgrel=0
pkgdesc="Fast and consistent wire protocol for IPC"
url="https://github.com/hyprwm/hyprwire"
arch="all"
license="BSD-3-Clause"
source="
	https://github.com/hyprwm/hyprwire/archive/v$pkgver/hyprwire-v$pkgver.tar.gz
	"
subpackages="$pkgname-doc $pkgname-dev"
makedepends="
	cmake
	hyprutils-dev
	libffi-dev
	pugixml-dev
	samurai
	"
options="!check" # building tests not convenient

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_BUILD_TYPE=None
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}


sha512sums="
eb4d7d71d3101ad33897c06f08095d528a525880fbb20bb69b22d49bd8d920368cddea294125c814ebaf874574e63b268593b94443ab6cb6690d9990fe1d25f5  hyprwire-v0.3.1.tar.gz
"
