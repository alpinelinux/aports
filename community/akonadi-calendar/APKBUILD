64882690f06fe85df3f7006a28bc6b62cd06c990705c485ca30e87b4c901045dfb39b4f532b981dcdec93b6ea3674abac3218e60c6872d6ec6c3f900bffd1662  0001-akonadi-calendar-KMime-from-KF6.patch
"
