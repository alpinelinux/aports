# Maintainer: Willow Barraco <contact@willowbarraco.fr>
pkgname=bonsai
pkgver=1.5.2
pkgrel=1
pkgdesc="A Finite State Machine structured as a tree that trigger commands"
url="https://sr.ht/~stacyharper/bonsai/"
arch="x86_64 aarch64 riscv64" # hare
license="AGPL-3.0-or-later"
makedepends="hare hare-json hare-ev haredo"
subpackages="$pkgname-openrc"
source="
	$pkgname-v$pkgver.tar.gz::https://git.sr.ht/~stacyharper/bonsai/archive/v$pkgver.tar.gz
	bonsaid.initd
	"
builddir="$srcdir/$pkgname-v$pkgver"

build() {
	haredo
}

check() {
	haredo check
}

package() {
	DESTDIR="$pkgdir" PREFIX="/usr" haredo install
	install -Dm755 "$srcdir"/bonsaid.initd "$pkgdir"/etc/user/init.d/bonsaid
}

