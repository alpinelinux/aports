maintainer="Sören Tempel <soeren+alpine@soeren-tempel.net>"
pkgname=simple-cc
pkgver=0.1
pkgrel=0
pkgdesc="Portable toolchain that can be compiled on any UNIX system"
url="https://www.simple-cc.org/"
arch="x86_64 aarch64" # Limited upstream support.
license="ISC"
depends="qbe>=1.3 binutils $pkgname-dev !scc"
makedepends="ed"
subpackages="$pkgname-dev $pkgname-doc"
source="https://www.simple-cc.org/releases/scc-$pkgver.tar.gz
	fix-check.patch"
builddir="$srcdir/scc-$pkgver"

# TODO: check() only works on x86_64.
case "${CARCH}" in
x86_64) ;;
*) options="!check" ;;
esac

_arch() {
	case "${CARCH}" in
	x86_64)  echo "amd64" ;;
	aarch64) echo "arm64" ;;
	esac
}

build() {
	make TOOL=gnu HOST=linux CONF="$(_arch)-linux" \
		SCCMAKE=make config

	# By default, simple-cc is built using its own make(1)
	# implementation. However, this implementation does not
	# support parallel builds (as of now). Therefore, we force
	# usage of GNU make here to speedup the build significantly.
	make SCCMAKE=make
}

check() {
	# Adjust PATH to include the simple-cc programs. Further,
	# unset a bunch of environment varibales which interfere
	# with the tests, including MAKEFLAGS since the tests must
	# be run using scc-make.
	PATH="$PATH:$builddir/bin" \
		CFLAGS="" LDFLAGS="" \
		MAKEFLAGS="" make -j1 tests
}

package() {
	# XXX: Upstream does not ship a scripts/proto.arm64 file
	# in the release tarball, thus we generate it ourselves here.
	./scripts/update-proto.arch "$(_arch)"

	make SCCMAKE=make PREFIX=/usr DESTDIR="$pkgdir" install

	# Rename man pages of the standard library to avoid a conflict
	# with the ones provided by man-pages.
	local man=
	for man in "$pkgdir"/usr/share/man/man3/*; do
		mv "$man" "${man%/*}/scc-${man##*/}"
	done
}

sha512sums="
