# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-timer
pkgver=2.1.0_git20260512
pkgrel=0
_commit="eaa102fb833ca721173bd9cacfa3b28b3ac4155b"
pkgdesc="Default timer app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-timer"
# armhf blocked by qt6-qtdeclarative
#arch="all !armhf"
license="GPL-3.0-or-later"
depends="
	mapplauncherd
	nemo-qml-plugin-alarms
	"
makedepends="
	extra-cmake-modules
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-timer/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

