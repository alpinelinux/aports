# Contributor: Jonas <spameier+alpine@proton.me>
# Maintainer: Jonas <spameier+alpine@proton.me>
pkgname=goshs
pkgver=2.1.1
pkgrel=0
pkgdesc="A SimpleHTTPServer written in Go, enhanced with features and with a nice design."
url="https://goshs.de"
arch="all"
license="MIT"
makedepends="go"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/goshs-labs/goshs/archive/refs/tags/v$pkgver.tar.gz"
options="net !check" # no tests provided

export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

build() {
	go build -ldflags="-s -w"
}

package() {
	install -Dm755 "$builddir/goshs" -t "$pkgdir/usr/bin/"
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
bf7fd1046aaf9156885ba777401dfd83ea16697f638d9c11e8c83d7e5e697c7be54bfa5a4bb500c470ec2d598d897ef2c81aeb27dd71c09a828461ebe661bade  goshs-2.1.1.tar.gz
"
