# Contributor: Galen Abell <galen@galenabell.com>
# Maintainer: Galen Abell <galen@galenabell.com>
pkgname=py3-gls
pkgver=2.1.1
pkgrel=0
pkgdesc="pythonic generic language server"
url="https://github.com/openlawlibrary/pygls"
arch="noarch"
license="Apache-2.0"
depends="py3-lsprotocol py3-cattrs"
makedepends="py3-gpep517 py3-wheel py3-poetry-core"
checkdepends="py3-pytest py3-pytest-asyncio"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/openlawlibrary/pygls/archive/refs/tags/v$pkgver.tar.gz
	"
builddir="$srcdir/pygls-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
7d7582cfb5d15b523643a2ba662d3e6b083fd8f9f51b405f74e6491e7bdb6ebf6959b62b689d1368f0934542ccd9d6e7feb29ce28ac6c29f2c254a493e63bb0d  py3-gls-2.1.1.tar.gz
"
