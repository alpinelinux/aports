pkgname=somewm
pkgver=1.4.0
pkgrel=0
pkgdesc="awesomeWM port for wayland"
url="https://github.com/trip-zip/somewm"
arch="all !riscv64" # riscv64 doesn't have luajit package, yet
license="GPL-3.0-or-later"
depends="libdisplay-info libliftoff seatd xwayland libinput"
_luaver="5.4"
makedepends="meson
	cmake
	luajit
	cairo-dev
	gdk-pixbuf-dev
	glib-dev
	libev-dev
	imlib2-dev
	libinput-dev
	libxcb-dev
	libxdg-basedir-dev
	libxkbcommon-dev
	lua$_luaver-lgi
	lua$_luaver-dev
	pango-dev
	startup-notification-dev
	xcb-util-cursor-dev
	xcb-util-dev
	xcb-util-image-dev
	xcb-util-keysyms-dev
	xcb-util-wm-dev
	xcb-util-xrm-dev
	wlroots0.19-dev
	xwayland-dev
	wayland-protocols
	"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/trip-zip/somewm/archive/refs/tags/v$pkgver.tar.gz
	remove-dlvsym.patch
	"

build() {
	abuild-meson -Dwerror=false -Db_sanitize=none \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

