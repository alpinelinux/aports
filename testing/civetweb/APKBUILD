# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Jakub Jirutka <jakub@jirutka.cz>
pkgname=civetweb
pkgver=1.16
pkgrel=0
pkgdesc="Embedded C/C++ web server"
url="https://github.com/civetweb/civetweb"
arch="all"
license="MIT"
# NOTE: openssl is dynamically loaded in runtime
makedepends="
	cmake
	openssl-dev
	samurai
	zlib-dev
	"
subpackages="
	lib$pkgname
	lib$pkgname-cpp
	$pkgname-dev
	"
source="https://github.com/civetweb/civetweb/archive/v$pkgver/civetweb-$pkgver.tar.gz
	CMakeLists.txt.patch
	fix-heap-overflow.patch
	more-robust-url-parsing.patch
	"
builddir="$srcdir/civetweb-$pkgver"
options="!check"  # FIXME

prepare() {
	default_prepare

	rm build
}

build() {
	local crossopts=
	[ "$CBUILD" != "$CHOST" ] \
		&& crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"

	cmake -B build \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCIVETWEB_BUILD_TESTING=OFF \
		-DCIVETWEB_ENABLE_CXX=ON \
		-DCIVETWEB_ENABLE_ZLIB=ON \
		-DCIVETWEB_SSL_OPENSSL_API_1_1=OFF \
		-DCIVETWEB_SSL_OPENSSL_API_3_0=ON \
		$crossopts
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

libcivetweb() {
	pkgdesc="$pkgdesc (C library)"

	amove usr/lib/libcivetweb.so.*
}

cpp() {
	pkgdesc="$pkgdesc (C++ library)"

	amove usr/lib/libcivetweb-cpp.so.*
}

