# Contributor: Taner Tas <taner76@gmail.com>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=openfire
pkgver=5.1.1
pkgrel=0
pkgdesc="Openfire is a cross-platform real-time collaboration server based on the XMPP (Jabber) protocol"
url="https://www.igniterealtime.org/projects/openfire/"
# x86, armhf, armv7: blocked by openjdk>=11
# riscv64: blocked by maven
arch="noarch !x86 !armhf !armv7 !riscv64"
license="Apache-2.0"
depends="java-jre-headless $pkgname-plugins"
makedepends="maven"
subpackages="$pkgname-plugins $pkgname-openrc $pkgname-doc"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/igniterealtime/Openfire/archive/refs/tags/v$pkgver.tar.gz
	$pkgname.initd
	$pkgname.confd
	$pkgname.logrotate
	"
pkgusers="openfire"
pkggroups="openfire"
install="
	$pkgname.pre-install
	$pkgname.pre-upgrade
	openfire.post-install
	openfire.post-upgrade
	"
options="net !check" # No test suite
builddir="$srcdir/Openfire-$pkgver"
_dist="$builddir/distribution/target/distribution-base"

# secfixes:
#   4.7.5-r0:
#     - CVE-2023-32315

build() {
	rm -rf distribution/src/nativeAuth
	mvn package -Dmaven.test.skip=true
}

package() {
	_install_config
	_install_libs
	_install_resources
	_install_plugins
	_install_doc
	_install_openfirehome
	_install_openrc
}

plugins() {
	pkgdesc="$pkgdesc (bundled plugins)"
	depends="$pkgname=$pkgver-r$pkgrel"
	amove usr/share/openfire/plugins
}

doc() {
	pkgdesc="$pkgdesc (documentation)"
	depends="$pkgname=$pkgver-r$pkgrel"
	amove usr/share/doc/openfire
}

_install_config() {
	install -dm0700 -o $pkgusers -g $pkggroups "$pkgdir"/etc/openfire
	cp -r "$_dist"/conf/. "$pkgdir"/etc/openfire/
	cp -r "$_dist"/resources/security "$pkgdir"/etc/openfire

	for i in openfire.xml security.xml; do
		cp "$pkgdir"/etc/openfire/"$i" "$pkgdir"/etc/openfire/"$i".default
	done
	chmod 0600 "$pkgdir"/etc/openfire/openfire.xml \
		"$pkgdir"/etc/openfire/security.xml \
		"$pkgdir"/etc/openfire/openfire.xml.default \
		"$pkgdir"/etc/openfire/security.xml.default

	cd "$pkgdir"/etc/openfire/security
	for i in client.truststore keystore truststore; do
		mv "$i" "$i".default
		chmod 0600 "$i".default
	done

	chmod 0700 "$pkgdir"/etc/openfire/security
	chown -R $pkgusers:$pkggroups "$pkgdir"/etc/openfire
}

_install_libs() {
	install -dm0755 "$pkgdir"/usr/share/java/openfire
	cp -r "$_dist"/lib/. "$pkgdir"/usr/share/java/openfire/
	find "$pkgdir"/usr/share/java/openfire -type f -exec chmod 0644 {} \;
}

_install_resources() {
	install -dm0755 "$pkgdir"/usr/share/openfire/resources
	cp -r "$_dist"/resources/database "$pkgdir"/usr/share/openfire/resources
	cp -r "$_dist"/resources/spank "$pkgdir"/usr/share/openfire/resources
	ln -s /etc/openfire/security "$pkgdir"/usr/share/openfire/resources/security
	chown -R $pkgusers:$pkggroups "$pkgdir"/usr/share/openfire
}

_install_plugins() {
	cp -r "$_dist"/plugins "$pkgdir"/usr/share/openfire/
	chown -R $pkgusers:$pkggroups "$pkgdir"/usr/share/openfire/plugins
}

_install_doc() {
	install -dm0755 "$pkgdir"/usr/share/doc/openfire
	cp -r "$_dist"/documentation/. "$pkgdir"/usr/share/doc/openfire
}

_install_openfirehome() {
	install -dm0755 -o $pkgusers -g $pkggroups "$pkgdir"/var/lib/openfire
	ln -s /etc/openfire "$pkgdir"/var/lib/openfire/conf
	ln -s /usr/share/java/openfire "$pkgdir"/var/lib/openfire/lib
	ln -s /var/log/openfire "$pkgdir"/var/lib/openfire/logs
	ln -s /usr/share/openfire/resources "$pkgdir"/var/lib/openfire/resources

	install -dm775 -o $pkgusers -g $pkggroups "$pkgdir"/var/log/openfire
}

_install_openrc() {
	install -Dm0755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -Dm0644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
	install -Dm0644 "$srcdir"/$pkgname.logrotate "$pkgdir"/etc/logrotate.d/$pkgname
}

