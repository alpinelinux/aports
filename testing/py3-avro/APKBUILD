# Contributor: Gennady Feldman <gena01@gmail.com>
# Maintainer: Gennady Feldman <gena01@gmail.com>
pkgname=py3-avro
_pkgname=avro
pkgver=1.12.0
pkgrel=0
pkgdesc="Serialization and RPC framework"
url="https://avro.apache.org/"
arch="noarch"
license="Apache-2.0"
depends="python3"
makedepends="
	py3-gpep517
	py3-isort
	py3-setuptools
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/apache/avro/archive/release-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-release-$pkgver/lang/py"
options="net" # tests connect to apache.org

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m unittest discover
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
8cc6ef3cf1e0a919118c8ba5817a1866dc4f891fa95873c0fe1b4b388858fbadee8ed50406fa0006882cab40807fcf00c5a2dcd500290f3868d9d06b287eacb6  py3-avro-1.12.0.tar.gz
"
