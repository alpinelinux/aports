# Contributor: TBK <alpine@jjtc.eu>
# Maintainer: TBK <alpine@jjtc.eu>
pkgname=libwbxml
pkgver=0.11.10
pkgrel=0
pkgdesc="A library to encode and decode WBXML (WAP Binary XML)."
url="https://github.com/libwbxml/libwbxml"
arch="all"
license="LGPL-2.1-or-later"
makedepends="cmake expat-dev samurai"
checkdepends="check-dev coreutils perl"
subpackages="$pkgname-dev $pkgname-doc"
source="https://github.com/libwbxml/libwbxml/archive/libwbxml-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgname-$pkgver"

build() {
	if [ "$CBUILD" != "$CHOST" ]; then
		CMAKE_CROSSOPTS="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	fi
	cmake3.5 -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DENABLE_UNIT_TEST=ON \
		$CMAKE_CROSSOPTS
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	mv "$pkgdir"/cmake "$pkgdir"/usr/lib
}

sha512sums="
be8097a96ac82618e9e95c1368d502f46eab959e3ac6a5d5866b33d20f710c470df96928aa9bad5e785d2a2773186eadf1df7bcd7b4ffeaf9b05b92c8e1bc8f9  libwbxml-0.11.10.tar.gz
"
