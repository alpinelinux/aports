7150c16ceadc84ca3507d548fa363e4acd8f5c26dfe0df892aed40b751c3d2971f619ad6751f7bca9a8cacd6bfbc828add8b80931695b5204a089e72b628e2be  mpvqt-1.2.0.patch
"
