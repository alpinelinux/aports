From: Achill Gilgenast <achill@achill.org>
Date: Thu, 2 Jul 2026 22:37:31 +0200
Subject: [PATCH] resources: Add supported input methods

Signed-off-by: Achill Gilgenast <achill@achill.org>
---
 resources/meta/org.jellyfin.JellyfinDesktop.appdata.xml | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/resources/meta/org.jellyfin.JellyfinDesktop.appdata.xml b/resources/meta/org.jellyfin.JellyfinDesktop.appdata.xml
index 4f49dde78cb3..26680d1425b0 100644
--- a/resources/meta/org.jellyfin.JellyfinDesktop.appdata.xml
+++ b/resources/meta/org.jellyfin.JellyfinDesktop.appdata.xml
@@ -12,6 +12,14 @@
   <url type="help">https://github.com/jellyfin/jellyfin-desktop/blob/master/README.md</url>
   <url type="bugtracker">https://github.com/jellyfin/jellyfin-desktop/issues</url>
 
+  <supports>
+    <control>pointing</control>
+    <control>keyboard</control>
+    <control>touch</control>
+    <control>gamepad</control>
+    <control>tv-remote</control>
+  </supports>
+
   <provides>
     <binary>jellyfin-desktop</binary>
   </provides>
