maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=nemo-qml-plugin-calendar
pkgver=0.7.10
pkgrel=0
pkgdesc="QML plugin for calendars"
url="https://github.com/sailfishos/nemo-qml-plugin-calendar"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="BSD-3-Clause"
makedepends="
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	kcalendarcore-dev
	mkcal-dev
	libaccounts-qt-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/nemo-qml-plugin-calendar/archive/refs/tags/$pkgver.tar.gz
	0001-nemo-qml-plugin-calendar-feat-port-to-Qt6.patch
	"
options="!check"

build() {
	qmake6 PREFIX=/usr
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install

	# Remove installed tests
	rm -r "$pkgdir"/opt
}

