Subject: [PATCH] Fixup build on Qt >= 5.14

---
 .../mobiledataconnection.cpp                  |  2 +-
 src/nemo-connectivity/nemo-connectivity.pro   |  8 ++-
 src/nemo-connectivity/settingsvpnmodel.cpp    | 69 +++++++++++++++++++
 3 files changed, 77 insertions(+), 2 deletions(-)

diff --git a/src/nemo-connectivity/mobiledataconnection.cpp b/src/nemo-connectivity/mobiledataconnection.cpp
index a6d012b..1cddafb 100644
--- a/src/nemo-connectivity/mobiledataconnection.cpp
+++ b/src/nemo-connectivity/mobiledataconnection.cpp
@@ -128,7 +128,7 @@ void MobileDataConnectionPrivate::updateStatus()
     }
 
     qCDebug(CONNECTIVITY, "Update status: %d old: %d state: %s connecting service: %d %s", status, oldStatus,
-            qPrintable(state), connectingService, qPrintable(q->objectName()));
+            qPrintable(QVariant(state).toString()), connectingService, qPrintable(q->objectName()));
 }
 
 void MobileDataConnectionPrivate::updateNetworkServicePath()
diff --git a/src/nemo-connectivity/nemo-connectivity.pro b/src/nemo-connectivity/nemo-connectivity.pro
index 5509d98..f984382 100644
--- a/src/nemo-connectivity/nemo-connectivity.pro
+++ b/src/nemo-connectivity/nemo-connectivity.pro
@@ -8,7 +8,13 @@ CONFIG += \
         create_prl \
         no_install_prl
 
-QT = dbus network qml xmlpatterns
+QT = dbus network qml
+
+lessThan(QT_MAJOR_VERSION, 6) {
+    QT += xmlpatterns
+} else {
+    QT += xml
+}
 
 INCLUDEPATH += ..
 
