maintainer="Fabricio Silva <hi@fabricio.dev>"
pkgname=knot-git # conflicts with main/knot
_pkgdid="did:plc:j5hmlfdrwkvtxm7cjmu7j2is"
pkgver=1.15.0_alpha
_pkgver=${pkgver/_alpha/-alpha}
pkgrel=0
pkgdesc="Knot is the headless Git server to self-host on Tangled.org"
url="https://tangled.org/tangled.org/core"
arch="all"
license="MIT"
makedepends="go"
depends="git bash" # bash for git-hooks
options="net" # net for go
subpackages="$pkgname-doc $pkgname-openrc"
install="$pkgname.pre-install $pkgname.post-install"
# monorepo
source="
	$pkgname-$pkgver.tar.gz::https://tangled.org/tangled.org/core/archive/v$_pkgver
	knot-git.initd
	knot-git.confd
	"
builddir="$srcdir/$_pkgdid-v$_pkgver"

build() {
	go build ./cmd/knot
}

check() {
	# only need to tests knotserver
	go test ./knotserver/...
}

package() {
	install -Dm755 knot "$pkgdir"/usr/bin/knot-git
	install -Dm644 license -t "$pkgdir"/usr/share/licenses/$pkgname

	install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -Dm644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

