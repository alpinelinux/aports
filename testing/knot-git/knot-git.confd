# knot-git server configuration options
command_user="git:git" # user:group (has to run as "git" to prevent "fatal: detected dubious ownership")
directory="/var/lib/git"
supervisor="supervise-daemon"
error_log="/var/log/knot-git.log"

# Environment variabless
#export KNOT_SERVER_DEV=""                  # default: false
#export KNOT_SERVER_LISTEN_ADDR=""          # default: 0.0.0.0:5555
#export KNOT_SERVER_INTERNAL_LISTEN_ADDR="" # default: 127.0.0.1:5444

export KNOT_SERVER_DB_PATH="$directory/knotserver.db"
export KNOT_SERVER_HOSTNAME="" # required (knot.domain.com)
export KNOT_SERVER_OWNER=""    # required (did:plc:foobar)
#export KNOT_SERVER_LOG_DIDS="" # default: true

export KNOT_REPO_SCAN_PATH="$directory/repositories" # has to keep it under "git" rights
#export KNOT_REPO_MAIN_BRANCH="" # default: main

#export KNOT_GIT_USER_NAME=""  # default: Tangled
#export KNOT_GIT_USER_EMAIL="" # default: noreply@tangled.sh
