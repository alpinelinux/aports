# Maintainer: Willow Barraco <contact@willowbarraco.fr>
pkgname=py3-mpegdash
pkgver=0.4.1
pkgrel=0
pkgdesc="MPEG-DASH MPD (Media Presentation Description) Parser compatible with Python 3+"
url="https://pypi.org/project/mpegdash/"
arch="noarch"
license="MIT"
makedepends="py3-gpep517 py3-setuptools py3-wheel"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/sangwonl/python-mpegdash/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/python-mpegdash-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# skip test that uses http://yt-dash-mse-test.commondatastorage.googleapis.com
	.testenv/bin/python3 -m pytest \
		--deselect tests/test_xmltompd.py::XML2MPDTestCase::test_xml2mpd_from_url
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
cd2b077d652a2bcaf7bb250696e90df07efe69fe0aa76636363ae810c4ed9cdc6d5cc2521964b2f69f018526f5f150c931b1b0feba5ccb977f171e09b4ba16fb  py3-mpegdash-0.4.1.tar.gz
"
