maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=tree-sitter-scss
pkgver=1.0.0
pkgrel=0
pkgdesc="SCSS grammar for tree-sitter"
url="https://github.com/tree-sitter-grammars/tree-sitter-scss"
arch="all"
license="MIT"
makedepends="tree-sitter-dev tree-sitter-css"
checkdepends="tree-sitter-cli"
install_if="tree-sitter-grammars"
source="$pkgname-$pkgver.tar.gz::https://github.com/tree-sitter-grammars/tree-sitter-scss/archive/refs/tags/v$pkgver.tar.gz"

build() {
	abuild-tree-sitter build
}

check() {
	tree-sitter test
}

package() {
	DESTDIR="$pkgdir" abuild-tree-sitter install

	# Grammar extends tree-sitter-css, but its queries only cover the
	# SCSS-specific nodes. Concatenate them.
	cat /usr/share/tree-sitter/queries/css/highlights.scm \
		queries/highlights.scm \
		>"$pkgdir"/usr/share/tree-sitter/queries/scss/highlights.scm
}
sha512sums="
164d971ba26d67549c68a76c3c235d18c9551ebcdc0e5ef00b82f8ecb084ed63797e77331eef033363fcfa4d8b1820d7b1fd963e1e314402d98962756423f93f  tree-sitter-scss-1.0.0.tar.gz
"
