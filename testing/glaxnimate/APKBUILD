# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-other
maintainer="team/kde <bribbers@disroot.org>"
pkgname=glaxnimate
pkgver=0.6.0
pkgrel=0
# armhf blocked by qt6-qtdeclarative
# s390x blocked by test failures
arch="all !armhf !s390x"
url="https://apps.kde.org/glaxnimate/"
pkgdesc="A vector animation and motion design desktop application"
license="GPL-3.0-or-later"
makedepends="
	extra-cmake-modules
	karchive-dev
	kcompletion-dev
	kconfig-dev
	kcoreaddons-dev
	kcrash-dev
	ki18n-dev
	kiconthemes-dev
	kwidgetsaddons-dev
	kxmlgui-dev
	libarchive-dev
	potrace-dev
	qt6-qtbase-dev
	qt6-qtsvg-dev
	samurai
	"
subpackages="$pkgname-lang"
_repo_url="https://invent.kde.org/graphics/glaxnimate.git"
source="https://download.kde.org/stable/glaxnimate/$pkgver/glaxnimate-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DBUILD_WITH_QT6=ON \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
f07b021d4550d0b1b5a2a93a3eb86eda2312565ecfc43bb7da92ba6c4ede5b58609cb1dbebc6da80afbc3bca80b9056803d874bd2ceb63c18814e8b06521eddf  glaxnimate-0.6.0.tar.xz
"
