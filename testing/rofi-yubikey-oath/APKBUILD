# Contributor: Jacques Boscq <jacques@boscq.fr>
# Maintainer: Jacques Boscq <jacques@boscq.fr>
pkgname=rofi-yubikey-oath
pkgver=1.2.0
pkgrel=0
pkgdesc="Rofi plugin to access OATH TOTP codes from a YubiKey"
url="https://github.com/Amodio/rofi-yubikey-oath"
arch="all"
license="MIT"
# ccid supplies the CCID smart-card driver; pcsc-lite brings pcscd at runtime.
depends="
	ccid
	pcsc-lite
	rofi
	wl-clipboard
	"
makedepends="
	glib-dev
	meson
	pcsc-lite-dev
	rofi-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/Amodio/rofi-yubikey-oath/archive/refs/tags/v$pkgver.tar.gz"
options="!check"  # no tests available

build() {
	abuild-meson . build
	meson compile -C build
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C build
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

sha512sums="
9b2a3123bd405c3b2a887f39b1df4d7d9c142212d435922064ca4ad3d80be7ae209b855e5104c235e7dff8dc0cb9bbff196d0bccb792feb0d6b04d4d73a6a282  rofi-yubikey-oath-1.2.0.tar.gz
"
