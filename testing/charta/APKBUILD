pkgname=charta
pkgver=0.12.2
pkgrel=1
pkgdesc="Tool for displaying small colored charts in the terminal"
url="https://spn109.fr/charta/"
arch="all"
license="Apache-2.0"
makedepends="go"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/spn109/charta/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname/"
options="net" #go deps

build() {
	go build -v
}

check() {
	go test ./...
}

package() {
	install -m755 -D charta "$pkgdir"/usr/bin/charta
}

