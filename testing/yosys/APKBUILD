# Contributor: Dominika Liberda <ja@sdomi.pl>
# Maintainer: Dominika Liberda <ja@sdomi.pl>
pkgname=yosys
pkgver=0.66
pkgrel=0
pkgdesc="Yosys Open SYnthesis Suite"
url="https://yosyshq.net"
# s390x: https://github.com/YosysHQ/yosys/issues/2645
arch="all !s390x"
license="ISC"
depends="
	abc
	"
makedepends="
	bash
	bison
	boost-dev
	flex-dev
	gawk
	graphviz-dev
	libffi-dev
	lld
	protobuf-dev
	py3-cxxheaderparser
	py3-pybind11-dev
	python3
	readline-dev
	tcl-dev
	zlib-dev
	"
checkdepends="
	gtest-dev
	gtkwave
	iverilog
	"
subpackages="$pkgname-dev py3-$pkgname:py3:noarch"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/YosysHQ/yosys/releases/download/v$pkgver/yosys-src.tar.gz
	fix-32-bit-oom.patch
	fix-libyosys-python-link.patch
	fix-pybind11-unused-parameter.patch
	"
builddir="$srcdir"

prepare() {
	default_prepare

	cat > Makefile.conf <<- EOF
	CONFIG:=gcc
	PREFIX:=/usr
	ABCEXTERNAL:=/usr/bin/abc
	ENABLE_ABC:=1
	ENABLE_LIBYOSYS:=1
	ENABLE_NDEBUG:=1
	ENABLE_PROTOBUF:=1
	ENABLE_PYOSYS:=1
	PYOSYS_USE_UV:=0
	EOF
}

build() {
	# Not using LTO, as test segfault with LTO enabled. Not unique to Alpine:
	# https://gitlab.archlinux.org/archlinux/packaging/packages/yosys/-/blob/main/PKGBUILD?ref_type=heads#L20
	make CXX=g++
}

check() {
	make CXX=g++ ABCEXTERNAL=/usr/bin/abc test
}

package() {
	make CXX=g++ DESTDIR="$pkgdir" install

	# link python to the global yosys
	ln -sfv /usr/lib/yosys/libyosys.so "$pkgdir"/usr/lib/python3*/site-packages/pyosys/libyosys.so
}

py3() {
	pkgdesc="$pkgdesc (python module)"
	depends="python3 $pkgname=$pkgver-r$pkgrel"

	amove usr/lib/python3*
}

