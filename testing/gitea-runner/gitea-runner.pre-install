#!/bin/sh

addgroup -S gitea-runner 2>/dev/null
adduser -S -D -H -h /var/lib/gitea-runner -s /sbin/nologin -G gitea-runner -g gitea-runner gitea-runner 2>/dev/null

cat >&2 <<EOF
* In order to setup the runner, create a config file
* in /etc/gitea-runner/config.yaml (either from .example.yaml,
* or generating your own with 'gitea-runner generate-config'),
* then register it with 'doas -u gitea-runner gitea-runner register'
* ran in the /var/lib/gitea-runner directory.
EOF

exit 0
