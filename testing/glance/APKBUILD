pkgname=glance
pkgver=0.8.5
pkgrel=0
arch="all"
url="https://github.com/glanceapp/glance"
pkgdesc="Dashboard that puts all your feeds in one place"
source="$pkgname-$pkgver.tar.gz::https://github.com/glanceapp/glance/archive/refs/tags/v$pkgver.tar.gz"
license="AGPL-3.0-or-later"
makedepends="go binutils"
options="!check net" # no testsuite in upstream, go

export GOFLAGS="$GOFLAGS -modcacherw"

build() {
	go build
	strip glance
}

package() {
	mkdir -p "$pkgdir"/usr/bin
	install glance "$pkgdir"/usr/bin
}

sha512sums="
