maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=nemo-qml-plugin-connectivity
pkgver=0.2.24
pkgrel=0
pkgdesc="QML plugin for network connectivity"
url="https://github.com/sailfishos/nemo-qml-plugin-connectivity"
# armhf blocked by qt6-qtdeclarative
# riscv64 blocked by libqofono
arch="all !armhf !riscv64"
license="BSD-3-Clause"
depends_dev="
	karchive-dev
	libqofono-dev
	libqofonoext-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	"
makedepends="$depends_dev
	libconnman-qt-dev
	"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/nemo-qml-plugin-connectivity/archive/refs/tags/$pkgver.tar.gz
	0001-nemo-qml-plugin-connectivity-Fixup-build-on-Qt-6.patch
	0002-nemo-qml-plugin-connectivity-Find-qofonoext-Qt6.patch
	"
options="!check"

build() {
	qmake6 PREFIX=/usr
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install
}

