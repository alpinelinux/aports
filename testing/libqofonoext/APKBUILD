maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=libqofonoext
pkgver=1.0.35
pkgrel=0
pkgdesc="C++ API for Jolla ofono extensions"
url="https://github.com/sailfishos/libqofonoext"
# armhf blocked by qt6-qtdeclarative
# riscv64 blocked by libqofono
arch="all !armhf !riscv64"
license="BSD-3-Clause"
depends_dev="
	qt6-qtbase-dev
	libqofono-dev
	qt6-qtdeclarative-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	samurai
	"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/libqofonoext/archive/refs/tags/$pkgver.tar.gz"
options="!check" # No tests

build() {
	cmake -B build -G Ninja \
		-DQT_MAJOR_VERSION=6 \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
1d924e9b4c60e23303568a3443496b7eb3e93c5f45601c7dfee632f49128aeb8ca96f2d486c12faa2b7881b67408aebbd11a0df4d16189bd66897b3c2ce5a0ce  libqofonoext-1.0.35.tar.gz
"
