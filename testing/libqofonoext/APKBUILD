maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=libqofonoext
pkgver=1.0.34
pkgrel=0
pkgdesc="C++ API for Jolla ofono extensions"
url="https://github.com/sailfishos/libqofonoext"
# armhf blocked by qt6-qtdeclarative
# riscv64 blocked by libqofono
arch="all !armhf !riscv64"
license="BSD-3-Clause"
depends_dev="
	qt6-qtbase-dev
	libqofono-dev
	qt6-qtdeclarative-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	samurai
	"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/libqofonoext/archive/refs/tags/$pkgver.tar.gz
	0001-fix-cmake-add-the-qt6-suffix-to-the-lib-name-in-the-.patch
	"
options="!check" # No tests

build() {
	cmake -B build -G Ninja \
		-DQT_MAJOR_VERSION=6 \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

