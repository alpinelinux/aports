# Contributor: andar1an <stephen@theandar1an.com>
# Maintainer: andar1an <stephen@theandar1an.com>
pkgname=resvg
pkgver=0.47.0
pkgrel=1
pkgdesc="SVG rendering library"
url="https://github.com/linebender/resvg"
arch="all"
license="Apache-2.0 OR MIT"
makedepends="
	cargo
	cargo-c
	cargo-auditable
"
subpackages="$pkgname-dev $pkgname-libs"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/linebender/resvg/archive/refs/tags/v$pkgver.tar.gz
"
options="net" # cargo fetch

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen --workspace

	cargo auditable cbuild -p resvg-capi \
		--release \
		--frozen \
		--prefix /usr \
		--libdir=/usr/lib \
		--library-type cdylib \
		--library-type staticlib
}

check() {
	cargo test --release --frozen --workspace
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin/
	install -Dm755 target/release/usvg -t "$pkgdir"/usr/bin/

	cargo auditable cinstall -p resvg-capi \
		--release \
		--frozen \
		--prefix /usr \
		--libdir=/usr/lib \
		--destdir "$pkgdir" \
		--library-type cdylib \
		--library-type staticlib

	install -Dm644 LICENSE-APACHE LICENSE-MIT  -t "$pkgdir"/usr/share/licenses/$pkgname/

}

sha512sums="
f0fdbc2ec4c6cff5a5d7ed79450716467744195c882a2caa17b4b5ec5a9a9a79a15ed61ce8ab06cb52fa98288976fa555c51127cbb91a9e877879c496cd4d420  resvg-0.47.0.tar.gz
"
