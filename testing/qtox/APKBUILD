# Contributor: Patrycja Rosa <alpine@ptrcnull.me>
# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=qtox
pkgver=1.18.4
pkgrel=0
pkgdesc="IM client using the encrypted peer-to-peer Tox protocol"
url="https://qtox.github.io/"
# armhf: sonnet
arch="all !armhf !ppc64le"
license="GPL-3.0-or-later"
makedepends="
	cmake
	ffmpeg-dev
	libexif-dev
	libqrencode-dev
	libsodium-dev
	libvpx-dev
	libx11-dev
	libxscrnsaver-dev
	openal-soft-dev
	qt6-qtbase-dev
	qt6-qtsvg-dev
	qt6-qttools-dev
	samurai
	sonnet-dev
	sqlcipher-dev
	toxcore-dev
	"
source="https://github.com/TokTok/qTox/archive/refs/tags/v$pkgver/qtox-$pkgver.tar.gz"
builddir="$srcdir/qTox-$pkgver"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=True \
		-DCMAKE_BUILD_TYPE=MinSizeRel
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
265d4b7266e05f5ad2389a766d72af2be111089d77ddedff39b9409e519542c2712d49225b759f93d33bf2cf2b988d24338dd2225bcc0e2755f07129bb8a6797  qtox-1.18.4.tar.gz
"
