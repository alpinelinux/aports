# Contributor: Patrycja Rosa <alpine@ptrcnull.me>
# Maintainer: Patrycja Rosa <alpine@ptrcnull.me>
pkgname=qtox
pkgver=1.18.5
pkgrel=1
pkgdesc="IM client using the encrypted peer-to-peer Tox protocol"
url="https://qtox.github.io/"
# armhf: sonnet
arch="all !armhf !ppc64le"
license="GPL-3.0-or-later"
makedepends="
	cmake
	ffmpeg-dev
	libexif-dev
	libqrencode-dev
	libsodium-dev
	libvpx-dev
	libx11-dev
	libxscrnsaver-dev
	openal-soft-dev
	qt6-qtbase-dev
	qt6-qtsvg-dev
	qt6-qttools-dev
	samurai
	sonnet-dev
	sqlcipher-dev
	toxcore-dev
	"
source="https://github.com/TokTok/qTox/archive/refs/tags/v$pkgver/qtox-$pkgver.tar.gz"
builddir="$srcdir/qTox-$pkgver"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=True \
		-DCMAKE_BUILD_TYPE=MinSizeRel
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
25a6cbb1a7059740c3eea3667225d5460e4a686f175acb593f9248c2e3e7789bd2ad6edb829013abf09862f9ac60012e18aae477abf0c02f9b4d441afc4f359d  qtox-1.18.5.tar.gz
"
