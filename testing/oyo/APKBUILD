# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=oyo
pkgver=0.1.33
pkgrel=0
pkgdesc="diff & review TUI"
url="https://github.com/ahkohd/oyo"
license="MIT"
arch="all"
makedepends="cargo cargo-auditable"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/ahkohd/oyo/archive/refs/tags/v$pkgver.tar.gz"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 -t "$pkgdir"/usr/bin/ target/release/oy
	install -Dm644 -t "$pkgdir"/usr/share/doc/"$pkgname"/ \
		README.md docs/*
	install -Dm644 -t "$pkgdir"/usr/share/licenses/"$pkgname"/ \
		LICENSE.md
}

sha512sums="
73beda03bbf957a7564cc85e60f12164aa640416f0371e29009776b2f646d4f1bc57edeb76b562f4fea4f95ffcc3c184aea3ace50730bd1d270045c5487735a7  oyo-0.1.33.tar.gz
"
