From b68e51db6df1ed2637692dbff704374ab4c53fa7 Mon Sep 17 00:00:00 2001
From: OPNA2608 <opna2608@protonmail.com>
Date: Sat, 7 Feb 2026 13:50:13 +0100
Subject: [PATCH] Properly include lomiri-shell-api includedirs

In lomiri-api 0.3.0, the includedirs of the individual components were moved to subdir of <...>/include.

The includes here previously only worked because <...>/include is often put into the compiler's
list of default include dirs. Explicitly include the correct dirs instead.
---
 src/CMakeLists.txt | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index 56f2ab0..c9a7d2f 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -51,6 +51,11 @@ set_target_properties(notifyplugin PROPERTIES
   VERSION ${SOVERSION}
 )
 
+target_include_directories(notifybackend
+  PUBLIC
+  ${NOTIFICATIONS_API_INCLUDE_DIRS}
+)
+
 target_link_libraries(
   notifyplugin
   notifybackend
-- 
2.53.0

