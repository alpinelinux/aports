maintainer="Дмитрий <wakoo1337@yandex.ru>"
pkgname=xcursor-themes
pkgver=1.0.7
pkgrel=0
pkgdesc="Default cursor themes for libXcursor"
url="https://xorg.freedesktop.org/"
arch="noarch"
license="HPND-sell-variant"
makedepends="
	xcursorgen
	libxcursor-dev
"
source="https://www.x.org/archive/individual/data/xcursor-themes-$pkgver.tar.xz"

build() {
	./configure --prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--localstatedir=/var
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
