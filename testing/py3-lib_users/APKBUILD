# Contributor: Michael Pirogov <vbnet.ru@gmail.com>
# Maintainer: Michael Pirogov <vbnet.ru@gmail.com>
pkgname=py3-lib_users
_pkgname=lib_users
pkgver=0.15
pkgrel=5
pkgdesc="Checks /proc for libraries being mapped but marked as deleted"
url="https://codeberg.org/klausman/lib_users"
arch="noarch"
license="GPL-2.0-or-later"
depends="python3"
makedepends="py3-setuptools py3-gpep517"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver-1.tar.gz::https://codeberg.org/klausman/lib_users/archive/v$pkgver.tar.gz
	setuptools.patch
	assertEquals.patch
	"
builddir="$srcdir"/$_pkgname

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m unittest discover || [ "$?" = "120" ] # https://bugs.python.org/issue29130
}

package() {
	gpep517 install-wheel --destdir "$pkgdir" \
		.dist/*.whl
}

