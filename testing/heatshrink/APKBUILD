# Contributor: 7222e800 <aports@estrogen.zone>
# Maintainer: 7222e800 <aports@estrogen.zone>
pkgname=heatshrink
pkgver=0.4.1
pkgrel=0
pkgdesc="Data compression library for embedded/real-time systems"
url="https://github.com/atomicobject/heatshrink"
arch="all"
license="ISC"
makedepends="cmake samurai"
subpackages="$pkgname-dev"
_prusaslicer_ver=69c8e569410efe82259e706cd09a05ea82da9359
source="https://github.com/atomicobject/heatshrink/archive/v$pkgver/heatshrink-$pkgver.tar.gz
	CMakeLists.txt-$pkgname-$_prusaslicer_ver::https://raw.githubusercontent.com/prusa3d/PrusaSlicer/$_prusaslicer_ver/deps/%2Bheatshrink/CMakeLists.txt
	Config.cmake.in-$pkgname-$_prusaslicer_ver::https://raw.githubusercontent.com/prusa3d/PrusaSlicer/$_prusaslicer_ver/deps/%2Bheatshrink/Config.cmake.in"

prepare() {
	default_prepare
	cp "$srcdir/CMakeLists.txt-$pkgname-$_prusaslicer_ver" "$builddir/CMakeLists.txt"
	cp "$srcdir/Config.cmake.in-$pkgname-$_prusaslicer_ver" "$builddir/Config.cmake.in"
}

build() {
	if [ "$CBUILD" != "$CHOST" ]; then
		local crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	fi
	cmake -B build \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=None \
		$crossopts
	cmake --build build
}

check() {
	make test
}

package() {
	DESTDIR="$pkgdir" cmake --install build
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/"$pkgname"/
}

