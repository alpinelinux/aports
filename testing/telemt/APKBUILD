# Contributor: Oleg Titov <oleg.titov@gmail.com>
# Maintainer: Oleg Titov <oleg.titov@gmail.com>
pkgname=telemt
pkgver=3.3.27
pkgrel=0
pkgdesc="MTProxy for Telegram on Rust + Tokio"
url="https://github.com/telemt/telemt"
arch="all"
license="custom"
makedepends="cargo cargo-auditable"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/telemt/telemt/archive/refs/tags/$pkgver.tar.gz"
options="net" # To download crates

build() {
	cargo auditable build --release
}

check() {
	cargo test --frozen --offline
}

package() {
	install -Dm755 target/release/telemt -t "$pkgdir"/usr/bin/

	install -Dm644 config.toml -t "$pkgdir/etc/telemt"

	install -Dm644 README.md -t "$pkgdir/usr/share/doc/telemt"
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/"$pkgname"/
}

sha512sums="
bbb7ecece5bd5dc560c5e91df400d03c36966574706d9a4be3e59e584e052a656dbcc0c595501346e996c8de9a3223181d924aba4aec1e8ae15bb801797cc9a7  telemt-3.3.27.tar.gz
"
