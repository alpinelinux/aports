maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=cinnamon-screensaver
pkgver=6.6.1
pkgrel=0
pkgdesc="Cinnamon screen locker and screensaver program (fork of gnome-screensaver"
url="https://github.com/linuxmint/cinnamon-screensaver"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	gobject-introspection-dev
	gtk+3.0-dev
	linux-pam-dev
	meson
	xdotool-dev
	"
source="https://github.com/linuxmint/cinnamon-screensaver/archive/$pkgver/cinnamon-screensaver-$pkgver.tar.gz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
