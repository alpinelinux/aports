pkgname=diffoci
pkgver=0.1.8
pkgrel=0
pkgdesc="diff for Docker and OCI container images"
url="https://github.com/reproducible-containers/diffoci"
arch="all"
license="Apache-2.0"
makedepends="go"
source="https://github.com/reproducible-containers/diffoci/archive/v$pkgver/diffoci-$pkgver.tar.gz"
options="net !check"

prepare() {
	default_prepare
	mkdir -p build/
}

build() {
	go build -o "build" ./cmd/...
}

package() {
	install -Dm 755 "build/$pkgname" "$pkgdir/usr/bin/$pkgname"
}

