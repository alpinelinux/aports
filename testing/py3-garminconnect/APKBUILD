maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-garminconnect
pkgver=0.3.6
pkgrel=0
pkgdesc="API wrapper for Garmin Connect to get statistics and set activities"
url="https://github.com/cyberjunky/python-garminconnect"
arch="noarch"
license="MIT"
depends="
	py3-cffi
	py3-pydantic
	py3-requests
	"
makedepends="
	py3-gpep517
	py3-pdm-backend
	py3-setuptools
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-doc $pkgname-pyc"
source="https://github.com/cyberjunky/python-garminconnect/archive/$pkgver/python-garminconnect-$pkgver.tar.gz"
builddir="$srcdir/python-garminconnect-$pkgver"
options="!check" # integration-tests with garmin api can be bogus

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
	install -Dm644 demo.py example.py -t "$pkgdir"/usr/share/doc/$pkgname/
}

sha512sums="
dc9d3eabcac2b51d8240e84cff6d26226685621681e731e5598e4b271febcd54e0a1ac60a7bcac70e8533e8be6580e3b17ca378d2b7c3c81144ca791fdd6c728  python-garminconnect-0.3.6.tar.gz
"
