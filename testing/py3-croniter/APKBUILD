maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-croniter
pkgver=6.2.4
pkgrel=0
pkgdesc="Iteration for datetime object with cron like format"
url="https://pypi.org/project/croniter/"
arch="noarch"
license="MIT"
depends="py3-dateutil py3-tz"
makedepends="py3-gpep517 py3-setuptools py3-wheel py3-hatchling"
checkdepends="py3-pytest tzdata"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/c/croniter/croniter-$pkgver.tar.gz"
builddir="$srcdir/croniter-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
a94b0f9e21f37639a98b806c6be1064b3d0deb6237243a151edc7ab55c13ddf027d750e30107be828772f178366cbac9beab2e40fd3ee6b800f1dd2bb9b4ee8e  croniter-6.2.4.tar.gz
"
