maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-croniter
pkgver=6.2.2
pkgrel=0
pkgdesc="Iteration for datetime object with cron like format"
url="https://pypi.org/project/croniter/"
arch="noarch"
license="MIT"
depends="py3-dateutil py3-tz"
makedepends="py3-gpep517 py3-setuptools py3-wheel py3-hatchling"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/c/croniter/croniter-$pkgver.tar.gz"
builddir="$srcdir/croniter-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
f7b32c0f2984a34f401e9e5017a5a51a81d63a07c7081ae0da7606e01d41ccc06fdafcf5e8b27543bc8711ecd0552fb9650bd5acafe182fd31b43a85e3c8e885  croniter-6.2.2.tar.gz
"
