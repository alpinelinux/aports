# Contributor: Guy Godfroy <guy.godfroy@gugod.fr>
# Maintainer: Guy Godfroy <guy.godfroy@gugod.fr>
pkgname=mautrix-telegram
pkgver=0.2606.0
pkgrel=0
pkgdesc="Matrix-Telegram puppeting bridge"
url="https://go.mau.fi/mautrix-telegram/"
arch="all"
license="AGPL-3.0-or-later"
depends="ffmpeg lottieconverter"
makedepends="go olm-dev sqlite-dev"
install="$pkgname.pre-install"
subpackages="$pkgname-openrc $pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/mautrix/telegram/archive/v$pkgver.tar.gz
	mautrix-telegram.initd
	mautrix-telegram.confd
	"
builddir="$srcdir/telegram-$pkgver"
options="net"

export GOFLAGS="$GOFLAGS -tags=libsqlite3"
export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

build() {
	export CGO_CFLAGS="$CFLAGS"
	export CGO_LDFLAGS="$LDFLAGS"

	go build \
		-ldflags "-X main.Tag=$pkgver -X 'main.BuildTime=$(date -d @"$SOURCE_DATE_EPOCH" '+%b %_d %Y, %H:%M:%S')'" \
		./cmd/mautrix-telegram
}

check() {
	# test the bridge only; vendored pkg/gotd tests hang (neo clock) / miscompile (s390x)
	go list ./... | grep -v '/pkg/gotd' | xargs go test
}

package() {
	install -Dm755 mautrix-telegram \
		-t "$pkgdir"/usr/bin/
	install -Dm644 pkg/connector/example-config.yaml \
		"$pkgdir"/etc/mautrix-telegram/example-config.yaml

	install -Dm755 "$srcdir"/mautrix-telegram.initd \
		"$pkgdir"/etc/init.d/mautrix-telegram
	install -Dm644 "$srcdir"/mautrix-telegram.confd \
		"$pkgdir"/etc/conf.d/mautrix-telegram

	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE
}

