maintainer="Linus Groh <mail@linusgroh.de>"
pkgname=kiesel
pkgver=0.2.0
pkgrel=0
pkgdesc="JavaScript engine written in Zig"
url="https://kiesel.dev/"
# armhf, armv7, x86: no zig port
# riscv64: rust lacks riscv64gc-alpine-linux-musl target
# s390x: fails tests
arch="all !armhf !armv7 !riscv64 !s390x !x86"
license="MIT"
makedepends="zig cargo"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/kiesel-js/kiesel/archive/$pkgver.tar.gz
	alpine-rust-targets.patch
	"
builddir="$srcdir/kiesel"
options="net" # zig deps

build() {
	zig build \
		-Dcpu=baseline \
		-Doptimize=ReleaseSafe \
		-Dversion-string="$pkgver"
}

check() {
	zig build test
}

package() {
	install -Dm755 zig-out/bin/kiesel -t "$pkgdir"/usr/bin/
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
	install -Dm644 docs/kiesel.1 -t "$pkgdir"/usr/share/man/man1/
}

sha512sums="
1c2e93a4777af3fb17e4b19945bafafa6b3f8f8c527b84dafe2b7fb955712cc4f739e90c631313facf11891353b16869fd6c02ba3d6e7e9e6a18c847ca65d329  kiesel-0.2.0.tar.gz
cb4e266f4925d407f95b74b2d1ba1bf52470e0a31721b90cfc119b053fdcb2a4f70e1128ae6c6556826486598e3c7a5b407c16588a5c95497900b65eb0e9c561  alpine-rust-targets.patch
"
