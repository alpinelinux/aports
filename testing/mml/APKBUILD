# Contributor: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
maintainer=""
pkgname=mml
pkgver=1.1.1
pkgrel=0
pkgdesc="Command line tool for MIME message Meta Language"
url="https://github.com/soywod/mml"
# riscv64: ftbfs, segfault
# loongarch64: blocked by libc crate
arch="all !riscv64 !loongarch64"
license="MIT"
makedepends="cargo cargo-auditable"
subpackages="
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="mml-$pkgver.tar.gz::https://github.com/soywod/mml/archive/refs/tags/v$pkgver.tar.gz"
options="net" # fetch dependencies

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen --features cli
	./target/release/mml completion bash >$pkgname.bash
	./target/release/mml completion fish >$pkgname.fish
	./target/release/mml completion zsh >$pkgname.zsh
	./target/release/mml man ./
}

check() {
	cargo test --frozen
}

package() {
	install -Dm 0755 target/release/$pkgname "$pkgdir/usr/bin/$pkgname"

	install -Dm644 $pkgname.bash \
		"$pkgdir"/usr/share/bash-completion/completions/$pkgname
	install -Dm644 $pkgname.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/$pkgname.fish
	install -Dm644 $pkgname.zsh \
		"$pkgdir"/usr/share/zsh/site-functions/_$pkgname

	install -Dm 644 -t "$pkgdir/usr/share/man/man1/" \
		mime-meta-language-compile.1 \
		mime-meta-language-completions.1 \
		mime-meta-language-compose.1 \
		mime-meta-language-forward.1 \
		mime-meta-language-interpret.1 \
		mime-meta-language-manuals.1 \
		mime-meta-language-reply.1 \
		mime-meta-language-templates.1 \
		mime-meta-language.1

}

sha512sums="
7334ef694e93c479afc65ba3675d0257da363c76cc4093cd4a4244c4fe8a118cfc4cc1b641fef4d8bee8aa48479fa16782528b954da2703b31fef38d865bbaba  mml-1.1.1.tar.gz
"
