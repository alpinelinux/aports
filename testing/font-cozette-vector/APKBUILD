maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=font-cozette-vector
pkgver=2.0.0
pkgrel=0
_bitnpicas_ver=2.0
pkgdesc="Bitmap programming font optimized for coziness"
url="https://github.com/the-moonwitch/Cozette/"
# armhf, armv7, x86: openjdk25-jre-headless
arch="noarch !armhf !armv7 !x86"
license="MIT"
makedepends="
	fontforge
	openjdk25-jre-headless
	py3-crayons
	py3-gitpython
	py3-pillow
	"
source="https://github.com/the-moonwitch/Cozette/archive/refs/tags/v.$pkgver.tar.gz
	BitsNPicas-$pkgver.jar::https://github.com/kreativekorp/bitsnpicas/releases/download/v$_bitnpicas_ver/BitsNPicas.jar
	"
options="!check" # no tests
builddir="$srcdir/Cozette-v.$pkgver/"

prepare() {
	default_prepare
	mkdir deps/
	mv "$srcdir/BitsNPicas-$pkgver.jar" deps/BitsNPicas.jar
}

build() {
	python build.py fonts
}

package() {
	install -Dm 644 -t "$pkgdir/usr/share/fonts/cozette/" \
		./build/CozetteCrossedSevenVector.ttf \
		./build/CozetteCrossedSevenVectorBold.ttf \
		./build/CozetteVector.ttf \
		./build/CozetteVectorBold.ttf
}

sha512sums="
