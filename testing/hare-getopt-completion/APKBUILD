depends="hare"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~stacyharper/hare-getopt-completion/archive/$pkgver.tar.gz"

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
}

