maintainer="Willow Barraco <contact@willowbarraco.fr>"
pkgname=hare-getopt-completion
pkgver=0.5.0
pkgrel=0
pkgdesc="Companion module for Hare getopt to generate shell completion scripts"
url="https://git.sr.ht/~stacyharper/hare-getopt-completion"
arch="noarch !armhf !armv7 !ppc64le !s390x !x86 !loongarch64" # blocked by hare
