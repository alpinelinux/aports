# Contributor: Bart Ribbers <bribbers@disroot.org>
maintainer="Kaarle Ritvanen <kunkku@alpinelinux.org>"
pkgname=py3-altgraph
pkgver=0.17.5
pkgrel=0
pkgdesc="Python graph (network) package"
url="https://github.com/ronaldoussoren/altgraph"
arch="noarch"
license="MIT"
depends="python3"
makedepends="
	py3-gpep517
	py3-installer
	py3-setuptools
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://pypi.python.org/packages/source/a/altgraph/altgraph-$pkgver.tar.gz"
builddir="$srcdir/altgraph-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1cc3878946c92f8140e62a7e51d9ec3d58f4f9dfa854312522a2763aa7ed6f9a4b5a07430331b89fc1b69ab350ff9c3fb2f396040ba05e7e7f7c60167b69fe09  altgraph-0.17.5.tar.gz
"
