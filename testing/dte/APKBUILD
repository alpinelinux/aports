pkgname=dte
pkgver=1.11.1
pkgrel=0
pkgdesc="Small, configurable terminal text editor"
url="https://craigbarnes.gitlab.io/dte/"
arch="all"
license="GPL-2.0-only"
subpackages="$pkgname-bash-completion $pkgname-doc"
source="https://craigbarnes.gitlab.io/dist/dte/dte-$pkgver.tar.gz"

build() {
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" prefix=/usr install
}

