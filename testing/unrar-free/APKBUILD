maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=unrar-free
pkgver=0.3.3
pkgrel=0
pkgdesc="Extract files from RAR archives"
url="https://gitlab.com/bgermann/unrar-free"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	autoconf
	automake
	libtool
	libarchive-dev
	argp-standalone
	"
subpackages="$pkgname-doc"
provides="unrar"
source="https://gitlab.com/bgermann/unrar-free/-/archive/$pkgver/unrar-free-$pkgver.tar.gz"

build() {
	autoreconf -fvi
	./configure --prefix=/usr
	make LIBS="-largp"
}

package() {
	make DESTDIR="$pkgdir" install
	install -Dm644 README "$pkgdir/usr/share/doc/$pkgname/README"
	ln -s unrar-free "$pkgdir/usr/bin/unrar"
}

sha512sums="
753ef87f7ddfd08920c28b9d815bbcaf8a06d2a984b5918e2e08deb7ed605fe72ed4fd973009511880f3fde36a234f5e6d561d211dfa941ed9992fc9534f6c50  unrar-free-0.3.3.tar.gz
"
