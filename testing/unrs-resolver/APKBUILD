da0a70c4b7d052c9b7514ea54cbe3da02a3dcace1cc1ed11537047f71d39e2c88a5885e2d54fd5b4532e38b308f95fb3c8bdbeb94a983b40e6aab09dbe17fd38  napi-fixes.patch.noauto
"
