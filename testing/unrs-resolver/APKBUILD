# Contributor: lauren n. liberda <lauren@selfisekai.rocks>
# Maintainer: lauren n. liberda <lauren@selfisekai.rocks>
pkgname=unrs-resolver
pkgver=1.11.1
pkgrel=0
pkgdesc="Port of webpack/enhanced-resolve with PNP support"
url="https://www.npmjs.com/package/unrs-resolver"
arch="all"
license="MIT"
makedepends="
	cargo
	pnpm
	rollup
	"
# net: cargo, npm
options="net"
subpackages="$pkgname-doc"
source="
	https://github.com/unrs/unrs-resolver/archive/v$pkgver/unrs-resolver-$pkgver.tar.gz
	napi-fixes.patch.noauto
	"

prepare() {
	default_prepare

	pnpm install --frozen-lockfile --ignore-scripts --no-optional
	_rollup="$(echo node_modules/.pnpm/rollup@*/node_modules/rollup)"
	rm -r "$_rollup"
	ln -s /usr/share/node_modules/rollup "$_rollup"

	cargo fetch --target="$CHOST" --locked
}

build() {
	./node_modules/.bin/napi build --platform --manifest-path napi/Cargo.toml --release -- --frozen
	patch -p1 -i "$srcdir"/napi-fixes.patch.noauto
	case "$CARCH" in
		armhf) mv napi/resolver.linux-armv6-musleabihf.node napi/resolver.linux-arm-musleabihf.node ;;
		*) ;;
	esac
}

check() {
	pnpm run test
}

package() {
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
	cd napi
	install -Dm755 browser.js index.js index.d.ts resolver.*.node -t "$pkgdir"/usr/share/node_modules/unrs-resolver/
}

sha512sums="
