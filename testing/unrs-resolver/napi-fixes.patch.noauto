@@ -312,7 +312,7 @@
       }
     } else if (process.arch === 'ppc64') {
       try {
-        return require('./resolver.linux-ppc64-gnu.node')
+        return require('./resolver.linux-ppc64-musl.node')
       } catch (e) {
         loadErrors.push(e)
       }
@@ -324,12 +324,24 @@
 
     } else if (process.arch === 's390x') {
       try {
-        return require('./resolver.linux-s390x-gnu.node')
+        return require('./resolver.linux-s390x-musl.node')
       } catch (e) {
         loadErrors.push(e)
       }
       try {
         return require('@unrs/resolver-binding-linux-s390x-gnu')
+      } catch (e) {
+        loadErrors.push(e)
+      }
+    } else if (process.arch === 'loong64') {
+      try {
+        return require('./resolver.linux-loongarch64-musl.node')
+      } catch (e) {
+        loadErrors.push(e)
+      }
+    } else if (process.arch === 'ia32') {
