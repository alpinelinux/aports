maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=pure
pkgver=1.28.3
pkgrel=0
pkgdesc="Pretty, minimal and fast ZSH prompt"
arch="noarch"
url="https://github.com/sindresorhus/pure"
license="MIT"
depends="zsh"
source="$pkgname-$pkgver.tar.gz::https://github.com/sindresorhus/pure/archive/refs/tags/v$pkgver.tar.gz"
subpackages="$pkgname-doc"
options="!check" # no tests

package() {
	install -Dm644 pure.zsh \
		"$pkgdir/usr/share/zsh/functions/Prompts/prompt_pure_setup"
	install -Dm644 async.zsh \
		"$pkgdir/usr/share/zsh/functions/Misc/async"

	install -Dm644 readme.md -t "$pkgdir/usr/share/doc/pure/"
	install -Dm644 license   -t "$pkgdir"/usr/share/licenses/$pkgname/
}
sha512sums="
