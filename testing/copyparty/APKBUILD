# Contributor: lauren n. liberda <lauren@selfisekai.rocks>
# Maintainer: lauren n. liberda <lauren@selfisekai.rocks>
pkgname=copyparty
pkgver=1.20.16
pkgrel=0
pkgdesc="File server but fancy"
url="https://github.com/9001/copyparty"
arch="noarch"
license="MIT"
depends="py3-jinja2"
makedepends="
	python3
	py3-gpep517
	py3-setuptools
	"
checkdepends="py3-pytest"
subpackages="
	$pkgname-doc
	$pkgname-pyc
	"
source="https://github.com/9001/copyparty/archive/v$pkgver/copyparty-$pkgver.tar.gz"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
997de8bacfe32344a8165704b95a4f788534a9a82c5553f897f5d3a616dad9968758dd39392d19680ab9d49d4806952128220c9b71fd0a5cb2a27fc69722ecd4  copyparty-1.20.16.tar.gz
"
