From b65cd89f85a3be2122dcf1173a70a031039aca79 Mon Sep 17 00:00:00 2001
From: Phillip Schichtel <phillip@schich.tel>
Date: Mon, 30 Mar 2026 03:26:42 +0200
Subject: [PATCH] Changes to fix tests

1. Allow running them without root, see: https://github.com/nginx/docker-nginx-unprivileged/blob/61141700fbe3bb03ee7379fd0a5cba5c9c5fc885/stable/alpine-slim/Dockerfile#L105C18-L105C19
2. Significantly increase the sleep time to support slower CI
   environments
---
 tests/conftest.py      | 2 +-
 tests/requirements.txt | 1 +
 tests/trace_service.py | 2 +-
 3 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/tests/conftest.py b/tests/conftest.py
index 25933e4..431266c 100644
--- a/tests/conftest.py
+++ b/tests/conftest.py
@@ -57,7 +57,7 @@ def nginx_config(request, pytestconfig, testdir, logger):
         + f"load_module {os.path.abspath(pytestconfig.option.module)};\n"
         + pytestconfig.option.globals
     )
-    params["http_globals"] = f"root {testdir};\n" + "access_log off;\n"
+    params["http_globals"] = f"root {testdir};\naccess_log off;\nproxy_temp_path {testdir}/proxy_temp;\nclient_body_temp_path {testdir}/client_temp;\nfastcgi_temp_path {testdir}/fastcgi_temp;\nuwsgi_temp_path {testdir}/uwsgi_temp;\nscgi_temp_path {testdir}/scgi_temp;\n"
     conf = tmpl.render(params)
     logger.debug(conf)
     return conf
diff --git a/tests/trace_service.py b/tests/trace_service.py
index 5ef2bc6..b7dca5c 100644
--- a/tests/trace_service.py
+++ b/tests/trace_service.py
@@ -19,7 +19,7 @@ class TraceService(trace_service_pb2_grpc.TraceServiceServicer):
         for _ in range(10):
             if len(self.batches):
                 break
-            time.sleep(0.001)
+            time.sleep(0.1)
         assert len(self.batches) == 1
         assert len(self.batches[0]) == 1
         return self.batches.pop()[0]
-- 
2.53.0
