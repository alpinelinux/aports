# Contributor: Phillip Schichtel <phillip@schich.tel>
# Maintainer: Phillip Schichtel <phillip@schich.tel>
pkgname=nginx-mod-http-otel
_modname=http_otel
pkgver=0.1.2
pkgrel=0
pkgdesc="NGINX module implementing OpenTelemetry tracing"
url="https://github.com/nginxinc/nginx-otel"
arch="all"
license="Apache-2.0"
# curl-dev and nlohmann-dev are needed by opentelemetry-cpp
makedepends="
	cmake
	curl-dev
	grpc-dev
	nginx
	nginx-mod-dev
	nlohmann-json
	opentelemetry-cpp-dev
	protobuf-dev
	"
# cargo: needed for building jh2
# clang-dev: needed for building qh3
# ninja: needed for building qh3
# py3-charset-normalizer: dependency of niquests
# py3-protobuf: dependency of opentelemetry-proto
# python3-dev: needed for building qh3
checkdepends="
	cargo
	clang-dev
	ninja
	py3-charset-normalizer
	py3-grpcio
	py3-jinja2
	py3-openssl
	py3-protobuf
	py3-pytest
	py3-urllib3
	python3-dev
	"
_otel_proto_version="1.10.0"
source="
	nginx-otel-$pkgver.tar.gz::https://github.com/nginxinc/nginx-otel/archive/v$pkgver.tar.gz
	opentelemetry-proto-$_otel_proto_version.tar.gz::https://github.com/open-telemetry/opentelemetry-proto/archive/v$_otel_proto_version.tar.gz
	conftest.patch
	tests-requirements-relax.patch
	"
builddir="$srcdir/nginx-otel-$pkgver"

case "$CARCH" in
# Tests take very long time to run due to building dependencies.
riscv64) options="!check" ;;
esac

build() {
	cp -r /usr/src/"nginx-$(_ngxver)" "$srcdir"/nginx

	cd "$srcdir/nginx"
	CMAKE_GENERATOR="Unix Makefiles" \
	NGX_OTEL_CMAKE_OPTS="-DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DNGX_OTEL_GRPC=package -DNGX_OTEL_SDK=package -DNGX_OTEL_PROTO_DIR=$srcdir/opentelemetry-proto-$_otel_proto_version" \
	./configure --with-compat --add-dynamic-module="$builddir"

	make modules
}

check() {
	# FIXME: niquests and opentelemetry-proto are not packaged yet,
	#  se we have to install them using pip. To make matters worse, niquests
	#  has heavy dependencies with native code.
	#  This is NOT okay and should be fixed before moving to the community!
	python3 -m venv --system-site-packages tests-venv

	CARGO_PROFILE_RELEASE_OPT_LEVEL=0 \
	CARGO_PROFILE_RELEASE_CODEGEN_UNITS=16 \
	TMPDIR="$tmpdir" \
	tests-venv/bin/python3 -m pip install --no-binary :all: -r tests/requirements.txt

	tests-venv/bin/python3 -m pytest tests \
		--basetemp="$tmpdir" \
		--maxfail=10 \
		--nginx="$(which nginx)" \
		--module="$srcdir/nginx/objs/ngx_otel_module.so"
}

package() {
	local ngxver="$(_ngxver)"
	depends="nginx~${ngxver%.*}"
	local soname="ngx_http_otel_module.so"

	install -D -m755 "$srcdir/nginx/objs/ngx_otel_module.so" "$pkgdir/usr/lib/nginx/modules/$soname"

	echo "load_module \"modules/$soname\";" \
	        | install -D -m644 /dev/stdin "$pkgdir/etc/nginx/modules/10_${_modname}.conf"
}

_ngxver() {
	nginx -v 2>&1 | grep -Eo '(\d+\.\d+)+'
}

