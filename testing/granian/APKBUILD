maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=granian
pkgver=2.7.6
pkgrel=0
pkgdesc="Rust HTTP server for Python applications"
url="https://github.com/emmett-framework/granian"
# riscv64: tests fail: https://github.com/emmett-framework/granian/issues/855
arch="all !riscv64"
license="BSD-3-Clause"
depends="py3-click python3"
makedepends="
	cargo
	py3-gpep517
	py3-maturin
	"
checkdepends="
	py3-httpx
	py3-pytest
	py3-pytest-asyncio
	py3-sniffio
	py3-websockets
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/emmett-framework/granian/archive/refs/tags/v$pkgver.tar.gz"
# net: dependencies via cargo
# check: pytest hangs after all tests (which pass)
options="net !check"

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	rm -rf granian  # tests import this module instead of granian.so.
	.testenv/bin/python3 -m pytest -v tests
}

package() {
	python3 -m installer -d "$pkgdir" .dist/granian*.whl
}

sha512sums="
699f062825d74f212f712c04e754c19fdb0288103c3bdd49cc6ce80e3a418f3a6fa7ca372360ce323995f6827a172e31c9bf36d9c0c417499a847701913965fe  granian-2.7.6.tar.gz
"
