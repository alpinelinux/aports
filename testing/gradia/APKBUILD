# Maintainer: Saijin-Naib <Saijin-Naib_package-maintenance@outlook.com>
pkgname=gradia
pkgver=1.13.0
pkgrel=0
pkgdesc="Make your screenshots ready for all"
url="https://gradia.alexandervanhee.be/"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	appstream-dev
	blueprint-compiler
	cmake
	desktop-file-utils
	gettext-dev
	glib-dev
	gtk4.0-dev
	gtksourceview5-dev
	libadwaita-dev
	meson
	py3-gobject3-dev
	"
depends="gtk4.0 libadwaita"
subpackages="$pkgname-dev $pkgname-lang"
source="$pkgname-$pkgver.tar.gz::https://github.com/AlexanderVanhee/Gradia/archive/refs/tags/v$pkgver.tar.gz
	validateschema.patch
	"
builddir="$srcdir/Gradia-$pkgver/"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

