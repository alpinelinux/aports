# Contributor: Saijin-Naib <Saijin-Naib_package-maintenance@outlook.com>
# Maintainer: Saijin-Naib <Saijin-Naib_package-maintenance@outlook.com>
pkgname=cobang
pkgver=2.5.0
pkgrel=0
pkgdesc="A QR code and barcode scanner desktop app for Linux"
url="https://github.com/hongquan/CoBang"
arch="noarch"
license="GPL-3.0-or-later"
depends="gtk4.0 py3-logbook py3-pillow py3-zbar"
makedepends="
	appstream-glib
	blueprint-compiler
	desktop-file-utils
	glib-dev
	gobject-introspection-dev
	gtk4.0-dev
	meson
	"
subpackages="$pkgname-lang"
source="$pkgname-$pkgver.tar.gz::https://github.com/hongquan/CoBang/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/CoBang-$pkgver/"

build() {
	abuild-meson \
		. output
	meson compile -C output
}

check() {
	meson test --no-rebuild --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
667885ea222772a25d8c1c0b6c6afa13f5a9ccb04e0b5158dad2c188a30fc1c214a621fcbf15add281854da53537b01161feceec8296de221eb152e691e5107a  cobang-2.5.0.tar.gz
"
