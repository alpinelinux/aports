maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=keulim
pkgver=0_git20260526
_commit=28f7c39553b9949147521c44a12f87621c976d17
pkgrel=1
pkgdesc="Simple image C library"
url="https://gitlab.freedesktop.org/emersion/keulim"
arch="all"
license="LGPL-3.0-only"
makedepends="
	cargo
	clang-dev
	ffmpeg-dev
	libjxl-dev
	libpng-dev
	librsvg-dev
	meson
	resvg-dev
	"
subpackages="$pkgname-dev"
source="https://gitlab.freedesktop.org/emersion/keulim/-/archive/$_commit/keulim-$_commit.tar.gz"
builddir="$srcdir/keulim-$_commit"
options="net" # rust

prepare() {
	default_prepare

	cd rust && cargo fetch --target="$CTARGET" --locked
}

build() {
	abuild-meson \
		-Dlibpng=enabled \
		-Dlibjpeg=enabled \
		-Dlibjxl=enabled \
		-Dffmpeg=enabled \
		-Dresvg=enabled \
		-Dlibrsvg=enabled \
		-Drust=enabled \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
4c489605bce97afd2d3c8d41ddd5a300eee91561cc4875308ce8430e495333e5f658b356fc5bfa0d14e9b9a9524106ed34af73ef1b4f054830e442bd6cc24338  keulim-28f7c39553b9949147521c44a12f87621c976d17.tar.gz
"
