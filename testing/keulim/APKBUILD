maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=keulim
pkgver=0_git20260501
_commit=84ab0d89ad3b2624e1cc7d0c2fc5ef9f404073e9
pkgrel=0
pkgdesc="Simple image C library"
url="https://gitlab.freedesktop.org/emersion/keulim"
arch="all !aarch64 !armhf !armv7 !ppc64le !riscv64 !s390x"
# ARM, ppc64le, riscv64: mismatched types
# big endian: https://gitlab.freedesktop.org/emersion/keulim/-/work_items/12
license="LGPL-3.0-only"
makedepends="
	cargo
	ffmpeg-dev
	clang-dev
	libpng-dev
	librsvg-dev
	meson
	"
subpackages="$pkgname-dev"
source="https://gitlab.freedesktop.org/emersion/keulim/-/archive/$_commit/keulim-$_commit.tar.gz"
builddir="$srcdir/keulim-$_commit"
options="net" # rust

prepare() {
	default_prepare

	cd rust && cargo fetch --target="$CTARGET" --locked
}

build() {
	abuild-meson \
		-Dlibpng=enabled \
		-Dffmpeg=enabled \
		-Dlibrsvg=enabled \
		-Drust=enabled \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
53d9944e41bab7633265aa075c8da7773295b0d2e95c9b9643b9e6b19d2c6a4bea3c18bad5ff8ed4ef9636212725676c49b91751876fe408356156bf973b20a4  keulim-84ab0d89ad3b2624e1cc7d0c2fc5ef9f404073e9.tar.gz
"
