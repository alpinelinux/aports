maintainer="Hannes Braun <hannes@hannesbraun.net>"
pkgname=wlshiina
pkgver=1.0.2
pkgrel=0
pkgdesc="Interruptible display sleep for Wayland"
url="https://sr.ht/~hannes/wlshiina/"
arch="all"
license="EUPL-1.2"
makedepends="cargo cargo-auditable scdoc"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~hannes/wlshiina/archive/$pkgver.tar.gz"
options="!check net" # no test suite; downloads crates

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --frozen --release
	make wlshiina.1
}

package() {
	install -Dm755 target/release/wlshiina -t "$pkgdir"/usr/bin
	install -Dm644 wlshiina.1 -t "$pkgdir"/usr/share/man/man1
}

sha512sums="
54ad024600b7eb0c06d0b5755990b990d18fec79c37014fa36241cef68f4b5d97d4e4b983343b80d917d85074a936a6bb5a2b7dd37ed10447e8e34e99df35457  wlshiina-1.0.2.tar.gz
"
