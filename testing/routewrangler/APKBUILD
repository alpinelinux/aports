# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=routewrangler
pkgver=0.1
pkgrel=0
_commit="a49e3b4424b9d4ac50707585f073dc052763eb7b"
pkgdesc="Routing policy daemon for enforcing strict connection preferences in NetworkManager"
url="https://gitlab.postmarketos.org/postmarketOS/routewrangler"
arch="all"
license="GPL-3.0-or-later"
depends="iproute2 networkmanager"
makedepends="cargo-auditable dbus-dev"
source="https://gitlab.postmarketos.org/postmarketOS/routewrangler/-/archive/$pkgver/routewrangler-$pkgver.tar.gz"
subpackages="$pkgname-systemd $pkgname-openrc"
options="net"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen --all
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/routewrangler \
		-t "$pkgdir"/usr/bin
	install -Dm644 data/routewrangler.service \
		-t "$pkgdir"/usr/lib/systemd/system
	install -Dm755 data/routewrangler.initd \
		"$pkgdir"/etc/init.d/routewrangler
	install -Dm644 data/carrier-routing.conf \
		-t "$pkgdir"/usr/lib/NetworkManager/conf.d
}

sha512sums="
aa0bc84a1317fb917bd0df456b17caf144129d056a25787a1edeb4c655d82487e62fb14c3f3eba0bcdecd196998c05bba18c132d4e374bb82e1374c44a9e1050  routewrangler-0.1.tar.gz
"
