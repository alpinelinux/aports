pkgname=qml-box2d
pkgver=0_git20250930
_sha=e3674e0fe030c406a1d915e47eab760624fffa55
pkgrel=0
pkgdesc="Box2D QML plugin"
url="https://github.com/qml-box2d/qml-box2d"
arch="all !armhf" # Missing qt6-qtdeclarative
license="Zlib"
makedepends="cmake samurai qt6-qtbase-dev qt6-qtdeclarative-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/qml-box2d/qml-box2d/archive/$_sha.tar.gz"
builddir="$srcdir/$pkgname-$_sha"
options="!check" # No test suite

build() {
	cmake -B build \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
