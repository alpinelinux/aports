maintainer="Michał Polański <michal@polanski.me>"
pkgname=hashcards
pkgver=0.3.0
pkgrel=0
pkgdesc="Plain text-based spaced repetition system"
url="https://github.com/eudoxia0/hashcards"
license="Apache-2.0"
arch="all"
makedepends="cargo cargo-auditable openssl-dev sqlite-dev"
source="https://github.com/eudoxia0/hashcards/archive/v$pkgver/hashcards-$pkgver.tar.gz
	system-deps.patch
	cargo-lock.patch
	"
options="net" # cargo fetch

prepare() {
	default_prepare

	# Rust target triple
	local target="$(rustc -vV | sed -n 's/host: //p')"

	# Build against system-provided libraries
	mkdir -p .cargo
	cat >>.cargo/config.toml <<-EOF
		[target.$target]
		rusqlite = { rustc-link-lib = ["sqlite3"] }
	EOF

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/$pkgname -t "$pkgdir"/usr/bin/
}

