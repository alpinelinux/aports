maintainer="mekyt <hello@mek.yt>"
pkgname=lefthook
pkgver=2.1.4
pkgrel=0
pkgdesc="Fast and powerful Git hooks manager"
url="https://github.com/evilmartians/lefthook"
license="MIT"
arch="all"
subpackages="$pkgname-doc"
makedepends="go"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/evilmartians/lefthook/archive/refs/tags/v$pkgver.tar.gz
"
options="net" # download Go modules

export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

build() {
	go build -ldflags "-s -w -X main.version=$pkgver"
}

check() {
	# Auto-update only avaiable for x86_64 and aarch64 arch
	go test  ./... -skip TestUpdater_SelfUpdate
}

package() {
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
	install -Dm755 lefthook -t "$pkgdir"/usr/bin/
}

sha512sums="
d83a40ea97db04975658d5ab6e4694fb7de35b75ad9daffd1e012e7e04774e117468d1a78f429bf9e6096b07800ab7f07e3a97808af37e3e5e9172b53c70b410  lefthook-2.1.4.tar.gz
"
