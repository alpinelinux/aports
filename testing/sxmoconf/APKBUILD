# Maintainer: Willow Barraco <contact@willowbarraco.fr>
pkgname=sxmoconf
pkgver=0.3.2
pkgrel=0
pkgdesc="A general purpose configuration center"
url="https://git.sr.ht/~stacyharper/sxmo-config/"
arch="x86_64 aarch64 riscv64" # hare
license="AGPL-3.0-or-later"
makedepends="hare hare-scfg scdoc haredo"
subpackages="$pkgname-doc $pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~stacyharper/sxmo-config/archive/$pkgver.tar.gz"
builddir="$srcdir/sxmo-config-$pkgver"

build() {
	haredo -j1
}

check() {
	haredo check
}

package() {
	DESTDIR="$pkgdir" PREFIX="/usr" haredo install
}

dev() {
	amove usr/src
}

