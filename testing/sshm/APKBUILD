pkgname=sshm
pkgver=1.11.0
pkgrel=0
pkgdesc="TUI tool for managing SSH hosts"
url="https://github.com/Gu1llaum-3/sshm"
arch="all"
license="MIT"
makedepends="go"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/Gu1llaum-3/sshm/archive/refs/tags/v$pkgver.tar.gz"
options="net"

build() {
	local ldflags="-s -w -X github.com/Gu1llaum-3/sshm/cmd.AppVersion=$pkgver"
	go build -v -ldflags="$ldflags"
}

check() {
	go test ./...
}

package() {
	install -Dm755 sshm "$pkgdir"/usr/bin/sshm
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE

}

