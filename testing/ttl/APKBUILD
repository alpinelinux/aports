# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=ttl
pkgver=0.21.0
pkgrel=0
pkgdesc="Fast, modern traceroute with lot of options. A better mtr."
url="https://github.com/lance0/ttl"
arch="all !armhf !armv7 !x86"
license="Apache-2.0 AND MIT"
makedepends="
	cargo
	cargo-auditable
	cargo-c
	cmake
	rust-bindgen
	clang-dev
	samurai"
source="$pkgname-$pkgver.tar.gz::https://github.com/lance0/ttl/archive/refs/tags/v$pkgver.tar.gz"
options="net"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen --locked
}

check() {
	cargo test --release --frozen
}

package() {
	install -Dm755 "$builddir"/target/release/"$pkgname" "$pkgdir"/usr/bin/"$pkgname"
}

sha512sums="
011f99eafef131c32f8cc0c1516418d593e8924daeace681d1ad52dfdd3c8118a1d7623931c8e34e66679f2b354adc21bcdc65024f37318e8f1a97d5d5d3aa14  ttl-0.21.0.tar.gz
"
