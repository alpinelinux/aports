maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=cinnamon-session
pkgver=6.6.3
pkgrel=0
pkgdesc="Cinnamon session manager (fork of gnome-session)"
url="https://github.com/linuxmint/cinnamon-session"
arch="all !armhf" # cinnamon -> cjs -> mozjs
license="GPL-2.0-or-later"
depends="
	cinnamon
	cinnamon-screensaver
	cinnamon-settings-daemon
	nemo
	"
makedepends="
	cinnamon-desktop-dev
	glib-dev
	gtk+3.0-dev
	libcanberra-dev
	libsm-dev
	meson
	xapp-dev
	"
subpackages="$pkgname-doc"
source="https://github.com/linuxmint/cinnamon-session/archive/$pkgver/cinnamon-session-$pkgver.tar.gz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
3b6a89a405ee00adc7a8a62c447d1f92d9fb917b3b1801b3dc34d871e736da787f1b3359b8dc2ef42f097326e78fa364bfd1055cc8a49cc43a4252fa8ce5950b  cinnamon-session-6.6.3.tar.gz
"
