pkgname=authenticator-rs
pkgver=0.8.8
pkgrel=0
pkgdesc="TOTP MFA/2FA application written in Rust and GTK3"
url="https://github.com/grumlimited/authenticator-rs"
arch="all"
license="GPL-3.0-or-later"
subpackages="$pkgname-lang"
makedepends="
	cargo
	curl-dev
	gtk+3.0-dev
	meson
	openssl-dev>3
	sqlite-dev
	zlib-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/grumlimited/authenticator-rs/archive/refs/tags/$pkgver.tar.gz"
options="net !check" # No tests

# size optimisations


build() {
	RELEASE_VERSION=$pkgver make release-version
	make release
}

package() {
	DESTDIR="$pkgdir" make install
}

