# Contributor: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=py3-sentence-stream
_pyname=sentence_stream
pkgver=1.3.0
pkgrel=0
pkgdesc="Small sentence splitter for text streams"
url="https://github.com/OHF-Voice/sentence-stream"
arch="noarch"
license="Apache-2.0"
depends="
	python3
	py3-regex
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-pytest
	py3-pytest-asyncio
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/OHF-Voice/sentence-stream/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/sentence-stream-$pkgver"

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

check() {
	PYTHONPATH=. pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
