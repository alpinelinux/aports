# Contributor: Galen Abell <galen@galenabell.com>
# Maintainer: Galen Abell <galen@galenabell.com>
pkgname=py3-icalendar-searcher
_pyname=icalendar-searcher
pkgver=1.0.6
pkgrel=0
pkgdesc="Code for filtering, sorting and expanding icalendar components"
url="https://github.com/python-caldav/icalendar-searcher"
arch="noarch"
license="AGPL-3.0-only"
depends="py3-icalendar py3-recurring-ical-events"
makedepends="py3-gpep517 py3-hatchling py3-hatch-vcs py3-setuptools py3-wheel"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/python-caldav/icalendar-searcher/archive/v$pkgver/$_pyname-$pkgver.tar.gz"
builddir="$srcdir/$_pyname-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
3ab1a0268579d83bbad0d71d245a9c923349835a586bf53dd129bf2a0a980c56960091017e6bc6037befbd2b8a8fff3c2623685e5279e30ebde87f42453064f8  py3-icalendar-searcher-1.0.6.tar.gz
"
