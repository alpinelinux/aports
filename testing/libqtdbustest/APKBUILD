# Maintainer: Luca Weiss <luca@lucaweiss.eu>
pkgname=libqtdbustest
pkgver=0.4.1
pkgrel=0
pkgdesc='Library for testing DBus interactions using Qt'
url="https://gitlab.com/ubports/development/core/libqtdbustest"
arch="all"
license="LGPL-3.0-only"
makedepends="
	cmake
	cmake-extras
	gmock
	gtest-dev
	qt5-qtbase-dev
	samurai
	"
checkdepends="
	dbus-x11
	procps
	py3-dbusmock
	"
source="https://gitlab.com/ubports/development/core/libqtdbustest/-/archive/$pkgver/libqtdbustest-$pkgver.tar.gz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=None
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
bc40de0eec594780b8d73b790cca8abacff1d6b861f8a32f048a00f39071e10b677b336a168dda5ba48a2f589b7bfe172fefdd8dbd54b900d8ea96da2eb1d505  libqtdbustest-0.4.1.tar.gz
"
