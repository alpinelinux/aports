	--with-enchant=shared
	--enable-exif=shared
	--with-ffi=shared
	--enable-fileinfo=shared
	--enable-ftp=shared
	--enable-gd=shared --with-avif --with-freetype --with-jpeg --with-webp --with-xpm --disable-gd-jis-conv
	--with-gettext=shared
	--with-gmp=shared
	--with-iconv=shared
	--enable-intl=shared
	--with-ldap=shared --with-ldap-sasl
	--with-libedit
	--enable-mbstring=shared
	--with-mysqli=shared --with-mysql-sock=/run/mysqld/mysqld.sock
	--enable-mysqlnd=shared
	--with-openssl=shared --with-system-ciphers --with-openssl-argon2
	--with-password-argon2
	--enable-pcntl=shared
	--enable-pdo=shared
