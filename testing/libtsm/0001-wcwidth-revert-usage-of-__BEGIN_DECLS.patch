From ea8300e2d5464742556b1d1868f0e2078281ea35 Mon Sep 17 00:00:00 2001
From: Jocelyn Falempe <jfalempe@redhat.com>
Date: Wed, 25 Mar 2026 09:46:38 +0100
Subject: [PATCH] wcwidth: revert usage of __BEGIN_DECLS

This doesn't compile with musl libc

Signed-off-by: Jocelyn Falempe <jfalempe@redhat.com>
---
 external/wcwidth/wcwidth.h | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/external/wcwidth/wcwidth.h b/external/wcwidth/wcwidth.h
index 38c17ac..d0e1c22 100644
--- a/external/wcwidth/wcwidth.h
+++ b/external/wcwidth/wcwidth.h
@@ -3,10 +3,15 @@
 
 #include <stdlib.h>
 
-__BEGIN_DECLS
+#ifdef __cplusplus
+extern "C" {
+#endif
 
 int wcwidth(wchar_t ucs);
 
-__END_DECLS
+#ifdef __cplusplus
+}
+#endif
+
 
 #endif
-- 
2.53.0

