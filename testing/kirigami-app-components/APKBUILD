# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-other
maintainer="team/kde <bribbers@disroot.org>"
pkgname=kirigami-app-components
pkgver=1.0.0
pkgrel=0
pkgdesc="Kirigami addons and modules necessary to do a full featured KDE application"
url="https://invent.kde.org/libraries/kirigami-app-components"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="LGPL-2.0-or-later AND GPL-2.0-or-later"
depends="
	kirigami
	ki18n
	"
depends_dev="
	kconfig-dev
	kguiaddons-dev
	ki18n-dev
	kirigami-dev
	qt6-qtdeclarative-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	samurai
	"
checkdepends="xwayland-run"
subpackages="$pkgname-dev"
_repo_url="https://invent.kde.org/libraries/kirigami-app-components.git"
source="https://download.kde.org/stable/kirigami-app-components/kirigami-app-components-$pkgver.tar.xz"
options="!check" # Too flaky to rely on currently

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_TESTING="$(want_check && echo ON || echo OFF)"
	cmake --build build
}

check() {
	wlheadless-run -- ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
e40cbe928b20a40b89ebbdd17c26cf04cdb2610a8dd6a0cf2dded4b47b43a55ff391cb89edefb99a55f7b536620e3c874d51fd42e434137ebddaad6a4b2fe406  kirigami-app-components-1.0.0.tar.xz
"
