99785e0dc10eecd12543f8f5b1ee37bbc5c5f2e3b3eca1156b54a990321f149781b33c4d6846f010a222bdd24230b3d677653bb2c6f1393785eb213d2c258730  notune.patch
3df08b227fce7c6db983fa00f66fb8905da5f0d8b7c8a0604b794ef7f214d76b88ac612ddd6e0428385e1da676dd4527009ffd26351b8d3583bc1ee973df0f76  rpath.patch
"
