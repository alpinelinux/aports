# Contributor: Thomas Kienlen <kommander@laposte.net>
# Maintainer: Thomas Kienlen <kommander@laposte.net>
pkgname=bore
pkgver=0.6.0
pkgrel=0
pkgdesc="Simple CLI tool for making tunnels to localhost"
url="https://github.com/ekzhang/bore"
# riscv64: rust broken (panic in rustc)
# loongarch64: blocked by libc crate
arch="all !riscv64 !loongarch64"
license="MIT"
makedepends="cargo cargo-auditable"
source="$pkgname-$pkgver.tar.gz::https://github.com/ekzhang/bore/archive/v$pkgver/bore-$pkgver.tar.gz"


prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -D -m 755 target/release/bore -t "$pkgdir"/usr/bin
}

sha512sums="
74bb37ac205c30230bd7a0773943f251833787ec52f0be604dd7068ba926d68383c6d5572e3ce2e765088de1a388824c57f05d81ae92579365366339a46a650c  bore-0.6.0.tar.gz
"
