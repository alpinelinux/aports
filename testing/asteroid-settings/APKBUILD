# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-settings
pkgver=2.1_git20260612
pkgrel=0
_commit="f3f1e38685587dd97df59a553a04b4358cbe5b76"
pkgdesc="Default settings app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-settings"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="GPL-3.0-or-later"
depends="
	mapplauncherd
	mce
	nemo-qml-plugin-configuration
	nemo-qml-plugin-time
	"
makedepends="
	dbus-dev
	extra-cmake-modules
	mce-dev
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtmultimedia-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-settings/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
