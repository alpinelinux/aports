# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-settings
pkgver=2.1.0_git20260513
pkgrel=0
_commit="3298fd87c347a89f44538febac78f3725ae348ce"
pkgdesc="Default settings app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-settings"
# armhf blocked by qt6-qtdeclarative
# riscv64 blocked by libqofono -> nemo-qml-plugin-systemsettings
arch="all !armhf !riscv64"
license="GPL-3.0-or-later"
depends="
	mapplauncherd
	mce
	nemo-qml-plugin-configuration
	nemo-qml-plugin-systemsettings
	nemo-qml-plugin-time
	"
makedepends="
	dbus-dev
	extra-cmake-modules
	mce-dev
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtmultimedia-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-settings/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
cdcf55a6a02363f6a760d74705cd97cc690b01bceae230f6108a5ab6adae382fdc986caddd79efc3f0cc4b0816013c0ae9252282efadcc252983badf49b2c956  asteroid-settings-3298fd87c347a89f44538febac78f3725ae348ce.tar.gz
"
