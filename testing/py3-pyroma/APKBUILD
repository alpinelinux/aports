7cfc4dc8b42efd209407d2ad200dbb40376848bf384b53701b9ed41b6b40b911e44d37e465638fcb72deed9a77adec33224904f81eed759eb3dd0bc9d789f84f  fix-test-complete.patch
b21491df39654d29133650a8bd39e8384d8063342cba53ed29307673e338759f5bb6713ff836fdbcdc03a23aed2c5f6c5c5a8128aefa0420b5421237218606a2  replace-pkg-resources.patch
"
