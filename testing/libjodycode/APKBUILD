# Maintainer:
pkgname=libjodycode
pkgver=4.1.1
pkgrel=1
pkgdesc="Shared code used by several utilities written by Jody Bruchon"
url="https://codeberg.org/jbruchon/libjodycode"
arch="all"
license="MIT"
subpackages="$pkgname-dev $pkgname-doc"
makedepends="linux-headers"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/jbruchon/libjodycode/archive/refs/tags/v$pkgver.tar.gz"
options="!check" # no tests
builddir="$srcdir/$pkgname"

build() {
	make \
		NO_SIMD=1 \
		NO_SSE2=1 \
		NO_AVX2=1 \
		CFLAGS="$CFLAGS -DNO_SSE2 -DNO_SIMD -DNO_AVX2 -flto=auto"
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
	rm -v "$pkgdir"/usr/lib/*.a
}

sha512sums="
bc02d5c3fc8cc75c3a78736e6bc1cf525a3a172c67d36a530c2db8f0a3c2a485860c6a4a755f7a45fc391036f9f599e47fd9c044647a5a986f4836c09ee2b7f0  libjodycode-4.1.1.tar.gz
"
