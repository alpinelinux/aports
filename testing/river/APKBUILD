# Contributor: Anjandev Momi <anjan@momi.ca>
# Maintainer: Adam Thiede <me@adamthiede.com>
pkgname=river
pkgver=0.4.0
pkgrel=0
pkgdesc="Non-monolithic Wayland compositor"
url="https://codeberg.org/river/river"
arch="x86_64 aarch64" # limited by zig aport
license="GPL-3.0-only"
makedepends="
	libevdev-dev
	libxkbcommon-dev
	pixman-dev
	scdoc
	wayland-dev
	wayland-protocols
	wlroots0.19-dev
	zig
	"
depends="xwayland seatd"
subpackages="
	$pkgname-dev
	$pkgname-doc
	"
options="net"
source="
	https://codeberg.org/river/river/releases/download/v$pkgver/river-$pkgver.tar.gz
	"

# We may want other than "baseline" for other targets, when enabled by zig
case "$CARCH" in
	aarch64|x86_64) _cputarget=baseline ;;
esac

build() {
	# This installs it to $builddir/out
	DESTDIR="$builddir/out" zig build \
		-Doptimize=ReleaseSafe \
		-Dpie \
		-Dxwayland \
		--prefix /usr install \
		${_cputarget:+-Dcpu="$_cputarget"}
}

check() {
	zig build test
}

package() {
	mkdir -p "$pkgdir"
	cp -r out/* "$pkgdir"

	# Fix location of pkgconfig files, must be fixed upstream
	mkdir -p "$pkgdir"/usr/lib
	mv "$pkgdir"/usr/share/pkgconfig "$pkgdir"/usr/lib
}

dev() {
	default_dev
	amove usr/share/river-protocols
}

sha512sums="
f96048046b0e50f5c9859f503665b9003ab673c9429926fd6b7f374e0d3fbff52d69d6e02933b4243b0adb231d14ad789e8c037f8fd36f5fb74b51ada0a32fe7  river-0.4.0.tar.gz
"
