# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=py3-r2pipe
pkgver=6.1.2
pkgrel=0
pkgdesc="Access radare2 via pipe from python"
url="https://github.com/radareorg/radare2-r2pipe"
arch="noarch"
license="MIT"
depends="python3 radare2"
makedepends="py3-gpep517 py3-setuptools py3-setuptools_scm py3-wheel"
checkdepends="py3-coverage py3-pytest"
subpackages="$pkgname-doc $pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/radareorg/radare2-r2pipe/archive/refs/tags/$pkgver.tar.gz"
builddir="$srcdir/radare2-r2pipe-$pkgver/python"

export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl

	install -Dm0644 README.md -t "$pkgdir"/usr/share/doc/"$pkgname"
	mv examples "$pkgdir"/usr/share/doc/"$pkgname"/
}

sha512sums="
bbeb9d4f3e86b220aaccb1d78fff24ad93d293218fb6a48e67c1800967c76250cd1968bcc4550d564ef107845a8ca93b3a04798e11c0ed48625e94bac4145795  py3-r2pipe-6.1.2.tar.gz
"
