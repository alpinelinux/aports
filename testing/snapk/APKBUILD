908d6a3efc08dd16d65d8fdfc51d0a7c5fa50ddeeaa9afe6a08c3291842fc3006efba5148c0d984a1c4f51d7848ead4c5e7737e4c1ca90b689a70bfd9fa4678b  snapk.conf
0c2ed43ad6a64889dbeb1b16d435cc9456b5aca2580c5f352d57869fef079e82f4be653b0300d1570b650f06facec9193203998c092a82e8aa70ffd332b00a54  snapk.5.scd
"
