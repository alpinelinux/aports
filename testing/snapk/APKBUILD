# Contributor: Adam Thiede <me@adamthiede.com>
# Maintainer: Adam Thiede <me@adamthiede.com>
pkgname=snapk
pkgver=1
pkgrel=0
pkgdesc="btrfs snapshots on apk transactions"
url="https://alpinelinux.org"
arch="noarch"
license="GPL-3.0-or-later"
depends="btrfs-progs"
makedepends="scdoc"
subpackages="$pkgname-doc"
source="
	btrfs-snapshot.sh
	snapk.conf
	snapk.5.scd
"
builddir="$srcdir/"

# tests limited by shellcheck arches
case "$CARCH" in
	aarch64|x86_64)
		checkdepends="shellcheck"
		;;
	*)
		options="!check"
		;;
esac

build() {
	scdoc < snapk.5.scd > snapk.5
}

check() {
	# SC1091: sourced files
	shellcheck -e SC1091 btrfs-snapshot.sh
}

package() {
	install -Dm644 $srcdir/snapk.5 \
		$pkgdir/usr/share/man/man5/snapk.5
	install -Dm755 $srcdir/snapk.conf \
		$pkgdir/etc/snapk
	install -Dm755 $srcdir/btrfs-snapshot.sh \
		$pkgdir/lib/apk/commit_hooks.d/btrfs-snapshot.sh
}

sha512sums="
