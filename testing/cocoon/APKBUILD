maintainer="Fabricio Silva <hi@fabricio.dev>"
pkgname=cocoon
pkgver=0.10.0
_pkgver=0.10 # upstream missed the .0 patch
pkgrel=0
pkgdesc="ATProtocol PDS written in Go with a SQLite block and blob store"
url="https://github.com/haileyok/cocoon"
arch="all"
license="MIT"
makedepends="go"
options="net" # net for go
subpackages="$pkgname-doc $pkgname-openrc"
install="$pkgname.pre-install"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/haileyok/cocoon/archive/v$_pkgver.tar.gz
	cocoon.initd
	cocoon.confd
	"
builddir="$srcdir/$pkgname-$_pkgver"

build() {
	go build -ldflags "-X main.Version=$pkgver" ./cmd/cocoon
}

check() {
	go test ./...
}

package() {
	install -Dm755 cocoon -t "$pkgdir"/usr/bin/
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname

	install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -Dm644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

