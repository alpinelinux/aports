# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-frameworks
maintainer="team/kde <bribbers@disroot.org>"
pkgname=oxygen-icons
pkgver=6.28.0
pkgrel=0
pkgdesc="Oxygen icon theme"
arch="noarch"
url="https://invent.kde.org/frameworks/oxygen-icons"
license="LGPL-2.1-or-later"
makedepends="
	extra-cmake-modules
	qt6-qttools-dev
	samurai
	"
checkdepends="fdupes"
_repo_url="https://invent.kde.org/frameworks/oxygen-icons.git"
source="https://download.kde.org/stable/frameworks/${pkgver%.*}/oxygen-icons-$pkgver.tar.xz"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
