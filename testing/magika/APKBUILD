# Contributor: mekyt <hello@mek.yt>
# Maintainer: mekyt <hello@mek.yt>
pkgname=magika
pkgver=1.1.0
pkgrel=0
pkgdesc="Detect file content types with deep learning"
url="https://github.com/google/magika"
license="Apache-2.0"
arch="all !s390x !x86" # same as onnxruntime
makedepends="
	cargo
	cargo-auditable
	onnxruntime-dev
	openssl-dev
	"
source="$pkgname-cli-v$pkgver.tar.gz::https://github.com/google/magika/archive/refs/tags/cli/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-cli-v$pkgver/rust/cli"
options="net" # download rust packages

export ORT_PREFER_DYNAMIC_LINK=1
export ORT_LIB_LOCATION=/usr/lib

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo auditable test --frozen
}

package() {
	install -Dm755 ../target/release/magika -t "$pkgdir"/usr/bin/
}

sha512sums="
46e7d907ea7ef60aa9679d266f2b2d87639391bdfa3358fbf76214cd498999994d71f167860bf91d566dd86af5bc21eaf86d9ee13f2649e20d734a7a07f281b1  magika-cli-v1.1.0.tar.gz
"
