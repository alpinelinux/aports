Patch-Source: https://github.com/please-build/go-rules/blob/master/ChangeLog
--
Update go-rules plugin to v1.24.0 which ships please_go built with
Go >= 1.24. This fixes build failures with Go 1.26 where the pre-built
please_go v1.15.1 (compiled with Go ~1.22) fails to handle the
notgo124.go build constraint file in Go 1.26's stdlib.

--- a/plugins/BUILD
+++ b/plugins/BUILD
@@ -1,7 +1,7 @@
 plugin_repo(
     name = "go",
     plugin = "go-rules",
-    revision = "v1.21.5",
+    revision = "v1.24.0",
 )

 plugin_repo(
