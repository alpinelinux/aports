maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=gtranslator
pkgver=50.0
pkgrel=0
pkgdesc="GNOME Translation Editor"
url="https://gitlab.gnome.org/GNOME/gtranslator"
arch="all"
license="GPL-3.0-only"
makedepends="
	desktop-file-utils
	gsettings-desktop-schemas-dev
	gtk4.0-dev
	gtksourceview5-dev
	itstool
	json-glib-dev
	libadwaita-dev
	libsoup3-dev
	meson
	"
subpackages="$pkgname-doc $pkgname-lang"
source="https://download.gnome.org/sources/gtranslator/${pkgver%%.*}/gtranslator-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
