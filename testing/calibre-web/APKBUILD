# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=calibre-web
pkgver=0.6.26
pkgrel=0
pkgdesc="Web app for browsing, reading and downloading eBooks stored in a Calibre database"
url="https://github.com/janeczku/calibre-web"
arch="noarch !s390x" # py3-netifaces-plus not available
license="GPL-3.0-or-later"
depends="
	py3-apscheduler
	py3-babel
	py3-bleach
	py3-chardet
	py3-cryptography
	py3-flask
	py3-flask-babel
	py3-flask-httpauth
	py3-flask-limiter
	py3-flask-login
	py3-flask-principal
	py3-flask-wtf
	py3-iso639
	py3-isodate
	py3-jinja2
	py3-jsonschema
	py3-lxml
	py3-netifaces-plus
	py3-pycountry
	py3-pypdf
	py3-magic
	py3-regex
	py3-requests
	py3-sqlalchemy
	py3-tornado
	py3-unidecode
	py3-werkzeug
	py3-wand
	imagemagick
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	py3-pytest
	"
install="$pkgname.pre-install"
subpackages="$pkgname-openrc $pkgname-doc $pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/c/calibreweb/calibreweb-$pkgver.tar.gz
	calibre-web.initd
	calibre-web.confd
	flask-limiter-4.patch
	"
builddir="$srcdir/calibreweb-$pkgver"
options="!check" # tarball doesn't ship with tests

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	# Install documentation
	install -Dm644 README.md "$pkgdir"/usr/share/doc/$pkgname/README.md

	# Create directories for runtime
	install -dm755 "$pkgdir"/var/lib/$pkgname
	install -dm755 "$pkgdir"/var/log/$pkgname

	# Install init script
	install -Dm755 "$srcdir"/$pkgname.initd \
		"$pkgdir"/etc/init.d/$pkgname
	install -Dm644 "$srcdir"/$pkgname.confd \
		"$pkgdir"/etc/conf.d/$pkgname
}

