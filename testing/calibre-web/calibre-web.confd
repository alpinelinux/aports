# Configuration for calibre-web

# User to run calibre-web as
#calibre_web_user="calibre-web"

# Group to run calibre-web as
#calibre_web_group="calibre-web"

# Configuration directory
#calibre_web_config_dir="/var/lib/calibre-web"

# Log directory
#calibre_web_log_dir="/var/log/calibre-web"

# Port to listen on
#calibre_web_port="8083"

# Host to bind to
#calibre_web_host="0.0.0.0"

# Additional options to pass to calibre-web
#calibre_web_opts=""
