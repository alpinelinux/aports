# Contributor: Russ Webber <russ@rw.id.au>
# Maintainer: Russ Webber <russ@rw.id.au>
pkgname=rosdep
pkgver=0.26.0
pkgrel=0
pkgdesc="ROS multi-package manager system dependency tool"
url="http://ros.org/wiki/rosdep"
arch="noarch"
license="BSD-3-Clause"
depends="python3 py3-yaml py3-catkin-pkg py3-rosdistro py3-rospkg"
makedepends="py3-setuptools py3-gpep517"
checkdepends="py3-pytest py3-flake8 py3-pip bash ruby-rdoc"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/ros-infrastructure/rosdep/archive/$pkgver.tar.gz"
options="net"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	PATH="$PWD/.testenv/bin:$PATH" .testenv/bin/python3 -m pytest \
		--deselect test/test_rosdep_main.py::TestRosdepMain::test_check \
		--deselect test/test_rosdep_main.py::TestRosdepMain::test_install
}

package() {
	gpep517 install-wheel --destdir "$pkgdir" \
		.dist/*.whl
}

sha512sums="
77523e228ee4fdb25dbd4b0c77168c4ed5bbc7c4b4837f936d03029601ad511a9f9cfa7d2b1e30ef3a83c91f154e8e38392af9c5e827f170b5a299d2cf4cd9ed  rosdep-0.26.0.tar.gz
"
