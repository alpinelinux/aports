pkgname=restinio
pkgver=0.7.9.1
pkgrel=0
pkgdesc="Header-only C++14 library that gives you an embedded HTTP/Websocket server"
url="https://stiffstream.com/en/products/restinio.html"
arch="noarch"
license="BSD-3-Clause"
makedepends="asio-dev cmake fmt-dev llhttp-dev openssl-dev pcre2-dev samurai zlib-dev"
subpackages="$pkgname-dev"
source="https://github.com/Stiffstream/restinio/releases/download/v$pkgver/restinio-$pkgver-full.tar.bz2"
options="!check" # cant get checks to work

build() {
	if [ "$CBUILD" != "$CHOST" ]; then
		_cmake_crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	fi
	cmake -B build -G Ninja -S dev \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=True \
		-DCMAKE_BUILD_TYPE=None \
		-DRESTINIO_ASIO_SOURCE=standalone \
		-DRESTINIO_DEP_STANDALONE_ASIO=system \
		-DRESTINIO_DEP_LLHTTP=system \
		-DRESTINIO_DEP_FMT=system \
		-DRESTINIO_FMT_LIB_LINK_NAME=fmt \
		-DRESTINIO_TEST=OFF \
		-DRESTINIO_SAMPLE=OFF \
		-DRESTINIO_BENCHMARK=OFF \
		-DRESTINIO_WITH_SOBJECTIZER=OFF \
		$_cmake_crossopts
	cmake --build build
}

check() {
	cd build
	ctest
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
