From 028ce148a1e5446c60ab4c0c2efdbb5235568fd3 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Thomas=20B=C3=B6hler?= <witcher@wiredspace.de>
Date: Sat, 27 Jun 2026 10:11:08 +0200
Subject: [PATCH 1/2] doc: set language config key to valid lang code
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Sphinx emits the following warning when building the documentation:

    WARNING: Invalid configuration value found: 'language = None'. Update your configuration to a valid language code. Falling back to 'en' (English).

It is invalid to set the "language" configuration key to "None", and
Sphinx will fallback on the default of "en".

Mirror this fallback in the configuration file to get rid of the
warning.

Signed-off-by: Thomas Böhler <witcher@wiredspace.de>
---
 doc/conf.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/doc/conf.py b/doc/conf.py
index ed840fc..2914ce5 100644
--- a/doc/conf.py
+++ b/doc/conf.py
@@ -66,7 +66,7 @@ release = version_str
 #
 # This is also used if you do content translation via gettext catalogs.
 # Usually you set "language" from the command line for these cases.
-language = None
+language = "en"
 
 # List of patterns, relative to source directory, that match files and
 # directories to ignore when looking for source files.
-- 
