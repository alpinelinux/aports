From 76e0c77035e6affaa6c606602fa90a2142f9b81e Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Thomas=20B=C3=B6hler?= <witcher@wiredspace.de>
Date: Sat, 27 Jun 2026 10:16:41 +0200
Subject: [PATCH 2/2] doc: remove html_static_path config key
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Sphinx emits the following warning when building the documentation:

    WARNING: html_static_path entry '_static' does not exist

This is because the value of the "html_static_path" key includes
"_static", meaning Sphinx is searching for this "_static" directory to
include into the build output. The warning is emitted because the
"_static" directory does not exist.

Remove setting the "html_static_path" key to silence this warning.

Signed-off-by: Thomas Böhler <witcher@wiredspace.de>
---
 doc/conf.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/doc/conf.py b/doc/conf.py
index 2914ce5..73ef930 100644
--- a/doc/conf.py
+++ b/doc/conf.py
@@ -96,7 +96,7 @@ html_theme = "alabaster"
 # Add any paths that contain custom static files (such as style sheets) here,
 # relative to this directory. They are copied after the builtin static files,
 # so a file named "default.css" will overwrite the builtin "default.css".
-html_static_path = ["_static"]
+# html_static_path = ["_static"]
 
 # Custom sidebar templates, must be a dictionary that maps document names
 # to template names.
