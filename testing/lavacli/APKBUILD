4f874b6d7fbdec31affced9c945df5db43f8eb550f598f92933f46b83a659307b44fb1ede02d16f9fa62f154594d9dc5abab0d5722184551f37e22aadba38b1c  0001-doc-set-language-config-key-to-valid-lang-code.patch
15c7df1041b99fc6320e18a45a1b2112e84b70b11e7cba6f6b5c06b2dd7e6f0310ee0f6c447baa7e3b9cc86c3ba1f86d7c929d6a70984a207396d17d6622f7c5  0002-doc-remove-html_static_path-config-key.patch
"
