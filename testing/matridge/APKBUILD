# Maintainer: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
pkgname=matridge
pkgver=0.3.3
pkgrel=0
pkgdesc="XMPP gateway for Matrix"
url="https://codeberg.org/slidge/matridge"
arch="noarch"
license="AGPL-3.0-or-later"
pkgusers="matridge"
pkggroups="matridge"
install="$pkgname.pre-install"
depends="
	python3
	py3-async-lru
	py3-beautifulsoup4
	py3-matrix-nio-e2e
	py3-slidge
	py3-slidge-style-parser
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="
	py3-pytest
	py3-pytest-asyncio
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/m/matridge/matridge-$pkgver.tar.gz
	$pkgname.initd
	$pkgname.confd
	$pkgname.conf
	"

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl

	install -Dm 755 "$srcdir/$pkgname.initd" "$pkgdir/etc/init.d/$pkgname"
	install -Dm 644 "$srcdir/$pkgname.confd" "$pkgdir/etc/conf.d/$pkgname"
	install -Dm 640 -g matridge "$srcdir/matridge.conf" "$pkgdir/etc/matridge/matridge.conf"
	install -d -m 755 -o matridge -g matridge "$pkgdir/var/lib/matridge"
}

