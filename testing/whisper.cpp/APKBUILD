1de71ec1fd8f71c2de385ffd18cb9a2a8185661db974325f594aec846a860cd9a586aa0c707c836eb7ff1647bbdc9d2e931a168c6227177885079feb4887fa1a  0001-Install-libraries-into-WHISPER_LIB_INSTALL_DIR.patch
4db995b054007d7dc666a3bfb72952c6fedc4819f3c0ed671effe93e2b95afec9998e1375bba80a5b32faf832d35be645ba5eedc4d9ec1db952877d932d92dd1  whisper-server.initd
25aa31174946bd4cd4d6894ac4180d585071d06d51331b7fd8edb5dc617a2ed7fb247d0e4127254cfe8209f1393cbea9cb2dd96b9af20cca06402aa69f5d4bf6  whisper-server.confd
