# Contributor: Siva Mahadevan <me@svmhdvn.name>
# Maintainer: Siva Mahadevan <me@svmhdvn.name>
pkgname=zmx
pkgver=0.5.0
pkgrel=0
pkgdesc="Session persistence for terminal processes"
url="https://zmx.sh"
arch="x86_64 aarch64" # Limited by zig aport
license="MIT"
makedepends="linux-headers zig"
source="https://github.com/neurosnap/zmx/archive/v$pkgver/zmx-v$pkgver.tar.gz"
subpackages="$pkgname-doc"

# We may want other than "baseline" for other targets, when enabled by zig
case "$CARCH" in
	aarch64|x86_64) _cputarget=baseline ;;
esac

build() {
	zig build -Doptimize=ReleaseSafe ${_cputarget:+-Dcpu="$_cputarget"}
}

check() {
	zig build test
}

package() {
	install -Dm755 -t "$pkgdir"/usr/bin ./zig-out/bin/zmx
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

sha512sums="
252183c5f80d777b963e874ee425d1f90d3a7066e6523219e62b28074c09799c89957562e1add9151af7a175fea218a245a1b757006fc5f8009b10510af16caa  zmx-v0.5.0.tar.gz
"
