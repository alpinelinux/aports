From 3f1ee6cc7a1ff2f1e0da4ce8c462d98a3b81fd5b Mon Sep 17 00:00:00 2001
From: Jocelyn Falempe <jfalempe@redhat.com>
Date: Thu, 26 Mar 2026 17:25:56 +0100
Subject: [PATCH] unifont: fix build on i686
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

This is a trivial fix to this build error on i686:
../src/font_unifont.c: In function ‘kmscon_font_unifont_init’:
../src/font_unifont.c:270:39: error: passing argument 2 of ‘uncompress’ from incompatible pointer type [-Wincompatible-pointer-types]
  270 |         if (uncompress(uf->font_data, &uf->len,
      |                                       ^~~~~~~~
      |                                       |
      |                                       size_t * {aka unsigned int *}
In file included from ../src/font_unifont.c:47:
/usr/include/zlib.h:1251:70: note: expected ‘long unsigned int *’ but argument is of type ‘size_t *’ {aka ‘unsigned int *’}
 1251 | Z_EXTERN int Z_EXPORT uncompress(unsigned char *dest, unsigned long *destLen, const unsigned char *source, unsigned long sourceLen);
      |                                                       ~~~~~~~~~~~~~~~^~~~~~~

Signed-off-by: Jocelyn Falempe <jfalempe@redhat.com>
---
 src/font_unifont.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/font_unifont.c b/src/font_unifont.c
index 1df9b57..1918f08 100644
--- a/src/font_unifont.c
+++ b/src/font_unifont.c
@@ -67,7 +67,7 @@ struct unifont_glyph_block {
 
 struct unifont_data {
 	unsigned char *font_data;
-	size_t len;
+	unsigned long len;
 	struct shl_hashtable *cache;
 };
 
-- 
2.53.0

