9a171cd067455d91662ac07e4b707f1fe2bc3f3abebdd86f758caa0dd93f2c3741db99dfd7981e9de815b044bd1be5d1b2ca8e81642b08fdbe016f18de0a1da0  0001-unifont-fix-build-on-i686.patch
45ed47dcec4a257d8257389b83df0a82c38c33ba7dec6c0f13eb381cbc7acb1854df4b2d0ffeb4a2469f9c8cf90b0e870d8f1d5eb1c87a4e92025d8f1c0ea287  kmsconvt.initd
"
