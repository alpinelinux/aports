# Contributor: Dylan Van Assche <dylan@postmarketos.org>
# Maintainer: Dylan Van Assche <dylan@postmarketos.org>
pkgname=certbot-dns-hetzner
pkgver=4.0.0
pkgrel=0
pkgdesc="Certbot DNS Authenticator for Hetzner"
url="https://github.com/ctrlaltcoop/certbot-dns-hetzner"
arch="noarch"
license="Apache-2.0"
depends="
	certbot
	py3-tldextract
	py3-dns-lexicon
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	certbot
	py3-hcloud
	py3-tldextract
	py3-pytest
	"
subpackages="$pkgname-pyc"
source="https://github.com/ctrlaltcoop/certbot-dns-hetzner/archive/v$pkgver/certbot-dns-hetzner-$pkgver.tar.gz"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1343348eb3aa10bf7b27f32d73c1952faa0a50491a2ef4fad2ed065ca5689912c80604ce08e7912706a53555b4c97a66b8b9c9161757844849f8b9ec18859193  certbot-dns-hetzner-4.0.0.tar.gz
"
