maintainer="Iztok Fister, Jr. <iztok@iztok.dev>"
pkgname=eml2mbox
pkgver=0.1.1
pkgrel=0
pkgdesc="Convert .eml files to a standards-compliant .mbox archive"
url="https://codeberg.org/firefly-cpp/eml2mbox"
arch="noarch"
license="MIT"
depends="python3 py3-typer py3-tqdm"
makedepends="py3-gpep517 py3-poetry-core"
checkdepends="py3-pytest-xdist"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/firefly-cpp/eml2mbox/archive/$pkgver.tar.gz"
builddir="$srcdir/$pkgname"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
d6bcb483980aafc946af1dc947e98361f71ca50c8ac06af022a983628d49bb2234ce9cf6c2812c2b0da2ad0e8774b2ef8eb57463347aba76ff0e77bf453a3976  eml2mbox-0.1.1.tar.gz
"
