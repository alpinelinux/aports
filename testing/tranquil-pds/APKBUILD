# Maintainer: june <packages@koi.rip>
maintainer="june <packages@koi.rip>"
pkgname=tranquil-pds
pkgver=0.6.5
pkgrel=0
pkgdesc="ATProto Personal Data Server implementation"
_did="did:plc:jj6ajj6duxnlthwtnob4qyuv"
url="https://tangled.org/$_did"
arch="all !x86 !armhf !armv7 !riscv64 !s390x" # 32bit and single-endian systems are unsupported
license="AGPL-3.0-or-later"
subpackages="$pkgname-openrc $pkgname-frontend"
makedepends="
	rust
	cargo-auditable
	openssl-dev
	protobuf-dev
	nodejs
	pnpm
	"
install="$pkgname.pre-install"
pkgusers="$pkgname"
pkggroups="$pkgname"
source="
	$pkgname-$pkgver.tar.gz::https://tangled.org/$_did/archive/v$pkgver
	Cargo.lock
	$pkgname.initd
	$pkgname.confd
	"
options="net !check" # net for cargo, no tests

prepare() {
	default_prepare

	# setting builddir instead doesn't work because the path would contain colons
	mv "$srcdir/$_did-v$pkgver" "$builddir"
	cp "$srcdir/Cargo.lock" "$builddir/Cargo.lock"

	cargo fetch --target="$CTARGET" --locked --manifest-path="$builddir/Cargo.toml"
}

build() {
	cargo auditable build --frozen --release

	cd frontend
	pnpm install --frozen-lockfile
	pnpm build
}

frontend() {
	pkgdesc="Default $pkgname frontend"
	install -dm755 "$subpkgdir/usr/share/webapps/$pkgname"
	cp -r "$builddir/frontend/dist/"* "$subpkgdir/usr/share/webapps/$pkgname/"
}

package() {
	install -Dm755 target/release/tranquil-server "$pkgdir/usr/bin/$pkgname"

	install -Dm644 -o "$pkgname" -g "$pkgname" example.toml "$pkgdir/etc/$pkgname/config.toml"
	chown "$pkgname:$pkgname" "$pkgdir/etc/$pkgname"

	install -Dm755 "$srcdir/$pkgname.initd" "$pkgdir/etc/init.d/$pkgname"
	install -Dm755 "$srcdir/$pkgname.confd" "$pkgdir/etc/conf.d/$pkgname"
}

sha512sums="
