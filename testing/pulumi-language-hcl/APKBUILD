pkgname=pulumi-language-hcl
pkgver=0.4.0
pkgrel=0
pkgdesc="Infrastructure as Code SDK (HCL language provider)"
url="https://pulumi.com/"
# blocked by pulumi
arch="x86_64 aarch64"
license="Apache-2.0"
makedepends="go"
source="$pkgname-$pkgver.tar.gz::https://github.com/pulumi-labs/pulumi-hcl/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/pulumi-hcl-$pkgver"
options="net" # download Go modules

build() {
	mkdir -p out
	go build -v \
		-ldflags "-X github.com/pulumi-labs/pulumi-hcl/pkg/version.Version=v$pkgver" \
		-o out/ \
		./cmd/...
}

check() {
	# Skip broken integration tests
	go test -skip "TestMain|TestSmoke" ./...
}

package() {
	install -Dm755 out/pulumi-language-hcl out/pulumi-converter-hcl -t "$pkgdir"/usr/bin/
}

