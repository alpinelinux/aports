# Contributor: Jakub Jirutka <jakub@jirutka.cz>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=wolfssh
pkgver=1.5.0
_pkgver=$pkgver-stable
pkgrel=0
pkgdesc="Small, fast, portable SSH implementation, including SCP and SFTP"
url="https://www.wolfssl.com"
arch="all"
license="GPL-3.0-only"
depends_dev="wolfssl-dev"
makedepends="
	$depends_dev
	autoconf
	automake
	libtool
	"
checkdepends="bash"
subpackages="$pkgname-dev"
source="https://github.com/wolfSSL/wolfssh/archive/v$_pkgver/wolfssh-$_pkgver.tar.gz"
builddir="$srcdir/$pkgname-$_pkgver"

prepare() {
	default_prepare

	./autogen.sh
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--localstatedir=/var \
		--enable-distro
	make
}

check() {
	case "$CARCH" in
		x86_64|aarch64)
			make check
			;;
		*)
			# kex.test fails on other arches (ML-KEM / group16)
			local tests
			tests=$(find tests scripts -maxdepth 1 -name '*.test' ! -name 'kex.test' | sort | tr '\n' ' ')
			make check TESTS="$tests"
			;;
	esac
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
6a1eff11cbb7452c225506cc86f5404af84c69cb0871153a4e7efdbf5c725fccfcbc974d22665a984571ee06f92a65bc81b3d635c68a6460fe77fe0ee4590478  wolfssh-1.5.0-stable.tar.gz
"
