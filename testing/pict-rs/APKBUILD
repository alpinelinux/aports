fe57cc7b6d05b569dc634db7ade3bd4593f4f4a6c3991a0f140e7ab3b0b4988005cb322c3a426fe418981072dba0a30b040b640478603779146528a88c3a3765  quanta-0.12.6.tar.gz
e7c46270cae88c9980f183fe101896e1622b9ab0fe965595bc28b91d7564d76a486a53c72278474a70f97f5ea862c1fabe703a50c483d03da90ff282306ee976  config-file.patch
ef0714b3609ef31e0bc9cf86db561f7b3d17f44d5eb7e3016096b4f5201cd4cba23bfa6c068c6d1d6eecc590f33bf6485c93431378505ee2a4d9aa95b2142271  quanta-time64.patch
