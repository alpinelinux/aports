# Contributor: Celeste <cielesti@protonmail.com>
# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=pict-rs
pkgver=0.5.24
pkgrel=0
_quantaver=0.12.6
pkgdesc="Simple image hosting service written in Rust"
url="https://git.asonix.dog/asonix/pict-rs"
arch="all"
license="AGPL-3.0-or-later"
depends="
	exiftool
	ffmpeg
	imagemagick
	"
_llvmver=22 # keep in sync with main/rust
makedepends="
	cargo
	cargo-auditable
	clang$_llvmver-libclang
	cmake
	rust-bindgen
	samurai
	"
install="$pkgname.pre-install"
pkgusers="pict-rs"
pkggroups="pict-rs"
subpackages="$pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://git.asonix.dog/asonix/pict-rs/archive/v$pkgver.tar.gz
	quanta-$_quantaver.tar.gz::https://static.crates.io/crates/quanta/quanta-$_quantaver.crate
	config-file.patch
	quanta-time64.patch
	pict-rs.initd
	"
builddir="$srcdir/pict-rs"

prepare() {
	mv "$srcdir/quanta-$_quantaver" vendored-quanta
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/pict-rs -t "$pkgdir"/usr/bin
	install -Dm640 -g pict-rs pict-rs.toml -t "$pkgdir"/etc/pict-rs
	install -Dm755 "$srcdir"/pict-rs.initd "$pkgdir"/etc/init.d/pict-rs
}

sha512sums="
