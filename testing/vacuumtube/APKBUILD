maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=vacuumtube
pkgver=1.8.0
pkgrel=0
pkgdesc="YouTube Leanback on the desktop"
url="https://github.com/shy1132/VacuumTube"
arch="x86_64" # electron, aarch64: TODO: look where app.asar is located
license="MIT"
depends="electron"
makedepends="
	nodejs
	npm
	"
source="https://github.com/shy1132/VacuumTube/archive/v$pkgver/VacuumTube-$pkgver.tar.gz
	vacuumtube
	vacuumtube.desktop
	"
builddir="$srcdir/VacuumTube-$pkgver"
options="net !check" # npm & electron

prepare() {
	default_prepare

	npm i
}

build() {
	npm run linux:build-unpacked
}

package() {
	install -Dm644 "$srcdir"/vacuumtube.desktop -t "$pkgdir"/usr/share/applications/
	install -Dm755 "$srcdir"/vacuumtube -t "$pkgdir"/usr/bin/

	install -Dm644 dist/linux-unpacked/resources/app.asar -t "$pkgdir"/usr/lib/vacuumtube/

	for i in 16 32 48 64 128 256 512; do
		install -Dm644 assets/icons/${i}x${i}.png "$pkgdir"/usr/share/icons/hicolor/${i}x${i}/apps/vacuumtube.png
	done

	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE
}

