maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=vacuumtube
pkgver=1.8.0
pkgrel=1
pkgdesc="YouTube Leanback on the desktop"
url="https://github.com/shy1132/VacuumTube"
arch="aarch64 x86_64" # electron
license="MIT"
depends="electron"
makedepends="
	nodejs
	npm
	"
source="https://github.com/shy1132/VacuumTube/archive/v$pkgver/VacuumTube-$pkgver.tar.gz
	startvacuumtube
	"
builddir="$srcdir/VacuumTube-$pkgver"
options="net !check" # npm & electron

prepare() {
	default_prepare

	npm i
}

build() {
	npm run linux:build-unpacked
}

package() {
	install -Dm644 dist/linux*unpacked/resources/app.asar -t "$pkgdir"/usr/lib/vacuumtube/

	install -Dm755 "$srcdir"/startvacuumtube -t "$pkgdir"/usr/bin/

	install -Dm644 flatpak/rocks.shy.VacuumTube.metainfo.xml -t "$pkgdir"/usr/share/metainfo/
	install -Dm644 flatpak/rocks.shy.VacuumTube.desktop -t "$pkgdir"/usr/share/applications/
	install -Dm644 assets/icon.svg "$pkgdir"/usr/share/icons/hicolor/scalable/apps/rocks.shy.VacuumTube.svg

	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE
}

sha512sums="
