# Maintainer: Willow Barraco <contact@willowbarraco.fr>
pkgname=xdg-dgx
pkgver=0.5.0
pkgrel=0
pkgdesc="XDG utils implementations, and Hare external libraries"
url="https://git.sr.ht/~stacyharper/xdg-dgx"
arch="x86_64 aarch64 riscv64" # hare
license="AGPL-3.0-or-later"
depends="curl"
makedepends="hare haredo scdoc"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~stacyharper/xdg-dgx/archive/$pkgver.tar.gz"

_cmds="
	xdg-open
	xdg-desktop-list
	xdg-terminal-exec
	"
for cmd in $_cmds; do
	subpackages="$subpackages $pkgname-$cmd:xdg"
done

build() {
	haredo -j1
}

check() {
	haredo -j1 check
}

package() {
	DESTDIR="$pkgdir" PREFIX="/usr" haredo install
}

xdg() {
	_xdg="${subpkgname#$pkgname-}"
	_dgx="dgx-${_xdg#xdg-}"
	pkgdesc="Symlink to provide $_dgx as $_xdg"
	depends="xdg-dgx"
	mkdir -p "$subpkgdir/usr/bin"
	ln -s "$_dgx" "$subpkgdir/usr/bin/$_xdg"
}

sha512sums="
79dd30e56514d9f2beb680d4bf49fee25f4e9dbbb92f52d7418a7cd7ba2359d047d5a9ed18e1d8e864f92b35e21cee5d60ba0b258a6984507c9b2fdbc081d56c  xdg-dgx-0.5.0.tar.gz
"
