maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=yubico-authenticator
pkgver=7.3.0
pkgrel=0
pkgdesc="GUI for managing and using YubiKey devices"
url="https://developers.yubico.com/yubioath-flutter/"
arch="aarch64 x86_64" # restricted by flutter
license="Apache-2.0"
depends="
	pcsc-lite
	yubikey-manager
	"
makedepends="
	clang22
	cmake
	flutter
	flutter-gtk
	gtk+3.0-dev
	libayatana-appindicator-dev
	libnotify-dev
	py3-gpep517
	py3-poetry-core
	samurai
	"
subpackages="
	$pkgname-helper-pyc
	$pkgname-helper::noarch
	"
source="yubioath-$pkgver.tar.gz::https://github.com/Yubico/yubioath-flutter/archive/refs/tags/$pkgver.tar.gz
	system-libs.patch
	helper.patch
	system-path.patch
	pubspec-lock.patch
	"
builddir="$srcdir/yubioath-flutter-$pkgver"
options="net !check" # fetch dependencies, tests crash
sonameprefix="$pkgname:"

prepare() {
	default_prepare

	flutter --disable-analytics
	flutter pub get --enforce-lockfile
}

build() {
	cd helper
	gpep517 build-wheel --wheel-dir dist --output-fd 3 3>&1

	cd ..
	flutter build linux --release

	rm build/linux/*/release/bundle/lib/libflutter_linux_gtk.so

	sed -e 's/Exec.*/Exec=yubico-authenticator/' \
		-e 's/Icon=.*/Icon=com.yubico.yubioath/' \
		-i "$builddir/resources/linux/linux_support/com.yubico.yubioath.desktop"
}

check() {
	flutter test
}

package() {
	depends="$depends yubico-authenticator-helper"

	cd build/linux/*/release/bundle/
	rm README.adoc

	find . -type f -exec install -Dm 644 {} "$pkgdir/usr/lib/$pkgname/{}" \;
	chmod 755 "$pkgdir/usr/lib/$pkgname/authenticator"

	install -dm 755 "$pkgdir/usr/bin"
	ln -s "/usr/lib/$pkgname/authenticator" "$pkgdir/usr/bin/yubico-authenticator"

	install -Dm 644 "$builddir/resources/linux/linux_support/com.yubico.yubioath.desktop" \
		-t "$pkgdir/usr/share/applications/"

	install -Dm 644 "$builddir/resources/icons/com.yubico.yubioath.png" \
		-t "$pkgdir/usr/share/icons/hicolor/128x128/"

	python3 -m installer --destdir="$pkgdir" "$builddir"/helper/dist/*.whl
	install -Dm 755 "$builddir/helper/authenticator-helper.py" "$pkgdir/usr/bin/authenticator-helper"
}

helper() {
	pkgdesc="Yubico Authenticator Helper"
	depends="yubikey-manager py3-fido2 py3-mss py3-pillow py3-zxing-cpp py3-pyscard"

	amove usr/lib/python*
}

