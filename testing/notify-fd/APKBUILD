maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=notify-fd
pkgver=1.0.0
pkgrel=0
pkgdesc="Relay readiness from sd_notify services to ready-fd supervisors"
url="https://sr.ht/~whynothugo/notify-fd/"
arch="all"
license="ISC"
subpackages="$pkgname-doc"
source="notify-fd-$pkgver.tar.gz::https://git.sr.ht/~whynothugo/notify-fd/archive/v$pkgver.tar.gz"
builddir="$srcdir/notify-fd-v$pkgver/"
options="!check" # no tests

build() {
	make PREFIX=/usr build
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
	install -Dm644 LICENCE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

