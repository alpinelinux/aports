From eee1a9460a27c8d10cd6f1871bb3c61acb6b6a2f Mon Sep 17 00:00:00 2001
From: Guido Berhoerster <guido+ubports@berhoerster.name>
Date: Thu, 19 Mar 2026 07:03:19 +0100
Subject: [PATCH 9/9] Remove unnecessary requirements on QtGui and QtDBus

QtDBus is only needed in case timed support is enabled.
---
 CMakeLists.txt       | 8 ++++++--
 src/CMakeLists.txt   | 8 +++++---
 tests/CMakeLists.txt | 6 ++++--
 3 files changed, 15 insertions(+), 7 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 7436862..bbbe5b2 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -28,15 +28,19 @@ find_package(PkgConfig REQUIRED)
 
 if(ENABLE_QT6)
     set(QT_VERSION_MAJOR 6)
-    find_package(Qt6 COMPONENTS DBus Gui Test REQUIRED)
+    find_package(Qt6 COMPONENTS Core Test REQUIRED)
     find_package(KF6 COMPONENTS CalendarCore REQUIRED)
 else()
     set(QT_MIN_VERSION "5.6.0")
     set(QT_VERSION_MAJOR 5)
-    find_package(Qt5 ${QT_MIN_VERSION} COMPONENTS DBus Gui Test REQUIRED)
+    find_package(Qt5 ${QT_MIN_VERSION} COMPONENTS Core Test REQUIRED)
     find_package(KF5 COMPONENTS CalendarCore REQUIRED)
 
     pkg_check_modules(TIMED timed-qt5 IMPORTED_TARGET)
+    if(TIMED_FOUND)
+        find_package(Qt5 ${QT_MIN_VERSION} COMPONENTS DBus REQUIRED)
+    endif()
+
     pkg_check_modules(QMF QmfClient IMPORTED_TARGET)
 endif()
 
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index bec4b11..8ee4127 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -33,10 +33,8 @@ add_library(${MKCAL_NAME} SHARED ${SRC} ${HEADERS} ${PRIVATE_HEADERS})
 target_compile_definitions(${MKCAL_NAME} PRIVATE MKCAL_LIBRARY)
 target_link_libraries(${MKCAL_NAME}
 		PRIVATE
-	Qt${QT_VERSION_MAJOR}::DBus
 	PkgConfig::SQLITE3
 		PUBLIC
-	Qt${QT_VERSION_MAJOR}::Gui
 	KF${QT_VERSION_MAJOR}::CalendarCore)
 
 set_target_properties(${MKCAL_NAME} PROPERTIES
@@ -47,7 +45,11 @@ add_definitions(-fvisibility=hidden -fvisibility-inlines-hidden)
 add_definitions(-DMKCALPLUGINDIR="${CMAKE_INSTALL_FULL_LIBDIR}/mkcalplugins")
 
 if(TIMED_FOUND)
-    target_link_libraries(${MKCAL_NAME} PRIVATE PkgConfig::TIMED)
+    target_link_libraries(${MKCAL_NAME}
+        PRIVATE
+            Qt${QT_VERSION_MAJOR}::DBus
+            PkgConfig::TIMED
+    )
     add_definitions(-DTIMED_SUPPORT)
 endif()
 
diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
index a0f21e0..af37abc 100644
--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -8,14 +8,16 @@ add_executable(tst_storage ${SRC_STORAGE} ${HEADERS_STORAGE})
 target_include_directories(tst_storage PRIVATE ${PROJECT_SOURCE_DIR}/src)
 
 target_link_libraries(tst_storage
-	Qt${QT_VERSION_MAJOR}::DBus
 	Qt${QT_VERSION_MAJOR}::Test
 	KF${QT_VERSION_MAJOR}::CalendarCore
 	PkgConfig::SQLITE3
 	mkcal-qt${QT_VERSION_MAJOR})
 
 if(TIMED_FOUND)
-    target_link_libraries(tst_storage PkgConfig::TIMED)
+    target_link_libraries(tst_storage
+        Qt${QT_VERSION_MAJOR}::DBus
+        PkgConfig::TIMED
+    )
     add_definitions(-DTIMED_SUPPORT)
 endif()
 
