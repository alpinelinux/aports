maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=mkcal
pkgver=0.7.32
pkgrel=0
pkgdesc="The mobile version of the original KCAL from KDE"
url="https://github.com/sailfishos/mkcal"
# armhf blocked by qt6-qtdeclarative -> kcalendarcore
arch="all !armhf"
license="LGPL-2.0-or-later"
depends_dev="
	kcalendarcore-dev
	qt6-qtbase-dev
	timed-dev
	"
makedepends="$depends_dev
	doxygen
	extra-cmake-modules
	graphviz
	samurai
	"
checkdepends="
	dbus
	xwaland-run
	"
subpackages="
	$pkgname-dev
	$pkgname-doc
	$pkgname-tools
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/mkcal/archive/refs/tags/$pkgver.tar.gz
	0001-mkcal-Add-optional-support-for-building-against-Qt6.patch
	"
options="!check" # Fails to connect to DBus server

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DENABLE_QT6=ON \
		-DBUILD_PLUGINS=OFF \
		-DBUILD_DOCUMENTATION=ON
	cmake --build build
}

check() {
	wlheadless-run -- dbus-run-session ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

tools() {
	pkgdesc="$pkgdesc (tools)"

	amove usr/bin/mkcaltool
}
sha512sums="
