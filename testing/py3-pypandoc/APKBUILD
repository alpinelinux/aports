# Contributor: Rasmus Thomsen <oss@cogitri.dev>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=py3-pypandoc
pkgver=1.17
pkgrel=0
pkgdesc="Thin wrapper for pandoc"
url="https://github.com/JessicaTegner/pypandoc"
arch="aarch64 x86_64" # pandoc
license="MIT"
depends="python3 pandoc-cli"
makedepends="py3-gpep517 py3-hatchling"
options="!check" # missing pandoc-citeproc
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/pypandoc/pypandoc-$pkgver.tar.gz"
builddir="$srcdir/pypandoc-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/pypandoc-*.whl
}

sha512sums="
d109a9ecac105f3ead818916c587232884e59728b393475abd59333a711f5975e0619082c13af0fdc54bad417e463447adab92f65f6d99361c3ae2eb65679393  pypandoc-1.17.tar.gz
"
