# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-other
maintainer="team/kde <bribbers@disroot.org>"
pkgname=drawy
pkgver=1.0.1
pkgrel=0
pkgdesc="Your handy, infinite brainstorming tool!"
url="https://apps.kde.org/drawy/"
# armhf blocked by qt6-qtdeclarative -> ki18n
# armv7 and x86 blocked by build failure
arch="all !armhf !armv7 !x86"
license="BSD-2-Clause AND BSD-3-Clause AND GPL-2.0-or-later AND GPL-3.0-or-later AND LGPL-2.0-or-later AND MIT"
makedepends="
	extra-cmake-modules
	kconfig-dev
	kconfigwidgets-dev
	kcoreaddons-dev
	kcrash-dev
	kdoctools-dev
	ki18n-dev
	kiconthemes-dev
	kuserfeedback-dev
	kwidgetsaddons-dev
	kxmlgui-dev
	qt6-qtbase-dev
	qt6-qttools-dev
	samurai
	syntax-highlighting-dev
	"
subpackages="
	$pkgname-doc
	$pkgname-lang
	"
source="https://download.kde.org/stable/drawy/$pkgver/drawy-$pkgver.tar.xz"
options="!check" # No tests

build() {
	cmake -B build \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
2f9fbe6bb041d7f3d1bd9457a6560e7b2fa09af79177c137269f79ce13697cb28e2eee76d8f2f4ab299b9f1071c789133c0b47f5131b1055d8552655d151f82d  drawy-1.0.1.tar.xz
"
