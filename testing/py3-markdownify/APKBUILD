# Maintainer: Struan Robertson <contact@struanrobertson.co.uk>
pkgname=py3-markdownify
_pkgname=python-markdownify
pkgver=1.2.3
pkgrel=0
pkgdesc="Convert HTML to Markdown"
url="https://github.com/matthewwithanm/python-markdownify"
arch="noarch"
license="MIT"
depends="
	python3
	py3-beautifulsoup4
	py3-six
"
makedepends="
	py3-setuptools_scm
	py3-gpep517
	py3-wheel
"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$url/archive/$pkgver/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

export SETUPTOOLS_SCM_PRETEND_VERSION="$pkgver"


build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --system-site-packages .testenv
	.testenv/bin/python -m installer .dist/*.whl
	.testenv/bin/python -m pytest
}

package() {
	python3 -m installer \
		-d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
e2871a7971c538378112bd13da12cdb3983f93c98598d69db61c9e57c0a3366ba5c7889032b1f886afc408504e31b81217d526ff47aa032b6a5ac981d0d6ae24  python-markdownify-1.2.3.tar.gz
"
