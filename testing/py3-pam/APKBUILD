f1cf9e5efe877e40c70a4967f4d66ea8ce985e1d4fe1dc1d32b09b58a16c3df178cd490f938d9b53a5c573ab264740e0b0cdb8754549f5675d604ea656112feb  fix-pytest-config.patch
"
