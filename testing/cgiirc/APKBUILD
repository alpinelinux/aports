# Contributor: Francesco Colista <fcolista@alpinelinux.org>
# Maintainer: Francesco Colista <fcolista@alpinelinux.org>
pkgname=cgiirc
pkgver=0.5.12
pkgrel=2
pkgdesc="A perl/CGI program to use IRC from a web browser"
url="http://cgiirc.org/"
arch="all"
license="GPL-2.0-or-later"
depends="perl"
install="$pkgname.post-install"
source="http://cgiirc.org/releases/cgiirc-$pkgver.tar.gz
	cgiirc.config"
options="!check" # no tests

build() {
	$CC $CFLAGS $LDFLAGS -O2 -o client.cgi client.c
}

package() {
	install -Dm644 -t "$pkgdir"/etc/cgiirc/ \
		cgiirc.config.full "$srcdir"/cgiirc.config ipaccess.example
	install -Dm644 -t "$pkgdir"/etc/cgiirc/formats/ formats/*
	install -Dm755 -t "$pkgdir"/usr/share/webapps/$pkgname/ ./*.cgi
	cp -r modules "$pkgdir"/usr/share/webapps/$pkgname/
	cp -r images "$pkgdir"/usr/share/webapps/$pkgname/
	cp -r interfaces "$pkgdir"/usr/share/webapps/$pkgname/
}

sha512sums="ba156bbf036846e2bdd1d5f219d837bcfc23c690593740bccad375af95f3d4c56c3624621d03b47145b5dbb73e2fed5a16b6917f81ac784de04e0e9d6afdd2eb  cgiirc-0.5.12.tar.gz
