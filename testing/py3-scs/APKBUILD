# Contributor: Anjandev Momi <anjan@momi.ca>
# Maintainer: Anjandev Momi <anjan@momi.ca>
pkgname=py3-scs
pkgver=3.2.11
pkgrel=0
pkgdesc="C package that solves convex cone problems via operator splitting"
url="https://github.com/cvxgrp/scs"
arch="all"
license="MIT"
depends="python3 py3-numpy py3-scipy"
makedepends="openblas-dev py3-meson-python py3-numpy-dev python3-dev py3-gpep517"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="scs-$pkgver.tar.gz::https://files.pythonhosted.org/packages/source/s/scs/scs-$pkgver.tar.gz"
builddir="$srcdir/scs-$pkgver"

case "$CARCH" in
# Check segfaults on 32-bit arches
arm*|x86) options="!check" ;;
esac

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1e5e4ce7243315854496a90d1f7783b52b06192be5355b3ed82f6f9c7286551f6247d9f68393510e089fae42766a7d45d62ed9983a6b3a42efd9d50397c51176  scs-3.2.11.tar.gz
"
