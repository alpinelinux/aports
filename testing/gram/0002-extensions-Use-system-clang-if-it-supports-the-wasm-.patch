From e5e18e73a5fc314a145627c6959338fd6845342d Mon Sep 17 00:00:00 2001
From: LN Liberda <lauren@selfisekai.rocks>
Date: Sun, 8 Mar 2026 05:04:38 +0100
Subject: [PATCH] extensions: Use system clang, if it supports the wasm target

Bug: https://codeberg.org/GramEditor/gram/issues/58
---
 Cargo.lock                                |  1 +
 crates/extension/Cargo.toml               |  1 +
 crates/extension/src/extension_builder.rs | 14 +++++++++++++-
 3 files changed, 15 insertions(+), 1 deletion(-)

diff --git a/Cargo.lock b/Cargo.lock
index 1385c62537..a9df10e990 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -3358,6 +3358,7 @@ dependencies = [
  "util",
  "wasm-encoder 0.221.3",
  "wasmparser 0.221.3",
+ "which 6.0.3",
 ]
 
 [[package]]
diff --git a/crates/extension/Cargo.toml b/crates/extension/Cargo.toml
index b62095af86..aca9977414 100644
--- a/crates/extension/Cargo.toml
+++ b/crates/extension/Cargo.toml
@@ -35,6 +35,7 @@ url.workspace = true
 util.workspace = true
 wasm-encoder.workspace = true
 wasmparser.workspace = true
+which.workspace = true
 
 [dev-dependencies]
 fs = { workspace = true, "features" = ["test-support"] }
diff --git a/crates/extension/src/extension_builder.rs b/crates/extension/src/extension_builder.rs
index 48d7182a30..9de902ad53 100644
--- a/crates/extension/src/extension_builder.rs
+++ b/crates/extension/src/extension_builder.rs
@@ -264,7 +264,7 @@ impl ExtensionBuilder {
         } else {
             log::info!("compiling {grammar_name} parser");
             let clang_output = util::command::new_smol_command(&clang_path)
-                .args(["-fPIC", "-shared", "-Os"])
+                .args(["-fPIC", "-shared", "-Os", &format!("--target={RUST_TARGET}"), "--sysroot=/usr/share/wasi-sysroot"])
                 .arg(format!("-Wl,--export=tree_sitter_{grammar_name}"))
                 .arg("-o")
                 .arg(&grammar_wasm_path)
@@ -423,6 +423,18 @@ impl ExtensionBuilder {
     }
 
     async fn install_wasi_sdk_if_needed(&self) -> Result<PathBuf> {
+        if let Ok(system_clang) = which::which(format!("clang{}", env::consts::EXE_SUFFIX)) {
+            if util::command::new_smol_command(&system_clang)
+                .args([&format!("--target={RUST_TARGET}"), "-print-supported-cpus"])
+                .output()
+                .await
+                .is_ok_and(|o| o.status.success())
+            {
+                return Ok(system_clang);
+            }
+        }
+        bail!("Install clang and rust-wasm from apk to build extensions");
+
         let url = if let Some(asset_name) = WASI_SDK_ASSET_NAME {
             format!("{WASI_SDK_URL}{asset_name}")
         } else {
