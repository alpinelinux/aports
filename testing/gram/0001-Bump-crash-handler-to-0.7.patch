From ab9cd6b719510c27dffbc02ca98c4c836b9dd1ca Mon Sep 17 00:00:00 2001
From: LN Liberda <lauren@selfisekai.rocks>
Date: Fri, 6 Mar 2026 07:37:57 +0100
Subject: [PATCH] Bump crash-handler to 0.7

Needed to build for dynamically-linked musl.
https://github.com/EmbarkStudios/crash-handling/pull/105
---
 Cargo.lock | 4 ++--
 Cargo.toml | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 79e1aaa8a2..1385c62537 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -2225,9 +2225,9 @@ dependencies = [
 
 [[package]]
 name = "crash-handler"
-version = "0.6.3"
+version = "0.7.0"
 source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "2066907075af649bcb8bcb1b9b986329b243677e6918b2d920aa64b0aac5ace3"
+checksum = "0df5c9639f4942eb7702b964b3f9adf03a55724a57558cc177407388a8b936e2"
 dependencies = [
  "cfg-if",
  "crash-context",
diff --git a/Cargo.toml b/Cargo.toml
index ba44830e8f..dd2b9c2a06 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -369,7 +369,7 @@ core-foundation = "=0.10.0"
 core-foundation-sys = "0.8.6"
 core-video = { version = "0.4.3", features = ["metal"] }
 cpal = "0.16"
-crash-handler = "0.6"
+crash-handler = "0.7"
 criterion = { version = "0.5", features = ["html_reports"] }
 ctor = "0.4.0"
 dap-types = { git = "https://github.com/zed-industries/dap-types", rev = "1b461b310481d01e02b2603c16d7144b926339f8" }
