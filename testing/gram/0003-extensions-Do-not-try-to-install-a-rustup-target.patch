From 90ebc0d78cf3bebb780d2b9c52fd818da5b11bac Mon Sep 17 00:00:00 2001
From: LN Liberda <lauren@selfisekai.rocks>
Date: Wed, 11 Mar 2026 21:33:01 +0100
Subject: [PATCH] extensions: Do not try to install a rustup target

---
 crates/extension/src/extension_builder.rs | 1 +
 1 file changed, 1 insertion(+)

diff --git a/crates/extension/src/extension_builder.rs b/crates/extension/src/extension_builder.rs
index 5940450c70..a95f884945 100644
--- a/crates/extension/src/extension_builder.rs
+++ b/crates/extension/src/extension_builder.rs
@@ -404,6 +404,7 @@ impl ExtensionBuilder {
         if sysroot.join("lib/rustlib").join(RUST_TARGET).exists() {
             return Ok(());
         }
+        bail!("Install rust-wasm to build extensions");
 
         let output = util::command::new_smol_command("rustup")
             .args(["target", "add", RUST_TARGET])
