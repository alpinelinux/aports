maintainer="Hoang Nguyen <folliekazetani@protonmail.com>"
pkgname=opa
pkgver=1.15.2
pkgrel=0
pkgdesc="Open source, general-purpose policy engine"
url="https://www.openpolicyagent.org/"
# 32bit: blocked by wasmtime
# riscv64: test fails
arch="all !x86 !armv7 !armhf !riscv64"
license="Apache-2.0"
makedepends="go wasmtime-dev"
checkdepends="tzdata"
subpackages="
	$pkgname-doc
	$pkgname-bash-completion
	$pkgname-fish-completion
	$pkgname-zsh-completion
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/open-policy-agent/opa/archive/refs/tags/v$pkgver.tar.gz"
options="net" # download Go modules

# secfixes:
#   1.4.2-r0:
#     - CVE-2025-46569

build() {
	local goldflags="
	-X github.com/open-policy-agent/opa/v1/version.Version=$pkgver
	-X github.com/open-policy-agent/opa/v1/version.Hostname=AlpineLinux
	-X github.com/open-policy-agent/opa/v1/version.Vcs=0000000000000000000000000000000000000000
	-X github.com/open-policy-agent/opa/v1/version.Timestamp=$(date -u "+%Y-%m-%dT%H:%M:%SZ" ${SOURCE_DATE_EPOCH:+-d @$SOURCE_DATE_EPOCH})
	-X github.com/open-policy-agent/opa/internal/versioncheck.ExternalServiceURL=http://0.0.0.0
	"

	export CGO_CFLAGS="$CFLAGS"
	export CGO_LDFLAGS="$LDFLAGS -L/usr/lib -lwasmtime"

	go build -v -ldflags "$goldflags" -tags opa_wasm

	mkdir -p man/
	go run build/generate-man/generate.go man/

	for shell in bash fish zsh; do
		./opa completion $shell > opa.$shell
	done
}

check() {
	go test ./...
}

package() {
	install -Dm755 opa -t "$pkgdir"/usr/bin/

	install -Dm644 man/*.1 -t "$pkgdir"/usr/share/man/man1/

	install -Dm644 opa.bash \
		"$pkgdir"/usr/share/bash-completion/completions/opa
	install -Dm644 opa.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/opa.fish
	install -Dm644 opa.zsh \
		"$pkgdir"/usr/share/zsh/site-functions/_opa
}

sha512sums="
9b0c6131a8fb72ee54935f3f5fa11f3043b99f73c98e7ecbf08cfbae5751d42bf5ad457c03b0267d011919238bcb68e7f38459c33bc771cc8af85bb80b768fb0  opa-1.15.2.tar.gz
"
