maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=ministream
pkgver=0_git20260228
_commit=2dcbcf5bd53646f82a49e2ce1b2415bebcc19b17
pkgrel=0
pkgdesc="Small appstream manifest parser"
url="https://gitlab.gnome.org/sp1rit/ministream"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	glib-dev
	gobject-introspection-dev
	meson
	"
checkdepends="
	appstream-dev
	libxml2-dev
	"
subpackages="$pkgname-dev"
source="https://gitlab.gnome.org/sp1rit/ministream/-/archive/$_commit/ministream-$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit"

build() {
	abuild-meson \
		-Dtests="$(want_check && echo true || echo false)" \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
