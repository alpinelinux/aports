maintainer="Dylan Van Assche <dylan@postmarketos.org>"
pkgname=usb-signaller
pkgver=0.2.0
pkgrel=0
pkgdesc="Replacement for usb-moded for mainline devices."
url="https://codeberg.org/DylanVanAssche/usb-signaller"
arch="all"
license="GPL-3.0-or-later"
source="
	$pkgname-$pkgver.tar.gz::https://codeberg.org/DylanVanAssche/usb-signaller/archive/v$pkgver.tar.gz
	usb-signaller.initd
"
makedepends="cargo-auditable dbus-dev"
subpackages="$pkgname-systemd $pkgname-openrc"
builddir="$srcdir/$pkgname"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/usb-signaller "$pkgdir"/usr/bin/usb-signaller

	# Init service files
	install -Dm755 "$srcdir"/usb-signaller.initd "$pkgdir"/etc/init.d/usb-signaller
	install -Dm644 usb-signaller.service -t "$pkgdir"/usr/lib/systemd/system/

	# DBus policy
	install -Dm644 com.meego.usb_moded.conf -t "$pkgdir"/usr/share/dbus-1/system.d/
}

sha512sums="
2a8203cb4d98fd6fc80a0768242743abba53d3c9efa9b807e554cd463e15d872374e97e943d6fdd6c4f12d1cadd68c7e3f9a359bef01f99fdeb690f54cbbd20a  usb-signaller-0.2.0.tar.gz
006e7150c4818d44f7b8fae7853ab01902985fb7d6998f779652665eb22a24016a96621b397642891d02ae0f83269b85029693207ec57cae5a0630c5eb1f180f  usb-signaller.initd
"
