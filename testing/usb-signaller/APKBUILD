maintainer="Dylan Van Assche <dylan@postmarketos.org>"
pkgname=usb-signaller
pkgver=0.3.1
pkgrel=0
pkgdesc="Switch between different USB gadgets"
url="https://codeberg.org/DylanVanAssche/usb-signaller"
arch="all"
license="GPL-3.0-or-later"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/DylanVanAssche/usb-signaller/archive/v$pkgver.tar.gz
	usb-signaller.initd
"
makedepends="cargo-auditable dbus-dev"
subpackages="$pkgname-systemd $pkgname-openrc"
builddir="$srcdir/$pkgname"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/usb-signaller "$pkgdir"/usr/bin/usb-signaller

	# Init service files
	install -Dm755 "$srcdir"/usb-signaller.initd "$pkgdir"/etc/init.d/usb-signaller
	install -Dm644 usb-signaller.service -t "$pkgdir"/usr/lib/systemd/system/

	# DBus policy
	install -Dm644 com.meego.usb_moded.conf -t "$pkgdir"/usr/share/dbus-1/system.d/
}

sha512sums="
5dccfde66faef64b8535882fb9c237ba54c094ac647fef9235322ea3f197d6b3a785f7d85145f0836bbc35cefcc2855b4ba3ce6cf2d9286c1cbe6b15fb69a5f5  usb-signaller-0.3.1.tar.gz
39d604f91a8cb5bdb358fda05902a67de6403b99e5cba8d094b18f463cc1520cf80a43e2a60acf7fcfff85b9d4b0c57f64cedba8d080acd2f809b0c699683490  usb-signaller.initd
"
