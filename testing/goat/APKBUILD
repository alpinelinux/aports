maintainer="Fabricio Silva <hi@fabricio.dev>"
pkgname=goat
pkgver=0.2.3
pkgrel=0
pkgdesc="Go AT protocol CLI tool"
url="https://github.com/bluesky-social/goat"
arch="all"
license="Apache-2.0 AND MIT"
makedepends="go"
options="net !check" # net for go / no tests upstream
subpackages="$pkgname-doc"
source="https://github.com/bluesky-social/goat/archive/refs/tags/v$pkgver/goat-$pkgver.tar.gz"

build() {
	go build -ldflags "-X main.Version=$pkgver" .
}

package() {
	install -Dm755 goat -t "$pkgdir"/usr/bin/
	install -Dm644 LICENSE-MIT "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

sha512sums="
