# Contributor: Austin Page <jaustinpage@gmail.com>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=py3-cassandra-driver
_pkgname=cassandra_driver
pkgver=3.30.0
pkgrel=0
pkgdesc="Python driver for Apache Cassandra"
url="https://github.com/datastax/python-driver"
arch="all"
license="Apache-2.0"
makedepends="libev-dev py3-gpep517 py3-setuptools py3-wheel python3-dev"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/${_pkgname:0:1}/$_pkgname/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"
options="!check" # no tests included

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl

}

sha512sums="
eae4a2b995007e4a41a42546cab4884030b19548c8d246655d14a870f6514780b1110cb5c70aa8fc32f6272761eb4076179b56e45140ff197a577430a31ece20  cassandra_driver-3.30.0.tar.gz
"
