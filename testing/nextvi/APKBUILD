# Maintainer: omni <omni+alpine@hack.org>
maintainer="omni <omni+alpine@hack.org>"
pkgname=nextvi
pkgver=4.0
pkgrel=0
pkgdesc="A small vi/ex terminal text editor (neatvi rewrite)"
arch="all"
url="https://github.com/kyx0r/nextvi/"
license="ISC"
subpackages="$pkgname-doc
	$pkgname-vi:_vi
	$pkgname-vi-doc:_vi_doc
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/kyx0r/nextvi/archive/refs/tags/$pkgver.tar.gz"

build() {
	sh cbuild.sh
}

check() {
	sh test.sh
}

package() {
	install -Dm0755 vi "$pkgdir"/usr/bin/"$pkgname"

	install -Dm0644 vi.1 "$pkgdir"/usr/share/man/man1/"$pkgname".1
	install -Dm0644 LICENSE -t "$pkgdir"/usr/share/licenses/"$pkgname"/
}

_vi() {
	pkgdesc="nextvi vi provider"
	depends="$pkgname=$pkgver-r$pkgrel"

	install -dm0755 "$subpkgdir"/usr/bin/
	ln -s "$pkgname" "$subpkgdir"/usr/bin/vi
}

_vi_doc() {
	pkgdesc="nextvi vi(1) provider manpage"
	depends="$pkgname-doc=$pkgver-r$pkgrel"
	install_if="docs $pkgname-vi=$pkgver-r$pkgrel"

	install -dm0755 "$subpkgdir"/usr/share/man/man1/
	ln -s "$pkgname".1.gz "$subpkgdir"/usr/share/man/man1/vi.1.gz
}

sha512sums="
1abffe78fa9e77e890007ae96ad6ebd59c54b30a8273c75f53e786bdc782bdc4f64a6a4cef4622969cdb95a891347bd764ac9936610414081f91154ee07dc204  nextvi-4.0.tar.gz
"
