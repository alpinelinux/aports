# Contributor: kpcyrd <git@rxv.cc>
# Maintainer: kpcyrd <git@rxv.cc>
pkgname=signal-tlsd
pkgver=0.1.1
pkgrel=0
pkgdesc="Standalone Rust implementation of Signal's domain fronting TLS proxy"
url="https://github.com/kpcyrd/signal-tlsd"
arch="all"
license="MIT-0"
makedepends="
	cargo
	cargo-auditable
	libcap-utils
	"
pkgusers="$pkgname"
pkggroups="$pkgname"
install="$pkgname.pre-install"
subpackages="$pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/kpcyrd/signal-tlsd/archive/v$pkgver.tar.gz"
options="setcap net"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 "$builddir/target/release/signal-tlsd" -t "$pkgdir/usr/bin"
	setcap cap_net_bind_service=+ep "$pkgdir"/usr/bin/signal-tlsd

	# config directory
	install -d -m750 -o root -g "$pkggroups" "$pkgdir/etc/$pkgname"

	# openrc
	install -Dm755 "$builddir/contrib/$pkgname.initd" "$pkgdir/etc/init.d/$pkgname"
	install -Dm644 "$builddir/contrib/$pkgname.confd" "$pkgdir/etc/conf.d/$pkgname"
}

sha512sums="
6476da167a71ed40d1c75897ac025a1e6fcd80241f95aec018dbb71b7dfed62736b24f9da1bb87d37750d391218d590c98e06552c86c9373bc344c349437edcd  signal-tlsd-0.1.1.tar.gz
"
