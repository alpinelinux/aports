# Contributor: kpcyrd <git@rxv.cc>
# Maintainer: kpcyrd <git@rxv.cc>
pkgname=signal-tlsd
pkgver=0.1.0
pkgrel=0
pkgdesc="Standalone Rust implementation of Signal's domain fronting TLS proxy"
url="https://github.com/kpcyrd/signal-tlsd"
arch="all"
license="MIT-0"
makedepends="
	cargo
	cargo-auditable
	libcap-utils
	"
pkgusers="$pkgname"
pkggroups="$pkgname"
install="$pkgname.pre-install"
subpackages="$pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/kpcyrd/signal-tlsd/archive/v$pkgver.tar.gz
	$pkgname.initd
	$pkgname.confd
	"
options="setcap net"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 "$builddir/target/release/signal-tlsd" -t "$pkgdir/usr/bin"
	setcap cap_net_bind_service=+ep "$pkgdir"/usr/bin/signal-tlsd

	# data directory
	install -d -m750 -o root -g "$pkggroups" "$pkgdir/var/lib/$pkgname"

	# openrc
	install -Dm755 "$srcdir/$pkgname.initd" "$pkgdir/etc/init.d/$pkgname"
	install -Dm644 "$srcdir/$pkgname.confd" "$pkgdir/etc/conf.d/$pkgname"
}

sha512sums="
