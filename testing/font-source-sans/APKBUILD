maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=font-source-sans
pkgver=3.052
pkgrel=0
pkgdesc="Sans-serif font family for user interface environments"
url="https://adobe-fonts.github.io/source-sans/"
arch="noarch"
license="OFL-1.1"
options="!check"
source="source-sans-${pkgver}R.tar.gz::https://github.com/adobe-fonts/source-sans/archive/refs/tags/${pkgver}R.tar.gz"
builddir="$srcdir/source-sans-${pkgver}R"

package() {
	install -Dm644 OTF/*.otf VF/*.otf -t "$pkgdir"/usr/share/fonts/source-sans
	install -Dm644 LICENSE.md -t "$pkgdir"/usr/share/licenses/$pkgname
}

