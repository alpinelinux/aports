# Contributor: Wen Heping <wenhepingalpine@sohu.com>
# Maintainer: Wen Heping <wenhepingalpine@sohu.com>
pkgname=angie
pkgver=1.11.8
pkgrel=0
pkgdesc="Drop-in replacement for nginx, a high-performance web server"
url="https://angie.software/"
arch="all"
license="BSD-2-Clause"
makedepends="openssl-dev pcre2-dev zlib-dev linux-headers"
checkdepends="perl perl-json perl-net-ssleay perl-test-deep perl-test-most perl-utils"
subpackages="$pkgname-openrc"
install="$pkgname.pre-install"

source="https://download.angie.software/files/angie-$pkgver.tar.gz
	angie.initd
	angie.confd
	angie.logrotate
	"

options="!check"  # some tests fail

build() {
	./configure \
		--prefix=/var/lib/angie \
		--sbin-path=/usr/sbin/angie \
		--modules-path=/usr/lib/angie/modules \
		--conf-path=/etc/angie/angie.conf \
		--error-log-path=/var/log/angie/error.log \
		--http-log-path=/var/log/angie/access.log \
		--pid-path=/run/angie.pid \
		--lock-path=/run/lock/angie.lock \
		--http-client-body-temp-path=/var/lib/angie/tmp/client_body_temp \
		--http-proxy-temp-path=/var/lib/angie/tmp/proxy_temp \
		--http-fastcgi-temp-path=/var/lib/angie/tmp/fastcgi_temp \
		--http-uwsgi-temp-path=/var/lib/angie/tmp/uwsgi_temp \
		--http-scgi-temp-path=/var/lib/angie/tmp/scgi_temp \
		--user=angie \
		--group=angie \
		--with-http_ssl_module \
		--with-http_v2_module \
		--with-http_v3_module \
		--with-http_realip_module \
		--with-http_addition_module \
		--with-http_sub_module \
		--with-http_dav_module \
		--with-http_flv_module \
		--with-http_mp4_module \
		--with-http_gunzip_module \
		--with-http_gzip_static_module \
		--with-http_random_index_module \
		--with-http_secure_link_module \
		--with-http_stub_status_module \
		--with-http_auth_request_module \
		--with-threads \
		--with-pcre \
		--with-pcre-jit \
		--with-stream \
		--with-stream_ssl_module \
		--with-stream_realip_module \
		--with-mail \
		--with-mail_ssl_module
	make
}

check() {
	make test
}

package() {
	make DESTDIR="$pkgdir" install
	
	install -d "$pkgdir"/var/log/angie
	install -d "$pkgdir"/var/lib/angie
	install -d "$pkgdir"/var/lib/angie/tmp/client_body_temp
	install -d "$pkgdir"/var/lib/angie/tmp/proxy_temp
	install -d "$pkgdir"/var/lib/angie/tmp/fastcgi_temp
	install -d "$pkgdir"/var/lib/angie/tmp/uwsgi_temp
	install -d "$pkgdir"/var/lib/angie/tmp/scgi_temp
	
	install -Dm755 "$srcdir"/angie.initd "$pkgdir"/etc/init.d/angie
	install -Dm644 "$srcdir"/angie.confd "$pkgdir"/etc/conf.d/angie
	install -Dm644 "$srcdir"/angie.logrotate "$pkgdir"/etc/logrotate.d/angie
}
