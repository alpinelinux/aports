maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=casilda
pkgver=1.4.0
pkgrel=0
pkgdesc="Wayland compositor widget for Gtk 4"
url="https://gitlab.gnome.org/jpu/casilda"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	gobject-introspection-dev
	gtk4.0-dev
	libepoxy-dev
	meson
	wlroots0.20-dev
	"
subpackages="$pkgname-dev"
source="https://gitlab.gnome.org/jpu/casilda/-/archive/$pkgver/casilda-$pkgver.tar.gz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
77795ae06285d888d2126e838acacf8223e563449ce740e3cae40101cbe7e74d27ac841599d39a73e62f12a9b5b5da14bc36c2df0539f18dce250357e11871e5  casilda-1.4.0.tar.gz
"
