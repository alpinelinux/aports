# Maintainer: agxr <agxr@disroot.org>
pkgname=xray
pkgver=26.3.27
pkgrel=2
pkgdesc="Unified platform for anti-censorship"
url="https://github.com/XTLS/Xray-core"
# s390x: using a custom implementation of ChaCha20 that uses binary.LittleEndian
arch="all !s390x"
license="MPL-2.0"
makedepends="go"
options="net"
subpackages="$pkgname-openrc $pkgname-doc"
builddir="$srcdir/Xray-core-$pkgver"
install="$pkgname.pre-install"

_geosite_ver=20260628154711
_geoip_ver=202606191114

source="xray-$pkgver.tar.gz::https://github.com/XTLS/Xray-core/archive/v$pkgver.tar.gz
	geosite-$_geosite_ver.dat::https://github.com/v2fly/domain-list-community/releases/download/$_geosite_ver/dlc.dat
	geoip-$_geoip_ver.dat::https://github.com/v2fly/geoip/releases/download/$_geoip_ver/geoip.dat
	xray.initd
	xray.logrotate
	xray.pre-install
	"

check() {
	mkdir -p "$builddir/resources"
	ln -s "$srcdir/geosite-$_geosite_ver.dat" "$builddir/resources/geosite.dat"
	ln -s "$srcdir/geoip-$_geoip_ver.dat" "$builddir/resources/geoip.dat"
	export XRAY_LOCATION_ASSET="$builddir/resources"

	# TestECHDial - wants direct udp
	# TestGetAssetLocation - conflicts with XRAY_LOCATION_ASSET
	# TestGeoIPMatcher6US - wants older geoip versions
	# testing/scenarios - timeouts on riscv64, aarch64 under QEMU
	local packages=$(go list ./... | grep -v "/testing/scenarios")
	go test -skip "TestECHDial|TestGetAssetLocation|TestGeoIPMatcher6US" $packages
}

build() {
	local _ldflags="-s -w -X github.com/xtls/xray-core/core.build=v$pkgver -buildid="

	go build -v -o "$pkgname" \
		-buildmode=pie \
		-trimpath \
		-buildvcs=false \
		-ldflags="$_ldflags" \
		./main
}

package() {
	install -Dm755 "$pkgname" "$pkgdir/usr/bin/$pkgname"

	install -Dm755 "$srcdir"/xray.initd "$pkgdir"/etc/init.d/xray
	install -Dm644 "$srcdir"/xray.logrotate "$pkgdir"/etc/logrotate.d/$pkgname
	install -Dm644 "$srcdir/geosite-$_geosite_ver.dat" "$pkgdir/usr/share/$pkgname/geosite.dat"
	install -Dm644 "$srcdir/geoip-$_geoip_ver.dat" "$pkgdir/usr/share/$pkgname/geoip.dat"
	install -Dm644 "$builddir"/LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}
