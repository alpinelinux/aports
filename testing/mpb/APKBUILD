# Contributor: Leon White <badfunkstripe@gmail.com>
maintainer="Leon White <badfunkstripe@gmail.com>"
pkgname=mpb
pkgver=1.12.0
pkgrel=0
pkgdesc="MIT Photonic Bands computes electromagnetic band structures and modes"
url="https://mpb.readthedocs.io/"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	fftw-dev
	gfortran
	guile-dev
	hdf5-dev
	libctl-dev
	openblas-dev
	"
subpackages="$pkgname-dev $pkgname-doc"
source="https://github.com/NanoComp/mpb/releases/download/v$pkgver/mpb-$pkgver.tar.gz"

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--localstatedir=/var \
		--enable-shared \
		--with-blas=openblas \
		--with-lapack=openblas
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
656c14de736443022201bae57b271d38101710fe60dee82894ef0b4e7b8b142ddc744dfaff1ea76ee02fbd7c1d52d9f1b5c022a9736277d83789ee2813bbca70  mpb-1.12.0.tar.gz
"
