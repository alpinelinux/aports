maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=vt-wait
pkgver=1.0.1
pkgrel=0
pkgdesc="Wait until a VT becomes active"
url="https://sr.ht/~whynothugo/vt-wait/"
arch="all"
license="ISC"
makedepends="linux-headers scdoc"
subpackages="$pkgname-doc"
source="vt-wait-$pkgver.tar.gz::https://git.sr.ht/~whynothugo/vt-wait/archive/v$pkgver.tar.gz"
builddir="$srcdir/vt-wait-v$pkgver/"
options="!check" # no tests

build() {
	make PREFIX=/usr build
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
	install -Dm644 LICENCE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

