# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-calculator
pkgver=2.0
pkgrel=0
pkgdesc="Default calculator app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-calculator"
# armhf blocked by qt6-qtdeclarative -> qml-asteroid
arch="all !armhf"
license="GPL-3.0-or-later"
depends="mapplauncherd-qt"
makedepends="
	extra-cmake-modules
	samurai
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/AsteroidOS/asteroid-calculator/archive/refs/tags/$pkgver.tar.gz
	0001-fix-cmake-use-the-correct-project-version.patch
	0002-chore-prettify-CMake-usage.patch
	0003-feat-port-to-Qt6.patch
	"
options="!check" # no tests

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

