From a7ba2bfd3dba30f037945f6abaea8f7634b80a71 Mon Sep 17 00:00:00 2001
From: Bart Ribbers <bribbers@disroot.org>
Date: Fri, 20 Mar 2026 10:31:40 +0100
Subject: [PATCH 3/3] feat: port to Qt6

---
 CMakeLists.txt         | 8 ++++----
 asteroid-calculator.in | 2 +-
 src/CMakeLists.txt     | 4 ++--
 src/CalcButton.qml     | 4 ++--
 src/Display.qml        | 6 +++---
 src/main.qml           | 6 +++---
 6 files changed, 15 insertions(+), 15 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 4c6e983..894dcf0 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,4 +1,4 @@
-cmake_minimum_required(VERSION 3.6.0)
+cmake_minimum_required(VERSION 3.10.0)
 
 project(
 	asteroid-calculator
@@ -6,14 +6,14 @@ project(
 	DESCRIPTION "Default calculator app for AsteroidOS"
 )
 
-find_package(AsteroidApp REQUIRED)
+find_package(AsteroidApp6 REQUIRED)
 
 set(CMAKE_MODULE_PATH ${ASTEROID_MODULE_PATH})
 
 include(FeatureSummary)
 include(GNUInstallDirs)
-include(AsteroidCMakeSettings)
-include(AsteroidTranslations)
+include(Asteroid6CMakeSettings)
+include(Asteroid6Translations)
 
 add_subdirectory(src)
 
diff --git a/asteroid-calculator.in b/asteroid-calculator.in
index 8cb93f8..d769322 100644
--- a/asteroid-calculator.in
+++ b/asteroid-calculator.in
@@ -1,3 +1,3 @@
 #!/bin/sh
 
-exec invoker --single-instance --type=qt5 @CMAKE_INSTALL_FULL_LIBDIR@/asteroid-calculator.so
+exec invoker --single-instance --type=qt6 @CMAKE_INSTALL_FULL_LIBDIR@/asteroid-calculator.so
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index df2154f..c571c9e 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -3,8 +3,8 @@ set_target_properties(asteroid-calculator PROPERTIES PREFIX "")
 
 target_link_libraries(
 	asteroid-calculator
-	PUBLIC
-		AsteroidApp
+	PRIVATE
+		Asteroid::AsteroidApp6
 )
 
 install(
diff --git a/src/CalcButton.qml b/src/CalcButton.qml
index 0f3de77..717112c 100644
--- a/src/CalcButton.qml
+++ b/src/CalcButton.qml
@@ -17,8 +17,8 @@
  * along with this program. If not, see <http://www.gnu.org/licenses/>.
  */
 
-import QtQuick 2.9
-import org.asteroid.controls 1.0
+import QtQuick
+import org.asteroid.controls
 
 MouseArea {
     id: button
diff --git a/src/Display.qml b/src/Display.qml
index d3cfcaf..e85eb15 100644
--- a/src/Display.qml
+++ b/src/Display.qml
@@ -17,9 +17,9 @@
  * along with this program. If not, see <http://www.gnu.org/licenses/>.
  */
 
-import QtQuick 2.9
-import org.asteroid.controls 1.0
-import org.asteroid.utils 1.0
+import QtQuick
+import org.asteroid.controls
+import org.asteroid.utils
 import "calculator.js" as CalcEngine
 
 Label {
diff --git a/src/main.qml b/src/main.qml
index 460180c..6f3fac2 100644
--- a/src/main.qml
+++ b/src/main.qml
@@ -17,9 +17,9 @@
  * along with this program. If not, see <http://www.gnu.org/licenses/>.
  */
 
-import QtQuick 2.9
-import org.asteroid.controls 1.0
-import org.asteroid.utils 1.0
