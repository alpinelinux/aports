# Contributor: Guy Godfroy <guy.godfroy@gugod.fr>
maintainer="Guy Godfroy <guy.godfroy@gugod.fr>"
pkgname=authelia
pkgver=4.39.20
pkgrel=0
pkgdesc="Single Sign-On Multi-Factor portal for web apps"
url="https://www.authelia.com/"
# other arches lack native musl bindings for the frontend toolchain (rolldown)
arch="x86_64 aarch64"
license="Apache-2.0"
makedepends="
	go
	nodejs
	pnpm
	"
checkdepends="bash"
install="$pkgname.pre-install"
pkgusers="authelia"
pkggroups="authelia"
subpackages="$pkgname-openrc $pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/authelia/authelia/archive/refs/tags/v$pkgver.tar.gz
	authelia.initd
	authelia.confd
	"
options="net"

build() {
	( cd web && pnpm install --frozen-lockfile --ignore-scripts && pnpm build )

	# vite wipes public_html; restore the embedded API docs assets
	cp -r api internal/server/public_html/

	local ldflags="
		-linkmode=external -s -w
		-X 'github.com/authelia/authelia/v4/internal/utils.BuildTag=v$pkgver'
		-X 'github.com/authelia/authelia/v4/internal/utils.BuildState=tagged clean'
		-X 'github.com/authelia/authelia/v4/internal/utils.BuildExtra=Alpine'
		-X 'github.com/authelia/authelia/v4/internal/utils.BuildNumber=$pkgrel'
		"
	go build -buildmode=pie -trimpath -ldflags "$ldflags" -o authelia ./cmd/authelia
}

check() {
	# skip env-bound tests: developer-local TZ, build-path basename, CI-only DNS
	# shellcheck disable=SC2046
	go test -skip 'TestNewOAuth2DeviceCodeSessionFromRequest|^TestWebAuthnCredential$|TestShouldExecCommandOnAutheliaRootPath|TestShouldServeOverTLS|TestShouldRaiseErrorWhenClientDoesNotSkipVerify|TestShouldRaiseWhenMutualTLSIsConfiguredAndClientIsNotAuthenticated|TestShouldServeProperlyWhenMutualTLSIsConfiguredAndClientIsAuthenticated' \
		$(go list ./... | grep -v suites)
}

package() {
	install -Dm755 authelia "$pkgdir"/usr/bin/authelia

	install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -Dm644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname

	install -Dm644 config.template.yml \
		"$pkgdir"/usr/share/doc/$pkgname/config.template.yml

	install -dm750 -o authelia -g authelia \
		"$pkgdir"/etc/authelia
}

