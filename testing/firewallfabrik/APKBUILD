# Contributor: Henrik Riomar <henrik.riomar@gmail.com>
# Maintainer: Henrik Riomar <henrik.riomar@gmail.com>
pkgname=firewallfabrik
pkgver=1.9.0
pkgrel=1
pkgdesc="Modern fwbuilder successor"
url="https://linuxfabrik.github.io/firewallfabrik/"
arch="noarch !armhf" # pyside6-dev missing
license="GPL-2.0-or-later"
depends="
	py3-defusedxml
	py3-jinja2
	py3-sqlalchemy
	py3-yaml
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	pyside6-dev
	"
checkdepends="
	py3-pytest
	"
subpackages="
	$pkgname-gui-pyc:gui_pyc
	$pkgname-gui
	$pkgname-pyc
	"
source="https://github.com/Linuxfabrik/firewallfabrik/archive/v$pkgver/firewallfabrik-$pkgver.tar.gz"
options="net" # Needed for tests to pass in rootbld

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

gui() {
	pkgdesc="$pkgname gui"
	depends="$pkgname=$pkgver-r$pkgrel py3-pyside6"

	amove usr/bin/fwf
	amove usr/lib/python3*/site-packages/firewallfabrik/gui
}

gui_pyc() {
	pkgdesc="Precompiled Python bytecode for ${subpkgname%-pyc}"
	install_if="${subpkgname%-pyc}=$pkgver-r$pkgrel pyc"
	depends="$pkgname-gui=$pkgver-r$pkgrel"

	amove usr/lib/python*/site-packages/firewallfabrik/gui/__pycache__
}

sha512sums="
507253e890277d81fa147ab7a2f72d224d95d3183a1cfc921dcaea1d0c3cb686365a0b77b1a2bf938362f6ef03ae9725e687d92957a0ca9163c3b7a0a9ccd00d  firewallfabrik-1.9.0.tar.gz
"
