---
 Cargo.lock | 3 +--
 Cargo.toml | 2 +-
 2 files changed, 2 insertions(+), 3 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 9e38b028fee4..98f96db7c094 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -166,8 +166,7 @@ dependencies = [
