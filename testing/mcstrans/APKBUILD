maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=mcstrans
pkgver=3.11
pkgrel=0
pkgdesc="Label translation daemon to support MLS systems"
url="https://github.com/SELinuxProject/selinux"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	libselinux-dev
	libcap-dev
	linux-headers
	"
subpackages="
	$pkgname-doc
	$pkgname-systemd
	"
source="https://github.com/SELinuxProject/selinux/releases/download/$pkgver/mcstrans-$pkgver.tar.gz"

build() {
	make
}

check() {
	make test
}

package() {
	make DESTDIR="$pkgdir" SBINDIR=/usr/sbin install

	rm -r "$pkgdir"/etc/rc.d
}

