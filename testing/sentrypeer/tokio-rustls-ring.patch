Use the ring crypto provider for rustls instead of the default aws-lc-rs.

aws-lc-rs pulls in aws-lc-sys, which builds a bundled BoringSSL with CMake.
That CMake build fails on architectures without prebuilt artifacts (notably
loongarch64 and s390x). The ring provider is already pulled in by rcgen and
builds cleanly on all supported architectures, so use it for rustls too.

--- a/sentrypeer_rust/Cargo.toml
+++ b/sentrypeer_rust/Cargo.toml
@@ -20,7 +20,7 @@
 [dependencies]
 chrono = "0.4.40"
 libc = "0.2.170"
-tokio-rustls = "0.26.2"
+tokio-rustls = { version = "0.26.2", default-features = false, features = ["ring", "logging", "tls12"] }
 rustls-pemfile = "2.2.0"
 tokio = { version = "1.44.0", features = ["full"] }
 pki-types = { package = "rustls-pki-types", version = "1" }
