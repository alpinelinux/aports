Bump bindgen to 0.72 to fix the Rust build with the current libclang.

bindgen 0.71 generates opaque (field-less) structs for sentrypeer_config
and sip_message_event when run against llvm/clang 20+, which makes the
Rust code fail to compile with "no field ... on type" errors. bindgen
0.72 parses the headers correctly again.

--- a/sentrypeer_rust/Cargo.toml
+++ b/sentrypeer_rust/Cargo.toml
@@ -47,7 +47,7 @@
 ]
 
 [build-dependencies]
-bindgen = "0.71.1"
+bindgen = "0.72"
 cbindgen = "0.28.0"
 
 [lib]
--- a/sentrypeer_rust/Cargo.lock
+++ b/sentrypeer_rust/Cargo.lock
@@ -184,9 +184,9 @@
 
 [[package]]
 name = "bindgen"
-version = "0.71.1"
+version = "0.72.1"
