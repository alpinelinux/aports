# Contributor: Marian Buschsieweke <marian.buschsieweke@posteo.net>
maintainer="Marian Buschsieweke <marian.buschsieweke@posteo.net>"
pkgname=mermaid-rs-renderer
pkgver=0.3.1
pkgrel=0
pkgdesc="Fast Mermaid Diagram Renderer"
url="https://github.com/1jehuang/mermaid-rs-renderer"
arch="all"
license="MIT"
makedepends="
	cargo-auditable
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/1jehuang/mermaid-rs-renderer/archive/refs/tags/v$pkgver.tar.gz"

export CARGO_PROFILE_RELEASE_OPT_LEVEL="z"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	# See https://github.com/1jehuang/mermaid-rs-renderer/issues/84 for
	# failure of `dense_flowchart_keeps_mid_span_edge_reasonably_direct`
	cargo test --frozen -- \
		--skip all_repository_fixtures_satisfy_layout_invariants \
		--skip cycle_fixture_subgraph_entry_aligns_with_spine \
		--skip dense_flowchart_avoids_crossing_between_middle_and_far_edges \
		--skip every_fixture_renders_validly_and_preserves_content \
		--skip every_fixture_satisfies_type_semantics \
		--skip flowchart_fixtures_have_zero_hard_routing_violations \
		--skip rendering_is_deterministic_for_every_fixture \
		#
}

package() {
	install -D -m755 target/release/mmdr -t "$pkgdir"/usr/bin/
	install -Dm644 -t "$pkgdir"/usr/share/licenses/"$pkgname" LICENSE
}

sha512sums="
116916ea43691729a0d263319b4a917128b50b7cf6778d139d7c039f04b28ad7654073531ef5b3f03c4ba2fa969f54a07260bd67d8d457b8bbd1a00bf5a0508a  mermaid-rs-renderer-0.3.1.tar.gz
"
