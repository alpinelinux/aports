# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-btsyncd
pkgver=2.1_git20260512
pkgrel=0
_commit="180fce3b84d219626bed1ffc6dd152bdcfd0ff58"
pkgdesc="Bluetooth Low Energy synchronization daemon for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-btsyncd"
# armhf blocked by qt6-qtdeclarative -> qml-asteroid
# riscv64 blocked by libqofono -> nemo-qml-plugin-systemsettings
arch="all !armhf !riscv64"
license="GPL-3.0-or-later"
makedepends="
	amber-mpris-dev
	extra-cmake-modules
	glibmm2.66-dev
	nemo-qml-plugin-systemsettings-dev
	qml-asteroid-dev
	qt6-qtbase-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-btsyncd/archive/$_commit.tar.gz
	0001-asteroid-btsyncd-Find-AmberMpris.patch
	"
options="!check" # no tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

