# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-netifaces-plus
_pkgname=netifaces-plus
pkgver=0.12.5
pkgrel=0
pkgdesc="Portable network interface information"
url="https://github.com/tsukumijima/netifaces-plus"
arch="all !s390x" # tests fail on s390x
license="MIT"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	python3-dev
	linux-headers
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/${_pkgname:0:1}/$_pkgname/netifaces_plus-$pkgver.tar.gz"
builddir="$srcdir/netifaces_plus-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m test
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
f3fc51d42e0542151d6af12ac2b66384e8ad257bd368b911b50e581a68fdae94119c0b840b67fb8e7dd3821199c9d31d8c7d7e36c0530e500dfa72008492d623  netifaces_plus-0.12.5.tar.gz
"
