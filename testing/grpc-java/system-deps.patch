+    includes = ["include"],
+    linkopts = [
+        "-lprotobuf-lite",
+        "-labsl_log_internal_check_op",
+        "-labsl_log_internal_message",
+        "-labsl_log_internal_nullguard",
+        "-labsl_raw_logging_internal",
+        "-labsl_strings",
+        "-labsl_throw_delegate",
+        "-labsl_base",
+        "-labsl_spinlock_wait",
