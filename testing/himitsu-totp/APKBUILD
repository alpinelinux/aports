pkgname=himitsu-totp
pkgver=0.10
pkgrel=0
pkgdesc="TOTP support for Himitsu"
url="https://himitsustore.org"
arch="x86_64 aarch64 riscv64" # Hare
license="GPL-3.0-only"
depends="himitsu"
makedepends="hare scdoc himitsu-dev"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~sircmpwn/himitsu-totp/archive/$pkgver.tar.gz"

build() {
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
}

