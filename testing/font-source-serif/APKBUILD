maintainer="Runxi Yu <me@runxiyu.org>"
pkgname=font-source-serif
pkgver=4.005
pkgrel=0
pkgdesc="Open source typeface to complement Source Sans"
url="https://adobe-fonts.github.io/source-serif/"
arch="noarch"
license="OFL-1.1"
options="!check"
source="source-serif-${pkgver}R.tar.gz::https://github.com/adobe-fonts/source-serif/archive/refs/tags/${pkgver}R.tar.gz"
builddir="$srcdir/source-serif-${pkgver}R"

package() {
	install -Dm644 OTF/*.otf VAR/*.otf -t "$pkgdir"/usr/share/fonts/source-serif
	install -Dm644 LICENSE.md -t "$pkgdir"/usr/share/licenses/$pkgname
}

