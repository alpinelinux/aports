# Contributor: leso-kn <info@lesosoftware.com>
maintainer="leso-kn <info@lesosoftware.com>"
pkgname=py3-sphinx_rtd_dark_mode
pkgver=1.3.0
pkgrel=0
pkgdesc="Adds a toggleable dark mode to the Read the Docs theme for Sphinx"
url="https://github.com/MrDogeBro/sphinx_rtd_dark_mode"
arch="noarch"
license="MIT"
depends="py3-sphinx_rtd_theme"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-nose
	py3-sphinx
	"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/MrDogeBro/sphinx_rtd_dark_mode/archive/v$pkgver.tar.gz"
builddir="$srcdir/sphinx_rtd_dark_mode-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	nosetests tests
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
2871309a1683eba0c415fefd3acdddba641ac445e6ada95298320a5de586264d52c130b42ae5cbb51c76fe3534b22608b8c4ed82dc3a2d8c8ffed6823db3c047  py3-sphinx_rtd_dark_mode-1.3.0.tar.gz
"
