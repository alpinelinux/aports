maintainer="Michał Polański <michal@polanski.me>"
pkgname=py3-sh
pkgver=2.2.0
pkgrel=0
pkgdesc="Python subprocess replacement"
url="https://sh.readthedocs.io/"
license="MIT"
arch="noarch"
makedepends="py3-gpep517 py3-poetry-core"
checkdepends="py3-pytest lsof coreutils"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://pypi.io/packages/source/s/sh/sh-$pkgver.tar.gz"
builddir="$srcdir/sh-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
85815ba61f9d8bb0fcbbe2c5a25fc0ae5d1c5633522c1774a3015e7b4eb5c23b3bb6c018a4045eab7f5741451d5153ac559e0874c36cd63840cb5c25551e33f2  py3-sh-2.2.0.tar.gz
"
