maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=android-translation-layer
pkgver=0_git20260705
pkgrel=1
_commit="f4622e36186f5757b75a605deff543145df3094b"
pkgdesc="A translation layer for running Android apps on a Linux system"
url="https://gitlab.com/android_translation_layer/android_translation_layer"
arch="x86_64 aarch64 armv7 x86"
license="GPL-3.0-only"
# libopensles-standalone is not strictly required but some Android applications depend on it
depends="libopensles-standalone"
makedepends="
	alsa-lib-dev
	bionic_translation-dev
	art_standalone-dev
	ffmpeg-dev
	fontconfig-dev
	glib-dev
	gtk4.0-dev
	java-common
	libandroidfw-dev
	libgudev-dev
	libportal-dev
	meson
	openjdk8-jdk
	openxr-dev
	vulkan-loader-dev
	webkit2gtk-6.0-dev
	"
subpackages="$pkgname-dbg"
source="https://gitlab.com/android_translation_layer/android_translation_layer/-/archive/$_commit/android_translation_layer-$_commit.tar.gz"
builddir="$srcdir/android_translation_layer-$_commit"

build() {
	abuild-meson \
		. output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
f3d33d72e5fec2f278a9ceaff34ac1926d1416f947c38c2c046abb0b6a7f8b106a92fc7b135ea4c50bdf0353d753f33cdd1f759a499c0c369943ad3025d1c6af  android_translation_layer-f4622e36186f5757b75a605deff543145df3094b.tar.gz
"
