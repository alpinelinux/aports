# Contributor: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=curl-impersonate
pkgver=1.5.6
pkgrel=0
pkgdesc="Special curl that can impersonate Chrome, Edge, Safari and Firefox"
url="https://github.com/lexiforest/curl-impersonate"
# ppc64le, s390x: Unknown target CPU
arch="all !ppc64le !s390x"
license="MIT AND curl"
depends="ca-certificates"
makedepends="
	autoconf
	automake
	bash
	brotli-dev
	bzip2
	cmake
	libidn2-dev
	libtool
	libunistring-dev
	linux-headers
	nghttp2-dev
	ninja
	patch
	pkgconfig
	python3
	xz
	zlib-dev
	zstd-dev
	"
# libcurl-impersonate-static: broken
subpackages="
	libcurl-impersonate:libcurl
	libcurl-impersonate-dev
	"
# curl-impersonate requires ngtcp2 and nghttp3 with boringssl, by design.
# the system packages are built with openssl and are unsuitable.
_boringssl_commit="673e61fc215b178a90c0e67858bbf162c8158993"
_ngtcp2_ver="1.20.0"
_nghttp3_ver="1.15.0"
_curl_ver="8_15_0"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/lexiforest/curl-impersonate/archive/refs/tags/v$pkgver.tar.gz
	use-system-libs.patch

	boringssl-$_boringssl_commit.zip::https://github.com/google/boringssl/archive/$_boringssl_commit.zip
	ngtcp2-$_ngtcp2_ver.tar.bz2::https://github.com/ngtcp2/ngtcp2/releases/download/v$_ngtcp2_ver/ngtcp2-$_ngtcp2_ver.tar.bz2
	nghttp3-$_nghttp3_ver.tar.bz2::https://github.com/ngtcp2/nghttp3/releases/download/v$_nghttp3_ver/nghttp3-$_nghttp3_ver.tar.bz2
	curl-$_curl_ver.tar.gz::https://github.com/curl/curl/archive/curl-$_curl_ver.tar.gz
	"
options="!check" # Tests require network

prepare() {
	default_prepare

	# Makefile expects sources at these locations.
	ln -s "$srcdir/boringssl-$_boringssl_commit" "$builddir/boringssl-$_boringssl_commit"
	ln -s "$srcdir/ngtcp2-$_ngtcp2_ver" "$builddir/ngtcp2-$_ngtcp2_ver"
	ln -s "$srcdir/nghttp3-$_nghttp3_ver" "$builddir/nghttp3-$_nghttp3_ver"
	ln -s "$srcdir/curl-$_curl_ver" "$builddir/curl-$_curl_ver"

	# Makefile checks that these are here.
	ln -s "$srcdir/boringssl-$_boringssl_commit.zip" "$builddir/boringssl-$_boringssl_commit.zip"
	ln -s "$srcdir/ngtcp2-$_ngtcp2_ver.tar.bz2" "$builddir/ngtcp2-$_ngtcp2_ver.tar.bz2"
	ln -s "$srcdir/nghttp3-$_nghttp3_ver.tar.bz2" "$builddir/nghttp3-$_nghttp3_ver.tar.bz2"
	ln -s "$srcdir/curl-$_curl_ver.tar.gz" "$builddir/curl-$_curl_ver.tar.gz"
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--with-ca-bundle=/etc/ssl/certs/ca-certificates.crt \
		--with-ca-path=/etc/ssl/certs

	# Build fails with multiple jobs (apparent races).
	make -j1 build
}

check() {
	make checkbuild
}

package() {
	make install DESTDIR="$pkgdir"

	rm "$pkgdir"/usr/lib/libcurl-impersonate.a
}

libcurl() {
	pkgdesc="Special build of libcurl that can impersonate Chrome, Edge, Safari and Firefox"
	amove usr/lib/libcurl-impersonate.so*
}

