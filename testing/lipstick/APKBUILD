# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=lipstick
pkgver=2.1_git20260611
pkgrel=0
_commit="adf0ef35a198bef51d94ea4f3c24f304a75478b2"
pkgdesc="A project aimed at offering easy to modify user experiences for varying mobile device form factors"
url="https://github.com/AsteroidOS/lipstick"
# armhf and riscv64 blocked by nemo-qml-plugin-devicelock
arch="all !armhf !riscv64"
license="LGPL-2.1-only"
depends="dsme"
depends_dev="
	dbus-glib-dev
	bluez-qt-dev
	elogind-dev
	libdsme-dev
	libmce-qt-dev
	libngf-qt-dev
	libusb-moded-qt-dev
	libxkbcommon-dev
	mlite-dev
	nemo-keepalive-dev
	nemo-qml-plugin-connectivity-dev
	nemo-qml-plugin-devicelock-dev
	pulseaudio-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtsensors-dev
	qt6-qtwayland-dev
	ssu-sysinfo-dev
	timed-dev
	user-managerd-dev
	wayland-dev
	"
makedepends="$depends_dev
	doxygen
	graphviz
	qt6-qtdeclarative-private-dev
	qt6-qttools-dev
	samurai
	"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/lipstick/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	PATH="$PATH:/usr/lib/qt6/bin"
	qmake6 PREFIX=/usr
	make
}

package() {
	make INSTALL_ROOT="$pkgdir" install

	mkdir -p "$pkgdir"/usr/share/dbus-1/system.d/
	mv "$pkgdir"/etc/dbus-1/system.d/* "$pkgdir"/usr/share/dbus-1/system.d/
}

sha512sums="
1e65c08cc7054fe980079b8689fffb7912b9c89528e3747c442d89fd70d06e39d08b1d6209405ac6c83953324328d79d4630dfd0ee2396a2074b2c0cffc8a8a0  lipstick-adf0ef35a198bef51d94ea4f3c24f304a75478b2.tar.gz
"
