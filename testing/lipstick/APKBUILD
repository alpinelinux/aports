# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=lipstick
pkgver=1.4.3
pkgrel=0
_commit_dbus_glib="d42176ae4763e5288ef37ea314fe58387faf2005"
pkgdesc="A project aimed at offering easy to modify user experiences for varying mobile device form factors"
url="https://github.com/nemomobile-ux/lipstick"
# armhf and riscv64 blocked by nemo-qml-plugin-devicelock
arch="all !armhf !riscv64"
license="LGPL-2.1-only"
depends="dsme"
depends_dev="
	dbus-glib-dev
	bluez-qt-dev
	elogind-dev
	libdsme-dev
	libmce-qt-dev
	libngf-qt-dev
	libresourceqt-dev
	libusb-moded-qt-dev
	libxkbcommon-dev
	mlite-dev
	nemo-keepalive-dev
	nemo-qml-plugin-connectivity-dev
	nemo-qml-plugin-devicelock-dev
	nemo-qml-plugin-systemsettings-dev
	pulseaudio-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtsensors-dev
	qt6-qttools-dev
	qt6-qtwayland-dev
	ssu-sysinfo-dev
	user-managerd-dev
	wayland-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	doxygen
	graphviz
	qt6-qtdeclarative-private-dev
	samurai
	"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/nemomobile-ux/lipstick/archive/refs/tags/$pkgver.tar.gz
	dbus-glib-$_commit_dbus_glib.tar.gz::https://github.com/sailfishos-mirror/dbus-glib/archive/$_commit_dbus_glib.tar.gz
	0001-lipstick-Deps-without-suffix.patch
	"
options="!check" # Broken

prepare() {
	default_prepare

	rmdir src/3rdparty/dbus-gmain
	mv "$srcdir/dbus-glib-$_commit_dbus_glib" src/3rdparty/dbus-gmain
}

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

check() {
	ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	mkdir -p "$pkgdir"/usr/share/dbus-1/system.d/
	mv "$pkgdir"/etc/dbus-1/system.d/* "$pkgdir"/usr/share/dbus-1/system.d/
}

sha512sums="
