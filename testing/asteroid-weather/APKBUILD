# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-weather
pkgver=2.1.0
pkgrel=0
_commit="a79894dcf50dd9289e5759db15f689006f52aa2f"
pkgdesc="Default weather app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-weather"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="GPL-3.0-or-later"
depends="
	mapplauncherd
	nemo-qml-plugin-configuration
	"
makedepends="
	extra-cmake-modules
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-weather/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
