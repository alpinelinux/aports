# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-hrm
pkgver=2.1.0_git20260512
pkgrel=0
_commit="b50250c53594af24e1316dd6caf0d8fe14d3ab2a"
pkgdesc="Default heart-rate-monitor app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-hrm"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="GPL-3.0-or-later"
depends="
	mapplauncherd
	qt6-qtsensors
	"
makedepends="
	extra-cmake-modules
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-hrm/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
