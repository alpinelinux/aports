maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=podium
pkgver=0_git20260712
_commit=c6f220af0bead337ea1218502d80e041697093b8
pkgrel=0
pkgdesc="Create pretty talks"
url="https://gitlab.gnome.org/feaneron/podium"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	desktop-file-utils
	gettext-dev
	glib-dev
	gobject-introspection-dev
	gtk4.0-dev
	gtksourceview5-dev
	libadwaita-dev
	libarchive-dev
	libdex-dev
	libglycin-gtk4-dev
	libpeas2-dev
	libsass-dev
	md4c-dev
	meson
	"
subpackages="$pkgname-dev $pkgname-libs"
source="https://gitlab.gnome.org/feaneron/podium/-/archive/$_commit/podium-$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

