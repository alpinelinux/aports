# Contributor: Russ Webber <russ@rw.id.au>
# Maintainer: Russ Webber <russ@rw.id.au>
pkgname=py3-rosdistro
_pkgname=rosdistro
pkgver=1.0.1
pkgrel=0
pkgdesc="Tools to work with catkinized rosdistro files"
url="https://github.com/ros-infrastructure/rosdistro"
arch="noarch"
license="BSD-3-Clause"
depends="python3 py3-yaml py3-catkin-pkg"
makedepends="py3-gpep517 py3-setuptools"
checkdepends="git py3-pytest"
options="net" # tests use networking
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/ros-infrastructure/rosdistro/archive/$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
3b7eb5fbcd5002239db3a50262456416168b1be6c9728d6359e07b6ee94a481453f7e8c0d05ac4361e2cb565b820e9d7792e8d376678927ece72273f7b0b6c9a  py3-rosdistro-1.0.1.tar.gz
"
