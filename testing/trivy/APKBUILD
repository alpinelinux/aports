# Contributor: TBK <alpine@jjtc.eu>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=trivy
pkgver=0.72.0
pkgrel=1
pkgdesc="Simple and comprehensive vulnerability scanner for containers"
url="https://github.com/aquasecurity/trivy"
arch="all"
license="Apache-2.0"
makedepends="btrfs-progs-dev go linux-headers lvm2-dev"
source="https://github.com/aquasecurity/trivy/archive/v$pkgver/trivy-$pkgver.tar.gz"
options="net !check" # needs tinygo to turn go into wasm for tests

build() {
	# see https://github.com/aquasecurity/trivy/discussions/9557
	GOEXPERIMENT=jsonv2 go build -o trivy -ldflags "-X github.com/aquasecurity/trivy/pkg/version/app.ver=$pkgver" cmd/trivy/main.go
}

check() {
	GOEXPERIMENT=jsonv2 go test ./...
}

package() {
	install -Dm755 trivy -t "$pkgdir"/usr/bin/
}

sha512sums="
7407a8de54c0594a5a350eea0acb4cc8bdf75275cbe51a5e92ba6079aec7a634b4c2e9ad332089f0ae05e5772a9a625800aa7eab6611fdf87639275bb0af3be5  trivy-0.72.0.tar.gz
"
