maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=devpod
pkgver=0.26.1
pkgrel=0
pkgdesc="Codespaces but open-source, client-only, and unopinionated"
url="https://github.com/skevetter/devpod"
# ppc64le blocked by undefined references
# armhf, armv7, x86 and riscv64 blocked by -race not being supported
arch="x86_64 aarch64 loongarch64 s390x"
license="MPL-2.0"
makedepends="
	go
	linux-headers
	"
checkdepends="
	bash
	docker
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/skevetter/devpod/archive/refs/tags/v$pkgver.tar.gz
	0001-devpod-busybox-base64-decode.patch
	"
subpackages="
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"
# net required for downloading go modules
# no unit tests
options="net !check"

build() {
	go build -trimpath -v -o devpod-cli \
		-ldflags="-X github.com/skevetter/devpod/pkg/version.version=v$pkgver -extldflags=-static"
}

package() {
	install -Dm755 devpod-cli "$pkgdir"/usr/bin/devpod-cli
	ln -s /usr/bin/devpod-cli "$pkgdir"/usr/bin/devpod

	mkdir -p \
		"$pkgdir"/usr/share/bash-completion/completions \
		"$pkgdir"/usr/share/zsh/site-functions \
		"$pkgdir"/usr/share/fish/vendor_completions.d

	./devpod-cli completion bash > "$pkgdir"/usr/share/bash-completion/completions/$pkgname
	./devpod-cli completion zsh > "$pkgdir"/usr/share/zsh/site-functions/$pkgname
	./devpod-cli completion fish > "$pkgdir"/usr/share/fish/vendor_completions.d/$pkgname.fish
}

sha512sums="
b7f554bb4b5c88556f5593e120b3c00c6f35cfb614ed2e6c8fb0579c5753ab802eacb70d7d55419b288e127a96a595c4164d0a20698b58a78f4d08c43a87f128  devpod-0.26.1.tar.gz
ca3d9bc0fdc00eb2e60484803d502f00e280e291b134cd784ebf627f7d60938f405c89539d45e980c31db2752736f1fb8afe08380ea3fe1cbc20f40c81cdad3e  0001-devpod-busybox-base64-decode.patch
"
