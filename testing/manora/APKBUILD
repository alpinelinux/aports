# Contributor: Robin Candau <robincandau@protonmail.com>
# Maintainer: Robin Candau <robincandau@protonmail.com>
pkgname=manora
pkgver=2.2.4
pkgrel=0
pkgdesc="Simple CLI / TUI tool to display, download and save man pages as PDF files"
url="https://github.com/Antiz96/manora"
arch="all"
license="GPL-3.0-or-later"
depends="cmd:man groff xdg-utils util-linux-misc"
makedepends="cargo-auditable scdoc"
subpackages="$pkgname-doc $pkgname-bash-completion $pkgname-zsh-completion $pkgname-fish-completion"
source="$pkgname-$pkgver.tar.gz::https://github.com/Antiz96/manora/archive/refs/tags/v$pkgver.tar.gz"
options="net" # cargo fetch

prepare() {
	default_prepare
	cargo fetch --locked --target="$CTARGET"
}

build() {
	cargo auditable build --release --frozen
	scdoc < "doc/man/$pkgname.1.scd" > "doc/man/$pkgname.1"
}

check() {
	cargo test --frozen
}

package() {
	install -Dm 755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
	install -Dm 644 "res/completions/$pkgname.bash" "$pkgdir/usr/share/bash-completion/completions/$pkgname"
	install -Dm 644 "res/completions/$pkgname.zsh" "$pkgdir/usr/share/zsh/site-functions/_$pkgname"
	install -Dm 644 "res/completions/$pkgname.fish" "$pkgdir/usr/share/fish/vendor_completions.d/$pkgname.fish"
	install -Dm 644 "doc/man/$pkgname.1" "$pkgdir/usr/share/man/man1/$pkgname.1"
	install -Dm 644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}

sha512sums="
65f3bc184aaf2b45bc8ed72508b893ebd5adf02a0eeed12b071ff094b38d00863ccd4c71b66ee9cda33d848580710274542209eaf03dd2498dedf4023d2915b1  manora-2.2.4.tar.gz
"
