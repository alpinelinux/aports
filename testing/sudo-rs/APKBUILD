# Co-Maintainer: Aelin <aelin@postmarketos.org>
# Co-Maintainer: Achill Gilgenast <achill@achill.org>
maintainer="Aster Boese <asterboese@mailbox.org>"
pkgname=sudo-rs
pkgver=0.2.13
pkgrel=0
pkgdesc="Memory safe implementation of sudo and su"
arch="all"
url="https://github.com/trifectatechfoundation/sudo-rs"
license="Apache-2.0 OR MIT"
depends="
	linux-pam
	tzdata
"
makedepends="
	cargo
	cargo-auditable
	linux-pam-dev
	tzdata
"
checkdepends="
	busybox-binsh
	uutils-coreutils
	xz
"
subpackages="$pkgname-doc $pkgname-su"
source="$pkgname-$pkgver.tar.gz::https://github.com/trifectatechfoundation/sudo-rs/archive/refs/tags/v$pkgver.tar.gz
	sudoers
"
# net: cargo fetch
# suid: su and sudo binaries
options="net suid"
provides="sudo-virt"
provider_priority=90

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --target="$CTARGET" --frozen --release
}

check() {
	# canonicalization: requires /bin to be a symlink to /usr/bin
	# test_build_run_context: requires /bin to be a symlink to /usr/bin
	# mark_fds_as_cloexec: uses a syscall that takes a very long time
	# test_traverse_secure_open_positive: no perms to write file in CI
	cargo test --frozen --release -- \
		--skip \
		common::resolve::test::canonicalization \
		--skip \
		common::context::tests::test_build_run_context \
		--skip \
		system::tests::mark_fds_as_cloexec \
		--skip \
		system::audit::test::test_traverse_secure_open_positive
}

package() {
	# Install binaries
	local suid_bins="su sudo"
	for i in $suid_bins; do
		install -Dm4755 "$builddir"/target/"$CTARGET"/release/"$i" \
			-t "$pkgdir"/usr/bin/
	done
	install -Dm755 "$builddir"/target/"$CTARGET"/release/visudo \
		-t "$pkgdir"/usr/bin/

	# Install system config
	install -Dm644 "$srcdir"/sudoers \
		"$pkgdir"/etc/sudoers

	# Install documentation
	install -Dm644 LICENSE-APACHE LICENSE-MIT -t \
		"$pkgdir"/usr/share/licenses/"$pkgname"
	install -Dm644 docs/man/sudo.8.man \
		"$pkgdir"/usr/share/man/man8/sudo.8
	install -Dm644 docs/man/sudoers.5.man \
		"$pkgdir"/usr/share/man/man5/sudoers.5
	install -Dm644 docs/man/visudo.8.man \
		"$pkgdir"/usr/share/man/man8/visudo.8
}

su() {
	pkgdesc="$pkgdesc (su binary)"

	amove usr/bin/su
}

sha512sums="
