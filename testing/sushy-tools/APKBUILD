maintainer="Natanael Copa <ncopa@alpinelinux.org>"
pkgname=sushy-tools
pkgver=2.2.0
pkgrel=0
pkgdesc="Redfish development tools for Sushy"
url="https://opendev.org/openstack/sushy-tools"
arch="noarch"
license="Apache-2.0"
depends="
	py3-bcrypt
	py3-flask
	py3-libvirt
	py3-pbr
	py3-requests
	py3-tenacity
	py3-webob
	python3
	"
makedepends="
	py3-gpep517
	py3-installer
	py3-pbr
	py3-setuptools
	py3-wheel
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/s/sushy-tools/sushy_tools-$pkgver.tar.gz"
builddir="$srcdir/sushy_tools-$pkgver"
options="!check" # tests require optional OpenStack backend dependencies

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
