maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=py3-evalidate
pkgver=2.1.4
pkgrel=0
pkgdesc="Validation and secure evaluation of untrusted python expressions"
url="https://pypi.org/project/evalidate/"
arch="noarch"
license="MIT"
makedepends="py3-gpep517 py3-setuptools py3-wheel py3-hatchling"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/e/evalidate/evalidate-$pkgver.tar.gz"
builddir="$srcdir/evalidate-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
6aad61282d16ad64455f50c7edf64d8533dcf6a72badc1dd04c4be98af8f336aca467baf8c3d1e5f896505c0298bb8ddacdc01653411e65849b026f09a08d4fb  evalidate-2.1.4.tar.gz
"
