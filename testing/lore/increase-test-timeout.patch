Raise the events integration-test timeout from 5s to 120s so it does not
spuriously fail on slow/busy CI builders (e.g. emulated ppc64le, loongarch64).
Suggested at https://gitlab.alpinelinux.org/alpine/aports/-/merge_requests/104254

--- a/lore/tests/events.rs
+++ b/lore/tests/events.rs
@@ -45,7 +45,7 @@
     static REPOSITORY_STATUS_COMPLETE: LazyLock<Arc<Mutex<bool>>> =
         LazyLock::new(|| Arc::new(Mutex::new(false)));

-    static TIMEOUT_DURATION: Duration = Duration::from_secs(5);
+    static TIMEOUT_DURATION: Duration = Duration::from_secs(120);

     async fn repository_create(
         callback: LoreEventCallback,
