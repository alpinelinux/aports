# Contributor: Guy Godfroy <guy.godfroy@gugod.fr>
# Maintainer: Guy Godfroy <guy.godfroy@gugod.fr>
pkgname=lore
pkgver=0.8.3
pkgrel=0
pkgdesc="Next-generation version control system for code and large binary assets"
url="https://lore.org/"
# aarch64: SIGILL; loongarch64: test timeout; riscv64: build exceeds CI limits; 32-bit: quanta time64
arch="x86_64 s390x ppc64le"
license="MIT"
makedepends="cargo-auditable"
pkgusers="lore"
pkggroups="lore"
install="$pkgname-server.pre-install"
subpackages="
	$pkgname-server
	$pkgname-server-openrc
	$pkgname-bash-completion
	$pkgname-zsh-completion
	$pkgname-fish-completion
	"
source="https://github.com/EpicGames/lore/archive/v$pkgver/lore-$pkgver.tar.gz
	gate-windows-sys.patch
	increase-test-timeout.patch
	lore-server.initd
	lore-server.toml
	"

# build script reads the library version from this (else it falls back to "0")
export LORE_BUILD_VERSION_NAME="$pkgver"
# abuild's RUSTFLAGS overrides .cargo/config.toml; re-add the cfgs the code needs
export RUSTFLAGS="$RUSTFLAGS --cfg tokio_unstable --cfg uuid_unstable"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen --bin lore -p lore-client
	cargo auditable build --release --frozen --bin loreserver -p lore-server
}

check() {
	# dev profile: release LTO + codegen-units=1 OOMs on parallel test builds
	cargo test --frozen -p lore -p lore-client
}

package() {
	install -Dm755 target/release/lore -t "$pkgdir"/usr/bin/
	install -Dm755 target/release/loreserver -t "$pkgdir"/usr/bin/
	install -Dm644 "$srcdir"/lore-server.toml \
		"$pkgdir"/etc/lore/server/default.toml
	install -Dm755 "$srcdir"/lore-server.initd \
		"$pkgdir"/etc/init.d/lore-server

	local sh
	for sh in bash zsh fish; do
		target/release/lore completions "$sh" > "lore.$sh"
	done
	install -Dm644 lore.bash \
		"$pkgdir"/usr/share/bash-completion/completions/lore
	install -Dm644 lore.zsh \
		"$pkgdir"/usr/share/zsh/site-functions/_lore
	install -Dm644 lore.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/lore.fish

	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

server() {
	pkgdesc="Lore revision control server"
	amove usr/bin/loreserver etc/lore/server/default.toml

	install -Dm644 "$builddir"/LICENSE \
		"$subpkgdir"/usr/share/licenses/$subpkgname/LICENSE
}

