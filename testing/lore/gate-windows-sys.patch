Backport of upstream https://github.com/EpicGames/lore/pull/45

Move the windows-sys dependency into a [target.'cfg(target_family = "windows")']
table so the workspace builds on non-Windows targets (it was an unconditional
dependency, which fails to compile on several non-x86_64 arches).

diff --git a/lore-base/Cargo.toml b/lore-base/Cargo.toml
index d85d371..c533f3d 100644
--- a/lore-base/Cargo.toml
+++ b/lore-base/Cargo.toml
@@ -33,9 +33,6 @@ rand = { workspace = true }
 serde = { workspace = true }
 uuid = { workspace = true, features = ["zerocopy"] }

-# fs
-windows-sys = { workspace = true, features = ["Win32_Storage_ProjectedFileSystem", "Win32_Storage_FileSystem", "Win32_System_Diagnostics", "Win32_System_Diagnostics_Debug", "Win32_System_IO", "Win32_Security"] }
-
 # log
 chrono = { workspace = true }

@@ -44,6 +41,10 @@ pin-project = { workspace = true }
 rayon = { workspace = true }
 tokio = { workspace = true }

+# fs
+[target.'cfg(target_family = "windows")'.dependencies]
+windows-sys = { workspace = true, features = ["Win32_Storage_ProjectedFileSystem", "Win32_Storage_FileSystem", "Win32_System_Diagnostics", "Win32_System_Diagnostics_Debug", "Win32_System_IO", "Win32_Security"] }
+
 [dev-dependencies]
 serde_json = { workspace = true, features = ["std"] }

