pkgname=ttf-ubuntu-font-family
pkgver=0.83
pkgrel=0
pkgdesc="Ubuntu font family"
url="https://font.ubuntu.com/"
arch="noarch"
license="Ubuntu-font-1.0"
depends="fontconfig"
options="!check"
# added fontconfig configuration from:
# https://github.com/bohoomil/fontconfig-ultimate/tree/master/fontconfig_patches/fonts-settings
source="https://assets.ubuntu.com/v1/0cef8205-ubuntu-font-family-$pkgver.zip
	45-ubuntu.conf
	90-tt-ubuntu.conf
	"
builddir="$srcdir/ubuntu-font-family-$pkgver"

package() {
	install -Dm644 "$builddir"/*.ttf -t "$pkgdir"/usr/share/fonts/$pkgname/

	mkdir -p "$pkgdir"/etc/fonts/conf.d

	local j; for j in "$srcdir"/*.conf; do
		install -Dm644 "$j" -t "$pkgdir"/etc/fonts/conf.avail/
		ln -s ../conf.avail/${j##*/} "$pkgdir"/etc/fonts/conf.d/${j##*/}
	done
}

sha512sums="
