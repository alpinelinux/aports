# Contributor: Amelia Clarke <selene@perilune.dev>
# Maintainer: Amelia Clarke <selene@perilune.dev>
pkgname=kwim
pkgver=0.2.0
pkgrel=0
pkgdesc="Simple input manager for the River Wayland compositor"
url="https://github.com/kewuaa/kwim"
arch="aarch64 x86_64" # limited by zig aport
license="GPL-3.0-only"
makedepends="
	libxkbcommon-dev
	wayland-dev
	wayland-protocols
	zig
	"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/kewuaa/kwim/archive/refs/tags/v$pkgver.tar.gz"
options="net"

build() {
	DESTDIR="$builddir/zig-out" zig build \
		-Doptimize=ReleaseSafe \
		-Dpie \
		--prefix /usr install
}

check() {
	zig build test
}

package() {
	mkdir -p "$pkgdir"
	cp -R zig-out/* "$pkgdir"

	local docdir="$pkgdir"/usr/share/doc/"$pkgname"
	mkdir -p "$docdir"/examples
	mv "$docdir"/config.zon "$docdir"/examples
}

sha512sums="
064dbd2ec78b5f06b345e25ec18d4e3afaa1db53f5e0a6490ae28d442d8e98875e40001230f634d3b379341d99fa5f5bd3cd21275788e2b1646a1263e0934e6b  kwim-0.2.0.tar.gz
"
