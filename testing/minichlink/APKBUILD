# Contributor: Robert Eckelmann <longnoserob@gmail.com>
# Maintainer: Robert Eckelmann <longnoserob@gmail.com>
pkgname=minichlink
pkgver=1
pkgrel=0
pkgdesc="Firmware porgammer for CH32-family of microcontrollers"
url="https://github.com/cnlohr/ch32fun/tree/master/minichlink"
_commit="2f2267fed2451414a931666ba750fa723b653334"
arch="all"
license="MIT"
makedepends="
	eudev-dev
	libusb-dev
	linux-headers
"
subpackages="$pkgname-udev"
source="https://github.com/cnlohr/ch32fun/archive/$_commit.tar.gz"
# as minichlink is in a subdirectory of the source package, set the builddir accordingly
builddir="$srcdir"/ch32fun-"$_commit"/minichlink
# package currently (20206-05) does not have a test-suite
options="!check"

build() {
	make
}

package() {
	install -Dm755 minichlink "$pkgdir"/usr/bin/minichlink
	install -Dm755 minichlink.so "$pkgdir"/usr/lib/minichlink.so
	install -Dm644 99-minichlink.rules -t \
		"$pkgdir"/usr/lib/udev/rules.d
}

sha512sums="
e77aefdd841bd180dc0a689ca372d6f1e4ab78aac9859b6a7f343a909e30a4fd6c03c471b949de7efb3ca66f2710026805b5ec320ca899b267b97d803f498e99  2f2267fed2451414a931666ba750fa723b653334.tar.gz
"
