maintainer="Willow Barraco <contact@willowbarraco.fr>"
pkgname=zine
pkgver=0.11.2
pkgrel=0
pkgdesc="Fast, Scalable, Flexible Static Site Generator (SSG)"
url="https://zine-ssg.io/"
# limited by zig
arch="aarch64 x86_64"
license="MIT"
makedepends="zig linux-headers"
# !check: manual test suite requiring git
# net: zig dependencies
options="!check net"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/kristoff-it/zine/archive/refs/tags/v$pkgver.tar.gz"

build() {
	zig build --release=small
}

package() {
	install -Dm755 zig-out/bin/zine -t "$pkgdir"/usr/bin/
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
