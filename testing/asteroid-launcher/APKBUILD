# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-launcher
pkgver=2.1_git20260618
pkgrel=0
_commit="b019133de91d4da82446bb8d806cc3b0402866fa"
pkgdesc="AsteroidOS launcher and Wayland compositor based on Qt, QML and QtWayland"
url="https://github.com/AsteroidOS/asteroid-launcher"
# armhf blocked by qt6-qtdeclarative
# loongarch64 blocked due to for some reason not finding the nemo-qml-plugin-calendar QML module
arch="all !armhf !riscv64 !loongarch64"
license="BSD-3-Clause AND MIT"
depends="
	asteroid-icons-ion
	asteroid-languages
	asteroid-wallpapers
	mce
	nemo-qml-plugin-calendar
	nemo-qml-plugin-configuration
	nemo-qml-plugin-time
	qt6-qt5compat
	qt6-qtmultimedia
	"
# Normally we shouldn't hard depend on fonts, but in this case these fonts are
# hardcoded for some supported watchfaces
depends="$depends
	font-noto-emoji
	font-opensans
	font-raleway-otf
	font-roboto
	"
makedepends="
	dsme-dev
	elogind-dev
	extra-cmake-modules
	libmce-qt-dev
	libngf-qt-dev
	libusb-moded-qt-dev
	mce-dev
	mlite-dev
	nemo-keepalive-dev
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtbase-private-dev
	qt6-qtdeclarative-dev
	qt6-qtdeclarative-private-dev
	qt6-qtwayland-dev
	qt6-qtwayland-private-dev
	samurai
	timed-dev
	"
subpackages="$pkgname-dbg"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-launcher/archive/$_commit.tar.gz
	0001-Find-QtCore-Private.patch
	0002-Use-ngf-as-IMPORTED_TARGET.patch
	"
options="!check" # no tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	install -dm755 "$pkgdir"/usr/share/translations
	lrelease6 -idbased i18n/asteroid-launcher.*.ts
	cp i18n/asteroid-launcher.*.qm "$pkgdir"/usr/share/translations/
}

sha512sums="
b2f7d3f2c112e0eb122a75c9fbe3247e12bda5436144e399456fdcd01d662b5f105a1e03b77e8fb3c9d37cb2890f43a6f10aa3610d8263de97a40464587f16d9  asteroid-launcher-b019133de91d4da82446bb8d806cc3b0402866fa.tar.gz
dc72b8fcaef1113e6f8863849b2e892ca2552baeec51e3f5495688ffe76645c4a3205adaa894f59cc7d8fbe01daff294c551492c15675f1dce1b30a6763767b5  0001-Find-QtCore-Private.patch
5f4dc42c67bdda4b9ac1ff9f2d862f385618b4b65c135e42b7454a775cca398eae97296e530a29ff6672bedbbc21fe964d9579eb10c7bd1f73b1697cb4f7c557  0002-Use-ngf-as-IMPORTED_TARGET.patch
"
