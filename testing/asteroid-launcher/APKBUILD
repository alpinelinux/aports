5699488bed3be0b7c8ca916e7152a278ce6f579b31144fc50efda5080223a855b188bdc46aec75de256738db76d4d7207d1fb0469a70b87cfc52503691f57944  0001-fix-cmake-use-the-correct-project-version.patch
4056b628b4aadeb58804ac33d07f79aa174efce5ce9d97040c8d250def0505e7dd534503f5f263046decc79a6f6bed71f8ed8fa0582c8d6f6b8e19539fe1ad10  0002-chore-prettify-CMake-usage.patch
