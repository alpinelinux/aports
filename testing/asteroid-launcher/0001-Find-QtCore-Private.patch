From 6611cde4e8fb5ac74d8e91673260a432ab200053 Mon Sep 17 00:00:00 2001
From: Bart Ribbers <bribbers@disroot.org>
Date: Thu, 18 Jun 2026 08:37:57 +0200
Subject: [PATCH] fix(cmake): search for the Qt private libraries that are in
 use

Otherwise you can't link to it in Lipstick.
---
 CMakeLists.txt | 13 ++++++++++++-
 1 file changed, 12 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 52a1170..ecb968b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -17,7 +17,18 @@ include(ECMFindQmlModule)
 include(Asteroid6CMakeSettings)
 include(Asteroid6Translations)
 
-find_package(Qt6 COMPONENTS REQUIRED Quick WaylandCompositor DBus ShaderTools Sql)
+find_package(Qt6 COMPONENTS REQUIRED
+	CorePrivate
+	GuiPrivate
+	QmlPrivate
+	QuickPrivate
+	WaylandCompositorPrivate
+	Quick
+	WaylandCompositor
+	DBus
+	ShaderTools
+	Sql
+)
 find_package(Timed REQUIRED)
 pkg_check_modules(mlite6 REQUIRED IMPORTED_TARGET mlite6)
 
