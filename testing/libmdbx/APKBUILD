# Maintainer: Noel Kuntze <noel.kuntze@thermi.consulting>
pkgname=libmdbx
pkgver=0.14.1
pkgrel=0
pkgdesc="Fast, compact, powerful, embedded, transactional key-value database with permissive license"
url="https://libmdbx.dqdkfa.ru/"
arch="all !armhf !armv7 !x86 !riscv64"   # build fails on these archs
license="Apache 2.0"
makedepends="linux-headers cmake bash samurai"
subpackages="$pkgname-dbg $pkgname-dev $pkgname-doc"
source="$pkgname-$pkgver.tar.xz::https://libmdbx.dqdkfa.ru/release/libmdbx-amalgamated-$pkgver.tar.xz"

options="!check" # no test suite
builddir="$srcdir"

build() {
	# Suppress false positive -Wmaybe-uninitialized warnings triggered by GCC LTO
	# in CI mode. Variables are properly initialized via output parameters but GCC
	# cannot see through the function calls at link time.
	export CFLAGS="$CFLAGS -Wno-maybe-uninitialized"
	export CXXFLAGS="$CXXFLAGS -Wno-maybe-uninitialized"	

	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DMDBX_BUILD_TIMESTAMP:STRING=unknown
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
