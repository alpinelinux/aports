maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=tree-sitter-scfg
pkgver=0.0.1_git20251029
_commit=d850fd470445d73de318a21d734d1e09e29b773c
pkgrel=0
pkgdesc="scfg grammar for tree-sitter"
url="https://github.com/rockorager/tree-sitter-scfg"
arch="all"
license="MIT"
makedepends="tree-sitter-dev"
checkdepends="tree-sitter-cli"
install_if="tree-sitter-grammars"
source="$pkgname-$_commit.tar.gz::https://github.com/rockorager/tree-sitter-scfg/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit"

prepare() {
	default_prepare

	# the corpus is at the historical top-level location, but modern
	# tree-sitter only looks for it under test/
	mkdir -p test
	ln -s ../corpus test/corpus
}

build() {
	abuild-tree-sitter build
}

check() {
	tree-sitter test
}

package() {
	DESTDIR="$pkgdir" abuild-tree-sitter install
}
sha512sums="
