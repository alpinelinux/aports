# Contributor: prspkt <prspkt@protonmail.com>
# Maintainer: prspkt <prspkt@protonmail.com>
pkgname=py3-protego
pkgver=0.6.0
pkgrel=0
pkgdesc="Pure-Python robots.txt parser with support for modern conventions"
url="https://github.com/scrapy/protego"
arch="noarch"
license="BSD-3-Clause"
depends="python3"
makedepends="py3-gpep517 py3-hatchling py3-installer"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/p/protego/protego-$pkgver.tar.gz"
builddir="$srcdir/protego-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
175396095cfa51613b8c70fb902a75da72132400d27fb22cbf619ae2adbcf744d8f02a4d7dd2a3c389d44069b72a06d229e3519f2fbb82d23b9a9ef2a21e997e  protego-0.6.0.tar.gz
"
