# Contributor: Saijin-Naib <Saijin-Naib_package-maintenance@outlook.com>
# Maintainer: Saijin-Naib <Saijin-Naib_package-maintenance@outlook.com>
pkgname=menulibre
pkgver=2.4.0
pkgrel=0
pkgdesc="Advanced menu editor that provides modern features in a clean, easy-to-use interface"
url="https://bluesabre.org/menulibre"
arch="noarch"
license="GPL-3.0-only"
depends="
	gnome-menus
	python3
	py3-gobject3
	py3-psutil
	xdg-utils
	"
makedepends="
	intltool
	py3-distutils-extra
	py3-gpep517
	py3-psutil
	py3-setuptools
	py3-wheel
	"
subpackages="
	$pkgname-doc
	$pkgname-lang
	$pkgname-pyc
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/bluesabre/menulibre/archive/refs/tags/menulibre-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgname-$pkgver/"
options="!check" # No upstream testsuite defined

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
1661f3ba275469d93c163469a24e9a7bb50e3f68b14551784e86ab6cbf5850d944e7171dece4cef4bf5636c2db654c97079e2048dfd5e04938bc411a75125cf2  menulibre-2.4.0.tar.gz
"
