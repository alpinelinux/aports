maintainer="team/phosh <achill@achill.org>"
pkgname=syncbus
pkgver=0.1.0
pkgrel=0
pkgdesc="D-Bus server for Syncthing"
url="https://gitlab.gnome.org/World/Phosh/syncbus"
arch="all"
license="GPL-3.0-only"
depends="syncthing"
makedepends="
	cargo-auditable
	meson
	"
subpackages="$pkgname-systemd"
source="https://sources.phosh.mobi/releases/syncbus/syncbus-$pkgver.tar.xz"
options="net" # cargo

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
