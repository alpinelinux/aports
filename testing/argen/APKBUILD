# Contributor: Amelia Clarke <selene@perilune.dev>
# Maintainer: Amelia Clarke <selene@perilune.dev>
pkgname=argen
pkgver=0.1.1_git20260707
pkgrel=0
_commit=6ec8cdc7729594b56737423ee8a49ff0e87ccf6f
pkgdesc="Task-oriented tiling window manager for the River Wayland compositor"
url="https://codeberg.org/pkap/argen"
arch="aarch64 x86_64" # limited by zig aport
license="GPL-3.0-only"
depends="python3"
makedepends="
	fcft-dev
	libevdev-dev
	libxkbcommon-dev
	pixman-dev
	scdoc
	wayland-dev
	wayland-protocols
	zig
	"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/pkap/argen/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname"
# !check: no test suite
# net: zig dependencies
options="!check net"

build() {
	DESTDIR="$builddir/zig-out" zig build \
		-Doptimize=ReleaseSafe \
		--prefix /usr install
}

package() {
	mkdir -p "$pkgdir"
	cp -R zig-out/* "$pkgdir"

	install -Dm644 -t "$pkgdir"/usr/share/doc/"$pkgname" README.md
	install -Dm644 -t "$pkgdir"/usr/share/doc/"$pkgname"/examples example/init
}

sha512sums="
90b76efc8071d2661d0e3c45ae68efc009256e08b8d004865f69feee0aff59ff5d632c6531c4f5e4fcfc7f31d21a3137a51bc0fb5f04af2f6eb4cdcfbe1a33a7  argen-0.1.1_git20260707.tar.gz
"
