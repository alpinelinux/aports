# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-compass
pkgver=2.1.0_git20260512
pkgrel=0
_commit="d75baf52cf9d380b093c81aba5cca5437378c996"
pkgdesc="Default compass app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-compass"
# armhf blocked by q6-qtdeclarative
arch="all !armhf"
license="GPL-3.0-or-later"
depends="
	mapplauncherd
	qt6-qtsensors
	"
makedepends="
	extra-cmake-modules
	qml-asteroid-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-compass/archive/$_commit.tar.gz"
options="!check" # No tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
