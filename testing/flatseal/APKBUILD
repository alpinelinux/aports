# Contributor: Rasmus Thomsen <oss@cogitri.dev>
# Maintainer: Saijin-Naib <Saijin-Naib_package-maintenance@outlook.com>
pkgname=flatseal
pkgver=2.4.1
pkgrel=1
pkgdesc="Manage Flatpak permissions"
url="https://github.com/tchx84/Flatseal"
arch="noarch !armhf" #armhf no gjs
license="GPL-3.0-or-later"
depends="
	flatpak
	gjs
	libadwaita
	webkit2gtk-6.0
	"
makedepends="appstream-dev cmake desktop-file-utils gettext gjs-dev libadwaita-dev meson webkit2gtk-6.0-dev"
subpackages="$pkgname-doc $pkgname-lang"
source="$pkgname-$pkgver.tar.gz::https://github.com/tchx84/Flatseal/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/Flatseal-$pkgver"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}
sha512sums="
