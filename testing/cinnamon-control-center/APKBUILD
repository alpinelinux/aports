maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=cinnamon-control-center
pkgver=6.6.0
pkgrel=0
pkgdesc="Collection of configuration plugins used in cinnamon-settings (fork of gnome-control-center)"
url="https://github.com/linuxmint/cinnamon-control-center"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	cinnamon-desktop-dev
	cinnamon-menus-dev
	colord-dev
	libgudev-dev
	libnma-dev
	libnotify-dev
	libwacom-dev
	meson
	modemmanager-dev
	networkmanager-dev
	polkit-dev
	upower-dev
	"
subpackages="$pkgname-dev"
source="https://github.com/linuxmint/cinnamon-control-center/archive/$pkgver/cinnamon-control-center-$pkgver.tar.gz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

