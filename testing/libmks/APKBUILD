maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=libmks
pkgver=0.1.5
pkgrel=0
pkgdesc="Mouse, Keyboard, and Screen to QEMU"
url="https://gitlab.gnome.org/GNOME/libmks"
arch="all"
license="LGPL-2.1-or-later"
makedepends="
	glib-dev
	gtk4.0-dev
	libepoxy-dev
	meson
	"
subpackages="$pkgname-dev"
source="https://download.gnome.org/sources/libmks/${pkgver%.*}/libmks-$pkgver.tar.xz"

build() {
	abuild-meson \
		-Dtests="$(want_check && echo true || echo false)" \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
29b0fd6a081b6b180fdcf53f56b27e9d9bbb415a0e96af3a9539b940c8e4936c2e54ffa7e55c1f617156f842f2e44badbc4a60542f7fde4efcd7c6f1790fb1d1  libmks-0.1.5.tar.xz
"
