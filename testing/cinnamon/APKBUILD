maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=cinnamon
pkgver=6.6.7
pkgrel=0
pkgdesc="Desktop environment featuring a traditional layout (fork of gnome-session)"
url="https://github.com/linuxmint/cinnamon"
arch="all !armhf" # cjs -> mozjs
license="GPL-2.0-only"
depends="
	gtk+3.0
	keybinder3
	py3-gobject3
	py3-psutil
	py3-setproctitle
	"
makedepends="
	cinnamon-menus-dev
	cjs-dev
	dbus-dev
	gcr-dev
	gobject-introspection-dev
	gstreamer-dev
	libsecret-dev
	meson
	muffin-dev
	networkmanager-dev
	perl
	polkit-dev
	sassc
	xapp-dev
	"
subpackages="
	$pkgname-doc
	$pkgname-pyc
	"
source="https://github.com/linuxmint/cinnamon/archive/$pkgver/cinnamon-$pkgver.tar.gz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
