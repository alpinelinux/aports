# Contributor: Ryan Wiseman <ryanwisemanmusic@gmail.com>
# Maintainer: Ryan Wiseman <ryanwisemanmusic@gmail.com>
pkgname=juce
pkgver=7.0.8
pkgrel=0
pkgdesc="Headless JUCE framework for audio applications"
url="https://juce.com/"
arch="all"
license="GPL-3.0-or-later"
depends="
	alsa-lib
	curl
	freetype
	gtk+3.0
	libdw
"
makedepends="
	alsa-lib-dev
	cmake
	curl-dev
	freetype-dev
	gtk+3.0-dev
	libx11-dev
	libxcomposite-dev
	libxcursor-dev
	libxext-dev
	libxinerama-dev
	libxrandr-dev
	mesa-dev
	musl-dev
	samurai
"
options="!check"
subpackages="$pkgname-examples $pkgname-extras"
source="juce-$pkgver.tar.gz::https://github.com/juce-framework/JUCE/archive/refs/tags/$pkgver.tar.gz
	cmake.patch
	core_execinfo.patch
	execinfo-compat.patch
	locale_compat.patch
	locale_region_script.patch
	juce_bineof.patch
	juce_config.patch
	juce_cmake_eof.patch
	juce_pkgconfig.patch
	web-browser-and-curl.patch
	errno-musl.patch
	tuple-include.patch
	language.patch
"
builddir="$srcdir/JUCE-$pkgver"

prepare() {
	# Handle CRLF line endings BEFORE applying patches and also handling CMakeLists.txt
	msg "Converting line endings in files to be patched..."
	sed -i 's/\r$//' modules/juce_gui_basics/juce_gui_basics.h
	sed -i 's/\r$//' modules/juce_core/juce_core.h
	sed -i 's/\r$//' modules/juce_core/native/juce_SharedCode_posix.h
	sed -i 's/\r$//' modules/juce_core/native/juce_SystemStats_linux.cpp
	sed -i 's/\r$//' modules/juce_core/containers/juce_FixedSizeFunction_test.cpp
	sed -i 's/\r$//' modules/juce_core/juce_core.cpp
	rm -f CMakeLists.txt
	default_prepare
}

build() {
	cmake -B build \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_CXX_FLAGS="$CXXFLAGS -fPIC -DNDEBUG" \
		-DJUCE_WEB_BROWSER=OFF \
		-DJUCE_ENABLE_GUI_DRIVERS=OFF
	cmake --build build 2>&1 || {
			tail -50 "$builddir/build/CMakeFiles/CMakeError.log" 2>/dev/null || true
			return 1
		}
	find "$builddir/build" -name "*.a" -exec ls -lh {} \;
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

examples() {
	pkgdesc="$pkgdesc (example code)"
	msg2 "=== Installing JUCE examples ==="
	mkdir -p "$subpkgdir/usr/share/$pkgname"
	cp -r "$builddir/examples" "$subpkgdir/usr/share/$pkgname/examples"
}

extras() {
	pkgdesc="$pkgdesc (additional utilities)"
	msg2 "=== Installing JUCE extras ==="
	mkdir -p "$subpkgdir/usr/share/$pkgname"
	cp -r "$builddir/extras" "$subpkgdir/usr/share/$pkgname/extras"
}

