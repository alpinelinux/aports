# Contributor: Dmitry Valter <`echo ZHZhbHRlciA8YXQ+IHByb3Rvbm1haWwgPGRvdD4gY29tCg== | base64 -d`>
# Contributor: Carl Smedstad <carsme@archlinux.org>
maintainer="Marian Buschsieweke <marian.buschsieweke@posteo.net>"
pkgname=drawio-desktop
pkgver=30.2.6
pkgrel=0
pkgdesc="Electron based desktop app of draw.io"
url="https://github.com/jgraph/drawio-desktop"
# limited by electron
arch="noarch !armhf !armv7 !loongarch64 !ppc64le !riscv64 !s390x !x86"
license="Apache-2.0"
depends="
	electron
	"
makedepends="
	electron-tasje
	nodejs
	npm
	pnpm
	yarn
	"
options="net !check"

source="
	$pkgname-$pkgver.tar.gz::https://github.com/jgraph/drawio-desktop/archive/refs/tags/v$pkgver.tar.gz
	drawio-$pkgver.tar.gz::https://github.com/jgraph/drawio/archive/refs/tags/v$pkgver.tar.gz

	drawio.sh

	tasje-fixes.patch
	disable-update.patch
	"

prepare() {
	default_prepare
	# Set desktop name to match with the desktop file
	npm pkg set desktopName='drawio'

	# Populate drawio folder (which is downloaded separately, as it is a git
	# submodule in the upstream repo).
	rm -rf drawio
	cp "$srcdir/drawio-$pkgver" drawio -r
}

build() {
	yarn install --frozen-lockfile
	tasje --config electron-builder-linux-mac.json pack
}

package() {
	install -vDm644 -t "$pkgdir/usr/lib/$pkgname" "$builddir/dist/resources/app.asar"
	install -vDm755 "$srcdir/drawio.sh" "$pkgdir/usr/bin/drawio"
}

