pkgname=openrsync
pkgver=0.5.0_git20260531
pkgrel=0
_commit=48070e68d73f67d6922b2ffc8c2dee9754e659c6
pkgdesc="OpenBSD implementation of rsync"
url="https://github.com/kristapsdz/openrsync"
arch="all"
license="ISC"
subpackages="$pkgname-doc"
source="$pkgname-$_commit.tar.gz::https://github.com/kristapsdz/openrsync/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit/"
options="!check" # package has no test suite

build() {
	./configure PREFIX=/usr MANDIR=/usr/share/man
	make
}

package() {
	make DESTDIR="$pkgdir" install
	install -Dm644 LICENSE.md -t "$pkgdir"/usr/share/licenses/$pkgname/
}

