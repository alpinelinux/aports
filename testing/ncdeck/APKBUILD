pkgname=ncdeck
pkgver=0.1.1
pkgrel=0
pkgdesc="CLI and TUI client for Nextcloud Deck"
url="https://github.com/raspbeguy/ncdeck"
arch="all"
license="GPL-3.0-or-later"
makedepends="go"
source="$pkgname-$pkgver.tar.gz::https://github.com/raspbeguy/ncdeck/archive/v$pkgver.tar.gz"
options="net" # go dependencies

build() {
	go build -trimpath -ldflags "-s -w -X main.version=$pkgver" -o ncdeck .
}

check() {
	go test ./...
}

package() {
	install -Dm755 ncdeck "$pkgdir"/usr/bin/ncdeck
}

sha512sums="
