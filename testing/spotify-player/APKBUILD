# Contributor: Thomas Kienlen <kommander@laposte.net>
# Maintainer: Thomas Kienlen <kommander@laposte.net>
pkgname=spotify-player
pkgver=0.23.0
pkgrel=0
pkgdesc="Command driven spotify player"
url="https://github.com/aome510/spotify-player"
arch="all"
license="MIT"
makedepends="
	alsa-lib-dev
	cargo
	cargo-auditable
	clang-dev
	cmake
	dbus-dev
	openssl-dev
	rust-bindgen
	wayland-dev
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/aome510/spotify-player/archive/v$pkgver.tar.gz"
options="net"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen \
		--no-default-features --features 'alsa-backend,media-control,notify,streaming,daemon'
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/spotify_player -t "$pkgdir"/usr/bin
}

sha512sums="
7e329a49b16881e2dc66f6d797dbda01ff2005eb0ccac3a32ecfa1294de39fc0fa0bca13b242fd9dd926aec2809fa14d26b05ba0f43b3d9978a2f96449b73336  spotify-player-0.23.0.tar.gz
"
