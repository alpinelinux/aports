# Contributor: Leon White <badfunkstripe@gmail.com>
maintainer="Leon White <badfunkstripe@gmail.com>"
pkgname=py3-pycollada
pkgver=0.9.3
pkgrel=0
pkgdesc="Python module for creating, editing and loading COLLADA"
url="https://github.com/pycollada/pycollada"
arch="noarch"
license="BSD-3-Clause"
depends="
	python3
	py3-dateutil
	py3-numpy
	"
makedepends="
	py3-gpep517
	py3-numpy-dev
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="py3-pytest"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/pycollada/pycollada/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/pycollada-$pkgver"

build() {
	export SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
ffd73d130c797ddc25a660a33c1d8957d826af2423b76200f82e73454d02184628728d3c2dc6980c2235f69e14f1c563c8da4946a8328f8827692d30d19326e9  py3-pycollada-0.9.3.tar.gz
"
