# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-plasma
maintainer="team/kde <bribbers@disroot.org>"
pkgname=union
pkgver=6.7.1
pkgrel=0
pkgdesc="A Qt style supporting both QtQuick and QtWidgets"
url="https://kde.org/plasma-desktop/"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-only OR LGPL-3.0-only OR LicenseRef-KDE-Accepted-LGPL"
depends_dev="
	breeze-dev
	cxx-rust-cssparser
	kcolorscheme-dev
	kcoreaddons-dev
	kguiaddons-dev
	kiconthemes-dev
	kirigami-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtshadertools-dev
	"
makedepends="$depends_dev
	extra-cmake-modules
	samurai
	"
checkdepends="xwayland-run"
subpackages="$pkgname-dev"
case "$pkgver" in
	*.90*) _rel=unstable;;
	*) _rel=stable;;
esac
_repo_url="https://invent.kde.org/plasma/union.git"
source="https://download.kde.org/stable/plasma/$pkgver/union-$pkgver.tar.xz"

# spdx: LicenseRef licenses are not SPDX compliant
options="!spdx"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_TOOLS=OFF \
		-DBUILD_EXAMPLES=OFF \
		-DBUILD_TESTING="$(want_check && echo ON || echo OFF)"
	cmake --build build
}

check() {
	wlheadless-run -- ctest --test-dir build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}


sha512sums="
0cf4ed284dda15708833d47e4b0407d9a05a54f20e9070357736e3dd56a21e57478787b6dca0000ffd814364668d81993c075921829ada1620d6fa7fc8920430  union-6.7.1.tar.xz
"
