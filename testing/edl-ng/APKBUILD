maintainer="Aelin <aelin@postmarketos.org>"
pkgname=edl-ng
pkgver=1.5.0
pkgrel=0
pkgdesc="A modern, user-friendly tool for interacting with Qualcomm devices in Emergency Download (EDL) mode"
url="https://github.com/strongtz/edl-ng"
arch="all !x86 !armhf !riscv64 !s390x !ppc64le !loongarch64" # dotnet
license="MIT"
makedepends="dotnet9-sdk"
depends="aspnetcore9-runtime libusb"
subpackages="$pkgname-doc"
source="https://github.com/strongtz/edl-ng/archive/v$pkgver/edl-ng-$pkgver.tar.gz
	buildconfig.patch
	version.patch
	"
options="!strip net" # downloads dependencies from nuget

build() {
	dotnet publish QCEDL.CLI \
		--configuration Release \
		--output publish \
		--no-self-contained \
		--use-current-runtime
}

check() {
	./publish/edl-ng --version
}

package() {
	install -Dm755 publish/edl-ng -t "$pkgdir"/usr/bin

	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

