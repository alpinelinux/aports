31a812c61280cc266b5dfb8c97c7adbe4e69420ad580a1a8a2eb83346abecdea9962638bc789b23ff0d60eea75f052d4f95deb0bc92a9e48f5c6053ebb61426a  buildconfig.patch
00ec5ffc3a9cf4371a9541c6c1189f1a330e677e009180b4f92e6f572f119a62d53bbabfd6a159db769e4f16fbf0f797b4f2469e2e16cb6cdab28aca5affbbab  version.patch
"
