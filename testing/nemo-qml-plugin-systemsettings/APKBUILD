maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=nemo-qml-plugin-systemsettings
pkgver=0.10.18
pkgrel=0
pkgdesc="Nemo QML systemsettings plugin"
url="https://github.com/sailfishos/nemo-qml-plugin-systemsettings"
# armhf blocked by qt6-qtdeclarative
# riscv64 blocked by libqofono
arch="all !armhf !riscv64"
license="BSD-3-Clause"
depends_dev="
	libqofono-dev
	libusb-moded-qt-dev
	mce-dev
	mlite-dev
	nemo-qml-plugin-dbus-dev
	openssl-dev>3
	qt6-qtdeclarative-dev
	sailfish-access-control
	ssu-sysinfo-dev
	timed-dev
	user-managerd-dev
	"
makedepends="$depends_dev
	libconnman-qt-dev
	libsailfishkeyprovider-dev
	nemo-qml-plugin-models-dev
	profiled-dev
	qt6-qt5compat-dev
	qt6-qtbase-dev
	qt6-qttools-dev
	"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/nemo-qml-plugin-systemsettings/archive/refs/tags/$pkgver.tar.gz
	0001-Remove-developer-mode.patch
	0002-Remove-packagekit-usage.patch
	0003-Port-to-Qt6.patch
	0004-Include-linux-quota.h.patch
	"

build() {
	qmake6
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install
}

