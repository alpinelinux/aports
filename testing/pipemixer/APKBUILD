maintainer="Hayden Cianessi <hayden@cianessi.com>"
pkgname=pipemixer
pkgver=0.4.2
pkgrel=0
pkgdesc="TUI volume control app for pipewire"
url="https://github.com/heather7283/pipemixer"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	meson
	ncurses-dev
	inih-dev
	git
	pkgconf-dev
	pipewire-dev
	gawk
	ninja
"
options="!check" # contains no test suite
subpackages="
	$pkgname-doc
	$pkgname-zsh-completion
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/heather7283/pipemixer/archive/v$pkgver.tar.gz"

build() {
	abuild-meson \
		-Dshell-completions=true \
		. output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
