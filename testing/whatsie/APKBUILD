6bcc352a60e980c18c070b742ec378950e568a23a1f4955d4c36a2b25b89acf4b589ba3c32dec725e7d1ba21d9a0f00caf41a83aa124831bd274351f2ea0be35  libnotify-qt-3f54515cce45fa1eef54d23bc586462011f1bba6.tar.gz
"
