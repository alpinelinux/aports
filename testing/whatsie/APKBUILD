# Contributor: Fabricio Silva <hi@fabricio.dev>
# Maintainer: Fabricio Silva <hi@fabricio.dev>
pkgname=whatsie
pkgver=5.1.0
_commit_libnotify_qt="3f54515cce45fa1eef54d23bc586462011f1bba6"
pkgrel=0
pkgdesc="Feature rich WhatsApp Client for Desktop Linux"
url="https://github.com/keshavbhatt/whatsie"
# armhf, s390x, riscv64, x86 and armv7 blocked by qt5-qtwebengine
arch="all !armhf !s390x !riscv64 !x86 !armv7"
license="MIT"
makedepends="
	cmake
	libnotify-dev
	qt6-qtbase-dev
	qt6-qtlocation-dev
	qt6-qtwebengine-dev
	samurai
	"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/keshavbhatt/whatsie/archive/refs/tags/v$pkgver.tar.gz
	libnotify-qt-$_commit_libnotify_qt.tar.gz::https://github.com/ahm-forks/libnotify-qt/archive/$_commit_libnotify_qt.tar.gz
	"
options="!check" # no test

prepare() {
	rmdir src/libnotify-qt
	mv "$srcdir"/libnotify-qt-$_commit_libnotify_qt src/libnotify-qt

	default_prepare
}

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

