248688cdc645f3fc7c107af679d8c20e63f9e6c2d678dc4a94df01cd2020e21c6123d2f38404a35e2d1ccae83087069ae4eb220e99651d13f516763eefd276d3  cmake-system-libs.patch
ea1328e55efcfc0a64f484b140955bffe9de9665dbee14a0486cceaaeda6a60b600f0b1987c2b8521f48dcd55a430d547919adc9c87c91f4e4c796b87287952e  libpiper-system-libs.patch
"
