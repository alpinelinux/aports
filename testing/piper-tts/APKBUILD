# Maintainer: leso-kn <info@lesosoftware.com>
pkgname=piper-tts
pkgver=1.4.2
pkgrel=0
pkgdesc="Fast, local neural text to speech system"
url="https://github.com/OHF-Voice/piper1-gpl"
provides="larynx2=$pkgver-r$pkgrel"
replaces=larynx2
# s390x, x86: onnxruntime-dev
# armhf: py3-onnxruntime
arch="noarch !s390x !x86 !armhf"
license="MIT"
makedepends="
	cmake
	espeak-ng-dev
	onnxruntime-dev
	pcaudiolib-dev
	py3-gpep517
	py3-installer
	py3-numpy
	py3-onnxruntime
	py3-pathvalidate
	py3-scikit-build
	py3-scikit-build-core
	py3-wheel
	python3-dev
	samurai
	"
checkdepends="py3-pytest"

subpackages="
	libpiper::all
	libpiper-dev
	py3-$pkgname-pyc
	py3-$pkgname:py3:all
"
source="$pkgname-$pkgver.tar.gz::https://github.com/OHF-Voice/piper1-gpl/archive/refs/tags/v$pkgver.tar.gz
	cmake-system-libs.patch
	libpiper-system-libs.patch
	"
builddir="$srcdir/piper1-gpl-$pkgver/"

build() {
	cmake -B libpiper/build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		libpiper
	cmake --build libpiper/build

	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages _testenv
	_testenv/bin/python3 -m installer .dist/*.whl
	_testenv/bin/python3 -m pytest
}

py3() {
	amove usr/lib/python3.14/
}

package() {
	depends="py3-piper-tts"

	python3 -m installer -d "$pkgdir" .dist/*.whl

	DESTDIR="$pkgdir" cmake --install libpiper/build

	install -dm 755 "$pkgdir/usr/share/licenses/$pkgname/"
	mv "$pkgdir/usr/COPYING" "$pkgdir/usr/share/licenses/$pkgname/"
}

libpiper() {
	pkgdesc="C++ library for Piper text-to-speech"

	amove usr/lib/libpiper.so
}

libpiper_dev() {
	pkgdesc="Development files for libpiper"
	depends="libpiper=$pkgver-r$pkgrel"

	amove usr/include/piper.h
}

