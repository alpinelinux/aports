# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-other
maintainer="team/kde <bribbers@disroot.org>"
pkgname=cxx-rust-cssparser
pkgver=1.0.0
pkgrel=1
pkgdesc="Library for parsing CSS using the Rust cssparser crate"
url="https://invent.kde.org/libraries/cxx-rust-cssparser"
arch="all"
license="LGPL-2.1-only OR LGPL-3.0-only OR LicenseRef-KDE-Accepted-LGPL"
makedepends="
	corrosion
	extra-cmake-modules
	qt6-qtbase-dev
	samurai
	"
case "$pkgver" in
	*.90*) _rel=unstable;;
	*) _rel=stable;;
esac
_repo_url="https://invent.kde.org/libraries/cxx-rust-cssparser.git"
source="https://download.kde.org/stable/cxx-rust-cssparser/cxx-rust-cssparser-$pkgver.tar.xz"

# spdx: LicenseRef licenses are not SPDX compliant
options="
	!check
	!spdx
	net
	"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}


sha512sums="
6fb0f7deb6e3bfcfdc120677e4a9c83f6923531ef92cb97175973c730f3fbc22a168330e788759a2605caa386d061d16771a7ed7080a2539d4ccf67a9b4e83fe  cxx-rust-cssparser-1.0.0.tar.xz
"
