maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=gtimelog
pkgver=0.12_git20260324
_commit=d2c5059e769b92bd0108997a85c4af10df61d9aa
pkgrel=0
pkgdesc="Time tracking application"
url="https://gtimelog.org/"
arch="noarch"
license="GPL-2.0-only"
depends="
	gtk+3.0
	librsvg
	libsecret
	libsoup3
	py3-gobject3
	python3
	"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-wheel
	"
checkdepends="
	py3-freezegun
	py3-pytest
	"
subpackages="$pkgname-pyc"
source="$pkgname-$_commit.tar.gz::https://github.com/gtimelog/gtimelog/archive/$_commit.tar.gz
	fix-timedelta-test.patch
	"
builddir="$srcdir/$pkgname-$_commit"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
