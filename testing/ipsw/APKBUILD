maintainer="Aster Boese <asterboese@mailbox.org>"
pkgname=ipsw
pkgver=3.1.694
pkgrel=0
pkgdesc="iOS/macOS research swiss army knife"
url="https://github.com/blacktop/ipsw"
arch="all"
license="MIT"
depends="libusb"
makedepends="
	bash
	fd
	go
	libusb-dev
	"
subpackages="$pkgname-doc $pkgname-daemon"
source="https://github.com/blacktop/ipsw/archive/v$pkgver/ipsw-$pkgver.tar.gz
	0001-strip-out-code-calling-LLMs.patch
	"
# !check: no tests
# net: go downloads packages from the internet
options="!check net"

build() {
	go build ./cmd/ipsw
	go build ./cmd/ipswd
}

package() {
	# install binaries
	for i in ipsw ipswd; do
		install -Dm755 "$builddir"/"$i" \
			"$pkgdir"/usr/bin/"$i"
	done

	install -Dm644 "$builddir"/LICENSE \
		"$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE
}

daemon() {
	pkgdesc="$pkgdesc (daemon)"

	amove usr/bin/ipswd
}

