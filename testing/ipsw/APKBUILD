cd42de30a2d4ac2aa52da423b862e910e4b7cffa64c7d935fe08663c6621e06bd1d2694bc34268d3929bd9e73163b8c3efaaaeb59d75a8b3cbcc2e6740a6b4cf  0001-strip-out-code-calling-LLMs.patch
"
