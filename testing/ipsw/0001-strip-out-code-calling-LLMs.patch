-func readTextWindow(content string, line, limit *int) string {
-	if line == nil && limit == nil {
-		return content
-	}
-	lines := strings.Split(content, "\n")
-	start := 0
-	if line != nil && *line > 1 {
-		start = min(*line-1, len(lines))
-	}
-	end := len(lines)
-	if limit != nil {
-		if *limit <= 0 {
-			end = start
-		} else if start+*limit < end {
-			end = start + *limit
-		}
-	}
-	return strings.Join(lines[start:end], "\n")
-}
