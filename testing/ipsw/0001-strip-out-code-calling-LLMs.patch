-
-	reqBody := chatRequest{
-		Model:       c.models[c.conf.Model],
-		Messages:    []chatMessage{{Role: "user", Content: c.conf.Prompt}},
-		Temperature: c.conf.Temperature,
-		TopP:        c.conf.TopP,
