# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-saltext-alpine
_pkgname=saltext_alpine
pkgver=1.0.0
pkgrel=0
pkgdesc="Salt Extension that adds first class support for Alpine Linux"
url="https://github.com/salt-extensions/saltext-alpine"
arch="noarch"
license="Apache-2.0"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
checkdepends="
	py3-pytest
	py3-pytest-instafail
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/${_pkgname:0:1}/$_pkgname/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/${_pkgname//./_}-$pkgver"
options="!check" # missing pytest-salt-factories

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest tests/unit/ -v
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
e527b14a1779d28bb312c47765969364cec29a43dab67b71571fd7ce7e9a10272d332f335b38ccc4ce19140a5faf88831a5dd592363cd2faf72823a37b8a0dba  saltext_alpine-1.0.0.tar.gz
"
