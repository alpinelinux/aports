pkgname=ovhcloud-cli
pkgver=0.11.0
pkgrel=0
pkgdesc="Official Command Line Interface to manage OVHcloud services"
url="https://github.com/ovh/ovhcloud-cli"
arch="all"
license="Apache-2.0"
makedepends="go"
source="$pkgname-$pkgver.tar.gz::https://github.com/ovh/ovhcloud-cli/archive/refs/tags/v$pkgver.tar.gz"
options="net" #go deps

build() {
	go build -v -ldflags "-s -w -extldflags -static -X github.com/ovh/ovhcloud-cli/internal/version.Version=$pkgver" -o ovhcloud ./cmd/ovhcloud
}

check() {
	go test ./...
}

package() {
	install -Dm0755 ovhcloud -t "$pkgdir"/usr/bin/
}

sha512sums="
