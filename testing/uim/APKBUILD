maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=uim
pkgver=1.9.6
pkgrel=0
pkgdesc="Multilingual input method framework"
url="https://github.com/uim/uim"
# arm{hf,v7}: segfault while building
# loongarch64: "collector has not been ported"
arch="all !armhf !armv7 !loongarch64"
license="BSD-3-Clause"
makedepends="
	gettext-dev
	gtk+3.0-dev
	intltool
	ncurses-dev
	qt6-qtbase-dev
	"
subpackages="
	$pkgname-dev
	$pkgname-doc
	$pkgname-lang
	"
source="https://github.com/uim/uim/releases/download/$pkgver/uim-$pkgver.tar.gz"
options="!check" # xgettext fails

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var
	make
}

check() {
	make check
}

package() {
	# -j1 because of dependency errors
	make DESTDIR="$pkgdir" install -j1
}

sha512sums="
4d07f4994a96c9805109137679e51cd94ea5743522903567b43ed131426f61f73332a1d3b069edd060959b2c92aac97350c6f668999160584bdbef3d5e34bb12  uim-1.9.6.tar.gz
"
