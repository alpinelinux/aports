# Maintainer: nicole mikołajczyk <git@mkljczk.pl>
pkgname=gnujump
pkgver=1.0.8
pkgrel=0
pkgdesc="A clone of the simple yet addictive game Xjump"
url="https://jump.gnu.sinusoid.es"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	autoconf
	gettext-tiny-dev
	sdl12-compat-dev
	sdl_image-dev
	sdl_mixer-dev
	glu-dev
"
subpackages="$pkgname-doc"
source="https://ftp.gnu.org/gnu/gnujump/gnujump-$pkgver.tar.gz
	locale.patch
	gnujump.desktop
"

prepare() {
	default_prepare
	update_config_guess
	update_config_sub
}

build() {
	CFLAGS="$CFLAGS -std=gnu17" \
	./configure --prefix=/usr
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
	install -Dm644 -t "$pkgdir"/usr/share/applications/ \
		"$srcdir"/gnujump.desktop
}

