# Contributor: guddaff <alpine@guddaff.de>
# Contributor: Rosie Keith Languet <rkl@rosiesworkshop.net>
# Maintainer: Rosie Keith Languet <rkl@rosiesworkshop.net>
pkgname=dune3d
pkgver=1.4.0
pkgrel=0
pkgdesc="3D CAD application"
url="https://dune3d.org/"
# s390x blocked by opencascade -> vtk -> netcdf
# riscv should work, but dependency on vtk-dev fails - is builder behind?
arch="all !s390x !riscv64"
license="GPL-3.0-only"
depends="
	gtkmm4
	cairomm
	opencascade
"

makedepends="
	gtkmm4-dev
	cairomm-dev
	librsvg-dev
	libspnav-dev
	opencascade-dev
	glm-dev
	python3
	cmake
	meson
	eigen-dev
	py3-gobject3
	py3-cairo
"

source="$pkgname-$pkgver.tar.gz::https://github.com/dune3d/dune3d/archive/refs/tags/v$pkgver.tar.gz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --no-rebuild --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
4af4b821d9d61d6c03836d1082f0c51bf40f12c005fe31f9e53bc020073e36e0c6bae73897308c20e392fbe700508f55e5343690e366b7617750a44a57a5038d  dune3d-1.4.0.tar.gz
"
