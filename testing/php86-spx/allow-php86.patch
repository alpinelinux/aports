Patch-Source: https://github.com/NoiseByNorthwest/php-spx
Extend the supported PHP version guard to accept PHP 8.6 (ZEND_MODULE_API_NO
20250926). No further source changes are needed; the extension compiles and
its module info loads unchanged on 8.6.
--- a/src/php_spx.h	2025-10-08 20:10:28.000000000 +0000
+++ b/src/php_spx.h	2026-07-01 01:27:09.841285691 +0000
@@ -31,8 +31,8 @@
 #   error "Only x86-64 and ARM64 architectures are supported"
 #endif
 
-#if ZEND_MODULE_API_NO < 20100525 || ZEND_MODULE_API_NO > 20250925
-#   error "Only the following PHP versions are supported: 5.4 to 8.5"
+#if ZEND_MODULE_API_NO < 20100525 || ZEND_MODULE_API_NO > 20250926
+#   error "Only the following PHP versions are supported: 5.4 to 8.6"
 #endif
 
 #define PHP_SPX_EXTNAME "SPX"
