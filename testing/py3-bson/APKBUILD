# Maintainer: Marian Buschsieweke <marian.buschsieweke@posteo.net>
pkgname=py3-bson
_pkgname=bson
pkgver=0.5.10
pkgrel=7
pkgdesc="Independent BSON codec for Python that doesn’t depend on MongoDB"
url="https://github.com/py-bson/bson"
arch="noarch"
license="BSD-3-Clause"
depends="py3-dateutil"
makedepends="py3-setuptools py3-gpep517"
subpackages="$pkgname-pyc"
# Use GitHub tarball, PyPI version does not include tests
source="$pkgname-$pkgver.tar.gz::https://github.com/py-bson/bson/archive/refs/tags/$pkgver.tar.gz
	drop-python2-support.patch
	fix-assertequal.patch
	replace-pkgutil.patch
	"
builddir="$srcdir"/$_pkgname-$pkgver

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m unittest discover
}

package() {
	gpep517 install-wheel --destdir "$pkgdir" \
		.dist/*.whl
}

