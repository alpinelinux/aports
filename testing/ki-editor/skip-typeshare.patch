Skip IDE protocol generation via typeshare(1). The ki binary does not need
TypeScript/Kotlin stubs; typeshare is not packaged in Alpine and would add a
bootstrap dependency.
--- a/build.rs
+++ b/build.rs
@@ -21,6 +21,15 @@ fn main() {
     println!("cargo:rustc-env=GIT_HASH={git_hash}");
     println!("cargo:rustc-env=BUILD_TIME={build_time}");
 
+    if std::env::var_os("KI_PACKAGE_BUILD").is_some() {
+        println!("cargo:warning=Skipping IDE protocol generation (KI_PACKAGE_BUILD is set)");
+        println!("cargo:rerun-if-changed=build.rs");
+        println!("cargo:rerun-if-changed=src/vscode_ipc.rs");
+        println!("cargo:rerun-if-changed=src/vscode.rs");
+        println!("cargo:rerun-if-changed=ki-protocol-types/src/lib.rs");
+        return;
+    }
+
     println!("Generating types...");
 
     let out_dir = std::path::PathBuf::from(std::env::var("CARGO_MANIFEST_DIR").unwrap());
