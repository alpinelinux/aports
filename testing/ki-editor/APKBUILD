# Maintainer: Robert Mongold <rtmongold@gmail.com>
pkgname=ki-editor
pkgver=2025.12.22
pkgrel=0
pkgdesc="Multi-cursor modal tree-sitter editor"
url="https://github.com/ki-editor/ki-editor"
arch="all"
license="MPL-2.0"
makedepends="
	cargo
	cargo-auditable
	cmake
	openssl-dev
	samurai
	zlib-dev
	"
_gitver=${pkgver//./-}
source="
	$pkgname-$pkgver.tar.gz::https://github.com/ki-editor/ki-editor/archive/refs/tags/$_gitver.tar.gz
	skip-typeshare.patch
	portable-pty-nix-musl.patch
	"
builddir="$srcdir"/ki-editor-$_gitver
options="net !check" # tests need fixtures; cargo needs git crates (typeshare fork)

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	export KI_PACKAGE_BUILD=1
	export CARGO_PROFILE_RELEASE_LTO="false"
	export CARGO_PROFILE_RELEASE_CODEGEN_UNITS=16
	cargo auditable build --frozen --release -p ki
}

package() {
	install -Dm755 target/release/ki -t "$pkgdir"/usr/bin/
	install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
