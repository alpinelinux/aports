maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=tree-sitter-vue
pkgver=0.1.0_git20260124
_commit=ce8011a414fdf8091f4e4071752efc376f4afb08
pkgrel=0
pkgdesc="Vue grammar for tree-sitter"
url="https://github.com/tree-sitter-grammars/tree-sitter-vue"
arch="all"
license="MIT"
makedepends="tree-sitter-dev"
checkdepends="tree-sitter-cli"
install_if="tree-sitter-grammars"
source="$pkgname-$_commit.tar.gz::https://github.com/tree-sitter-grammars/tree-sitter-vue/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit"

build() {
	abuild-tree-sitter build
}

check() {
	tree-sitter test
}

package() {
	DESTDIR="$pkgdir" abuild-tree-sitter install -q queries/vue

	install -D -m755 queries/html_tags/*.scm \
		-t "$pkgdir"/usr/share/tree-sitter/queries/html_tags/
}
