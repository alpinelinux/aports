# Contributor: Andy Postnikov <apostnikov@gmail.com>
# Maintainer: Andy Postnikov <apostnikov@gmail.com>
pkgname=ctranslate2
pkgver=4.8.1
pkgrel=0
pkgdesc="Fast inference engine for Transformer models"
url="https://github.com/OpenNMT/CTranslate2"
# ruy/cpuinfo SIMD paths are x86_64/aarch64-centric; widen after testing
arch="x86_64 aarch64"
license="MIT"
makedepends="
	cmake
	cxxopts-dev
	openblas-dev
	py3-gpep517
	py3-installer
	py3-pybind11-dev
	py3-setuptools
	py3-wheel
	python3-dev
	samurai
	spdlog-dev
	"
checkdepends="gtest-dev py3-numpy py3-pytest py3-wurlitzer py3-yaml"
subpackages="$pkgname-dev $pkgname-libs py3-$pkgname:py3"
# release tarball ships without submodules — pin the ones not packaged
# in Alpine (pins read from third_party/ at the v$pkgver tag; cpuinfo is
# ruy's own pin); spdlog/cxxopts/gtest come from system via unbundle.patch
_cpu_features=8a494eb1e158ec2050e5f699a504fbc9b896a43b
_ruy=363f252289fb7a1fba1703d99196524698cb884d
_cpuinfo=082deffc80ce517f81dc2f3aebe6ba671fcd09c9
source="$pkgname-$pkgver.tar.gz::https://github.com/OpenNMT/CTranslate2/archive/refs/tags/v$pkgver.tar.gz
	cpu_features-$_cpu_features.tar.gz::https://github.com/google/cpu_features/archive/$_cpu_features.tar.gz
	ruy-$_ruy.tar.gz::https://github.com/google/ruy/archive/$_ruy.tar.gz
	cpuinfo-$_cpuinfo.tar.gz::https://github.com/pytorch/cpuinfo/archive/$_cpuinfo.tar.gz
	unbundle.patch
	"
builddir="$srcdir/CTranslate2-$pkgver"

# thrust/cutlass submodules are CUDA-only, intentionally not fetched

prepare() {
	default_prepare

	rmdir third_party/cpu_features third_party/ruy
	mv "$srcdir"/cpu_features-$_cpu_features third_party/cpu_features
	mv "$srcdir"/ruy-$_ruy third_party/ruy
	rmdir third_party/ruy/third_party/cpuinfo
	mv "$srcdir"/cpuinfo-$_cpuinfo third_party/ruy/third_party/cpuinfo
}

build() {
	# bundled deps (cpu_features, ruy, cpuinfo) still declare cmake <3.5
	cmake -B build -G Ninja \
		-DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DBUILD_CLI=ON \
		-DWITH_MKL=OFF \
		-DWITH_OPENBLAS=ON \
		-DWITH_RUY=ON \
		-DOPENMP_RUNTIME=COMP \
		-DBUILD_TESTS="$(want_check && echo ON || echo OFF)"
	cmake --build build

	# python bindings link against the staged C++ library
	DESTDIR="$builddir/staging" cmake --install build
	cd python
	CTRANSLATE2_ROOT="$builddir/staging/usr" \
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

check() {
	build/tests/ctranslate2_test tests/data

	# converter tests (test_transformers.py etc.) need torch, skip them.
	# get_data_dir() skips everything unless this CI-download sentinel dir
	# exists; the tests we run only use the in-repo aren-transliteration model
	mkdir -p tests/data/models/transliteration-aren-all
	python3 -m venv --clear --without-pip --system-site-packages test-env
	test-env/bin/python3 -m installer python/.dist/*.whl
	LD_LIBRARY_PATH="$builddir/staging/usr/lib" \
	test-env/bin/python3 -m pytest \
		python/tests/test_translator.py \
		python/tests/test_misc.py
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

py3() {
	pkgdesc="$pkgdesc (python bindings)"
	depends="py3-numpy py3-setuptools py3-yaml"

	cd "$builddir"/python
	python3 -m installer -d "$subpkgdir" .dist/*.whl
}

