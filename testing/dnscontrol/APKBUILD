# Contributor: Nicolas Lorin <androw95220@gmail.com>
# Maintainer: Nicolas Lorin <androw95220@gmail.com>
pkgname=dnscontrol
pkgver=4.41.0
pkgrel=0
pkgdesc="Synchronize your DNS to multiple providers from a simple DSL"
url="https://dnscontrol.org/"
arch="all"
license="MIT"
makedepends="go"
subpackages="$pkgname-doc"
options="net"
source="$pkgname-$pkgver.tar.gz::https://github.com/DNSControl/dnscontrol/archive/v$pkgver.tar.gz
	dnsconfig.js"

export GOCACHE="${GOCACHE:-"$srcdir/go-cache"}"
export GOTMPDIR="${GOTMPDIR:-"$srcdir"}"
export GOMODCACHE="${GOMODCACHE:-"$srcdir/go"}"

build() {
	go build -ldflags="-X github.com/DNSControl/dnscontrol/v4/pkg/version.version=$pkgver"
}

check() {
	./dnscontrol check --config ../dnsconfig.js
}

package() {
	install -Dm755 dnscontrol "$pkgdir"/usr/bin/dnscontrol
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

sha512sums="
3d03bf1b297945f693bbc37779cd2bb9288ec7537361a0860d8e23291ec60b795a7d221644a0500b357c87a49fd58cd79e2e6c3fda605c0fb1cdfeeedec9fbf7  dnscontrol-4.41.0.tar.gz
5503f149662dcf4d8548bc7e60bf566b2c4e7580593a15cca8f344f37103f413b860f4cb25ed38a620cf650528f133e4dc4d51824993b4e314acba5308a225d4  dnsconfig.js
"
