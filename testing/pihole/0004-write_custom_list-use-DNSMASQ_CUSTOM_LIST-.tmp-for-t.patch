From d1f33681ca1a9dcc6434422a137c5ba05c4a487f Mon Sep 17 00:00:00 2001
From: Henrik Grimler <henrik@grimler.se>
Date: Mon, 23 Feb 2026 08:53:39 +0100
Subject: [PATCH] write_custom_list: use DNSMASQ_CUSTOM_LIST".tmp" for tmpfile

DNSMASQ_CUSTOM_LIST_LEGACY might be on a different disk or filesystem
than DNSMASQ_CUSTOM_LIST, giving EXDEV errors when we try to rename
DNSMASQ_CUSTOM_LIST_LEGACY".tmp" to DNSMASQ_CUSTOM_LIST.

Fix by putting the tmpfile next to the target.
---
 src/config/dnsmasq_config.c | 16 ++++++++--------
 1 file changed, 8 insertions(+), 8 deletions(-)

diff --git a/FTL-6.4.1/src/config/dnsmasq_config.c b/FTL-6.4.1/src/config/dnsmasq_config.c
index 8e2396ad3b56..4eff26c55b85 100644
--- a/FTL-6.4.1/src/config/dnsmasq_config.c
+++ b/FTL-6.4.1/src/config/dnsmasq_config.c
@@ -1099,17 +1099,17 @@ bool write_custom_list(void)
 		}
 	}
 
-	log_debug(DEBUG_CONFIG, "Opening "DNSMASQ_CUSTOM_LIST_LEGACY".tmp for writing");
-	FILE *custom_list = fopen(DNSMASQ_CUSTOM_LIST_LEGACY".tmp", "w");
+	log_debug(DEBUG_CONFIG, "Opening "DNSMASQ_CUSTOM_LIST".tmp for writing");
+	FILE *custom_list = fopen(DNSMASQ_CUSTOM_LIST".tmp", "w");
 	// Return early if opening failed
 	if(!custom_list)
 	{
-		log_err("Cannot open "DNSMASQ_CUSTOM_LIST_LEGACY".tmp for writing, unable to update custom.list: %s", strerror(errno));
+		log_err("Cannot open "DNSMASQ_CUSTOM_LIST".tmp for writing, unable to update custom.list: %s", strerror(errno));
 		return false;
 	}
 
 	// Lock file, may block if the file is currently opened
-	const bool locked = lock_file(custom_list, DNSMASQ_CUSTOM_LIST_LEGACY".tmp");
+	const bool locked = lock_file(custom_list, DNSMASQ_CUSTOM_LIST".tmp");
 
 	write_config_header(custom_list, "Custom DNS entries (HOSTS file)");
 	fputc('\n', custom_list);
@@ -1135,7 +1135,7 @@ bool write_custom_list(void)
 
 	// Unlock file
 	if(locked)
-		unlock_file(custom_list, DNSMASQ_CUSTOM_LIST_LEGACY".tmp");
+		unlock_file(custom_list, DNSMASQ_CUSTOM_LIST".tmp");
 
 	// Close file
 	if(fclose(custom_list) != 0)
@@ -1146,9 +1146,9 @@ bool write_custom_list(void)
 
 	// Check if the new config file is different from the old one
 	// Skip the first 24 lines as they contain the header
-	if(files_different(DNSMASQ_CUSTOM_LIST_LEGACY".tmp", DNSMASQ_CUSTOM_LIST, 24))
+	if(files_different(DNSMASQ_CUSTOM_LIST".tmp", DNSMASQ_CUSTOM_LIST, 24))
 	{
-		if(rename(DNSMASQ_CUSTOM_LIST_LEGACY".tmp", DNSMASQ_CUSTOM_LIST) != 0)
+		if(rename(DNSMASQ_CUSTOM_LIST".tmp", DNSMASQ_CUSTOM_LIST) != 0)
 		{
 			log_err("Cannot install custom.list: %s", strerror(errno));
 			return false;
@@ -1159,7 +1159,7 @@ bool write_custom_list(void)
 	{
 		log_debug(DEBUG_CONFIG, "custom.list unchanged");
 		// Remove temporary config file
-		if(remove(DNSMASQ_CUSTOM_LIST_LEGACY".tmp") != 0)
+		if(remove(DNSMASQ_CUSTOM_LIST".tmp") != 0)
 		{
 			log_err("Cannot remove temporary custom.list: %s", strerror(errno));
 			return false;
-- 
2.53.0

