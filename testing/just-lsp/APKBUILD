# Contributor: Marian Buschsieweke <marian.buschsieweke@posteo.net>
maintainer="Marian Buschsieweke <marian.buschsieweke@posteo.net>"
pkgname=just-lsp
pkgver=0.4.6
pkgrel=0
pkgdesc="Language server for just"
url="https://github.com/terror/just-lsp"
arch="all"
license="CC0-1.0"
makedepends="
	cargo-auditable
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/terror/just-lsp/archive/refs/tags/$pkgver.tar.gz"

export CARGO_PROFILE_RELEASE_OPT_LEVEL="z"

prepare() {
	default_prepare

	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -D -m755 target/release/just-lsp -t "$pkgdir"/usr/bin/
}

sha512sums="
cb94f6cd87485c3e3f59e8def00a19aa6c59933f57f437618ba5c9d6b28ee3f0caeec65702ccce043a71b30f823f0bd05c94dc03bf9c5265626f7a15130748bb  just-lsp-0.4.6.tar.gz
"
