arch="all"
license="GPL-2.0-or-later"
depends="python3"
makedepends="
	gettext
	libselinux-dev
	libsepol-dev
	linux-headers
	py3-setuptools
	py3-pip
	"
subpackages="
	$pkgname-bash-completion
	$pkgname-doc
	$pkgname-lang
	$pkgname-pyc
	"
source="https://github.com/SELinuxProject/selinux/releases/download/$pkgver/selinux-python-$pkgver.tar.gz
	no-pip-net.patch
	"
options="!check" # needs PYTHONPATH adapting

build() {
	make
}

check() {
	make test
}

package() {
	make DESTDIR="$pkgdir" install
}

