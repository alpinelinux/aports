# Contributor: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=py3-curl-cffi
_pyname=curl_cffi
pkgver=0.15.0
pkgrel=0
pkgdesc="Python binding for curl-impersonate via"
url="https://github.com/lexiforest/curl_cffi"
# ppc64le, s390x: libcurl-impersonate
arch="all !ppc64le !s390x"
license="MIT"
depends="
	python3
	py3-cffi
	py3-certifi
	"
makedepends="
	libcurl-impersonate
	py3-gpep517
	py3-setuptools
	py3-wheel
	python3-dev
	"
subpackages="$pkgname-pyc"
source="
	https://files.pythonhosted.org/packages/source/${_pyname:0:1}/$_pyname/$_pyname-$pkgver.tar.gz
	0001-Simplify-mapping-of-target-properties.patch
	0002-Dynamically-link-system-libcurl-impersonate.patch
	"
builddir="$srcdir/$_pyname-$pkgver"

options="!check" # Tests require network

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

