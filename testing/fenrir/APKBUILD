maintainer="Aster Boese <asterboese@mailbox.org>"
pkgname=fenrir
pkgver=2026.01.28
pkgrel=1
pkgdesc="Modern, modular, flexible and fast console screen reader for Linux"
url="https://git.stormux.org/storm/fenrir"
arch="all"
license="LGPL-3.0-only"
depends="
	py3-daemonize
	py3-dbus
	py3-enchant
	py3-evdev
	py3-pexpect
	py3-pyperclip
	py3-pyte
	py3-setproctitle
	py3-udev
	py3-xdg
	python3
	"
makedepends="
	py3-gpep517
	py3-setuptools
	python3-dev
	"
checkdepends="py3-pytest"
subpackages="
	$pkgname-doc
	$pkgname-lang
	$pkgname-openrc
	$pkgname-progs
	$pkgname-scripts
	$pkgname-systemd
	$pkgname-pyc
	"
source="$pkgname-$pkgver.tar.gz::https://git.stormux.org/storm/fenrir/archive/$pkgver.tar.gz
	fenrir.initd"
builddir="$srcdir/$pkgname"

prepare() {
	default_prepare

	# fix missing version in setup.py
	sed -i "s/name=\"fenrir-screenreader\",/name=\"fenrir-screenreader\",\n\tversion=\"$pkgver\",\n/g" "$builddir"/setup.py
}

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	PYTHONPATH="$(echo "$builddir"/build/lib.linux-*)" \
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	# move non-python files out of site-packages
	mkdir -p "$pkgdir"/etc "$pkgdir"/usr
	mv "$pkgdir"/usr/lib/python*/site-packages/etc/* \
		"$pkgdir"/etc/
	rmdir "$pkgdir"/usr/lib/python*/site-packages/etc
	mv "$pkgdir"/usr/lib/python*/site-packages/usr/* \
		"$pkgdir"/usr/
	rmdir "$pkgdir"/usr/lib/python*/site-packages/usr/

	install -Dm644 "$builddir"/config/settings/settings.conf \
		-t "$pkgdir"/etc/fenrirscreenreader/settings/

	# Cleanup fenrir manpage for compression
	mv "$pkgdir"/usr/share/man/man1/fenrir.1 \
		"$pkgdir"/usr/share/man/man1/fenrir.1.gz

	# Copy license for -doc
	install -Dm644 "$pkgdir"/usr/lib/python*/site-packages/fenrir_screenreader-*.dist-info/licenses/LICENCE \
		"$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE

	# systemd service
	install -Dm644 "$builddir"/autostart/systemd/Arch/fenrir.service \
		-t "$pkgdir"/usr/lib/systemd/system/

	# openrc service
	install -Dm755 "$srcdir"/fenrir.initd \
		"$pkgdir"/etc/init.d/fenrir
}

progs() {
	pkgdesc="$pkgdesc (extra tools)"

	amove usr/share/fenrirscreenreader/tools
}

scripts() {
	pkgdesc="$pkgdesc (demo scripts)"

	amove usr/share/fenrirscreenreader/scripts
}

sha512sums="
