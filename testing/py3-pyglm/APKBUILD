maintainer="Thomas Aldrian <aldrian.thom@proton.me>"
pkgname=py3-pyglm
pkgver=2.8.3
pkgrel=0
pkgdesc="OpenGL Mathematics library for Python"
url="https://github.com/Zuzu-Typ/PyGLM"
arch="all"
license="Zlib"
depends="python3"
makedepends="
	glm-dev
	py3-gpep517
	py3-setuptools
	py3-wheel
	python3-dev
	"
subpackages="$pkgname-pyc"
checkdepends="py3-pytest"
source="$pkgname-$pkgver.tar.gz::https://github.com/Zuzu-Typ/PyGLM/archive/refs/tags/$pkgver.tar.gz
	fix-usubBorrow-test.patch"

builddir="$srcdir/PyGLM-$pkgver/"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl

	cd .testenv
	bin/python3 -m pytest ../test/
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
