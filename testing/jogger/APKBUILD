maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=jogger
pkgver=1.3.2
pkgrel=0
pkgdesc="Run tracking app for GNOME Mobile"
url="https://codeberg.org/baarkerlounger/jogger"
arch="all"
license="GPL-3.0-only"
makedepends="
	alsa-lib-dev
	appstream-glib
	blueprint-compiler
	cargo
	clang-dev
	desktop-file-utils
	espeak-ng-dev
	glib-dev
	gtk4.0-dev
	libadwaita-dev
	libshumate-dev
	meson
	rust
	"
checkdepends="rust-clippy"
subpackages="$pkgname-lang"
source="https://codeberg.org/baarkerlounger/jogger/releases/download/$pkgver/jogger-$pkgver.tar.xz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test -t 10 --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
ee07d5e3f3b61214b98ea5cadf5e743edb8b83c3f84c3d11f696992e75fd60551031cd7f2fafb2aee5b0ac03f06dc0e39bc7037e01cabb63869034f8e713a6cb  jogger-1.3.2.tar.xz
"
