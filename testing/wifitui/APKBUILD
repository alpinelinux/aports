# Maintainer: Graham King <grking.email@gmail.com>
maintainer="Graham King <grking.email@gmail.com>"
pkgname=wifitui
pkgver=0.13.0
pkgrel=0
pkgdesc="Fast featureful friendly wifi terminal UI"
url="https://github.com/shazow/wifitui"
arch="all"
license="MIT"
options="net"
makedepends="go"
subpackages="$pkgname-doc"
source="https://github.com/shazow/wifitui/archive/v$pkgver/wifitui-$pkgver.tar.gz"

build() {
	go build -o wifitui
}

check() {
	go test -test.timeout 30s ./...
}

package() {
	install -Dm755 ./wifitui "$pkgdir/usr/bin/wifitui"
	install -Dm644 ./LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

