maintainer="ROllerozxa <rollerozxa@voxelmanip.se>"
pkgname=principia
pkgver=2026.06.19
pkgrel=0
pkgdesc="Physics-based sandbox building game"
url="https://principia-web.se"
arch="all !s390x" # https://github.com/Bithack/principia/issues/27
license="BSD-3-Clause"
makedepends="cmake curl-dev freetype-dev gtk+3.0-dev jpeg-dev libpng-dev samurai sdl2-dev zlib-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/Bithack/principia/archive/$pkgver.tar.gz"
# there is no test suite/unit tests
options="!check"

build() {
	cmake -B build \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=None
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

