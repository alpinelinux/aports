pkgname=cloud-provider-kind
pkgver=0.11.1
pkgrel=0
pkgdesc="Cloud provider for KIND clusters"
url="https://github.com/kubernetes-sigs/cloud-provider-kind"
arch="all"
license="Apache-2.0"
makedepends="go"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/kubernetes-sigs/cloud-provider-kind/archive/refs/tags/v$pkgver.tar.gz"
options="net"

build() {
	go build -v
}

check() {
	go test -v ./...
}

package() {
	install -Dm755 cloud-provider-kind -t "$pkgdir/usr/bin/"
	install -Dm644 "LICENSE" -t "$pkgdir/usr/share/licenses/$pkgname/"
}

