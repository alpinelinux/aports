# Maintainer: Zhurman <svyat0063@gmail.com>
pkgname=gpu-screen-recorder
pkgver=5.13.5
pkgrel=0
pkgdesc="Shadowplay-like screen recorder for X11 and Wayland. The fastest screen recorder for Linux"
url="https://git.dec05eba.com/gpu-screen-recorder/about/"

arch="all"
license="GPL-3.0-only"

subpackages="$pkgname-doc"
# !check: project doesn't provides any tests
options="!check"
makedepends="
	meson
	pkgconfig
	wayland-dev
	dbus-dev
	ffmpeg-dev
	libcap-dev
	libdrm-dev
	mesa-dev
	vulkan-loader-dev
	libva-dev
	libx11-dev
	libxcomposite-dev
	libxcursor-dev
	libxdamage-dev
	libxext-dev
	libxfixes-dev
	libxi-dev
	libxinerama-dev
	libxrandr-dev
	pipewire-dev
	pulseaudio-dev
"

source="https://dec05eba.com/snapshot/gpu-screen-recorder.git.$pkgver.tar.gz"
builddir="$srcdir/"


build() {
	abuild-meson build

	meson compile -C build
}

package() {
	DESTDIR="$pkgdir/" meson install -C build
}


