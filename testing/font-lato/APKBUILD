maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=font-lato
pkgver=2.015
pkgrel=0
pkgdesc="Sans-serif typeface family"
url="https://www.latofonts.com/"
arch="noarch"
license="OFL-1.1"
options="!check"
source="https://www.latofonts.com/files/Lato2OFL.zip"
builddir="$srcdir/Lato2OFL"

package() {
	install -Dm644 -t "$pkgdir"/usr/share/fonts/lato -- *.ttf
	install -Dm644 -t "$pkgdir"/usr/share/licenses/$pkgname OFL.txt
}

