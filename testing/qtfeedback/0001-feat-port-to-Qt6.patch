From: Bart Ribbers <bribbers@disroot.org>
Date: Mon, 30 Mar 2026 16:29:40 +0200
Subject: [PATCH] feat: port to Qt6

---
 .qmake.conf                                   |  2 --
 qtfeedback.pro                                | 27 ++++++++++++++++-
 src/feedback/feedback.pro                     | 29 +++++++++++++++----
 src/feedback/qfeedbackactuator.h              |  2 --
 src/feedback/qfeedbackeffect.h                |  3 +-
 src/feedback/qfeedbackplugininterfaces.h      |  2 --
 src/imports/feedback/feedback.pro             | 27 +++++++++++++++--
 .../feedback/qdeclarativehapticseffect.cpp    |  5 ++++
 .../qfeedbackplugin/testplugin/testplugin.pro |  1 -
 10 files changed, 84 insertions(+), 17 deletions(-)

diff --git a/.qmake.conf b/.qmake.conf
index 8840bd9..0742660 100644
--- a/.qmake.conf
+++ b/.qmake.conf
@@ -1,3 +1 @@
-load(qt_build_config)
-
 MODULE_VERSION = 0.0.0
diff --git a/qtfeedback.pro b/qtfeedback.pro
index 58c33f2..c658c2b 100644
--- a/qtfeedback.pro
+++ b/qtfeedback.pro
@@ -1 +1,26 @@
-load(qt_parts)
+TEMPLATE = subdirs
+SUBDIRS += src examples
+
+# Generate docs
+QDOC = $$[QT_INSTALL_BINS]/qdoc
+QDOCCONF = $$PWD/doc/qtfeedback.qdocconf
+QHELP_GENERATOR = $$[QT_INSTALL_BINS]/qhelpgenerator
+!exists($$QHELP_GENERATOR) {
+	QHELP_GENERATOR = $$[QT_INSTALL_BINS]/../libexec/qhelpgenerator
+}
+DOCS_OUTPUT_DIR=$$PWD/doc-build
+
+# Set environment variables referred to by qtfeedback.qdocconf
+docs.commands = QT_INSTALL_DOCS=$$[QT_INSTALL_DOCS] QT_VERSION=$$QT_VERSION QT_VERSION_TAG=$$QT_VERSION QT_VER=$$QT_MAJOR_VERSION BUILDDIR=$$DOCS_OUTPUT_DIR
+# Generate documentation
+docs.commands += $$QDOC $$QDOCCONF --outputdir $$DOCS_OUTPUT_DIR
+# Generate a compressed version
+docs.commands += $$escape_expand(\n\t) $$QHELP_GENERATOR -o $$DOCS_OUTPUT_DIR/qtfeedback.qch $$DOCS_OUTPUT_DIR/qtfeedback.qhp
+docs.target = docs
+docs.CONFIG += phony
+QMAKE_EXTRA_TARGETS += docs
+
+install_qch_docs.depends = docs
+install_qch_docs.commands = install -Dm644 $$DOCS_OUTPUT_DIR/qtfeedback.qch $(INSTALL_ROOT)$$[QT_INSTALL_DOCS]/qtfeedback.qch
+install_qch_docs.CONFIG += phony
+QMAKE_EXTRA_TARGETS += install_qch_docs
diff --git a/src/feedback/feedback.pro b/src/feedback/feedback.pro
index 4ed9e23..9aeda83 100644
--- a/src/feedback/feedback.pro
+++ b/src/feedback/feedback.pro
@@ -1,13 +1,11 @@
-TARGET = QtFeedback
+TARGET = Qt$${QT_MAJOR_VERSION}Feedback
 QT = core
+TEMPLATE = lib
+CONFIG += create_pc create_prl
 
 MODULE_PLUGIN_TYPES = \
     feedback
 
-QMAKE_DOCS = $$PWD/../../doc/qtfeedback.qdocconf
-
-load(qt_module)
-
 PUBLIC_HEADERS += qfeedbackglobal.h \
                   qfeedbackactuator.h \
                   qfeedbackeffect.h \
@@ -22,3 +20,24 @@ HEADERS =  $$PUBLIC_HEADERS $$PRIVATE_HEADERS
 SOURCES += qfeedbackactuator.cpp \
            qfeedbackeffect.cpp \
            qfeedbackplugin.cpp
+
+public_headers.files = $$PUBLIC_HEADERS
+public_headers.path = /usr/include/qt$${QT_MAJOR_VERSION}/QtFeedback
+
+target.path = $$[QT_INSTALL_LIBS]
+
+pkgconfig.files = $$TARGET.pc
+pkgconfig.path = $$target.path/pkgconfig
+
+QMAKE_PKGCONFIG_NAME = lib$$TARGET
+QMAKE_PKGCONFIG_DESCRIPTION = Qt Feedback module
+QMAKE_PKGCONFIG_LIBDIR = $$target.path
+QMAKE_PKGCONFIG_INCDIR = $$public_headers.path
+QMAKE_PKGCONFIG_DESTDIR = pkgconfig
+QMAKE_PKGCONFIG_REQUIRES = Qt$${QT_MAJOR_VERSION}Core
+QMAKE_PKGCONFIG_VERSION = $$VERSION
+
+INSTALLS += \
+        public_headers \
+        target \
+        pkgconfig
