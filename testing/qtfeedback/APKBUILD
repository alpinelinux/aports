maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=qtfeedback
pkgver=5.2.0_git9
pkgrel=2
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
url="https://qt-project.org/"
license="LGPL-2.1-only AND LGPL-3.0-only AND GPL-3.0-only AND Qt-GPL-exception-1.0"
pkgdesc="Qt Tactile Feedback"
depends_dev="qt6-qtdeclarative-dev"
makedepends="$depends_dev
	qt6-qtbase-doc
	qt6-qttools
	"
subpackages="
	$pkgname-dev
	$pkgname-doc
	"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/qtfeedback/archive/refs/tags/mer/${pkgver/_/+}.tar.gz
	0001-feat-port-to-Qt6.patch
	"
builddir="$srcdir/qtfeedback-mer-${pkgver/_/-}"

build() {
	qmake6 \
		CONFIG+=package \
		multimedia_disabled=yes \
		immersion_enabled=no \
		meegotouchfeedback_enabled=no
	make
	make docs
}

check() {
	make check
}

package() {
	make INSTALL_ROOT="$pkgdir" install
	make INSTALL_ROOT="$pkgdir" install_qch_docs

	# Drop QMAKE_PRL_BUILD_DIR because reference the build dir
	find "$pkgdir/usr/lib" -type f -name '*.prl' \
		-exec sed -i -e '/^QMAKE_PRL_BUILD_DIR/d' {} \;
}

sha512sums="
