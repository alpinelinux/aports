maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=selinux-policy
pkgver=43.6
_container_selinux_ver=2.247.0
pkgrel=1
pkgdesc="SELinux policy used by Fedora"
url="https://github.com/fedora-selinux/selinux-policy"
arch="noarch"
license="GPL-2.0-or-later"
makedepends="
	checkpolicy
	libselinux-utils
	m4
	policycoreutils
	py3-libselinux
	python3
	selinux-python
	semodule-utils
	"
source="https://github.com/fedora-selinux/selinux-policy/archive/v$pkgver/selinux-policy-$pkgver.tar.gz
	https://github.com/containers/container-selinux/archive/v$_container_selinux_ver/container-selinux-$_container_selinux_ver.tar.gz
	0001-Label-sshd-and-helpers-on-Alpine-Linux.patch
	config
	selinux-policy.conf
	"
options="!check" # no tests

prepare() {
	default_prepare

	mv "$srcdir"/container-selinux-$_container_selinux_ver/container.* policy/modules/contrib
}

build() {
	make UBAC=n DISTRO=redhat DIRECT_INITRC=n MONOLITHIC=n MLS_CATS=1024 MCS_CATS=1024 UNK_PERMS=allow NAME=targeted TYPE=mcs bare
	make UBAC=n DISTRO=redhat DIRECT_INITRC=n MONOLITHIC=n MLS_CATS=1024 MCS_CATS=1024 UNK_PERMS=allow NAME=targeted TYPE=mcs conf

	install -p -m0644 ./dist/targeted/booleans.conf ./policy/booleans.conf
	install -p -m0644 ./dist/targeted/users ./policy/users
	install -p -m0644 ./dist/targeted/modules.conf ./policy/modules.conf

	make UBAC=n DISTRO=redhat DIRECT_INITRC=n MONOLITHIC=n MLS_CATS=1024 MCS_CATS=1024 UNK_PERMS=allow NAME=targeted TYPE=mcs base.pp
	make UBAC=n DISTRO=redhat DIRECT_INITRC=n MONOLITHIC=n MLS_CATS=1024 MCS_CATS=1024 UNK_PERMS=allow NAME=targeted TYPE=mcs validate modules
}

package() {
	make UBAC=n DISTRO=redhat DIRECT_INITRC=n MONOLITHIC=n MLS_CATS=1024 MCS_CATS=1024 UNK_PERMS=allow NAME=targeted TYPE=mcs DESTDIR="$pkgdir" install
	make UBAC=n DISTRO=redhat DIRECT_INITRC=n MONOLITHIC=n MLS_CATS=1024 MCS_CATS=1024 UNK_PERMS=allow NAME=targeted TYPE=mcs DESTDIR="$pkgdir" install-appconfig

	make UBAC=n DISTRO=redhat DIRECT_INITRC=n MONOLITHIC=n MLS_CATS=1024 MCS_CATS=1024 UNK_PERMS=allow NAME=targeted TYPE=mcs DESTDIR="$pkgdir" SEMODULE="semodule -p $pkgdir -X 100 " load

	mkdir -p "$pkgdir"/etc/selinux/targeted/logins
	touch "$pkgdir"/etc/selinux/targeted/contexts/files/file_contexts.subs
	install -p -m0644 ./config/file_contexts.subs_dist "$pkgdir"/etc/selinux/targeted/contexts/files
	install -p -m0644 ./dist/targeted/setrans.conf "$pkgdir"/etc/selinux/targeted/setrans.conf
	install -p -m0644 ./dist/customizable_types "$pkgdir"/etc/selinux/targeted/contexts/customizable_types
	touch "$pkgdir"/etc/selinux/targeted/contexts/files/file_contexts.bin
	touch "$pkgdir"/etc/selinux/targeted/contexts/files/file_contexts.local
	touch "$pkgdir"/etc/selinux/targeted/contexts/files/file_contexts.local.bin
	install -p -m0644 ./dist/booleans.subs_dist "$pkgdir"/etc/selinux/targeted
	rm -f "$pkgdir"/usr/share/selinux/targeted/*pp*
	rm -rf "$pkgdir"/etc/selinux/targeted/contexts/netfilter_contexts
	rm -rf "$pkgdir"/etc/selinux/targeted/modules/active/policy.kern
	rm -f "$pkgdir"/usr/share/selinux/targeted/active/*.linked

	install -Dm644 "$srcdir"/config -t "$pkgdir"/etc/selinux/
	install -Dm644 "$srcdir"/selinux-policy.conf -t "$pkgdir"/usr/lib/tmpfiles.d/
}

