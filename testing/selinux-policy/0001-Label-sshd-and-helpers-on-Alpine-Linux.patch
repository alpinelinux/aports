From a16641d9a51b5c61cd7db7817f3e16e8f9ee70ba Mon Sep 17 00:00:00 2001
From: Aelin <aelin@postmarketos.org>
Date: Tue, 14 Apr 2026 06:11:12 +0200
Subject: [PATCH] Label sshd and helpers on Alpine Linux

Alpine puts OpenSSH helper binaries in /usr/lib/ssh, and does not yet
have a merged bin, so sshd must be found in sbin as well. Also, there's
several flavors of sshd, e.g. for the PAM-enabled binary, so also match
on those.
---
 policy/modules/services/ssh.fc | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/policy/modules/services/ssh.fc b/policy/modules/services/ssh.fc
index d95875c15..bb76e71d1 100644
--- a/policy/modules/services/ssh.fc
+++ b/policy/modules/services/ssh.fc
@@ -34,7 +34,12 @@ HOME_DIR/\.shosts			gen_context(system_u:object_r:ssh_home_t,s0)
 /usr/libexec/openssh/sshd-session	--	gen_context(system_u:object_r:sshd_session_exec_t,s0)
 /usr/libexec/openssh/ssh-pkcs11-helper	--	gen_context(system_u:object_r:ssh_agent_exec_t,s0)
 
-/usr/bin/sshd			--	gen_context(system_u:object_r:sshd_exec_t,s0)
+/usr/lib/ssh/ssh-keysign	--	gen_context(system_u:object_r:ssh_keysign_exec_t,s0)
+/usr/lib/ssh/sshd-auth.*	--	gen_context(system_u:object_r:sshd_auth_exec_t,s0)
+/usr/lib/ssh/sshd-session.*	--	gen_context(system_u:object_r:sshd_session_exec_t,s0)
+/usr/lib/ssh/ssh-pkcs11-helper	--	gen_context(system_u:object_r:ssh_agent_exec_t,s0)
+
+/usr/s?bin/sshd.*			--	gen_context(system_u:object_r:sshd_exec_t,s0)
 /usr/bin/sshd-keygen   --	gen_context(system_u:object_r:sshd_keygen_exec_t,s0)
 /usr/bin/gsisshd		--	gen_context(system_u:object_r:sshd_exec_t,s0)
 
-- 
2.53.0

