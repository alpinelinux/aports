# Maintainer: Yagnesh Mistry <ysh@live.in>

pkgname=twemproxy
_akaname=nutcracker
pkgver=0.5.0
pkgrel=1
pkgdesc="A fast, light-weight proxy for memcached and redis"
url="https://github.com/twitter/twemproxy"
arch="all"
license="Apache-2.0"
makedepends="automake autoconf libtool yaml-dev"
subpackages="$pkgname-doc $pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/twitter/twemproxy/archive/$pkgver.tar.gz
	nutcracker.initd
	nutcracker.confd
	use-system-libyaml.patch
	"

case "$CARCH" in
	# FIXME https://github.com/twitter/twemproxy/issues/680
	s390x) options="!check" ;;
esac

build() {
	autoreconf -vif
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
	install -m644 -D -t "$pkgdir"/etc/$_akaname/ conf/*.yml
	install -m755 -D "$srcdir"/$_akaname.initd \
		"$pkgdir"/etc/init.d/$_akaname
	install -m644 -D "$srcdir"/$_akaname.confd \
		"$pkgdir"/etc/conf.d/$_akaname

	install -m0755 -d "$pkgdir"/var/run/$_akaname
	install -m0755 -d "$pkgdir"/var/log/$_akaname

	# remove test_all binary
	rm "$pkgdir/usr/bin/test_all"

	install -m644 -D README.md NOTICE ChangeLog \
		-t "$pkgdir"/usr/share/doc/$_akaname/

	install -m644 -D LICENSE \
		-t "$pkgdir"/usr/share/licenses/$_akaname/
}

