maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=libngf-qt
pkgver=0.9.2
pkgrel=1
pkgdesc="Qt-based client for NGF daemon (Non-Graphic Feedback)."
url="https://github.com/sailfishos/libngf-qt"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="LGPL-2.1-or-later"
depends_dev="
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qtfeedback-dev
	"
makedepends="$depends_dev"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/sailfishos/libngf-qt/archive/refs/tags/$pkgver.tar.gz"
options="!check" # No suitable tests

build() {
	qmake6 \
		PREFIX=/usr
	make
}

package() {
	INSTALL_ROOT="$pkgdir" make install

	# Remove tests
	rm -rf "$pkgdir"/opt
}

sha512sums="
a6eb3e8c57ff228d853c0dbbc4f19a6893fd9d7ca869f65bcfec62a69d1774e4155a859e5dc4da9ef27d7cfe7e8bb852e347571ecdb72b3941e1127aaff47d4e  libngf-qt-0.9.2.tar.gz
"
