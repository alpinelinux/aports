maintainer="Leon White <badfunkstripe@gmail.com>"
pkgname=protoc-gen-go-grpc
pkgver=1.80.0
pkgrel=1
pkgdesc="protoc plugin to generate Go language bindings of services in protobuf definition files for gRPC"
url="https://github.com/grpc/grpc-go"
arch="all"
license="Apache-2.0"
depends="protoc"
makedepends="go"
source="$pkgname-$pkgver.tar.gz::https://github.com/grpc/grpc-go/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/grpc-go-$pkgver/cmd/protoc-gen-go-grpc"
options="net" # download Go modules

build() {
	go build -v .
}

check() {
	go test ./...
}

package() {
	install -Dm755 protoc-gen-go-grpc -t "$pkgdir"/usr/bin/
}

