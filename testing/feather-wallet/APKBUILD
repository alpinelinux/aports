# Contributor: RavFX XMR <ravfx@xmr.mx>
maintainer="RavFX XMR <ravfx@xmr.mx>"
pkgname=feather-wallet
pkgver=2.8.1
pkgrel=0
pkgdesc="Free Monero desktop wallet"
url="https://featherwallet.org"
arch="all !riscv64" # get stuck during build most of the time, then timeout
license="BSD-3-Clause"
depends="tor"
makedepends="
	boost-dev
	cmake
	hidapi-dev
	libgcrypt-dev
	libqrencode-dev
	libsodium-dev
	libusb-dev
	openssl-dev
	protobuf-dev
	qt6-qtbase-dev
	qt6-qtmultimedia-dev
	qt6-qtsvg-dev
	qt6-qtwebsockets-dev
	rapidjson-dev
	samurai
	unbound-dev
	zbar-dev
	zxing-cpp-dev
	"
options="!check" # There is no test suits
source="feather-$pkgver.tar.gz::https://github.com/feather-wallet/feather/releases/download/2.8.1/feather-2.8.1.tar.gz
	loongarch64.patch"
builddir="$srcdir/feather-$pkgver"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCHECK_UPDATES=OFF \
		-DDONATE_BEG=OFF \
		-DSELF_CONTAINED=OFF \
		-DTOR_INSTALLED=ON \
		-DWITH_SCANNER=ON \
		.

	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	install -Dm644 "$builddir/src/assets/org.featherwallet.feather.metainfo.xml" \
		"$pkgdir/usr/share/metainfo/org.featherwallet.feather.metainfo.xml"
}

