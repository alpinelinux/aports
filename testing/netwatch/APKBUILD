pkgname=netwatch
pkgver=0.12.5
pkgrel=0
pkgdesc="real-time network diagnostics TUI"
url="https://github.com/matthart1983/netwatch"
arch="all"
license="MIT"
makedepends="cargo cargo-auditable libpcap-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/matthart1983/netwatch/archive/refs/tags/v$pkgver.tar.gz"

prepare() {
	default_prepare

	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --frozen --release
}

check() {
	cargo test --frozen
}

package() {
	cargo auditable install --locked --offline --path . --root="$pkgdir/usr"
	rm "$pkgdir"/usr/.crates*
}

sha512sums="
077b5f138a867353d839ed0f02f7ff211121d14df617b4d04342ad58e0412bb9abf1e6236d5225c0e1b5946619e6affb1be361c214a5e73f3c93913cb8574a56  netwatch-0.12.5.tar.gz
"
