# Contributor: Sertonix <sertonix@posteo.net>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=rpi-imager
pkgver=2.0.7
pkgrel=0
pkgdesc="A user-friendly tool for creating bootable media for Raspberry Pi devices"
url="https://www.raspberrypi.com/software/"
# only supports little endian
# armhf: qt6-qtdeclarative-dev
arch="all !s390x !armhf"
license="Apache-2.0"
makedepends="
	cmake
	curl-dev
	eudev-dev
	gnutls-dev
	libarchive-dev
	liburing-dev
	libusb-dev
	ninja
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtdeclarative-private-dev
	qt6-qtsvg-dev
	qt6-qttools-dev
	xz-dev
	zstd-dev
	"
subpackages="$pkgname-doc"
source="https://github.com/raspberrypi/rpi-imager/archive/v$pkgver/rpi-imager-$pkgver.tar.gz
	devendor.patch
	alpine.patch
	"
options="!check"

prepare() {
	default_prepare

	# Remove vendored dependencies
	local i
	for i in src/dependencies/*; do
		case $i in
			*/yescrypt*|*/sha256crypt) continue ;;
		esac
		rm -r "$i"
	done
}

build() {
	if [ "$CBUILD" != "$CHOST" ]; then
		local crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	fi
	VERSION_STR=$pkgver-alpine \
	cmake -B build -S src \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=None \
		-DENABLE_CHECK_VERSION=OFF \
		-DENABLE_TELEMETRY=OFF \
		-DGENERATE_TIMEZONES_FROM_IANA=OFF \
		-DGENERATE_COUNTRIES_FROM_REGDB=OFF \
		-DGENERATE_CAPITAL_CITIES=OFF \
		$crossopts
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
	install -Dm644 -t "$pkgdir"/usr/share/man/man1/ doc/man/*.1
}

