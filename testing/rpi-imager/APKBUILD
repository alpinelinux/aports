4127cc1f478a63082bd1b54fb154aa69605b03abd5eda7f3f6a92e0c2756bf9a92e1f931bbbde5914b2b4a8f3f154a3c5441e540482d22f211ec62c7554f9bba  devendor.patch
c7f1afff26ef875c15ef85996f0ffde5082fa00d9d3a93ea627668f1a9e993e5f5bad7e348e1445bd09127e7bf83a33491f55654185793c91b2a91b3cfe4e8ec  alpine.patch
