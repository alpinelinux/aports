# Maintainer: Willow Barraco <contact@willowbarraco.fr>
pkgname=py3-tidalapi
pkgver=0.8.11
pkgrel=0
pkgdesc="Unofficial Python API for TIDAL music streaming service"
url="https://pypi.org/project/tidalapi/"
arch="noarch"
license="LGPL-3.0-or-later"
depends="
	python3
	py3-dateutil
	py3-isodate
	py3-mpegdash
	py3-pyaes
	py3-requests
	py3-typing-extensions
	"
makedepends="py3-gpep517 py3-wheel py3-installer py3-poetry-core"
checkdepends="py3-pytest py3-keyring py3-ffmpeg py3-pillow"
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/EbbLabs/python-tidal/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/python-tidal-$pkgver"
options="!check" # Visit https://link.tidal.com/... to log in

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
326ae211b87245230c39d7601a65b89f6e51baf0ea850c90f11464691611337301addafc819a66479dce289d30ce4537f5ceab493437e38ff91e9e37f3896adf  py3-tidalapi-0.8.11.tar.gz
"
