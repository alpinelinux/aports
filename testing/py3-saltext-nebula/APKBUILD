# Contributor: Will Sinatra <wpsinatra@gmail.com>
# Maintainer: Will Sinatra <wpsinatra@gmail.com>
pkgname=py3-saltext-nebula
_pkgname=saltext_nebula
pkgver=1.1.0
pkgrel=0
pkgdesc="Salt Extension that adds support for managing Nebula mesh infrastructure through salt."
url="https://github.com/salt-extensions/saltext-nebula"
arch="noarch"
license="Apache-2.0"
makedepends="
	py3-gpep517
	py3-setuptools
	py3-setuptools_scm
	py3-wheel
	"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/${_pkgname:0:1}/$_pkgname/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/${_pkgname//./_}-$pkgver"
options="!check" # checks require a saltstack environment

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	.testenv/bin/python3 -m pytest
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
671905cdac7b0cec654c2a5d343ef9eceeab85e70d71f384007e6b1e0c1ab027ecb7c8f84cc3256174bd09567f2e62fb123016c661431d5ae4dee32913ba706a  saltext_nebula-1.1.0.tar.gz
"
