maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=cinnamon-settings-daemon
pkgver=6.6.4
pkgrel=0
pkgdesc="Settings daemon for the Cinnamon desktop (fork of gnome-settings-daemon)"
url="https://github.com/linuxmint/cinnamon-settings-daemon"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	cinnamon-desktop-dev
	colord-dev
	coreutils
	cups-dev
	elogind-dev
	libcanberra-dev
	libnotify-dev
	librsvg-dev
	libwacom-dev
	meson
	nss-dev
	upower-dev
	"
source="https://github.com/linuxmint/cinnamon-settings-daemon/archive/$pkgver/cinnamon-settings-daemon-$pkgver.tar.gz"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
