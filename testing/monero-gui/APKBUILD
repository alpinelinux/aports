50a5a0ae05a76a35b819013c2376faf5253fd651b82bd1eecf0d9e20f503075b33b81f5c122f6d4bc2e6c7e22a6672a859c9c26b229d2a4f3f8561fa8595fac8  loongarch64.patch
ac80d8cb7eb81c5f07cd88b5c1260c76979d8a4fe750b94f18a46cd58e6e7d7d7907a0711d5386a2c1cbd2c5fef6b17ccf0f0d1d2459a3ed3a09d1767a4e785f  easylogging.patch
