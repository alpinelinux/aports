maintainer="Hugo Osvaldo Barrera <hugo@whynothugo.nl>"
pkgname=dxvk
pkgver=2.7.1
pkgrel=0
_libdisplay_commit=275e6459c7ab1ddd4b125f28d0440716e4888078
pkgdesc="Vulkan-based implementation of D3D9, D3D10 and D3D11 for Wine"
url="https://github.com/doitsujin/dxvk"
arch="x86_64"
license="Zlib"
makedepends="
	glslang
	i686-mingw-w64-gcc
	meson
	mingw-w64-gcc
	spirv-headers
	vulkan-headers
	"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/doitsujin/dxvk/archive/v$pkgver.tar.gz
	libdisplay-info-$_libdisplay_commit.tar.gz::https://github.com/doitsujin/libdisplay-info/archive/$_libdisplay_commit.tar.gz
	setup-dxvk
	"
# strip: non-ELF binary
options="!check !strip"

prepare() {
	default_prepare

	# Cross compiler searches mingw sysroot, no system headers.
	mkdir -p include/vulkan/include include/spirv/include
	ln -s /usr/include/vulkan include/vulkan/include/vulkan
	ln -s /usr/include/vk_video include/vulkan/include/vk_video
	ln -s /usr/include/spirv include/spirv/include/spirv

	# Custom fork of libdisplay-info is required.
	rmdir subprojects/libdisplay-info
	mv "$srcdir"/libdisplay-info-$_libdisplay_commit subprojects/libdisplay-info
}

build() {
	# ELF-specific flags are incompatible with cross-linker.
	unset LDFLAGS

	meson setup build-x64 \
		--cross-file build-win64.txt \
		--prefix "/usr/share/dxvk/x64" \
		--bindir "" --libdir "" \
		--buildtype release \
		--strip \
		-Db_ndebug=if-release
	meson compile -C build-x64

	meson setup build-x32 \
		--cross-file build-win32.txt \
		--prefix "/usr/share/dxvk/x32" \
		--bindir "" --libdir "" \
		--buildtype release \
		--strip \
		-Db_ndebug=if-release
	meson compile -C build-x32
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C build-x64
	DESTDIR="$pkgdir" meson install --no-rebuild -C build-x32

	find "$pkgdir" -name '*.a' -delete

	install -Dm644 dxvk.conf -t "$pkgdir"/usr/share/dxvk
	install -Dm755 "$srcdir"/setup-dxvk -t "$pkgdir"/usr/bin
}

