maintainer="Alex Denes <caskd@redxen.eu>"
pkgname=obs-pipewire-audio-capture
pkgver=1.2.1
pkgrel=0
pkgdesc="Audio device and application capture for OBS Studio using PipeWire"
url="https://github.com/dimtpap/obs-pipewire-audio-capture"
# riscv64, loongarch64: obs-studio-dev missing
# armhf: simde: 'simde_x_mm_round_ps': incompatible types when assigning to type 'v2i64' from type '__m128'
arch="all !riscv64 !loongarch64 !armhf"
license="GPL-2.0-or-later"
makedepends="
	cmake
	pipewire-dev
	simde-dev
	obs-studio-dev
	samurai
"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/dimtpap/obs-pipewire-audio-capture/archive/refs/tags/$pkgver.tar.gz
"
options="!check" # no test suite

prepare() {
	default_prepare

	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib
}

build() {
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}
sha512sums="
