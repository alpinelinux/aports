 src/analysis/processing/qgsalgorithmimportphotos.cpp |  2 +-
 src/core/providers/gdal/qgsgdalprovider.cpp          | 10 +++++-----
 src/core/providers/ogr/qgsogrproviderconnection.cpp  |  2 +-
 src/core/providers/ogr/qgsogrprovidermetadata.cpp    |  2 +-
 src/core/qgsgdalutils.cpp                            |  2 +-
 src/core/qgsogrutils.cpp                             |  2 +-
 src/core/qgsogrutils.h                               |  2 +-
 src/core/qgsvectorfilewriter.cpp                     |  4 ++--
 src/core/raster/qgsrasterfilewriter.cpp              |  4 ++--
 10 files changed, 16 insertions(+), 17 deletions(-)

