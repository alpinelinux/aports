pkgname=kew
pkgver=4.0.0
pkgrel=0
pkgdesc="A terminal music player with album art & visualizer"
url="https://codeberg.org/ravachol/kew"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	chafa-dev
	faad2-dev
	fftw-dev
	glib-dev
	gobject-introspection-dev
	libogg-dev
	libvorbis-dev
	opus-dev
	opusfile-dev
	taglib-dev
"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://codeberg.org/ravachol/kew/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname/"
options="!check" # No upstream testsuite defined

build() {
	make all USE_DBUS=1
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
}

