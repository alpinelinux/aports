maintainer="Paolo Barbolini <paolo.barbolini@m4ss.net>"
pkgname=cargo-udeps
pkgver=0.1.61
pkgrel=0
pkgdesc="Find unused dependencies in Cargo.toml"
url="https://github.com/est31/cargo-udeps"
arch="all"
license="Apache-2.0 OR MIT"
makedepends="
	cargo
	cargo-auditable
	curl-dev
	libgit2-dev
	openssl-dev
	"
checkdepends="cargo"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://github.com/est31/cargo-udeps/archive/refs/tags/v$pkgver.tar.gz
	gix-index-0.47.0.crate::https://static.crates.io/crates/gix-index/gix-index-0.47.0.crate
	"
# net: cargo fetch
# check: tests require Rust nightly
options="net !check"

export LIBGIT2_NO_VENDOR=1 # use system libgit2

prepare() {
	default_prepare

	# gix-index uses libc::stat fields (st_mtim, st_ctim) on loongarch64-musl,
	# but wraps rustix::fs::Stat which has st_mtime/st_mtime_nsec directly.
	# Remove loongarch64 from the special-case cfg and patch via [patch.crates-io].
	mkdir -p vendor/gix-index
	tar xzf "$srcdir"/gix-index-0.47.0.crate -C vendor/gix-index --strip-components=1
	sed -i '/all(target_arch = "loongarch64", target_env = "musl")/d' vendor/gix-index/src/fs.rs
	cat >> Cargo.toml <<-'EOF'

[patch.crates-io]
gix-index = { path = "vendor/gix-index" }
EOF

	cargo fetch --target="$CTARGET"
}

build() {
	cargo auditable build --release --frozen
}

package() {
	install -Dm755 target/release/cargo-udeps -t "$pkgdir"/usr/bin/

	install -Dm 644 README.md -t "$pkgdir"/usr/share/doc/"$pkgname"/
	install -Dm 644 LICENSE -t "$pkgdir"/usr/share/licenses/"$pkgname"/
}

sha512sums="
c4d1ee8a33c0b49081748b465b8ffe6c5010951e7dd74ae9f9fb96d1a7c4c3ce269ba1a3f35b56838dab2a01054320ed6cef67888fda41e998c61a862e1471b2  cargo-udeps-0.1.61.tar.gz
7bd2e98c91d668b132c86a361fb9a1996c29038a5abbc141687312b41954b4b721ec6f6a47aca949d623553b5335d7b9518058a59a234cbb9e9086ef8964ad01  gix-index-0.47.0.crate
"
