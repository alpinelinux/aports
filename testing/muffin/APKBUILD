maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=muffin
pkgver=6.6.3
pkgrel=0
pkgdesc="Window management library for the Cinnamon desktop (fork of mutter)"
url="https://github.com/linuxmint/muffin"
arch="all"
license="GPL-2.0-or-later"
makedepends="
	cinnamon-desktop-dev
	elogind-dev
	eudev-dev
	gobject-introspection-dev
	graphene-dev
	gtk+3.0-dev
	json-glib-dev
	libcanberra-dev
	libgudev-dev
	libice-dev
	libinput-dev
	libsm-dev
	libwacom-dev
	libx11-dev
	meson
	pipewire-dev
	startup-notification-dev
	xkeyboard-config-dev
	xwayland-dev
	"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	$pkgname-doc
	$pkgname-lang
	"
source="https://github.com/linuxmint/muffin/archive/$pkgver/muffin-$pkgver.tar.gz
	muffin-menu-icon.patch
	muffin-wayland-wm-capabilities.patch
	"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

