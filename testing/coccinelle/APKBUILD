# Maintainer: Marian Buschsieweke <marian.buschsieweke@posteo.net>

pkgname=coccinelle
pkgver=1.3.1
pkgrel=0
pkgdesc="provides the spatch matching and transformation engine implementing semantic patch language"
url="https://coccinelle.gitlabpages.inria.fr/website/"
makedepends="
	autoconf
	automake
	ocaml
	ocaml-findlib
	ocaml-num
	ocaml-ocamldoc
	"
depends="
	pcre
	python3
	"
subpackages="
	$pkgname-doc
	$pkgname-bash-completion
	"
# riscv64, loongarch64: ocaml
arch="all !riscv64 !loongarch64"
license="GPL-2.0-only"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/coccinelle/coccinelle/archive/$pkgver.tar.gz
	"

build() {
	./autogen
	./configure \
		--prefix=/usr \
		--enable-release=yes \
		--with-python=/usr/bin/python3

	make
}

package() {
	make DESTDIR="$pkgdir" MANDIR="/usr/share/man" install
	install -Dm644 license.txt "$pkgdir"/usr/share/doc/coccinelle/license.txt
}

check() {
	./spatch.opt \
		--testall
}

sha512sums="
0e50aa0f1ae174eb698fc8df3d1ef03e94bddddcec468061682bb54890c41d16427c6641e97cfc12774ef4331ff3f547ed12222431441370ebb91e9efaf94717  coccinelle-1.3.1.tar.gz
"
