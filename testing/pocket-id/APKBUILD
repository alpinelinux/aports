# Contributor: Guy Godfroy <guy.godfroy@ovhcloud.com>
# Maintainer: Guy Godfroy <guy.godfroy@ovhcloud.com>
pkgname=pocket-id
pkgver=2.9.0
pkgrel=0
pkgdesc="Simple OIDC provider that allows users to authenticate with passkeys"
url="https://pocket-id.org/"
arch="x86_64 aarch64" # rolldown ships musl bindings only for x64 and arm64
license="BSD-2-Clause"
makedepends="go nodejs pnpm"
install="$pkgname.pre-install"
pkgusers="$pkgname"
pkggroups="$pkgname"
subpackages="$pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/pocket-id/pocket-id/archive/refs/tags/v$pkgver.tar.gz
	$pkgname.initd
	$pkgname.confd
	"
options="net" # go modules and pnpm dependencies

export GOFLAGS="$GOFLAGS -trimpath -mod=readonly -buildvcs=false"

build() {
	# build the frontend; svelte's adapter-static writes to
	# backend/frontend/dist, which the backend embeds via go:embed
	pnpm --filter pocket-id-frontend install --frozen-lockfile
	pnpm --filter pocket-id-frontend run build

	cd backend
	go build \
		-ldflags="-X github.com/pocket-id/pocket-id/backend/internal/common.Version=$pkgver" \
		-o "$builddir/pocket-id" \
		./cmd
}

check() {
	cd backend
	# scope to self-contained packages; other suites need a database
	go test ./internal/common/... ./frontend/...
}

package() {
	install -Dm755 "$builddir/pocket-id" "$pkgdir/usr/bin/pocket-id"

	install -Dm755 "$srcdir/$pkgname.initd" "$pkgdir/etc/init.d/$pkgname"
	install -Dm640 -g "$pkgname" "$srcdir/$pkgname.confd" \
		"$pkgdir/etc/conf.d/$pkgname"

	install -dm750 -o "$pkgname" -g "$pkgname" "$pkgdir/var/lib/$pkgname"
}

