maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=setroubleshoot
pkgver=3.3.36
pkgrel=1
pkgdesc="Helps troubleshoot SELinux problems"
url="https://gitlab.com/setroubleshoot/setroubleshoot"
arch="all"
license="GPL-2.0-or-later"
depends="
	py3-dasbus
	py3-dbus
	py3-gobject3
	py3-libselinux
	xdg-utils
	"
makedepends="
	autoconf
	audit-dev
	dbus-dev
	glib-dev
	gtk+3.0-dev
	intltool
	libnotify-dev
	libselinux-dev
	py3-pip
	py3-setuptools
	automake
	"
subpackages="
	$pkgname-doc
	$pkgname-lang
	$pkgname-pyc
	$pkgname-systemd
	"
source="https://gitlab.com/-/project/24478376/uploads/51a9cda747130f92860720841a7fd9c9/setroubleshoot-$pkgver.tar.gz
	no-pip-net.patch
	"

prepare() {
	default_prepare

	# for no-pip-net.patch
	autoreconf -vfi
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

