# Maintainer: Marian Buschsieweke <marian.buschsieweke@posteo.net>
pkgname=push2talk
pkgver=1.3.3
pkgrel=0
pkgdesc="Push-to-Talk: Seamless Integration with Wayland, X11, PulseAudio & PipeWire"
url="https://github.com/cyrinux/push2talk"
license="ISC"
arch="all"
makedepends="
	cargo
	cargo-auditable
	eudev-dev
	libinput-dev
	libpulse
	libxkbcommon-dev
	"
subpackages="$pkgname-doc"
source="https://github.com/cyrinux/push2talk/archive/$pkgver/push2talk-$pkgver.tar.gz"
options="net" # cargo crates

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/push2talk -t "$pkgdir"/usr/bin/
	install -Dm644 LICENSE.md "$pkgdir"/usr/share/doc/$pkgname/LICENSE
}

sha512sums="
33497059093a1bcc5df227ad3eeee6bd75fe21133bacd58940da24d440bac883891874aa35b106fab259a32617b7a39a9cf93d5ae50b3b5275f712ca2228cb44  push2talk-1.3.3.tar.gz
"
