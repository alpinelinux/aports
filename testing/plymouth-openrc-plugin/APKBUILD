pkgname=plymouth-openrc-plugin
pkgver=0.4.0_git20250822
pkgrel=0
_commit="224f9f4fd6c16a012f11182e6a63891db21d51c0"
pkgdesc="Plugin for OpenRC that displays a Plymouth splash screen during boot"
url="https://github.com/Kangie/plymouth-openrc-plugin"
arch="all"
license="GPL-2.0-only"
depends="plymouth"
makedepends="meson openrc-dev"
source="$pkgname-$_commit.tar.gz::https://github.com/Kangie/plymouth-openrc-plugin/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname-$_commit"

build() {
	abuild-meson \
		output .
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
68e395bc892c2663aee7fcb2fcca356457be69d18f28174c110a6cf0414e99c9de91042e9e5ae7a258892ba1fcc58bf81446954647f51768d7c1c62c1bd2d0ce  plymouth-openrc-plugin-224f9f4fd6c16a012f11182e6a63891db21d51c0.tar.gz
"
