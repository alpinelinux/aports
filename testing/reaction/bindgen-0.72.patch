From d3ce1d64d5711bf1064cd32ab0b9154a3ed4c986 Mon Sep 17 00:00:00 2001
From: Aelin <aelin@postmarketos.org>
Date: Thu, 5 Mar 2026 21:45:48 +0100
Subject: [PATCH] bindgen 0.72

The ipset 0.9.0 crate from crates.io pins bindgen 0.70 which generates
broken size assertions against the libipset headers in current Alpine.
Switch ipset to a fork using bindgen 0.72; libnftables1-sys keeps 0.70.

Upstream MR: https://github.com/lazytiger/ipset/pull/21
---
 Cargo.lock | 25 ++++++++++++++++++++-----
 Cargo.toml |  3 +++
 2 files changed, 23 insertions(+), 5 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -278,6 +278,26 @@
 ]
 
 [[package]]
+name = "bindgen"
+version = "0.72.1"
+source = "registry+https://github.com/rust-lang/crates.io-index"
+checksum = "993776b509cfb49c750f11b8f07a46fa23e0a1386ffc01fb1e7d343efc387895"
+dependencies = [
+ "bitflags",
+ "cexpr",
+ "clang-sys",
+ "itertools",
+ "log",
+ "prettyplease",
+ "proc-macro2",
+ "quote",
+ "regex",
+ "rustc-hash 2.1.1",
+ "shlex",
+ "syn 2.0.114",
+]
+
+[[package]]
 name = "bitflags"
 version = "2.10.0"
 source = "registry+https://github.com/rust-lang/crates.io-index"
@@ -1591,10 +1611,9 @@
 [[package]]
 name = "ipset"
 version = "0.9.0"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "d3f6539e7df6df265a48ac3bfa1cc1b9fb37b604c92e9ab01521865e2323787f"
+source = "git+https://github.com/Gelbpunkt/ipset.git?branch=bindgen-0.72#df6e242e27bdfc713ab38b7c28691805ba6551b0"
 dependencies = [
- "bindgen",
+ "bindgen 0.72.1",
  "cc",
  "derive_more 1.0.0",
  "ipset_derive",
@@ -1986,7 +2005,7 @@
 source = "registry+https://github.com/rust-lang/crates.io-index"
 checksum = "1bdd82022bcc357bd117cf52cbd6a35f4adc6f94baae7f578b4e7f3115b68b04"
 dependencies = [
- "bindgen",
+ "bindgen 0.70.1",
  "pkg-config",
 ]
 
diff --git a/Cargo.toml b/Cargo.toml
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -79,6 +79,9 @@
 assert_cmd = "2.0.17"
 predicates = "3.1.3"
 
+[patch.crates-io]
+ipset = { git = "https://github.com/Gelbpunkt/ipset.git", branch = "bindgen-0.72" }
+
 [workspace]
 members = [
 	"crates/treedb",
