From: Guy Godfroy <guy.godfroy@gugod.fr>
Date: Sat, 2 May 2026 13:30:00 +0200
Subject: [PATCH] reaction-plugin-nftables: use c_char for FFI strings

`*const i8` is hardcoded for buffers returned by libnftables, but
`std::os::raw::c_char` is unsigned (u8) on aarch64, armhf, armv7,
ppc64le, riscv64 and s390x. Compilation fails there with E0308.
Use `c_char` so the type matches the platform's char signedness.
---
 plugins/reaction-plugin-nftables/src/nft.rs | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/plugins/reaction-plugin-nftables/src/nft.rs b/plugins/reaction-plugin-nftables/src/nft.rs
--- a/plugins/reaction-plugin-nftables/src/nft.rs
+++ b/plugins/reaction-plugin-nftables/src/nft.rs
@@ -1,5 +1,5 @@
 use std::{
-    ffi::{CStr, CString},
+    ffi::{c_char, CStr, CString},
     thread,
 };

@@ -71,7 +71,7 @@ struct NftCommand {
     ret: oneshot::Sender<Result<String, String>>,
 }

-fn to_rust_string(c_ptr: *const i8) -> Option<String> {
+fn to_rust_string(c_ptr: *const c_char) -> Option<String> {
     if c_ptr.is_null() {
         None
     } else {
