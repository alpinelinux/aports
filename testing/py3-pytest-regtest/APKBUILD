maintainer="Marian Buschsieweke <marian.buschsieweke@posteo.net>"
pkgname=py3-pytest-regtest
pkgver=2.6.0
pkgrel=0
pkgdesc="pytest-regtest is a pytest-plugin for implementing regression tests"
url="https://gitlab.com/uweschmitt/pytest-regtest"
arch="noarch"
license="MIT"
depends="
	py3-pytest
	py3-deepdiff
	"
makedepends="
	py3-gpep517
	py3-hatchling
	py3-setuptools
	py3-wheel
	twine
	"
checkdepends="
	py3-pexpect
	py3-tox
	py3-pandas
	"
subpackages="$pkgname-pyc"
source="
	$pkgname-$pkgver.tar.gz::https://pypi.python.org/packages/source/p/pytest_regtest/pytest_regtest-$pkgver.tar.gz
	"
builddir="$srcdir/pytest_regtest-$pkgver"

build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages test-env
	test-env/bin/python3 -m installer .dist/*.whl
	test-env/bin/python3 -m pytest tests \
		--deselect tests/test_cli.py::test_cli \
		--deselect tests/test_cli.py::test_tee \
		--deselect tests/test_regtest.py::test_identifier \
		--deselect tests/test_snapshot_python_types.py::test_snapshot_python_data_types \
		--deselect tests/test_snapshot_python_types.py::test_snapshot_with_version \
		--deselect tests/test_utils.py::test_highlight_mismatches \
		--deselect tests/test_snapshot_polars.py::test_snapshot_polars_changed_entry \
		--deselect tests/test_snapshot_polars.py::test_snapshot_polars_empty_diff \
		--deselect tests/test_snapshot_polars.py::test_snapshot_polars_rtol_atol \
		--deselect tests/test_snapshot_polars.py::test_snapshot_polars_diff_num_columns \
		#
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl
}

sha512sums="
2ac0e4ee8ea0e4f68e7610c990ae98d7bef49cc5244f80bbac1e6036dc6efaf6a0e28b740e91fa3cfa5ec25c07c8d50e5ddb828fc096256c2fa5ce52873bcacc  py3-pytest-regtest-2.6.0.tar.gz
"
