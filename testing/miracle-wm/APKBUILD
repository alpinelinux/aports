subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/miracle-wm-org/miracle-wm/archive/refs/tags/v$pkgver.tar.gz
	uint.patch
	0001-bugfix-only-install-libmirrenderer-dev-if-it-is-avai.patch
	0002-task-no-longer-need-mircommon-internal-767.patch
	0003-bugfix-add-ForwardingSurface-alpha-824.patch
	0004-Backport-alpha-changes-from-Lots-and-lots-of-new-plu.patch
