arch="all"
license="GPL-3.0-or-later"
depends="xwayland"
makedepends="
	boost1.84-dev
	cmake
	gtest-dev
	json-c-dev
	libevdev-dev
	libnotify-dev
	libxkbcommon-dev
	mesa-dev
	mir-dev
	nlohmann-json
	samurai
	yaml-cpp-dev
	"
subpackages="$pkgname-dev"
source="$pkgname-$pkgver.tar.gz::https://github.com/miracle-wm-org/miracle-wm/archive/refs/tags/v$pkgver.tar.gz
	uint.patch
	0001-bugfix-only-install-libmirrenderer-dev-if-it-is-avai.patch
	0002-task-no-longer-need-mircommon-internal-767.patch
	0003-bugfix-add-ForwardingSurface-alpha-824.patch
	0004-Backport-alpha-changes-from-Lots-and-lots-of-new-plu.patch
	0005-task-add-flag-for-MIR_VERSION_2_26_OR_GREATER-852.patch
	"

build() {
	if [ "$CBUILD" != "$CHOST" ]; then
		local crossopts="-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_HOST_SYSTEM_NAME=Linux"
	fi
	cmake -B build -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DBUILD_SHARED_LIBS=ON \
		-DCMAKE_BUILD_TYPE=None \
		$crossopts
	cmake --build build
}

check() {
	./build/tests/miracle-wm-tests
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

