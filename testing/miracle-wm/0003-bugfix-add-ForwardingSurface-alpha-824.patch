From 4ef68ea07daf59707d50836fd0cad004ba0ab8f8 Mon Sep 17 00:00:00 2001
From: Matthew Kosarek <matthew@matthewkosarek.xyz>
Date: Wed, 18 Mar 2026 17:55:29 -0700
Subject: [PATCH 3/5] bugfix: add ForwardingSurface alpha (#824)

(cherry picked from commit 778a0004e069b63c6182e9e45450ae4eb5bab8f3)
---
 src/forwarding_surface.cpp | 7 +++++++
 src/forwarding_surface.h   | 3 +++
 src/mir_version_manager.h  | 4 ++++
 3 files changed, 14 insertions(+)

diff --git a/src/forwarding_surface.cpp b/src/forwarding_surface.cpp
index e37953a..df9932f 100644
--- a/src/forwarding_surface.cpp
+++ b/src/forwarding_surface.cpp
@@ -244,6 +244,13 @@ void ForwardingSurface::set_transformation(const glm::mat4& t)
     surface_->set_transformation(t);
 }
 
+#ifdef MIR_COMPILING_AGAINST_DEV
+float ForwardingSurface::alpha() const
+{
+    return surface_->alpha();
+}
+#endif
+
 void ForwardingSurface::set_alpha(float alpha)
 {
     surface_->set_alpha(alpha);
diff --git a/src/forwarding_surface.h b/src/forwarding_surface.h
index c434435..0fa465f 100644
--- a/src/forwarding_surface.h
+++ b/src/forwarding_surface.h
@@ -64,6 +64,9 @@ public:
     std::vector<mir::geometry::Rectangle> get_input_region() const override;
     void resize(const mir::geometry::Size& window_size) override;
     void set_transformation(const glm::mat4& t) override;
+#ifdef MIR_COMPILING_AGAINST_DEV
+    float alpha() const override;
+#endif
     void set_alpha(float alpha) override;
     void set_orientation(MirOrientation orientation) override;
     void set_cursor_image(const std::shared_ptr<mir::graphics::CursorImage>& image) override;
diff --git a/src/mir_version_manager.h b/src/mir_version_manager.h
index 1928489..4044e68 100644
--- a/src/mir_version_manager.h
+++ b/src/mir_version_manager.h
@@ -24,4 +24,8 @@ along with this program.  If not, see <http://www.gnu.org/licenses/>.
 #define MIR_VERSION_2_24_OR_GREATER
 #endif
 
+#if COMPILING_AGAINST_DEV
+#define MIR_COMPILING_AGAINST_DEV
+#endif
+
 #endif // MIRACLE_MIR_VERSION_MANAGER_H
