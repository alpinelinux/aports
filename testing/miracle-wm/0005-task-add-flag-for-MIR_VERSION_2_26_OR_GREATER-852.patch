From 92a0c19a91c59b816842f44dd287096da0b42ea4 Mon Sep 17 00:00:00 2001
From: Matthew Kosarek <matthew@matthewkosarek.xyz>
Date: Wed, 1 Apr 2026 08:28:21 -0400
Subject: [PATCH 5/5] task: add flag for MIR_VERSION_2_26_OR_GREATER (#852)

(cherry picked from commit 2d6d1b393ec1761b26393ecb2de863267feaa189)
---
 src/forwarding_surface.cpp | 2 +-
 src/forwarding_surface.h   | 2 +-
 src/mir_version_manager.h  | 4 ++++
 tests/mock_surface.h       | 2 +-
 tests/stub_surface.h       | 2 +-
 5 files changed, 8 insertions(+), 4 deletions(-)

diff --git a/src/forwarding_surface.cpp b/src/forwarding_surface.cpp
index df9932f..274410f 100644
--- a/src/forwarding_surface.cpp
+++ b/src/forwarding_surface.cpp
@@ -244,7 +244,7 @@ void ForwardingSurface::set_transformation(const glm::mat4& t)
     surface_->set_transformation(t);
 }
 
-#ifdef MIR_COMPILING_AGAINST_DEV
+#ifdef MIR_VERSION_2_26_OR_GREATER
 float ForwardingSurface::alpha() const
 {
     return surface_->alpha();
diff --git a/src/forwarding_surface.h b/src/forwarding_surface.h
index 0fa465f..930713c 100644
--- a/src/forwarding_surface.h
+++ b/src/forwarding_surface.h
@@ -64,7 +64,7 @@ public:
     std::vector<mir::geometry::Rectangle> get_input_region() const override;
     void resize(const mir::geometry::Size& window_size) override;
     void set_transformation(const glm::mat4& t) override;
-#ifdef MIR_COMPILING_AGAINST_DEV
+#ifdef MIR_VERSION_2_26_OR_GREATER
     float alpha() const override;
 #endif
     void set_alpha(float alpha) override;
diff --git a/src/mir_version_manager.h b/src/mir_version_manager.h
index 4044e68..abaadf3 100644
--- a/src/mir_version_manager.h
+++ b/src/mir_version_manager.h
@@ -24,6 +24,10 @@ along with this program.  If not, see <http://www.gnu.org/licenses/>.
 #define MIR_VERSION_2_24_OR_GREATER
 #endif
 
+#if ((MIR_SERVER_MAJOR_VERSION > 2) || (MIR_SERVER_MAJOR_VERSION == 2 && MIR_SERVER_MINOR_VERSION >= 26)) || COMPILING_AGAINST_DEV
+#define MIR_VERSION_2_26_OR_GREATER
+#endif
+
 #if COMPILING_AGAINST_DEV
 #define MIR_COMPILING_AGAINST_DEV
 #endif
diff --git a/tests/mock_surface.h b/tests/mock_surface.h
index 5a4028b..bacfd20 100644
--- a/tests/mock_surface.h
+++ b/tests/mock_surface.h
@@ -99,7 +99,7 @@ namespace test
 #else
         MOCK_METHOD((mir::wayland::Weak<mir::frontend::WlSurface> const&), wayland_surface, (), (override));
 #endif
-#ifdef MIR_COMPILING_AGAINST_DEV
+#ifdef MIR_VERSION_2_26_OR_GREATER
         MOCK_METHOD(float, alpha, (), (const, override));
 #endif
     };
diff --git a/tests/stub_surface.h b/tests/stub_surface.h
index dfd5984..300b232 100644
--- a/tests/stub_surface.h
+++ b/tests/stub_surface.h
@@ -151,7 +151,7 @@ public:
     {
     }
 
-#ifdef MIR_COMPILING_AGAINST_DEV
+#ifdef MIR_VERSION_2_26_OR_GREATER
     float alpha() const override
     {
         return 1.f;
-- 
2.53.0

