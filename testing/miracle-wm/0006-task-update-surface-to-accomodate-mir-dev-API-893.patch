From fc08e69837f1735080c77e6ac6bd04c894841c86 Mon Sep 17 00:00:00 2001
From: Matthew Kosarek <matthew@matthewkosarek.xyz>
Date: Fri, 29 May 2026 11:08:33 -0400
Subject: [PATCH 6/6] task: update surface to accomodate mir dev API (#893)

* task: update surface to accomodate mir dev API

* Compile deb against release

* Update comment

(cherry picked from commit 0fcfb54c59327d0776f6e8074e885080731a95c4)
---
 src/forwarding_surface.cpp | 7 +++++++
 src/forwarding_surface.h   | 3 +++
 src/mir_version_manager.h  | 3 ++-
 tests/mock_surface.h       | 3 +++
 tests/stub_surface.h       | 4 ++++
 5 files changed, 19 insertions(+), 1 deletion(-)

diff --git a/src/forwarding_surface.cpp b/src/forwarding_surface.cpp
index 274410f..c4b99db 100644
--- a/src/forwarding_surface.cpp
+++ b/src/forwarding_surface.cpp
@@ -286,6 +286,13 @@ std::shared_ptr<mir::scene::Surface> ForwardingSurface::parent() const
     return surface_->parent();
 }
 
+#ifdef MIR_VERSION_2_28_OR_GREATER
+void ForwardingSurface::set_parent(std::weak_ptr<mir::scene::Surface> const& parent)
+{
+    surface_->set_parent(parent);
+}
+#endif
+
 int ForwardingSurface::configure(MirWindowAttrib attrib, int value)
 {
     return surface_->configure(attrib, value);
diff --git a/src/forwarding_surface.h b/src/forwarding_surface.h
index 930713c..1087887 100644
--- a/src/forwarding_surface.h
+++ b/src/forwarding_surface.h
@@ -74,6 +74,9 @@ public:
     void set_reception_mode(mir::input::InputReceptionMode mode) override;
     void request_client_surface_close() override;
     std::shared_ptr<Surface> parent() const override;
+#ifdef MIR_VERSION_2_28_OR_GREATER
+    void set_parent(std::weak_ptr<Surface> const& parent) override;
+#endif
     int configure(MirWindowAttrib attrib, int value) override;
     int query(MirWindowAttrib attrib) const override;
     void rename(const std::string& title) override;
diff --git a/src/mir_version_manager.h b/src/mir_version_manager.h
index abaadf3..fb6359d 100644
--- a/src/mir_version_manager.h
+++ b/src/mir_version_manager.h
@@ -28,7 +28,8 @@ along with this program.  If not, see <http://www.gnu.org/licenses/>.
 #define MIR_VERSION_2_26_OR_GREATER
 #endif
 
-#if COMPILING_AGAINST_DEV
+#if ((MIR_SERVER_MAJOR_VERSION > 2) || (MIR_SERVER_MAJOR_VERSION == 2 && MIR_SERVER_MINOR_VERSION >= 28)) || COMPILING_AGAINST_DEV
+#define MIR_VERSION_2_28_OR_GREATER
 #define MIR_COMPILING_AGAINST_DEV
 #endif
 
diff --git a/tests/mock_surface.h b/tests/mock_surface.h
index bacfd20..bab85b4 100644
--- a/tests/mock_surface.h
+++ b/tests/mock_surface.h
@@ -101,6 +101,9 @@ namespace test
 #endif
 #ifdef MIR_VERSION_2_26_OR_GREATER
         MOCK_METHOD(float, alpha, (), (const, override));
+#endif
+#ifdef MIR_VERSION_2_28_OR_GREATER
+        MOCK_METHOD(void, set_parent, (std::weak_ptr<Surface> const&), (override));
 #endif
     };
 
diff --git a/tests/stub_surface.h b/tests/stub_surface.h
index 300b232..da47ca6 100644
--- a/tests/stub_surface.h
+++ b/tests/stub_surface.h
@@ -184,6 +184,10 @@ public:
         return std::shared_ptr<Surface>();
     }
 
+#ifdef MIR_VERSION_2_28_OR_GREATER
+    void set_parent(std::weak_ptr<Surface> const& parent) override { }
+#endif
+
     int configure(MirWindowAttrib attrib, int value) override
     {
         return 0;
