8f5667869c215e46a004bd06538e4afd1705b64d4cfdd39e33b862366293df857c67ee9e2a27998bddf1c736bd30c49897ceb6cb7c6ecadcfe25232009019be6  fix_amd_npu_libc_type.patch
"
