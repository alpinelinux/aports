# Contributor: Angelo Verlain <hey@vixalien.com>
maintainer="Achill Gilgenast <achill@achill.org>"
pkgname=elementary-music
pkgver=8.1.0
pkgrel=0
pkgdesc="Music app designed for elementary OS"
url="https://github.com/elementary/music"
arch="all"
license="GPL-3.0-or-later"
makedepends="
	granite7-dev
	gstreamer-dev
	gst-plugins-base-dev
	gtk4.0-dev
	libadwaita-dev
	meson
	vala
	"
subpackages="$pkgname-lang"
source="$pkgname-$pkgver.tar.gz::https://github.com/elementary/music/archive/refs/tags/$pkgver.tar.gz"

builddir="$srcdir/music-$pkgver"

build() {
	abuild-meson . output
	meson compile -C output
}

check() {
	meson test --print-errorlogs -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
23fd8e8c46fe12f4ff985194560bdfc05afec2b99490e6970ed051e326632f42f0d118495087097ef0dbcd4e58b40a5ee09e08d043825bd307dc4f53fe42c52f  elementary-music-8.1.0.tar.gz
"
