pkgname=grub-btrfs
pkgver=4.14
pkgrel=0
pkgdesc="Include btrfs snapshots in grub menu"
url="https://github.com/Antynea/grub-btrfs"
arch="all !s390x" # s390x does not have grub
license="GPL-3.0-only"
depends="btrfs-progs grub inotify-tools bash gawk"
subpackages="$pkgname-doc $pkgname-systemd $pkgname-openrc"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/Antynea/grub-btrfs/archive/refs/tags/v$pkgver.tar.gz
	root_use_device.patch
"
options="!check" # no tests

package() {
	make install DESTDIR="$pkgdir" OPENRC=true
}

