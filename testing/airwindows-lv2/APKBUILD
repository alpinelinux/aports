maintainer="Hannes Braun <hannes@hannesbraun.net>"
pkgname=airwindows-lv2
pkgver=36.0
pkgrel=0
pkgdesc="Airwindows plugins (ported to LV2)"
url="https://sr.ht/~hannes/airwindows-lv2/"
arch="all"
license="MIT"
makedepends="muon lv2-dev"
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~hannes/airwindows-lv2/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-v$pkgver"
options="!check" # no test suite

build() {
	abuild-muon \
		output .
	ninja -C output
}

package() {
	DESTDIR="$pkgdir" muon -C output install
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

