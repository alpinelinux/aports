pkgname=hddfancontrol
pkgver=2.1.1
pkgrel=0
pkgdesc="Regulate fan speed according to hard drive temperature"
url="https://github.com/desbma/hddfancontrol"
arch="all"
license="GPL-3.0-only"
makedepends="cargo cargo-auditable"
install="$pkgname.post-upgrade"
subpackages="$pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/desbma/hddfancontrol/archive/$pkgver.tar.gz
	$pkgname.initd
	$pkgname.confd
	"
options="net" # cargo fetch

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	cargo auditable build --frozen --release --target="$CTARGET"
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/$CTARGET/release/$pkgname -t "$pkgdir"/usr/bin/
	install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -Dm644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

sha512sums="
