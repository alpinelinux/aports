maintainer="Fabricio Silva <hi@fabricio.dev>"
pkgname=bdinfo
pkgver=1.0.4
pkgrel=0
pkgdesc="A command-line Blu-ray disc analysis tool with UHD support, fork built on .NET 8."
url="https://github.com/tetrahydroc/BDInfoCLI"
arch="x86_64 aarch64 armv7" # limited by dotnet8-sdk
license="LGPL-2.1-or-later"
options="net !strip" # net for nuget | strip breaks the package
makedepends="dotnet8-sdk"
depends="dotnet8-runtime"
source="$pkgname-$pkgver.tar.gz::https://github.com/tetrahydroc/BDInfoCLI/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/BDInfoCLI-$pkgver"
provides="BDInfo"

build() {
	dotnet publish BDInfo \
		-p:EnableCompressionInSingleFile=false \
		-p:Version="$pkgver.$pkgrel" \
		--no-self-contained \
		--use-current-runtime \
		--configuration Release \
		--output publish
}

check() {
	./publish/BDInfo -v
}

package() {
	install -Dm755 publish/BDInfo -t "$pkgdir"/usr/bin
}

sha512sums="
3668f0f56988346e3a29dd5d183060b0605b42d562e10e50cfaa3df6ee03fa6e5cb55624dfa90799bd1021c494824bf17aa9cb28672cc14d012799833f79c581  bdinfo-1.0.4.tar.gz
"
