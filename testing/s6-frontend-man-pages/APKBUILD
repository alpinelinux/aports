# Maintainer: Peter Shkenev <santurysim@gmail.com>
pkgname=s6-frontend-man-pages
pkgver=0.0.1.1.1
pkgrel=0
pkgdesc="Unofficial mdoc versions of the s6-frontend documentation"
url="https://git.sr.ht/~humm/s6-frontend-man-pages"
arch="noarch"
license="ISC"
source="$pkgname-$pkgver.tar.gz::https://git.sr.ht/~humm/s6-frontend-man-pages/archive/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-v$pkgver"
options="!check" # no tests
install_if="execline>=${pkgver%.*} docs"

package() {
	make DESTDIR="$pkgdir" install

	find "$pkgdir" -type f ! -name "*.gz" \
		-exec gzip -9 {} \;
}

sha512sums="
