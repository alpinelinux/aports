# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=asteroid
maintainer="Bart Ribbers <bribbers@disroot.org>"
pkgname=asteroid-toolwatch
pkgver=2.1_git20250514
pkgrel=0
_commit="07b6675ae6e4734fee7971d4f4a22a9637f5f1a9"
pkgdesc="A useful sensor app for AsteroidOS"
url="https://github.com/AsteroidOS/asteroid-toolwatch"
# armhf blocked by qt6-qtdeclarative
arch="all !armhf"
license="GPL-3.0-or-later"
depends="mapplauncherd-qt"
makedepends="
	extra-cmake-modules
	qml-asteroid-dev
	qt6-qt5compat-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtsensors-dev
	samurai
	"
source="$pkgname-$_commit.tar.gz::https://github.com/AsteroidOS/asteroid-toolwatch/archive/$_commit.tar.gz"
options="!check" # no tests
builddir="$srcdir/$pkgname-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
