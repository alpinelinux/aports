From 1784fabd6543c6d563c4658714a5536d901e2f04 Mon Sep 17 00:00:00 2001
From: Andy Postnikov <apostnikov@gmail.com>
Date: Wed, 1 Jul 2026 02:48:21 +0200
Subject: [PATCH] Fix build against PHP 8.6 (INI_STR/INI_BOOL macros removed)

PHP 8.6 removed the legacy uppercase INI_STR() and INI_BOOL() macros in
favour of the lowercase zend_ini_string()/zend_ini_long() helpers, which
have been available since PHP 7. Building against 8.6 therefore fails with
implicit-function-declaration errors.

Add guarded fallback definitions so the extension keeps compiling on both
older and newer PHP versions without touching the call sites.

Ref: https://github.com/php/php-src/commit/df8ce6ddbd713d7e9163dd60d19648e2e4a8bb80

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 uploadprogress.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/uploadprogress.c b/uploadprogress.c
index 57f6f0b..d266b9a 100644
--- a/uploadprogress.c
+++ b/uploadprogress.c
@@ -29,6 +29,16 @@
 #define TMPDIR "/tmp"
 #endif
 
+/* PHP 8.6 removed the legacy INI_STR()/INI_BOOL() macros in favour of
+ * zend_ini_string()/zend_ini_long(). Provide fallbacks so the extension
+ * keeps building on both older and newer PHP versions. */
+#ifndef INI_STR
+# define INI_STR(name)  ((char *) zend_ini_string((name), strlen(name), 0))
+#endif
+#ifndef INI_BOOL
+# define INI_BOOL(name) ((bool) zend_ini_long((name), strlen(name), 0))
+#endif
+
 /* {{{ argument information */
 #if PHP_VERSION_ID < 80000
 #include "uploadprogress_legacy_arginfo.h"
