pkgname=widle
pkgver=1.0_git20250829
pkgrel=0
_commit=8d3575f8112a3ef7e909a093d91b3b05cdda0293
pkgdesc="widle is a tiny application that runs a command upon becoming idle utilizing the ext-idle-notify-v1 protocol"
url="https://codeberg.org/sewn/widle"
arch="all"
license="MIT"
makedepends="wayland-dev wayland-protocols"
options="!check" # No testsuite
subpackages="$pkgname-doc"
source="$pkgname-$pkgver.tar.gz::$url/archive/$_commit.tar.gz"
builddir="$srcdir/$pkgname"

build() {
	make
}

package() {
	make PREFIX=/usr DESTDIR="$pkgdir" install
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

