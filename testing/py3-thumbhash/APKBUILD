# Maintainer: Hugo Osvaldo Barrera <hugo@whynothugo.nl>
pkgname=py3-thumbhash
_pkgname=thumbhash
pkgver=0.1.2
pkgrel=0
pkgdesc="Compact representation of an image placeholder"
url="https://github.com/justinforlenza/thumbhash-py"
arch="noarch"
license="MIT"
depends="python3"
makedepends="py3-gpep517 py3-hatchling"
subpackages="$pkgname-pyc"
source="https://files.pythonhosted.org/packages/source/t/$_pkgname/$_pkgname-$pkgver.tar.gz"
builddir="$srcdir/$_pkgname-$pkgver"

build() {
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1
}

check() {
	python3 -m venv --clear --without-pip --system-site-packages .testenv
	.testenv/bin/python3 -m installer .dist/*.whl
	# No real tests.
	.testenv/bin/python3 -c "import thumbhash"
}

package() {
	python3 -m installer -d "$pkgdir" .dist/*.whl
}

sha512sums="
e4c2d753929589ae131ec957e467c72ed8e3786778a650bf8ea226851a599d4bceded71fe5551e493e5835be683aca94c28249e9bfb7fce5ef4a21c0d10f6eb7  thumbhash-0.1.2.tar.gz
"
