# Contributor: Orhun Parmaksız <orhunparmaksiz@gmail.com>
# Maintainer: Orhun Parmaksız <orhunparmaksiz@gmail.com>
pkgname=lychee
pkgver=0.23.0
pkgrel=0
pkgdesc="Fast, async, resource-friendly link checker written in Rust"
url="https://lychee.cli.rs"
arch="all"
license="MIT OR Apache-2.0"
makedepends="
	cargo
	cargo-auditable
	pkgconf
	"
subpackages="$pkgname-doc"
options="net"
source="$pkgname-$pkgver.tar.gz::https://github.com/lycheeverse/lychee/archive/lychee-v$pkgver/lychee-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgname-v$pkgver"

prepare() {
	default_prepare
	cargo fetch --target="$CTARGET" --locked
}

build() {
	# fix `rustc-LLVM ERROR: out of memory` and `std::bad_alloc` on 32-bit archs
	case "$CARCH" in
		armhf|armv7)
			export CARGO_PROFILE_RELEASE_LTO=thin
			export CARGO_PROFILE_RELEASE_CODEGEN_UNITS=16
			;;
	esac
	cargo auditable build --frozen --release
}

check() {
	# example.com uses distrusted root certificates, causing these tests to fail
	# https://github.com/lycheeverse/lychee/issues/2061
	local _skip="
		--skip client::tests::test_require_https
		--skip collector::tests::test_url_without_extension_is_html"

	# Test fails on some archs because it incorrectly assumes x86_64 chunking in html5ever
	case "$CARCH" in
		armhf|armv7|loongarch64|riscv64|s390x|ppc64le) _skip="$_skip
		--skip extract::html::html5ever::tests::test_include_verbatim" ;;
	esac

	# shellcheck disable=SC2086
	cargo test -- --test-threads 1 $_skip
}

package() {
	install -Dm 755 "target/release/$pkgname" -t "$pkgdir/usr/bin"
	install -Dm 644 README.md -t "$pkgdir/usr/share/doc/$pkgname"
	install -Dm 644 LICENSE-MIT -t "$pkgdir/usr/share/licenses/$pkgname"
}

sha512sums="
ac58a2497619b285e216d54f38a748585d9f36e06f5cfb608d2d2889ff7388ad39f94c95078de18138837b025ccdea93dd3f4765c0857156194822b3dd766e13  lychee-0.23.0.tar.gz
"
